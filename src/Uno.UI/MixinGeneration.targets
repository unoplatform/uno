<?xml version="1.0" encoding="utf-8" ?>
<Project>

	<!--
		Mixin code generation is handled by source generators in
		Uno.UI.SourceGenerators.Internal (Mixins/ namespace).
		This file provides the AdditionalFiles entry needed by the
		EffectiveViewport partial-class generators.
	-->

	<ItemGroup>
		<AdditionalFiles Include="$(MSBuildThisFileDirectory)UI\Xaml\FrameworkElement.EffectiveViewport.cs"
						 SourceItemGroup="EffectiveViewportTemplate" />
	</ItemGroup>

</Project>
