<Project Sdk="MSTest.Sdk/4.0.2">

	<!--
		Validates that every DevServer add-in shipped together in a single Uno.Sdk release
		(per src/Uno.Sdk/packages.json) is compatible with the DevServer host built by THIS
		branch — both individually (host can satisfy each add-in's transitive AssemblyRefs)
		and pairwise (no two add-ins disagree on the version of an assembly the host doesn't
		carry).

		The test is intentionally a regression gate: it is expected to be RED whenever the
		add-in maintainers ship a Uno.Sdk version with misaligned dependencies or the host
		bundles a lower-major version than an add-in needs. Turns GREEN once they align.
	-->

	<PropertyGroup>
		<TargetFramework>$(NetCurrent)</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<IsPackable>false</IsPackable>
		<NoWarn>$(NoWarn);VSTHRD200</NoWarn>
		<!--
			Disable apphost generation. MSTest.Sdk turns the project into an Exe; on Linux
			that produces a native apphost wrapper which fails to copy when a folder of the
			same name already exists at the destination (a Linux-only build error seen on
			the CI agent). The test runs via `dotnet test` against the DLL directly, so the
			apphost is not needed.
		-->
		<UseAppHost>false</UseAppHost>
	</PropertyGroup>

	<PropertyGroup>
		<UnoSdkManifestPath>$(MSBuildThisFileDirectory)..\Uno.Sdk\packages.json</UnoSdkManifestPath>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="AwesomeAssertions" />
	</ItemGroup>

	<ItemGroup>
		<!--
			DevServer host built from THIS repo. We reference the project (not a NuGet
			package) so the alignment check always validates the host being shipped by this
			branch, not a fixed published version that would drift out of sync with the
			add-ins. ReferenceOutputAssembly=false because we don't compile against the
			host's API; the test reads the bin output as a static set of DLLs.
		-->
		<ProjectReference Include="..\Uno.UI.RemoteControl.Host\Uno.UI.RemoteControl.Host.csproj"
		                  ReferenceOutputAssembly="false"
		                  SkipGetTargetFrameworkProperties="true"
		                  UndefineProperties="TargetFramework"
		                  Private="false" />
	</ItemGroup>

	<!--
		Inline MSBuild task: read a manifest group's version from packages.json. Lets the
		add-in PackageReferences below pull their versions from the single source of truth
		(the same manifest Uno.Sdk.Private itself consumes), so there is no manual sync
		requirement and no drift between this test and the SDK that ships the add-ins.
	-->
	<UsingTask TaskName="ReadManifestGroupVersion"
	           TaskFactory="RoslynCodeTaskFactory"
	           AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
		<ParameterGroup>
			<ManifestPath ParameterType="System.String" Required="true" />
			<GroupName ParameterType="System.String" Required="true" />
			<Version ParameterType="System.String" Output="true" />
		</ParameterGroup>
		<Task>
			<Using Namespace="System" />
			<Using Namespace="System.IO" />
			<Using Namespace="System.Text.RegularExpressions" />
			<Code Type="Fragment" Language="cs">
				<![CDATA[
				// Regex parse: the inline task runs under desktop MSBuild which does not carry
				// System.Text.Json. The packages.json structure is stable and consistent —
				// each entry is an object with adjacent "group" and "version" properties — so
				// regex is sufficient. The pattern tolerates whitespace and either property
				// ordering by checking both directions.
				var text = File.ReadAllText(ManifestPath);
				var escapedGroup = Regex.Escape(GroupName);
				var pattern1 = "\"group\"\\s*:\\s*\"" + escapedGroup + "\"\\s*,\\s*\"version\"\\s*:\\s*\"([^\"]+)\"";
				var pattern2 = "\"version\"\\s*:\\s*\"([^\"]+)\"\\s*,\\s*\"group\"\\s*:\\s*\"" + escapedGroup + "\"";
				var match = Regex.Match(text, pattern1, RegexOptions.IgnoreCase);
				if (!match.Success)
				{
					match = Regex.Match(text, pattern2, RegexOptions.IgnoreCase);
				}
				if (match.Success)
				{
					Version = match.Groups[1].Value;
				}
				else
				{
					Log.LogError("Group '" + GroupName + "' not found in manifest '" + ManifestPath + "'.");
				}
				// RoslynCodeTaskFactory appends `return !Log.HasLoggedErrors;` after the Fragment.
				// Don't add explicit returns or the appended return becomes unreachable (CS0162).
				]]>
			</Code>
		</Task>
	</UsingTask>

	<Target Name="_InjectAddInPackageReferencesFromManifest"
	        BeforeTargets="CollectPackageReferences;Restore">

		<ReadManifestGroupVersion ManifestPath="$(UnoSdkManifestPath)" GroupName="settings">
			<Output TaskParameter="Version" PropertyName="_UnoSettingsDevServerVersion" />
		</ReadManifestGroupVersion>
		<ReadManifestGroupVersion ManifestPath="$(UnoSdkManifestPath)" GroupName="hotdesign">
			<Output TaskParameter="Version" PropertyName="_UnoUIHotDesignVersion" />
		</ReadManifestGroupVersion>
		<ReadManifestGroupVersion ManifestPath="$(UnoSdkManifestPath)" GroupName="AppMcp">
			<Output TaskParameter="Version" PropertyName="_UnoUIAppMcpVersion" />
		</ReadManifestGroupVersion>

		<ItemGroup>
			<PackageReference Include="Uno.Settings.DevServer"
			                  Version="$(_UnoSettingsDevServerVersion)"
			                  GeneratePathProperty="true" />
			<PackageReference Include="Uno.UI.HotDesign"
			                  Version="$(_UnoUIHotDesignVersion)"
			                  GeneratePathProperty="true" />
			<PackageReference Include="Uno.UI.App.Mcp"
			                  Version="$(_UnoUIAppMcpVersion)"
			                  GeneratePathProperty="true" />
		</ItemGroup>
	</Target>

	<!--
		Expose paths and manifest location to the test code via assembly metadata. The
		AssemblyMetadataAttribute entries get read at test runtime to locate each package's
		content root without guessing where NuGet put it (handles NUGET_PACKAGES overrides
		cleanly).

		The host path points directly at the bin output of the locally-built project — the
		test's BuildHostTpa understands both the NuGet `tools/rc/host/net10.0/` layout and
		the direct `bin/<config>/<tfm>/` layout.
	-->
	<ItemGroup>
		<AssemblyMetadata Include="UnoSettingsDevServerPath" Value="$(PkgUno_Settings_DevServer)" Condition="'$(PkgUno_Settings_DevServer)' != ''" />
		<AssemblyMetadata Include="UnoUIHotDesignPath" Value="$(PkgUno_UI_HotDesign)" Condition="'$(PkgUno_UI_HotDesign)' != ''" />
		<AssemblyMetadata Include="UnoUIAppMcpPath" Value="$(PkgUno_UI_App_Mcp)" Condition="'$(PkgUno_UI_App_Mcp)' != ''" />
		<AssemblyMetadata Include="UnoHostBinDir" Value="$(MSBuildThisFileDirectory)..\Uno.UI.RemoteControl.Host\bin\$(Configuration)\$(NetCurrent)" />
		<AssemblyMetadata Include="UnoSdkManifestPath" Value="$(UnoSdkManifestPath)" />
	</ItemGroup>

</Project>
