<UserControl x:Class="Uno.UI.RuntimeTests.Tests.Windows_UI_Xaml.Controls.BasicThemeResources_Test"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<UserControl.Resources>
		<ResourceDictionary>
			<ResourceDictionary.ThemeDictionaries>
				<ResourceDictionary x:Key="HighContrast">
					<SolidColorBrush x:Key="LocalThemeColor" Color="Red" />
				</ResourceDictionary>
				<ResourceDictionary x:Key="Default">
					<SolidColorBrush x:Key="LocalThemeColor" Color="Gray" />
				</ResourceDictionary>
				<ResourceDictionary x:Key="Dark">
					<SolidColorBrush x:Key="LocalThemeColor" Color="Blue" />
				</ResourceDictionary>
				<ResourceDictionary x:Key="Light">
					<SolidColorBrush x:Key="LocalThemeColor" Color="Yellow" />
				</ResourceDictionary>
			</ResourceDictionary.ThemeDictionaries>

			<SolidColorBrush x:Key="LocalThemeColor2" Color="Green" />
		</ResourceDictionary>
	</UserControl.Resources>

	<StackPanel Spacing="10" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition />
				<ColumnDefinition />
				<ColumnDefinition />
			</Grid.ColumnDefinitions>

			<!-- Column 0: Default (inherits from parent) -->
			<StackPanel x:Name="col0Panel" Spacing="10" RequestedTheme="Default">
				<Border x:Name="col0_ThemeResource_Themed" Width="300" Height="50"
						Background="{ThemeResource LocalThemeColor}">
					<TextBlock x:Name="col0_text0">{ThemeResource} on a themed resource</TextBlock>
				</Border>
				<Border x:Name="col0_StaticResource_Themed" Width="300" Height="50"
						Background="{StaticResource LocalThemeColor}">
					<TextBlock x:Name="col0_text1">{StaticResource} on a themed resource</TextBlock>
				</Border>
				<Border x:Name="col0_ThemeResource_Static" Width="300" Height="50"
						Background="{ThemeResource LocalThemeColor2}">
					<TextBlock x:Name="col0_text2">{ThemeResource} on a static resource (green)</TextBlock>
				</Border>
				<Border x:Name="col0_StaticResource_Static" Width="300" Height="50"
						Background="{StaticResource LocalThemeColor2}">
					<TextBlock x:Name="col0_text3">{StaticResource} on a static resource (green)</TextBlock>
				</Border>
			</StackPanel>

			<!-- Column 1: Explicit Dark -->
			<StackPanel x:Name="col1Panel" Spacing="10" RequestedTheme="Dark" Grid.Column="1">
				<Border x:Name="col1_ThemeResource_Themed" Width="300" Height="50"
						Background="{ThemeResource LocalThemeColor}">
					<TextBlock x:Name="col1_text0">{ThemeResource} on a themed resource</TextBlock>
				</Border>
				<Border x:Name="col1_StaticResource_Themed" Width="300" Height="50"
						Background="{StaticResource LocalThemeColor}">
					<TextBlock x:Name="col1_text1">{StaticResource} on a themed resource</TextBlock>
				</Border>
				<Border x:Name="col1_ThemeResource_Static" Width="300" Height="50"
						Background="{ThemeResource LocalThemeColor2}">
					<TextBlock x:Name="col1_text2">{ThemeResource} on a static resource (green)</TextBlock>
				</Border>
				<Border x:Name="col1_StaticResource_Static" Width="300" Height="50"
						Background="{StaticResource LocalThemeColor2}">
					<TextBlock x:Name="col1_text3">{StaticResource} on a static resource (green)</TextBlock>
				</Border>
			</StackPanel>

			<!-- Column 2: Explicit Light -->
			<StackPanel x:Name="col2Panel" Spacing="10" RequestedTheme="Light" Grid.Column="2">
				<Border x:Name="col2_ThemeResource_Themed" Width="300" Height="50"
						Background="{ThemeResource LocalThemeColor}">
					<TextBlock x:Name="col2_text0">{ThemeResource} on a themed resource</TextBlock>
				</Border>
				<Border x:Name="col2_StaticResource_Themed" Width="300" Height="50"
						Background="{StaticResource LocalThemeColor}">
					<TextBlock x:Name="col2_text1">{StaticResource} on a themed resource</TextBlock>
				</Border>
				<Border x:Name="col2_ThemeResource_Static" Width="300" Height="50"
						Background="{ThemeResource LocalThemeColor2}">
					<TextBlock x:Name="col2_text2">{ThemeResource} on a static resource (green)</TextBlock>
				</Border>
				<Border x:Name="col2_StaticResource_Static" Width="300" Height="50"
						Background="{StaticResource LocalThemeColor2}">
					<TextBlock x:Name="col2_text3">{StaticResource} on a static resource (green)</TextBlock>
				</Border>
			</StackPanel>
		</Grid>
	</StackPanel>
</UserControl>
