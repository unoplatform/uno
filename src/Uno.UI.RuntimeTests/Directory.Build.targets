<Project>
	<PropertyGroup>
		<NoWarn>$(NoWarn);MSTEST0010</NoWarn>
	</PropertyGroup>
	<Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Build.targets', '$(MSBuildThisFileDirectory)../'))" />

	<ItemGroup>
		<Content Include="$(MSBuildThisFileDirectory)..\SamplesApp\SamplesApp.Samples\Assets\colors300-transitive.png" Link="Assets\TransitiveTest\colors300.png" />
	</ItemGroup>

	<!-- 
	Exclude the hotreload sample app for all targets
	-->
	<ItemGroup>
		<Compile Remove="HotReload\Frame\HRApp\**\*.cs" />
		<Page Remove="HotReload\Frame\HRApp\**\*.xaml" />
		<Compile Remove="HotReload\Frame\HRApp\*.cs" />
		<Page Remove="HotReload\Frame\HRApp\*.xaml" />
		<Content Remove="HotReload\Frame\HRApp\**" />
		<ApplicationDefinition Remove="HotReload\Frame\HRApp\*.xaml" />

		<None Include="HotReload\Frame\HRApp\**\*.cs" Exclude="HotReload\Frame\HRApp\bin\**;HotReload\Frame\HRApp\obj\**" />
		<None Include="HotReload\Frame\HRApp\**\*.xaml" Exclude="HotReload\Frame\HRApp\bin\**;HotReload\Frame\HRApp\obj\**" />
	</ItemGroup>

	<ItemGroup>
		<Compile Remove="AssemblyLoadContext\AlcApp\**\*.cs" />
		<Page Remove="AssemblyLoadContext\AlcApp\**\*.xaml" />
		<Compile Remove="AssemblyLoadContext\AlcApp\*.cs" />
		<Page Remove="AssemblyLoadContext\AlcApp\*.xaml" />
		<Content Remove="AssemblyLoadContext\AlcApp\**" />
		<ApplicationDefinition Remove="AssemblyLoadContext\AlcApp\*.xaml" />

		<None Include="AssemblyLoadContext\AlcApp\**\*.cs" Exclude="AssemblyLoadContext\AlcApp\bin\**;AssemblyLoadContext\AlcApp\obj\**" />
		<None Include="AssemblyLoadContext\AlcApp\**\*.xaml" Exclude="AssemblyLoadContext\AlcApp\bin\**;AssemblyLoadContext\AlcApp\obj\**" />
	</ItemGroup>
</Project>
