<Page
    x:Class="Uno.UI.RuntimeTests.Tests_CSharpExpressions.Pages.CompoundExpressionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Uno.UI.RuntimeTests.Tests_CSharpExpressions.Pages">

    <StackPanel>
        <TextBlock x:Name="TotalLabel" x:FieldModifier="public" Text="{this.Price * this.Quantity}" />
        <TextBlock x:Name="WithTaxLabel" x:FieldModifier="public" Text="{this.Price * this.TaxRate}" />
        <TextBlock x:Name="TierLabel" x:FieldModifier="public" Text="{this.IsVip ? 'Gold' : 'Standard'}" />
    </StackPanel>
</Page>
