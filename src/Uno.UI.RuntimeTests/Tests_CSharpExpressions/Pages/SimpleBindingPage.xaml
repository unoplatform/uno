<Page
    x:Class="Uno.UI.RuntimeTests.Tests_CSharpExpressions.Pages.SimpleBindingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Uno.UI.RuntimeTests.Tests_CSharpExpressions.Pages"
    xmlns:vm="using:Uno.UI.RuntimeTests.Tests_CSharpExpressions.ViewModels">

    <StackPanel>
        <TextBox x:Name="FirstNameBox" x:FieldModifier="public" Text="{= FirstName}" />
        <TextBlock x:Name="FullNameLabel" x:FieldModifier="public" Text="{= FullName}" />
        <TextBlock x:Name="ThisCapturedLabel" x:FieldModifier="public" Text="{this.WindowTitle}" />
    </StackPanel>
</Page>
