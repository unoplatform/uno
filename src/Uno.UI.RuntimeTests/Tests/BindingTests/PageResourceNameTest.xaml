<Page x:Class="Uno.UI.RuntimeTests.Tests.PageResourceNameTest"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Repro for https://github.com/unoplatform/uno/issues/4032
         Bug: Named entries in Page.Resources > ResourceDictionary don't generate named fields
         Expected: MyTopLevelBrush should be accessible in code-behind -->
    <Page.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Name="MyTopLevelBrush" x:Key="MyTopLevelBrush" Color="Blue"/>
        </ResourceDictionary>
    </Page.Resources>
    <Grid>
        <TextBlock Text="Test" />
    </Grid>
</Page>
