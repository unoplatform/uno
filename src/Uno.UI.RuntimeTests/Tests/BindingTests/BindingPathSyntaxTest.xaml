<UserControl x:Class="Uno.UI.RuntimeTests.Tests.BindingPathSyntaxTest"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Repro for https://github.com/unoplatform/uno/issues/4051
         Bug: {Binding Path={Binding}} syntax causes compile error in Uno.
         Expected: Should be equivalent to {Binding} or {Binding Path=.} -->
    <StackPanel>
        <TextBlock x:Name="TestTextBlock" Text="{Binding Path={Binding}, Mode=OneWay}" />
    </StackPanel>
</UserControl>
