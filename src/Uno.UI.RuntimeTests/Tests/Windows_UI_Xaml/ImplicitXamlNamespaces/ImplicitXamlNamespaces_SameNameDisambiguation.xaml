<UserControl
	x:Class="Uno.UI.RuntimeTests.Tests.Windows_UI_Xaml.Controls.ImplicitXamlNamespaces_SameNameDisambiguation"
	Width="200" Height="200"
	xmlns:ambA="using:Uno.UI.RuntimeTests.Tests.Windows_UI_Xaml.Controls.AmbiguousA"
	xmlns:ambB="using:Uno.UI.RuntimeTests.Tests.Windows_UI_Xaml.Controls.AmbiguousB">

	<StackPanel>
		<!-- Same-named type resolved via explicit prefix to namespace A -->
		<ambA:SharedControl x:Name="SharedFromA"
							x:FieldModifier="public"
							Origin="Resolved A" />
		<!-- Same-named type resolved via explicit prefix to namespace B -->
		<ambB:SharedControl x:Name="SharedFromB"
							x:FieldModifier="public"
							Origin="Resolved B" />
	</StackPanel>
</UserControl>
