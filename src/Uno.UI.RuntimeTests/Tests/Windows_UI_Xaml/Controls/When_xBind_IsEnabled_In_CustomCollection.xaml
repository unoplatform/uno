<Page
	x:Class="Uno.UI.RuntimeTests.Tests.Windows_UI_Xaml.Controls.When_xBind_IsEnabled_In_CustomCollection"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="using:Uno.UI.RuntimeTests.Tests.Windows_UI_Xaml.Controls"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<StackPanel>
		<!-- Control inside a custom collection with x:Bind on IsEnabled -->
		<local:TestToolbar x:Name="TestToolbar" x:FieldModifier="public">
			<Button x:Name="ButtonInCollection"
					x:FieldModifier="public"
					Content="Test Button"
					IsEnabled="{x:Bind ViewModel.IsEnabled, Mode=OneWay}" />
		</local:TestToolbar>

		<!-- Same control outside the custom collection for comparison -->
		<Button x:Name="ButtonOutsideCollection"
				x:FieldModifier="public"
				Content="Reference Button"
				IsEnabled="{x:Bind ViewModel.IsEnabled, Mode=OneWay}" />
	</StackPanel>
</Page>
