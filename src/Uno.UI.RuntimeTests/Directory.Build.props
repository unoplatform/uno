<Project>
	<Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Build.props', '$(MSBuildThisFileDirectory)../'))" />
	<PropertyGroup>
		<UnoGenerateXamlSourcesProvider>True</UnoGenerateXamlSourcesProvider>
		<!-- Feature 004 — enable XAML C# expressions for the Tests_CSharpExpressions suite -->
		<UnoXamlCSharpExpressionsEnabled>true</UnoXamlCSharpExpressionsEnabled>
	</PropertyGroup>
</Project>
