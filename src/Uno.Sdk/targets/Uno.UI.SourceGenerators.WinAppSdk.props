<?xml version="1.0" encoding="utf-8" ?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

	<!--
		Auto Code-Behind Generation for WinUI targets.

		On WinUI builds (IsWinAppSdk=true), the Uno.UI.SourceGenerators analyzer is removed.
		This targets file re-adds it specifically for code-behind generation.
		The standalone XamlCodeBehindGenerator checks UnoCodeBehindGeneratorOnly=true to know it should run.
	-->

	<PropertyGroup Condition="'$(IsWinAppSdk)'=='true' and '$(ShouldRunGenerator)'!='true'">
		<UnoCodeBehindGeneratorOnly>true</UnoCodeBehindGeneratorOnly>
	</PropertyGroup>

	<!-- CompilerVisible items must be outside targets so GenerateMSBuildEditorConfigFile sees them -->
	<ItemGroup Condition="'$(UnoCodeBehindGeneratorOnly)'=='true'">
		<CompilerVisibleProperty Include="UnoGenerateCodeBehind" />
		<CompilerVisibleProperty Include="UnoCodeBehindGeneratorOnly" />
		<CompilerVisibleItemMetadata Include="AdditionalFiles" MetadataName="SourceItemGroup" />
		<CompilerVisibleItemMetadata Include="AdditionalFiles" MetadataName="UnoGenerateCodeBehind" />
	</ItemGroup>

	<Target Name="_AddCodeBehindGeneratorForWinUI"
			AfterTargets="_RemoveRoslynUnoSourceGeneration;_RemoveRoslynUnoSourceGenerationWinUI"
			Condition="'$(UnoCodeBehindGeneratorOnly)'=='true'">
		<ItemGroup>
			<Analyzer Include="$(MSBuildThisFileDirectory)../analyzers/dotnet/cs/Uno.UI.SourceGenerators.dll"
					  Condition="Exists('$(MSBuildThisFileDirectory)../analyzers/dotnet/cs/Uno.UI.SourceGenerators.dll')" />
		</ItemGroup>
	</Target>

</Project>
