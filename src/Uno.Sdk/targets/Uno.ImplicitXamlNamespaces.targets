<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

	<!--
	WinAppSDK XAML Pre-processing for Implicit Namespaces

	When building for WinAppSDK (IsWinAppSdk=true) and UnoEnableImplicitXamlNamespaces is enabled,
	this target pre-processes XAML files to inject missing xmlns declarations before the WinUI
	XAML compiler sees them. This enables the same XAML files (without explicit xmlns) to compile
	on both Uno targets (handled by source generator) and WinAppSDK targets (handled here).
	-->

	<UsingTask TaskName="InjectImplicitXamlNamespacesTask"
			   TaskFactory="RoslynCodeTaskFactory"
			   AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
		<ParameterGroup>
			<XamlFiles ParameterType="Microsoft.Build.Framework.ITaskItem[]" Required="true" />
			<OutputDirectory ParameterType="System.String" Required="true" />
			<PresentationNamespace ParameterType="System.String" Required="false" />
			<XamlNamespace ParameterType="System.String" Required="false" />
			<ProcessedFiles ParameterType="Microsoft.Build.Framework.ITaskItem[]" Output="true" />
		</ParameterGroup>
		<Task>
			<Using Namespace="System" />
			<Using Namespace="System.IO" />
			<Using Namespace="System.Text" />
			<Using Namespace="Microsoft.Build.Framework" />
			<Using Namespace="Microsoft.Build.Utilities" />
			<Code Type="Fragment" Language="cs">
<![CDATA[
var presentationNs = string.IsNullOrEmpty(PresentationNamespace)
	? "http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	: PresentationNamespace;
var xamlNs = string.IsNullOrEmpty(XamlNamespace)
	? "http://schemas.microsoft.com/winfx/2006/xaml"
	: XamlNamespace;

Directory.CreateDirectory(OutputDirectory);
var outputItems = new List<ITaskItem>();

foreach (var item in XamlFiles)
{
	var sourcePath = item.GetMetadata("FullPath");
	if (!File.Exists(sourcePath))
		continue;

	var content = File.ReadAllText(sourcePath);

	// Skip if already has a default xmlns
	if (content.Contains("xmlns=\""))
	{
		outputItems.Add(item);
		continue;
	}

	// Find the root element opening tag, skipping XML declarations and comments
	var rootTagStart = -1;
	for (var i = 0; i < content.Length - 1; i++)
	{
		if (content[i] == '<')
		{
			var next = content[i + 1];
			if (next == '?' || next == '!')
			{
				if (next == '?')
				{
					i = content.IndexOf("?>", i, StringComparison.Ordinal);
					if (i < 0) break;
					i++;
				}
				else if (i + 3 < content.Length && content[i + 2] == '-' && content[i + 3] == '-')
				{
					i = content.IndexOf("-->", i, StringComparison.Ordinal);
					if (i < 0) break;
					i += 2;
				}
				else
				{
					i = content.IndexOf('>', i);
					if (i < 0) break;
				}
			}
			else if (char.IsLetter(next) || next == '_')
			{
				rootTagStart = i;
				break;
			}
		}
	}

	if (rootTagStart < 0)
	{
		outputItems.Add(item);
		continue;
	}

	var rootTagEnd = content.IndexOf('>', rootTagStart);
	if (rootTagEnd < 0)
	{
		outputItems.Add(item);
		continue;
	}

	var rootTag = content.Substring(rootTagStart, rootTagEnd - rootTagStart);
	var injections = new StringBuilder();

	// Inject default xmlns
	injections.Append(" xmlns=\"");
	injections.Append(presentationNs);
	injections.Append('"');

	// Inject xmlns:x if missing
	if (!rootTag.Contains("xmlns:x=\""))
	{
		injections.Append(" xmlns:x=\"");
		injections.Append(xamlNs);
		injections.Append('"');
	}

	var isSelfClosing = rootTagEnd > 0 && content[rootTagEnd - 1] == '/';
	var insertPos = isSelfClosing ? rootTagEnd - 1 : rootTagEnd;
	var processed = content.Insert(insertPos, injections.ToString());

	// Write to temp directory preserving relative path
	var relativePath = item.GetMetadata("Link");
	if (string.IsNullOrEmpty(relativePath))
		relativePath = item.ItemSpec;
	var outputPath = Path.Combine(OutputDirectory, relativePath);
	Directory.CreateDirectory(Path.GetDirectoryName(outputPath));
	File.WriteAllText(outputPath, processed);

	var outputItem = new TaskItem(outputPath);
	item.CopyMetadataTo(outputItem);
	outputItem.SetMetadata("OriginalPath", sourcePath);
	outputItems.Add(outputItem);
}

ProcessedFiles = outputItems.ToArray();
]]>
			</Code>
		</Task>
	</UsingTask>

	<!-- Pre-process XAML files for WinAppSDK builds -->
	<Target Name="_UnoInjectImplicitXamlNamespaces"
			BeforeTargets="MarkupCompilePass1"
			Condition="'$(IsWinAppSdk)' == 'true' AND '$(UnoEnableImplicitXamlNamespaces)' == 'true'">

		<PropertyGroup>
			<_UnoImplicitXamlTempDir>$(IntermediateOutputPath)UnoImplicitXaml\</_UnoImplicitXamlTempDir>
		</PropertyGroup>

		<InjectImplicitXamlNamespacesTask
			XamlFiles="@(Page);@(ApplicationDefinition)"
			OutputDirectory="$(_UnoImplicitXamlTempDir)">
			<Output TaskParameter="ProcessedFiles" ItemName="_UnoProcessedXamlFiles" />
		</InjectImplicitXamlNamespacesTask>

		<!-- Replace original XAML items with processed versions -->
		<ItemGroup Condition="@(_UnoProcessedXamlFiles->Count()) > 0">
			<Page Remove="@(Page)" Condition="'%(Page.OriginalPath)' != ''" />
			<Page Include="@(_UnoProcessedXamlFiles)" Condition="'%(Extension)' == '.xaml'" />
		</ItemGroup>
	</Target>

	<!-- Clean up temp files after compilation -->
	<Target Name="_UnoCleanImplicitXamlNamespaces"
			AfterTargets="MarkupCompilePass2"
			Condition="'$(IsWinAppSdk)' == 'true' AND '$(UnoEnableImplicitXamlNamespaces)' == 'true'">
		<RemoveDir Directories="$(IntermediateOutputPath)UnoImplicitXaml" />
	</Target>

</Project>
