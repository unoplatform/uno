<?xml version="1.0" encoding="utf-8" ?>
<Project>
  <PropertyGroup>
	<!--
	  Exclude the source per-control XAML (merged into themeresources_v2.xaml below) and the merged
	  file itself from the automatic Page glob. The merged file is added to @(Page) explicitly by
	  _IncludeThemeResourceV2Page so it doesn't depend on existing on disk at evaluation time.
	-->
	<PageExclusions>$(MSBuildThisFileDirectory)Resources\**\*.xaml;$(MSBuildThisFileDirectory)themeresources_v2.xaml</PageExclusions>
  </PropertyGroup>

  <ItemGroup>
	<!-- Expand merge inputs at evaluation time so target incremental checks can compare timestamps. -->
	<ThemeResourceV2MergeInput Include="$(MSBuildThisFileDirectory)Resources\Version2\**\*.xaml" />
	<ThemeResourceV2MergeInput Include="$(MSBuildThisFileFullPath)" />
  </ItemGroup>

  <!--
    Merge the per-control source XAML into the single themeresources_v2.xaml that the XAML source
    generator consumes as a Page. This runs in the inner (per-TFM) build before the source generator
    reads its inputs (_InjectAdditionalFiles), not in the outer cross-targeting build: the file is a
    build artifact (no longer committed), and v2 is consumed by app heads purely through a
    ProjectReference, which builds the inner build directly and never runs DispatchToInnerBuilds. An
    outer-only hook would therefore never fire for those consumers, leaving the file ungenerated and
    the resource unregistered at runtime. Concurrent writers (multiple TFMs/variants sharing this one
    file) are made safe by the atomic write in BatchMergeXaml. themeresources_v2.xaml is in Outputs so
    a missing/deleted file forces regeneration.
  -->
  <Target Name="GenerateThemeResourceV2File"
          BeforeTargets="BeforeBuild;GenerateMSBuildEditorConfigFileCore;_InjectAdditionalFiles"
          Inputs="@(ThemeResourceV2MergeInput)"
          Outputs="$(MSBuildThisFileDirectory)themeresources_v2.xaml;$(IntermediateOutputPath)\Version2\GenerateThemeResourceFile.write.1u.tlog">
    <ItemGroup>
      <ExcludedTemplatesV2 Include="$(MSBuildThisFileDirectory)Resources\Version2\PriorityDefault\RadioMenuFlyoutItem_themeresources.xaml" />      
      <ExcludedTemplatesV2 Include="$(MSBuildThisFileDirectory)Resources\Version2\PriorityDefault\ProgressRing.xaml" />
      <ExcludedTemplatesV2 Include="$(MSBuildThisFileDirectory)Resources\Version2\PriorityDefault\ScrollViewer.xaml" />
      <ExcludedTemplatesV2 Include="$(MSBuildThisFileDirectory)Resources\Version2\PriorityDefault\ScrollViewer_themeresources.xaml" />
	  <!-- UNO TODO Fails to display correctly for multiple reasons, including https://github.com/unoplatform/uno/issues/325 but also undiagnosed issues -->
      <ExcludedTemplatesV2 Include="$(MSBuildThisFileDirectory)Resources\Version2\PriorityDefault\SplitView_themeresources.xaml" />
      <WinUIStylePageV2
		  Include="$(MSBuildThisFileDirectory)Resources\Version2\**\*.xaml" />
      <WinUIStylePageV2
		  Remove="@(ExcludedTemplatesV2)" />
    </ItemGroup>

    <Message Importance="high" Text="Generating theme resources XAML file " />
    <MakeDir Directories="$(IntermediateOutputPath)\Version2" />
    <BatchMergeXaml
	  Pages="@(WinUIStylePageV2)"
	  MergedXamlFile="$(MSBuildThisFileDirectory)themeresources_v2.xaml"
	  TlogReadFilesOutputPath="$(IntermediateOutputPath)\Version2\GenerateThemeResourceFile.read.1u.tlog"
	  TlogWriteFilesOutputPath="$(IntermediateOutputPath)\Version2\GenerateThemeResourceFile.write.1u.tlog" />
    <Message Text="Theme resources XAML file was generated" />
  </Target>

  <!--
    Add the generated themeresources_v2.xaml to @(Page) at build time (the automatic glob excludes it
    via PageExclusions because it may not exist at evaluation on a clean build). Must run before the
    source generator collects its inputs in _InjectAdditionalFiles. Gated on the same flag as the
    automatic Page glob so the Reference stub assembly keeps excluding it.
  -->
  <Target Name="_IncludeThemeResourceV2Page"
          DependsOnTargets="GenerateThemeResourceV2File"
          BeforeTargets="BeforeBuild;GenerateMSBuildEditorConfigFileCore;_InjectAdditionalFiles"
          Condition="'$(EnableAutomaticXamlPageInclusion)' != 'false'">
    <ItemGroup>
      <Page Include="$(MSBuildThisFileDirectory)themeresources_v2.xaml" />
    </ItemGroup>
  </Target>

  <PropertyGroup Condition="'$(UnoRuntimeIdentifier)'=='Reference'">
    <EnableAutomaticXamlPageInclusion>false</EnableAutomaticXamlPageInclusion>
  </PropertyGroup>

  <PropertyGroup>
	<UnoUIMSBuildTasksPath>$(MSBuildThisFileDirectory)..\SourceGenerators\Uno.UI.Tasks\bin\$(Configuration)_Shadow</UnoUIMSBuildTasksPath>
  </PropertyGroup>

  <Import Project="..\SourceGenerators\Uno.UI.SourceGenerators\Content\Uno.UI.SourceGenerators.props" />

</Project>
