<Project Sdk="Uno.Sdk.Private">
	<PropertyGroup>
		<!--
		Desktop intentionally not first (UNOB0011): keeps VS multi-target debugging working.
		The windows duplicate-internal collision is resolved by naming the WinUI assembly
		"SamplesApp.Windows" (no Toolkit/Foundation IVT) — see AssemblyName below.
		-->
		<TargetFrameworks>net10.0-browserwasm;$(NetCurrentWinAppSDK);net10.0-android;net10.0-ios;net10.0-tvos;net10.0-desktop</TargetFrameworks>
		<OutputType>Exe</OutputType>
		<OutputType Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">WinExe</OutputType>
		<UnoSingleProject>true</UnoSingleProject>
		<AssemblyName>SamplesApp</AssemblyName>
		<!--
		On WinUI the assembly is named like the old SamplesApp.Windows head, which is deliberately
		NOT in the Uno.UI.Toolkit / Uno.Foundation InternalsVisibleTo lists. That keeps Toolkit.Windows's
		self-linked *internal* helpers (AsyncLock, EnumerableExtensions, DependencyObjectExtensions)
		invisible, so the head uses the public Uno.Core.Extensions package APIs instead and there's no
		duplicate-type collision. (On Skia the "SamplesApp" name keeps the IVT the shared code relies on.)
		-->
		<AssemblyName Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">SamplesApp.Windows</AssemblyName>

		<!--
		Set Skia early (before the source-generator props evaluate) so XAML conditional namespaces
		like xmlns:skia="http://uno.ui/skia" are recognized and .skia.cs files are included. Uno.Sdk
		also sets it, but in .targets (too late for Uno.UI.SourceGenerators.props / Uno.CrossTargetting).
		ONLY for desktop + browserwasm (generic netX Skia, which use .skia.cs). On android/ios/tvos it
		must stay empty here so Uno.CrossTargetting picks the native .Android.cs/.iOS.cs/.UIKit.cs file
		variants (Skia rendering still comes from the Runtime.Skia.* runtime, set later) — matching the
		old netcoremobile head. On WinUI it stays empty (native rendering).
		-->
		<_IsDesktopOrWasm Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'desktop' OR $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'browserwasm'">true</_IsDesktopOrWasm>
		<UnoRuntimeIdentifier Condition="'$(UnoRuntimeIdentifier)' == '' AND '$(_IsDesktopOrWasm)' == 'true'">Skia</UnoRuntimeIdentifier>
		<!-- True for every non-WinUI TFM (desktop/wasm/android/ios/tvos) — gates the Skia framework refs. -->
		<_IsSkiaTfm Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) != 'windows'">true</_IsSkiaTfm>
		<!-- Skia mobile (android/ios/tvos): consumes samples from the SamplesApp.Skia base lib (generic
		     Skia) rather than inlining them, so they don't compile with native platform symbols. -->
		<_IsMobile Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android' OR $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios' OR $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'tvos'">true</_IsMobile>
		<!-- Apple UIKit (iOS + tvOS; no MacCatalyst). NOTE: these TFMs require macOS to build — not
		     compile-validated on Windows. Wiring mirrors the old netcoremobile head's apple <When> blocks. -->
		<_IsUIKit Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios' OR $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'tvos'">true</_IsUIKit>

		<!-- Keep full exception strings in release, as the current heads do -->
		<UseSystemResourceKeys>false</UseSystemResourceKeys>

		<SamplesAppUseImplicitPackages Condition="'$(SamplesAppUseImplicitPackages)' == ''">false</SamplesAppUseImplicitPackages>
		<DisableImplicitUnoPackages Condition="'$(SamplesAppUseImplicitPackages)' != 'true'">true</DisableImplicitUnoPackages>
		<DisableImplicitUnoWinAppSdkPackages Condition="'$(SamplesAppUseImplicitPackages)' != 'true'">true</DisableImplicitUnoWinAppSdkPackages>

		<!-- Build the Uno.UI.Tasks shadow assembly first (CI / clean builds), as the source heads do -->
		<PreBuildUnoUITasks Condition="'$(BuildingInsideVisualStudio)'==''">true</PreBuildUnoUITasks>
	</PropertyGroup>

	<!-- Honor UnoTargetFrameworkOverride (CI + local single-TFM builds), as the other heads do -->
	<Import Project="..\..\targetframework-override.props" />

	<!-- ==================== Source mode: framework via ProjectReference ==================== -->

	<!-- Cross-Skia framework + AddIns shared by every Skia TFM (desktop/wasm/android/ios/tvos), NOT windows -->
	<ItemGroup Condition="'$(SamplesAppUseImplicitPackages)' != 'true' AND '$(_IsSkiaTfm)' == 'true'">
		<ProjectReference Include="..\..\Uno.UI\Uno.UI.Skia.csproj" />
		<ProjectReference Include="..\..\Uno.UI.Composition\Uno.UI.Composition.Skia.csproj" />
		<ProjectReference Include="..\..\SourceGenerators\System.Xaml\Uno.Xaml.csproj" />
		<ProjectReference Include="..\..\Uno.UI.Adapter.Microsoft.Extensions.Logging\Uno.UI.Adapter.Microsoft.Extensions.Logging.csproj" />
		<ProjectReference Include="..\..\Uno.UI.FluentTheme\Uno.UI.FluentTheme.Skia.csproj" />
		<ProjectReference Include="..\..\Uno.UI.Toolkit\Uno.UI.Toolkit.Skia.csproj" />
		<ProjectReference Include="..\..\Uno.UI.RemoteControl\Uno.UI.RemoteControl.Skia.csproj" />
		<ProjectReference Include="..\..\Uno.UI.RuntimeTests\Uno.UI.RuntimeTests.Skia.csproj" />
		<ProjectReference Include="..\..\AddIns\Uno.UI.Lottie\Uno.UI.Lottie.Skia.csproj" />
		<ProjectReference Include="..\..\AddIns\Uno.UI.Svg\Uno.UI.Svg.Skia.csproj" />
		<ProjectReference Include="..\..\AddIns\Uno.WinUI.SpellChecking\Uno.WinUI.SpellChecking.csproj" />
		<ProjectReference Include="..\..\AddIns\Uno.WinUI.Graphics3DGL\Uno.WinUI.Graphics3DGL.csproj" />
		<ProjectReference Include="..\..\AddIns\Uno.WinUI.Graphics2DSK\Uno.WinUI.Graphics2DSK.Crossruntime.csproj" />
	</ItemGroup>

	<!-- Desktop framework variants + runtimes + AddIns (Win32/X11/FrameBuffer/macOS) -->
	<ItemGroup Condition="'$(SamplesAppUseImplicitPackages)' != 'true' AND $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'desktop'">
		<ProjectReference Include="..\..\Uno.Foundation\Uno.Foundation.Skia.csproj" />
		<ProjectReference Include="..\..\Uno.UWP\Uno.Skia.csproj" />
		<ProjectReference Include="..\..\Uno.UI.Dispatching\Uno.UI.Dispatching.Skia.csproj" />
		<ProjectReference Include="..\..\Uno.UI.Runtime.Skia.Win32\Uno.UI.Runtime.Skia.Win32.csproj" />
		<ProjectReference Include="..\..\Uno.UI.Runtime.Skia.Win32.Support\Uno.UI.Runtime.Skia.Win32.Support.csproj" />
		<ProjectReference Include="..\..\Uno.UI.Runtime.Skia.X11\Uno.UI.Runtime.Skia.X11.csproj" />
		<ProjectReference Include="..\..\Uno.UI.Runtime.Skia.Linux.FrameBuffer\Uno.UI.Runtime.Skia.Linux.FrameBuffer.csproj" />
		<ProjectReference Include="..\..\Uno.UI.Runtime.Skia.MacOS\Uno.UI.Runtime.Skia.MacOS.csproj" />
		<ProjectReference Include="..\..\AddIns\Uno.UI.MediaPlayer.Skia.Win32\Uno.UI.MediaPlayer.Skia.Win32.csproj" />
		<ProjectReference Include="..\..\AddIns\Uno.UI.MediaPlayer.Skia.X11\Uno.UI.MediaPlayer.Skia.X11.csproj" />
		<ProjectReference Include="..\..\AddIns\Uno.UI.WebView.Skia.X11\Uno.UI.WebView.Skia.X11.csproj" />
		<ProjectReference Include="..\..\AddIns\Uno.UI.MSAL\Uno.UI.MSAL.Reference.csproj" />
	</ItemGroup>

	<!-- browserwasm framework variants + runtime -->
	<ItemGroup Condition="'$(SamplesAppUseImplicitPackages)' != 'true' AND $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'browserwasm'">
		<ProjectReference Include="..\..\Uno.Foundation\Uno.Foundation.Wasm.csproj" />
		<ProjectReference Include="..\..\Uno.UWP\Uno.Wasm.csproj" />
		<ProjectReference Include="..\..\Uno.UI.Dispatching\Uno.UI.Dispatching.Wasm.csproj" />
		<ProjectReference Include="..\..\Uno.UI.Runtime.Skia.WebAssembly.Browser\Uno.UI.Runtime.Skia.WebAssembly.Browser.csproj" />
		<ProjectReference Include="..\..\AddIns\Uno.UI.MSAL\Uno.UI.MSAL.Reference.csproj" />
	</ItemGroup>

	<!-- Windows / WinAppSDK: NATIVE WinUI (no Uno.UI / SkiaSharp). Only the .Windows helper variants. -->
	<ItemGroup Condition="'$(SamplesAppUseImplicitPackages)' != 'true' AND $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">
		<ProjectReference Include="..\..\Uno.UI.Toolkit\Uno.UI.Toolkit.Windows.csproj" />
		<ProjectReference Include="..\..\AddIns\Uno.UI.MSAL\Uno.UI.MSAL.Windows.csproj" />
		<ProjectReference Include="..\..\AddIns\Uno.WinUI.Graphics2DSK\Uno.WinUI.Graphics2DSK.Windows.csproj" />
		<ProjectReference Include="..\..\AddIns\Uno.WinUI.Graphics3DGL\Uno.WinUI.Graphics3DGL.csproj" AdditionalProperties="BuildGraphics3DGLForWindows=true" />
		<ProjectReference Include="..\..\Uno.UI.RuntimeTests\Uno.UI.RuntimeTests.Windows.csproj" />
		<!-- No Uno.UI on WinUI: self-link the one Uno.UI extension the samples use that the
		     Uno.Core.Extensions packages don't provide (matches the old SamplesApp.Windows head). -->
		<Compile Include="..\..\Uno.UI\Extensions\DependencyObjectExtensions.cs" Link="Uno.UI\Extensions\DependencyObjectExtensions.cs" />
	</ItemGroup>

	<!-- ==================== Packages ==================== -->

	<!-- Platform-agnostic packages (all TFMs incl. windows) -->
	<ItemGroup>
		<PackageReference Include="Newtonsoft.Json" />
		<PackageReference Include="Uno.Core.Extensions.Logging.Singleton" />
		<PackageReference Include="MSTest.TestFramework" />
		<PackageReference Include="MSTest.Analyzers" />
		<PackageReference Include="System.CommandLine" />
		<PackageReference Include="IdentityModel.OidcClient" Version="6.0.0" />
		<PackageReference Include="Microsoft.Identity.Client" Version="4.72.1" />
		<PackageReference Include="Uno.BenchmarkDotNet" Version="0.11.7-develop" />
		<PackageReference Include="Uno.BenchmarkDotNet.Annotations" Version="0.11.7-develop" />
		<PackageReference Include="BenchmarkDotNet" Version="0.11.4-develop" />
		<PackageReference Include="Microsoft.Extensions.Logging.Console" Version="5.0.0" />
		<PackageReference Include="Microsoft.Extensions.Logging.Debug" Version="5.0.0" />
		<PackageReference Include="Microsoft.Graph" Condition="'$(Configuration)'!='Debug'">
			<!-- Workaround for https://github.com/microsoftgraph/msgraph-sdk-dotnet/issues/2617 -->
			<Version>5.56.0</Version>
		</PackageReference>
		<!-- Override vulnerable transitive Microsoft.Kiota.Abstractions 1.9.1 pulled in by Microsoft.Graph -->
		<PackageReference Include="Microsoft.Kiota.Abstractions" Version="1.22.2" Condition="'$(Configuration)'!='Debug'" />
	</ItemGroup>

	<!-- Skia-only packages (desktop/wasm/android/ios/tvos, NOT windows) -->
	<ItemGroup Condition="'$(_IsSkiaTfm)' == 'true'">
		<PackageReference Include="SkiaSharp" />
		<PackageReference Include="Uno.Fonts.Fluent" />
		<PackageReference Include="Uno.Extensions.Logging.WebAssembly.Console" />
	</ItemGroup>

	<!-- Desktop-specific packages -->
	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'desktop'">
		<PackageReference Include="SkiaSharp.NativeAssets.Linux" />
		<PackageReference Include="Microsoft.Web.WebView2" Aliases="MsWebView2" />
		<PackageReference Include="VideoLAN.LibVLC.Windows" Version="3.0.23.1" />
		<!-- WMI / system info (desktop-only; Microsoft.Windows.Compatibility provides it on wasm) -->
		<PackageReference Include="System.Management" Version="8.0.0" />
	</ItemGroup>

	<!-- browserwasm packages -->
	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'browserwasm'">
		<PackageReference Include="SkiaSharp.NativeAssets.WebAssembly" />
		<PackageReference Include="Uno.Wasm.Bootstrap" />
		<PackageReference Include="Microsoft.Windows.Compatibility" />
	</ItemGroup>

	<!-- Windows / WinAppSDK packages (real WinUI) -->
	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">
		<PackageReference Include="Microsoft.WindowsAppSDK" Version="2.1.3" />
		<PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.4654" />
		<PackageReference Include="Microsoft.Windows.SDK.BuildTools.WinApp" Version="0.3.1" PrivateAssets="all" />
		<PackageReference Include="CommunityToolkit.WinUI.Lottie" Version="8.0.0-rc" />
		<!-- Provided transitively via Uno.UI on Skia; explicit on native WinUI. -->
		<PackageReference Include="Uno.Core.Extensions.Logging" />
		<PackageReference Include="Uno.Core.Extensions.Disposables" />
		<PackageReference Include="Uno.Core.Extensions" />
		<PackageReference Include="Uno.Core.Extensions.Compatibility" />
	</ItemGroup>

	<!-- ==================== WASM build configuration ==================== -->
	<PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'browserwasm'">
		<!-- Required for net9+ workloads -->
		<AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
		<NoWarn>$(NoWarn);NU1903;NU1902</NoWarn>
		<!-- To remove when all linker warnings have been fixed -->
		<NoWarn>$(NoWarn);IL2026;IL2072;IL2067;IL2075;IL2070;IL2077;IL2057;IL2045;IL2111;IL2062;IL2104;IL2080;IL2065;IL2090;IL2007;IL2122</NoWarn>
		<PublishTrimmed>false</PublishTrimmed>
		<WasmShellILLinkerEnabled>false</WasmShellILLinkerEnabled>
		<WasmIncludeFullIcuData>true</WasmIncludeFullIcuData>
		<InvariantGlobalization>false</InvariantGlobalization>
		<WasmShellLoadAllSatelliteResources>true</WasmShellLoadAllSatelliteResources>
		<WasmShellEnableIDBFS>true</WasmShellEnableIDBFS>
		<WasmBuildNative>true</WasmBuildNative>
		<!-- Workaround for https://github.com/dotnet/aspnetcore/issues/63970 -->
		<WasmFingerprintAssets>false</WasmFingerprintAssets>
	</PropertyGroup>
	<PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'browserwasm' AND '$(Configuration)'=='Debug'">
		<MonoRuntimeDebuggerEnabled>true</MonoRuntimeDebuggerEnabled>
		<DefineConstants>$(DefineConstants);TRACE;DEBUG</DefineConstants>
		<DebugType>portable</DebugType>
		<DebugSymbols>true</DebugSymbols>
	</PropertyGroup>
	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'browserwasm'">
		<WasmShellMonoEnvironment Include="MONO_GC_PARAMS" Value="soft-heap-limit=1024m,nursery-size=64m,evacuation-threshold=66,major=marksweep" />
		<LinkerDescriptor Include="Platforms\WebAssembly\LinkerConfig.xml" />
		<EmbeddedResource Include="Platforms\WebAssembly\WasmScripts\AppManifest.js" />
		<Content Include="..\LinkedFiles\WebContent\**\*.*">
			<Link>WebContent\%(RecursiveDir)%(Filename)%(Extension)</Link>
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</Content>
		<WasmShellExtraFilesToDeploy Include="..\LinkedFiles\WebContent\**\*.*">
			<TargetPath>WebContent/%(RecursiveDir)%(Filename)%(Extension)</TargetPath>
		</WasmShellExtraFilesToDeploy>
	</ItemGroup>
	<!-- https://github.com/dotnet/runtime/issues/109289 — reorder SkiaSharp native files for emcc linking -->
	<Target Name="Issue109289_Workaround"
	        Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'browserwasm'"
	        AfterTargets="_BrowserWasmWriteRspForLinking">
		<ItemGroup>
			<_WasmLinkStepArgs Remove="@(_EmccLinkStepArgs)" />
			<_EmccLinkStepArgs Remove="&quot;%(_WasmNativeFileForLinking.Identity)&quot;" />
			<_WasmLinkDependencies Remove="@(_WasmNativeFileForLinking)" />
			<_SkiaSharpToReorder Include="@(_WasmNativeFileForLinking)" Condition="$([System.String]::Copy('%(FullPath)').Contains('SkiaSharp'))" />
			<_WasmNativeFileForLinking Remove="@(_SkiaSharpToReorder)" />
			<_WasmNativeFileForLinking Include="@(_SkiaSharpToReorder)" />
			<_EmccLinkStepArgs Include="&quot;%(_WasmNativeFileForLinking.Identity)&quot;" />
			<_WasmLinkDependencies Include="@(_WasmNativeFileForLinking)" />
			<_WasmLinkStepArgs Include="@(_EmccLinkStepArgs)" />
		</ItemGroup>
	</Target>

	<!-- ==================== android (Skia) ==================== -->
	<ItemGroup Condition="'$(SamplesAppUseImplicitPackages)' != 'true' AND $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">
		<ProjectReference Include="..\..\Uno.Foundation\Uno.Foundation.netcoremobile.csproj" />
		<ProjectReference Include="..\..\Uno.UWP\Uno.netcoremobile.csproj" />
		<ProjectReference Include="..\..\Uno.UI.Dispatching\Uno.UI.Dispatching.netcoremobile.csproj" />
		<ProjectReference Include="..\..\Uno.UI.Runtime.Skia.Android\Uno.UI.Runtime.Skia.Android.csproj" />
		<ProjectReference Include="..\..\AddIns\Uno.UI.MSAL\Uno.UI.MSAL.netcoremobile.csproj" />
		<ProjectReference Include="..\..\AddIns\Uno.UI.GooglePlay\Uno.UI.GooglePlay.netcoremobile.csproj" />
		<ProjectReference Include="..\..\AddIns\Uno.UI.Foldable\Uno.UI.Foldable.netcoremobile.csproj" />
	</ItemGroup>

	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">
		<PackageReference Include="SkiaSharp.NativeAssets.Android" />
		<PackageReference Include="Uno.UniversalImageLoader" Version="1.9.36" />
	</ItemGroup>
	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android' AND '$(TargetFramework)' == 'net10.0-android'">
		<PackageReference Include="Xamarin.AndroidX.Browser" Version="1.8.0.10" />
		<PackageReference Include="Xamarin.AndroidX.Core.SplashScreen" Version="1.0.1.16" />
		<PackageReference Include="Xamarin.Google.Android.Material" Version="1.12.0.4" />
	</ItemGroup>

	<PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">
		<DefineConstants>$(DefineConstants);XAMARIN;HAS_UNO</DefineConstants>
		<DefineConstants Condition=" '$(UseMonoRuntime)' == 'false' ">$(DefineConstants);RUNTIME_CORECLR</DefineConstants>
		<SupportedOSPlatformVersion>10.0</SupportedOSPlatformVersion>
		<!-- apk (not aab) so the runtime-test harness can deploy to emulators -->
		<AndroidPackageFormat>apk</AndroidPackageFormat>
		<AndroidEnableMultiDex>true</AndroidEnableMultiDex>
		<AndroidUseAssemblyStore>false</AndroidUseAssemblyStore>
		<!-- We need all the intermediate assemblies for the runtime tests -->
		<DisablePrivateProjectReference>true</DisablePrivateProjectReference>
		<!-- Temporarily disabled due to uno-private #647 -->
		<UnoDisableHotRestartHelperGeneration>true</UnoDisableHotRestartHelperGeneration>
		<IsUiAutomationMappingEnabled>true</IsUiAutomationMappingEnabled>
		<PublishAot Condition=" '$(SkiaPublishAot)' != '' ">$(SkiaPublishAot)</PublishAot>
		<NoWarn>$(NoWarn);NU1703;SYSLIB1045;IL2026;IL2057;IL2062;IL2065;IL2067;IL2068;IL2070;IL2072;IL2075;IL2077;IL2080;IL2104;IL2111;IL2122;IL3000;IL3002;IL3050;IL3053</NoWarn>
	</PropertyGroup>
	<PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android' AND '$(Configuration)'=='Release'">
		<RuntimeIdentifiers>android-x64;android-arm64</RuntimeIdentifiers>
	</PropertyGroup>
	<PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">
		<!-- Package id for the plain (mono) APK. Without it the package derives from the assembly
		     (SamplesApp.SamplesApp-Signed.apk) and the CI artifact copy can't find it. The
		     coreclr/nativeaot CI stages override this with .coreclr/.nativeaot suffixes. -->
		<ApplicationId>uno.platform.samplesapp.skia</ApplicationId>
	</PropertyGroup>

	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">
		<AndroidAsset Include="Platforms\Android\Assets\sound.mp3" Link="Assets\sound.mp3" />
		<AndroidAsset Include="Platforms\Android\Assets\Lottie\**\*.json" Link="Assets\Lottie\%(RecursiveDir)%(Filename)%(Extension)" />
		<AndroidEnvironment Include="Platforms\Android\environment.conf" />
		<TrimmerRootDescriptor Include="Platforms\Android\LinkerConfig.xml" />
	</ItemGroup>

	<Import Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'" Project="..\..\Uno.UI.Runtime.Skia.Android\build\*.Runtime.Skia.Android.props" />
	<Import Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'" Project="..\..\Uno.UI.Runtime.Skia.Android\build\*.Runtime.Skia.Android.targets" />

	<!-- ==================== iOS + tvOS (AppleUIKit + Skia) — REQUIRES macOS to build ==================== -->
	<!-- Mirrors the old SamplesApp.Skia.netcoremobile apple <When> blocks. Samples come from the
	     SamplesApp.Skia base lib (referenced for all Skia TFMs above). Not compile-validated on Windows. -->
	<ItemGroup Condition="'$(SamplesAppUseImplicitPackages)' != 'true' AND '$(_IsUIKit)' == 'true'">
		<ProjectReference Include="..\..\Uno.Foundation\Uno.Foundation.netcoremobile.csproj" />
		<ProjectReference Include="..\..\Uno.UWP\Uno.netcoremobile.csproj" />
		<ProjectReference Include="..\..\Uno.UI.Dispatching\Uno.UI.Dispatching.netcoremobile.csproj" />
		<ProjectReference Include="..\..\AddIns\Uno.UI.MSAL\Uno.UI.MSAL.netcoremobile.csproj" />
		<ProjectReference Include="..\..\Uno.UI.Runtime.Skia.AppleUIKit\Uno.UI.Runtime.Skia.AppleUIKit.csproj" />
	</ItemGroup>

	<PropertyGroup Condition="'$(_IsUIKit)' == 'true'">
		<SupportedOSPlatformVersion>12.2</SupportedOSPlatformVersion>
		<!-- iOS 17 compatibility -->
		<MtouchExtraArgs>$(MtouchExtraArgs) --weak-framework=NewsstandKit</MtouchExtraArgs>
		<!-- AOT currently fails (uno-private #648): interpret instead -->
		<MtouchUseLlvm>false</MtouchUseLlvm>
		<UseInterpreter>true</UseInterpreter>
		<MtouchInterpreter>all</MtouchInterpreter>
	</PropertyGroup>

	<!-- iOS/tvOS bundle the WebView2 test content. The .NET iOS/tvOS toolchain reserves the
	     top-level bundle folder name 'Resources' (_CollectBundleResources errors on it), so prefix
	     the Link with the platform name as the old netcoremobile head did. -->
	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">
		<BundleResource Include="..\LinkedFiles\WebContent\css\site.css" Link="iOS\Resources\WebContent\css\site.css" />
		<BundleResource Include="..\LinkedFiles\WebContent\index.html" Link="iOS\Resources\WebContent\index.html" />
		<BundleResource Include="..\LinkedFiles\WebContent\js\site.js" Link="iOS\Resources\WebContent\js\site.js" />
	</ItemGroup>
	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'tvos'">
		<BundleResource Include="..\LinkedFiles\WebContent\css\site.css" Link="tvOS\Resources\WebContent\css\site.css" />
		<BundleResource Include="..\LinkedFiles\WebContent\index.html" Link="tvOS\Resources\WebContent\index.html" />
		<BundleResource Include="..\LinkedFiles\WebContent\js\site.js" Link="tvOS\Resources\WebContent\js\site.js" />
	</ItemGroup>

	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">
		<PackageReference Include="SkiaSharp.NativeAssets.iOS" />
		<PackageReference Include="Uno.Extensions.Logging.OSLog" Version="1.7.0" />
	</ItemGroup>
	<PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">
		<!-- https://github.com/dotnet/runtime/issues/109966 -->
		<_IsDedupEnabled>false</_IsDedupEnabled>
		<RuntimeIdentifier Condition="'$(RuntimeIdentifier)' == ''">iossimulator-x64</RuntimeIdentifier>
	</PropertyGroup>

	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'tvos'">
		<PackageReference Include="SkiaSharp.NativeAssets.TvOS" />
	</ItemGroup>
	<PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'tvos'">
		<RuntimeIdentifier Condition="'$(RuntimeIdentifier)' == ''">tvossimulator-x64</RuntimeIdentifier>
	</PropertyGroup>

	<Import Condition="'$(_IsUIKit)' == 'true'" Project="..\..\Uno.UI.Runtime.Skia.AppleUIKit\build\*.Runtime.Skia.AppleUIKit.props" />
	<Import Condition="'$(_IsUIKit)' == 'true'" Project="..\..\Uno.UI.Runtime.Skia.AppleUIKit\build\*.Runtime.Skia.AppleUIKit.targets" />

	<!--
	WASM: register referenced content (the Uno.UI.RuntimeTests test assets/fonts) into the
	Uno ms-appx asset manifest (wwwroot/package_*/uno-assets.txt) that the runtime fetches.
	Uno.Sdk manifests the base-lib samples content, but not the head's directly-referenced
	RuntimeTests content for browserwasm, so image/font-loading runtime tests can't find
	their assets at runtime. The old WebAssembly head imported this; mirror it, gated to wasm.
	-->
	<PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'browserwasm'">
		<UnoUIMSBuildTasksPath>$(MSBuildThisFileDirectory)..\..\SourceGenerators\Uno.UI.Tasks\bin\$(Configuration)_Shadow</UnoUIMSBuildTasksPath>
	</PropertyGroup>
	<Import Project="..\..\SourceGenerators\Uno.UI.Tasks\Content\Uno.UI.Tasks.targets"
	        Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'browserwasm' AND '$(SkipUnoResourceGeneration)' == ''" />

	<!-- ==================== Windows build configuration ==================== -->
	<PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">
		<TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
		<UseWinUI>true</UseWinUI>
		<EnableMsixTooling>true</EnableMsixTooling>
		<DefineConstants>$(DefineConstants);WINAPPSDK</DefineConstants>
		<Platforms>x86;x64;ARM64</Platforms>
		<RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>
		<!-- Disabled because of https://github.com/dotnet/sdk/issues/43680#issuecomment-2401193028 -->
		<CsWinRTAotOptimizerEnabled>false</CsWinRTAotOptimizerEnabled>
		<!-- MSIX signing is configured via CI -->
		<AppxPackageSigningEnabled>true</AppxPackageSigningEnabled>
		<AppxPackageSigningTimestampDigestAlgorithm>SHA256</AppxPackageSigningTimestampDigestAlgorithm>
		<AppxAutoIncrementPackageRevision>false</AppxAutoIncrementPackageRevision>
		<GenerateAppxPackageOnBuild>false</GenerateAppxPackageOnBuild>
		<ApplicationManifest>Platforms\Windows\app.manifest</ApplicationManifest>
	</PropertyGroup>
	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">
		<AppxManifest Include="Platforms\Windows\Package.appxmanifest">
			<SubType>Designer</SubType>
		</AppxManifest>
		<Content Include="Platforms\Windows\Assets\*.png" Link="Assets\%(Filename)%(Extension)" />
		<Manifest Include="$(ApplicationManifest)" />
		<Content Include="..\LinkedFiles\WebContent\index.html" Link="WebContent\index.html" />
		<Content Include="..\LinkedFiles\WebContent\css\site.css" Link="WebContent\css\site.css" />
		<Content Include="..\LinkedFiles\WebContent\js\site.js" Link="WebContent\js\site.js" />
	</ItemGroup>
	<!-- Activate the MSIX single-project tooling even before the WindowsAppSDK package is restored -->
	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows' and '$(DisableMsixProjectCapabilityAddedByProject)'!='true' and '$(EnableMsixTooling)'=='true'">
		<ProjectCapability Include="Msix" />
	</ItemGroup>
	<PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows' and '$(DisableHasPackageAndPublishMenuAddedByProject)'!='true' and '$(EnableMsixTooling)'=='true'">
		<HasPackageAndPublishMenu>true</HasPackageAndPublishMenu>
	</PropertyGroup>

	<!-- ==================== App identity / icons / manifests ==================== -->

	<!-- App identity manifest read at runtime by SamplesApp on Skia (windows uses the real MSIX manifest) -->
	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) != 'windows'">
		<EmbeddedResource Include="Platforms\Windows\Package.appxmanifest" LogicalName="Package.appxmanifest" />
	</ItemGroup>

	<!--
	App icon + splash via Resizetizer (desktop + mobile). Excluded on browserwasm to match the
	previous WASM head (enabling it trips Uno.Wasm.Bootstrap's PWA generation) and on windows,
	which uses the MSIX logo assets above. PWA icons on wasm are a follow-up.
	-->
	<ItemGroup Condition="'$(_IsSkiaTfm)' == 'true' AND $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) != 'browserwasm'">
		<PackageReference Include="Uno.Resizetizer" />
		<UnoIcon Include="Assets\Icons\icon.svg" ForegroundFile="Assets\Icons\icon_foreground.svg" ForegroundScale="0.65" Color="#ffffff" />
		<UnoSplashScreen Include="Assets\Splash\splash_screen.svg" BaseSize="128,128" Color="#ffffff" />
	</ItemGroup>

	<!-- Win32 DPI-awareness manifest (desktop only; windows sets its own ApplicationManifest above) -->
	<PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'desktop'">
		<ApplicationManifest>app.manifest</ApplicationManifest>
	</PropertyGroup>
	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'desktop'">
		<Manifest Include="$(ApplicationManifest)" />
	</ItemGroup>

	<!-- Desktop: deploy the WebView2 test content folder (the old Skia.Generic head deployed it;
	     Given_WebView2.When_LocalFolder_File needs WebContent next to the app). -->
	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'desktop'">
		<Content Include="..\LinkedFiles\WebContent\**\*.*">
			<Link>WebContent\%(RecursiveDir)%(Filename)%(Extension)</Link>
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
	</ItemGroup>

	<!-- Desktop: stage the macOS native host dylib into runtimes/osx/native so the published
	     desktop artifact (built on Windows, run on macOS agents) can dlopen it. The dylib comes
	     from the downloaded native-assets-macos artifact, not the ProjectReference, so it must be
	     copied explicitly — mirrors the old Skia.Generic head's BuildUnoNativeMac target. -->
	<PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'desktop'">
		<_libUnoNativeMacPath>$(MSBuildThisFileDirectory)..\..\Uno.UI.Runtime.Skia.MacOS\UnoNativeMac\build\$(Configuration)\libUnoNativeMac.dylib</_libUnoNativeMacPath>
	</PropertyGroup>
	<Target Name="BuildUnoNativeMac" BeforeTargets="Compile"
	        Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'desktop' AND Exists('$(_libUnoNativeMacPath)')">
		<Copy SourceFiles="$(_libUnoNativeMacPath)" DestinationFolder="$(OutDir)runtimes\osx\native\" />
	</Target>
	<ItemGroup Label="AssemblyInfo" Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'desktop'">
		<AssemblyAttribute Include="System.Runtime.InteropServices.ComVisibleAttribute">
			<_Parameter1>false</_Parameter1>
		</AssemblyAttribute>
	</ItemGroup>

	<!--
	Fail the publish if the runtime-test fonts didn't make it into the output. Only meaningful on
	desktop + browserwasm, whose publish lays package content out flat under $(PublishDir) (this is
	where the original Skia.Generic/WebAssembly heads ran it). Android/iOS bundle assets inside the
	APK/.app, so this flat-path check can never pass there — and the old netcoremobile head never ran it.
	-->
	<Target Name="_ValidatePublishedItems" AfterTargets="Publish" Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'desktop' OR $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'browserwasm'">
		<ItemGroup>
			<_validationPath Include="Uno.Fonts.Fluent/Fonts/uno-fluentui-assets.ttf" />
			<_validationPath Include="Uno.UI.RuntimeTests/Assets/Fonts/uno-fluentui-assets-runtimetest01.ttf" />
		</ItemGroup>
		<Error Condition="!exists('$(PublishDir)%(_validationPath.Identity)')" Text="Failed to find published file: %(_validationPath.Identity)" />
	</Target>

	<!--
	On macOS, create a minimal .app bundle alongside the regular build output so that
	TCC-gated APIs (microphone, speech recognition) can present their authorization prompt.
	Launch via `open bin/.../SamplesApp.app`. Set SkipMacOSAppBundle=true to skip.
	-->
	<Target Name="_UnoBundleAppMacOS"
	        Condition="$([MSBuild]::IsOsPlatform('OSX')) and '$(SkipMacOSAppBundle)' != 'true' and '$(OutputType)' == 'Exe' and '$(TargetFramework)' != '' and $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'desktop'"
	        AfterTargets="Build">
		<PropertyGroup>
			<_AppBundleDir>$(OutputPath)$(AssemblyName).app</_AppBundleDir>
			<_AppBundleContentsDir>$(_AppBundleDir)/Contents</_AppBundleContentsDir>
			<_AppBundleMacOSDir>$(_AppBundleContentsDir)/MacOS</_AppBundleMacOSDir>
		</PropertyGroup>
		<RemoveDir Directories="$(_AppBundleDir)" />
		<MakeDir Directories="$(_AppBundleMacOSDir)" />
		<Copy SourceFiles="$(MSBuildThisFileDirectory)Resources/Info.plist" DestinationFolder="$(_AppBundleContentsDir)" />
		<Exec Command="rsync -a --exclude='$(AssemblyName).app' '$(OutputPath)/' '$(_AppBundleMacOSDir)/'" />
		<Message Importance="high" Text="Created macOS app bundle: $(_AppBundleDir)" />
	</Target>

	<!-- ==================== Shared content (samples, tests, benchmarks) ==================== -->
	<!--
	Content sourcing:
	  - Skia TFMs (desktop/wasm/android/ios/tvos): reference the generic-Skia SamplesApp.Skia library,
	    which compiles the samples ONCE as Skia (__SKIA__, the Skia/#else branches). This is what every
	    old Skia head did, and it's why mobile works: inlining would compile samples with the native
	    platform symbol (__ANDROID__/__APPLE_UIKIT__) and pull native-only types (e.g. BindableButtonEx)
	    that aren't in Uno.UI.Skia. The base lib provides App, samples, unit tests and benchmarks + the
	    Uno XAML/DP source generators.
	  - WinUI/WinAppSDK: the base lib is compiled against Uno's Microsoft.UI.Xaml (Uno.UI.Skia), a
	    different type identity than the real WinAppSDK WinUI, so windows can't reference it. It inlines
	    the shared content and lets the real WinUI XAML compiler build it (as the old SamplesApp.Windows
	    head did) — no Uno source generators here.
	-->
	<ItemGroup Condition="'$(_IsSkiaTfm)' == 'true'">
		<ProjectReference Include="..\SamplesApp.Skia\SamplesApp.Skia.csproj" />
	</ItemGroup>

	<Import Project="..\SamplesApp.Shared\SamplesApp.Shared.props" Condition="'$(_IsSkiaTfm)' != 'true'" />
	<Import Project="..\SamplesApp.Samples\SamplesApp.Samples.props" Condition="'$(_IsSkiaTfm)' != 'true'" />
	<Import Project="..\SamplesApp.UnitTests.Shared\SamplesApp.UnitTests.Shared.props" Condition="'$(_IsSkiaTfm)' != 'true'" />
	<Import Project="..\Benchmarks.Shared\Benchmarks.Shared.projitems" Label="Shared" Condition="'$(_IsSkiaTfm)' != 'true'" />
	<Import Project="..\SamplesApp.UnitTests.Shared\SamplesApp.UnitTests.targets" Condition="'$(_IsSkiaTfm)' != 'true'" />
</Project>
