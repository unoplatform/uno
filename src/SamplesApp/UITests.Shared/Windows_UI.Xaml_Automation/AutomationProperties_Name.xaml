<UserControl x:Class="UITests.Shared.Windows_UI_Xaml_Automation.AutomationProperties_Name"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="Uno.UI.Samples.Content.Accessibility"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<StackPanel Margin="0,40,0,0">
		<TextBlock AutomationProperties.Name="My Textblock"
		    Text="My Textblock" />
		<Button AutomationProperties.Name="My Button"
		    Content="My Button" />
		<Border Width="100"
		    Height="100"
		    AutomationProperties.Name="My Border"
		    Background="CornflowerBlue"
		    BorderBrush="Tomato"
		    BorderThickness="5" />
		<Image AutomationProperties.Name="My Image"
		    Source="https://blog.xenproject.org/wp-content/uploads/2014/10/Testing.jpg"
		    Stretch="None" />

		<!--  Duplicates tests  -->
		<TextBlock AutomationProperties.Name="My Duplicate TextBlock"
		    Text="test" />
		<TextBlock AutomationProperties.Name="My Duplicate TextBlock"
		    Text="test" />
	</StackPanel>
</UserControl>
