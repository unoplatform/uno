<Page x:Class="UITests.Windows_UI_Xaml_Media.GradientBrushTests.LinearGradientBrush_Width"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Media.GradientBrushTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<StackPanel>
		<StackPanel.Resources>
			<LinearGradientBrush x:Key="BrandColor" EndPoint="1,1" StartPoint="0,0">
				<GradientStop Color="Blue" Offset="0.0" />
				<GradientStop Color="Red" Offset="1.0" />
			</LinearGradientBrush>
		</StackPanel.Resources>

		<!--  This should end in red, ie, the gradient is applied to the text width instead of the full element width  -->
		<TextBlock x:Name="TextBlockShouldContainRed"
		    FontSize="30"
		    Foreground="{StaticResource BrandColor}"
		    Text="■■■■■■■■■■■■■■" />
	</StackPanel>
</Page>
