<Page
    x:Class="UITests.Windows_UI_Xaml_Media.AcrylicBrushTests.BasicAcrylicBrushTest2"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Media.AcrylicBrushTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <!--  In-App Acrylic (blurs content behind the element within the app)  -->
        <AcrylicBrush
            x:Key="CustomAcrylicInApp"
            FallbackColor="#2E86C1"
            TintColor="#2E86C1"
            TintOpacity="0.7" />

        <AcrylicBrush
            x:Key="AccentAcrylicBrush"
            FallbackColor="#E74C3C"
            TintColor="#E74C3C"
            TintOpacity="0.6" />

        <AcrylicBrush
            x:Key="DarkAcrylicBrush"
            FallbackColor="#1C1C1C"
            TintColor="#1C1C1C"
            TintOpacity="0.8" />

        <AcrylicBrush
            x:Key="LightAcrylicBrush"
            FallbackColor="#F0F0F0"
            TintColor="#FFFFFF"
            TintOpacity="0.5" />

        <AcrylicBrush
            x:Key="GreenAcrylicBrush"
            FallbackColor="#27AE60"
            TintColor="#27AE60"
            TintOpacity="0.65" />

        <AcrylicBrush
            x:Key="PurpleAcrylicBrush"
            FallbackColor="#8E44AD"
            TintColor="#8E44AD"
            TintOpacity="0.6" />
    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Title  -->
            <TextBlock
                Grid.Row="0"
                Margin="0,0,0,24"
                HorizontalAlignment="Center"
                FontSize="32"
                FontWeight="Bold"
                Text="AcrylicBrush Showcase" />

            <!--  Section 1: Side-by-side acrylic cards over a colorful background  -->
            <TextBlock
                Grid.Row="1"
                Margin="0,0,0,12"
                FontSize="20"
                FontWeight="SemiBold"
                Text="Acrylic Cards over Gradient Background" />

            <Grid
                Grid.Row="2"
                Height="320"
                Margin="0,0,0,32"
                CornerRadius="12">
                <!--  Colorful background to show the blur-through effect  -->
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0.0" Color="#FF6F61" />
                        <GradientStop Offset="0.3" Color="#6B5B95" />
                        <GradientStop Offset="0.6" Color="#88B04B" />
                        <GradientStop Offset="1.0" Color="#F7CAC9" />
                    </LinearGradientBrush>
                </Grid.Background>

                <!--  Some shapes behind the acrylic to demonstrate transparency  -->
                <Ellipse
                    Width="200"
                    Height="200"
                    Margin="40,20,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Fill="#FFFFFF"
                    Opacity="0.3" />
                <Ellipse
                    Width="160"
                    Height="160"
                    Margin="0,0,60,20"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Fill="#FFD700"
                    Opacity="0.4" />
                <Rectangle
                    Width="180"
                    Height="120"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Fill="#00CED1"
                    Opacity="0.35"
                    RadiusX="8"
                    RadiusY="8" />

                <!--  Acrylic cards floating on top  -->
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="20">

                    <!--  Blue Acrylic Card  -->
                    <Grid
                        Width="200"
                        Height="220"
                        Padding="16"
                        Background="{StaticResource CustomAcrylicInApp}"
                        CornerRadius="16">
                        <StackPanel VerticalAlignment="Center" Spacing="8">
                            <FontIcon
                                HorizontalAlignment="Center"
                                FontSize="36"
                                Foreground="White"
                                Glyph="&#xE790;" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Blue Acrylic" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="12"
                                Foreground="White"
                                Opacity="0.8"
                                Text="TintOpacity: 0.7" />
                        </StackPanel>
                    </Grid>

                    <!--  Red Acrylic Card  -->
                    <Grid
                        Width="200"
                        Height="220"
                        Padding="16"
                        Background="{StaticResource AccentAcrylicBrush}"
                        CornerRadius="16">
                        <StackPanel VerticalAlignment="Center" Spacing="8">
                            <FontIcon
                                HorizontalAlignment="Center"
                                FontSize="36"
                                Foreground="White"
                                Glyph="&#xE80F;" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Red Acrylic" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="12"
                                Foreground="White"
                                Opacity="0.8"
                                Text="TintOpacity: 0.6" />
                        </StackPanel>
                    </Grid>

                    <!--  Dark Acrylic Card  -->
                    <Grid
                        Width="200"
                        Height="220"
                        Padding="16"
                        Background="{StaticResource DarkAcrylicBrush}"
                        CornerRadius="16">
                        <StackPanel VerticalAlignment="Center" Spacing="8">
                            <FontIcon
                                HorizontalAlignment="Center"
                                FontSize="36"
                                Foreground="White"
                                Glyph="&#xE793;" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Dark Acrylic" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="12"
                                Foreground="White"
                                Opacity="0.8"
                                Text="TintOpacity: 0.8" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>

            <!--  Section 2: Interactive TintOpacity demo with a Slider  -->
            <TextBlock
                Grid.Row="3"
                Margin="0,0,0,12"
                FontSize="20"
                FontWeight="SemiBold"
                Text="Interactive Acrylic — Adjust TintOpacity" />

            <Grid Grid.Row="4" Margin="0,0,0,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="300" />
                </Grid.RowDefinitions>

                <!--  Sliders to control acrylic opacity properties  -->
                <StackPanel
                    Grid.Row="0"
                    Margin="0,0,0,12"
                    Spacing="8">
                    <StackPanel
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="16">
                        <TextBlock
                            Width="150"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="TintOpacity:" />
                        <Slider
                            x:Name="TintOpacitySlider"
                            Width="300"
                            Maximum="1"
                            Minimum="0"
                            StepFrequency="0.05"
                            ValueChanged="TintOpacitySlider_ValueChanged"
                            Value="0.6" />
                        <TextBlock VerticalAlignment="Center" FontSize="14">
                            <Run Text="{Binding Value, ElementName=TintOpacitySlider}" />
                        </TextBlock>
                    </StackPanel>
                    <StackPanel
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="16">
                        <TextBlock
                            Width="150"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="TintLuminosityOpacity:" />
                        <Slider
                            x:Name="TintLuminosityOpacitySlider"
                            Width="300"
                            Maximum="1"
                            Minimum="0"
                            StepFrequency="0.05"
                            ValueChanged="TintLuminosityOpacitySlider_ValueChanged"
                            Value="0.5" />
                        <TextBlock VerticalAlignment="Center" FontSize="14">
                            <Run Text="{Binding Value, ElementName=TintLuminosityOpacitySlider}" />
                        </TextBlock>
                    </StackPanel>
                    <StackPanel
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="16">
                        <TextBlock
                            Width="150"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="Element Opacity:" />
                        <Slider
                            x:Name="ElementOpacitySlider"
                            Width="300"
                            Maximum="1"
                            Minimum="0"
                            StepFrequency="0.05"
                            ValueChanged="ElementOpacitySlider_ValueChanged"
                            Value="1" />
                        <TextBlock VerticalAlignment="Center" FontSize="14">
                            <Run Text="{Binding Value, ElementName=ElementOpacitySlider}" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!--  Background with content to blur through  -->
                <Grid Grid.Row="1" CornerRadius="12">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0.0" Color="#FC5C7D" />
                            <GradientStop Offset="1.0" Color="#6A82FB" />
                        </LinearGradientBrush>
                    </Grid.Background>

                    <!--  Background decoration  -->
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="48"
                        Opacity="0.5"
                        Text="🌟 ✨ 🎨 🌈 💎 🔮" />

                    <!--  Row of colored rectangles behind acrylic  -->
                    <StackPanel
                        Margin="0,0,0,20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal"
                        Spacing="10">
                        <Rectangle
                            Width="60"
                            Height="60"
                            Fill="Yellow"
                            Opacity="0.6"
                            RadiusX="8"
                            RadiusY="8" />
                        <Rectangle
                            Width="60"
                            Height="60"
                            Fill="Cyan"
                            Opacity="0.6"
                            RadiusX="8"
                            RadiusY="8" />
                        <Rectangle
                            Width="60"
                            Height="60"
                            Fill="Magenta"
                            Opacity="0.6"
                            RadiusX="8"
                            RadiusY="8" />
                        <Rectangle
                            Width="60"
                            Height="60"
                            Fill="Lime"
                            Opacity="0.6"
                            RadiusX="8"
                            RadiusY="8" />
                    </StackPanel>

                    <!--  Acrylic overlay controlled by slider  -->
                    <Grid
                        x:Name="AcrylicPanel"
                        Width="400"
                        Height="180"
                        Padding="24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        CornerRadius="16">
                        <Grid.Background>
                            <AcrylicBrush
                                x:Name="InteractiveAcrylic"
                                FallbackColor="#1B1B2F"
                                TintColor="#1B1B2F"
                                TintOpacity="0.6" />
                        </Grid.Background>

                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="20"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="Interactive Acrylic Panel" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="14"
                                Foreground="White"
                                Opacity="0.85"
                                Text="Drag the slider above to change the TintOpacity."
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="12"
                                Foreground="White"
                                Opacity="0.65"
                                Text="Lower values = more transparent / more blur visible"
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>

            <!--  Section 3: Acrylic Notification Banners  -->
            <TextBlock
                Grid.Row="5"
                Margin="0,0,0,12"
                FontSize="20"
                FontWeight="SemiBold"
                Text="Acrylic Notification Banners" />

            <StackPanel
                Grid.Row="6"
                Margin="0,0,0,32"
                Spacing="12">
                <!--  Light Acrylic Banner  -->
                <Grid
                    Height="80"
                    Padding="20,0"
                    Background="{StaticResource LightAcrylicBrush}"
                    CornerRadius="12">
                    <StackPanel
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="16">
                        <FontIcon
                            FontSize="28"
                            Foreground="#333333"
                            Glyph="&#xE946;" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="#222222"
                                Text="Light Acrylic" />
                            <TextBlock
                                FontSize="12"
                                Foreground="#555555"
                                Text="TintColor: #FFFFFF — TintOpacity: 0.5 — Ideal for light themes" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!--  Green Acrylic Banner  -->
                <Grid
                    Height="80"
                    Padding="20,0"
                    Background="{StaticResource GreenAcrylicBrush}"
                    CornerRadius="12">
                    <StackPanel
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="16">
                        <FontIcon
                            FontSize="28"
                            Foreground="White"
                            Glyph="&#xE73E;" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Green Acrylic" />
                            <TextBlock
                                FontSize="12"
                                Foreground="White"
                                Opacity="0.85"
                                Text="TintColor: #27AE60 — TintOpacity: 0.65 — Great for success states" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!--  Purple Acrylic Banner  -->
                <Grid
                    Height="80"
                    Padding="20,0"
                    Background="{StaticResource PurpleAcrylicBrush}"
                    CornerRadius="12">
                    <StackPanel
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="16">
                        <FontIcon
                            FontSize="28"
                            Foreground="White"
                            Glyph="&#xE734;" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Purple Acrylic" />
                            <TextBlock
                                FontSize="12"
                                Foreground="White"
                                Opacity="0.85"
                                Text="TintColor: #8E44AD — TintOpacity: 0.6 — Perfect for accent highlights" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
