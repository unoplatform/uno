<Page x:Class="UITests.Shared.Windows_UI_Xaml_Media.Projection.Matrix3DProjection_Basic"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<ScrollViewer>
		<StackPanel Padding="20"
		    Spacing="20">
			<TextBlock FontSize="24"
			    FontWeight="Bold"
			    Text="Matrix3DProjection - Custom 3D Matrix" />
			<TextBlock Text="Matrix3DProjection allows you to apply a custom 4x4 transformation matrix for advanced 3D effects."
			    TextWrapping="Wrap" />

			<!--  Identity Matrix  -->
			<Border Padding="15"
			    Background="#E8F5E9"
			    CornerRadius="8">
				<StackPanel>
					<TextBlock Margin="0,0,0,10"
					    FontSize="18"
					    FontWeight="SemiBold"
					    Text="Identity Matrix (No Transform)" />
					<Border Padding="30"
					    HorizontalAlignment="Center"
					    Background="White"
					    CornerRadius="4">
						<Rectangle x:Name="IdentityRect"
						    Width="100"
						    Height="100"
						    Fill="#4CAF50" />
					</Border>
					<Button Margin="0,10,0,0"
					    HorizontalAlignment="Center"
					    Click="OnApplyIdentity"
					    Content="Apply Identity Matrix" />
				</StackPanel>
			</Border>

			<!--  Translation Matrix  -->
			<Border Padding="15"
			    Background="#E3F2FD"
			    CornerRadius="8">
				<StackPanel>
					<TextBlock Margin="0,0,0,10"
					    FontSize="18"
					    FontWeight="SemiBold"
					    Text="Translation via Matrix3D" />
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="200" />
						</Grid.ColumnDefinitions>

						<StackPanel Grid.Column="0"
						    Spacing="5">
							<Slider x:Name="TranslateXSlider"
							    Header="Translate X"
							    Maximum="50"
							    Minimum="-50"
							    Value="0" />
							<Slider x:Name="TranslateYSlider"
							    Header="Translate Y"
							    Maximum="50"
							    Minimum="-50"
							    Value="0" />
							<Slider x:Name="TranslateZSlider"
							    Header="Translate Z"
							    Maximum="100"
							    Minimum="-100"
							    Value="0" />
							<Button Margin="0,10,0,0"
							    Click="OnApplyTranslation"
							    Content="Apply Translation" />
						</StackPanel>

						<Border Grid.Column="1"
						    Padding="30"
						    HorizontalAlignment="Center"
						    VerticalAlignment="Center"
						    Background="White"
						    CornerRadius="4">
							<Rectangle x:Name="TranslationRect"
							    Width="80"
							    Height="80"
							    Fill="#2196F3" />
						</Border>
					</Grid>
				</StackPanel>
			</Border>

			<!--  Scale Matrix  -->
			<Border Padding="15"
			    Background="#FFF3E0"
			    CornerRadius="8">
				<StackPanel>
					<TextBlock Margin="0,0,0,10"
					    FontSize="18"
					    FontWeight="SemiBold"
					    Text="Scale via Matrix3D" />
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="200" />
						</Grid.ColumnDefinitions>

						<StackPanel Grid.Column="0"
						    Spacing="5">
							<Slider x:Name="ScaleXSlider"
							    Header="Scale X"
							    Maximum="2"
							    Minimum="0.5"
							    StepFrequency="0.1"
							    Value="1" />
							<Slider x:Name="ScaleYSlider"
							    Header="Scale Y"
							    Maximum="2"
							    Minimum="0.5"
							    StepFrequency="0.1"
							    Value="1" />
							<Button Margin="0,10,0,0"
							    Click="OnApplyScale"
							    Content="Apply Scale" />
						</StackPanel>

						<Border Grid.Column="1"
						    Padding="30"
						    HorizontalAlignment="Center"
						    VerticalAlignment="Center"
						    Background="White"
						    CornerRadius="4">
							<Rectangle x:Name="ScaleRect"
							    Width="80"
							    Height="80"
							    Fill="#FF9800" />
						</Border>
					</Grid>
				</StackPanel>
			</Border>

			<!--  Perspective Matrix  -->
			<Border Padding="15"
			    Background="#F3E5F5"
			    CornerRadius="8">
				<StackPanel>
					<TextBlock Margin="0,0,0,10"
					    FontSize="18"
					    FontWeight="SemiBold"
					    Text="Perspective Effect" />
					<TextBlock Margin="0,0,0,10"
					    Text="Adjusting M34 creates a perspective effect"
					    TextWrapping="Wrap" />
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="200" />
						</Grid.ColumnDefinitions>

						<StackPanel Grid.Column="0"
						    Spacing="5">
							<Slider x:Name="PerspectiveSlider"
							    Header="Perspective (M34)"
							    Maximum="0"
							    Minimum="-0.005"
							    StepFrequency="0.0001"
							    Value="-0.001" />
							<Slider x:Name="PerspectiveRotationY"
							    Header="Rotation Y"
							    Maximum="60"
							    Minimum="-60"
							    Value="30" />
							<Button Margin="0,10,0,0"
							    Click="OnApplyPerspective"
							    Content="Apply Perspective" />
						</StackPanel>

						<Border Grid.Column="1"
						    Padding="30"
						    HorizontalAlignment="Center"
						    VerticalAlignment="Center"
						    Background="White"
						    CornerRadius="4">
							<Rectangle x:Name="PerspectiveRect"
							    Width="80"
							    Height="80"
							    Fill="#9C27B0" />
						</Border>
					</Grid>
				</StackPanel>
			</Border>
		</StackPanel>
	</ScrollViewer>
</Page>
