<UserControl
    x:Class="SamplesApp.Wasm.Windows_UI_Xaml_Media.Transform.Border_With_Off_Centre_ScaleTransform"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <controls:SampleControl SampleDescription="Border with ScaleTransform with CenterX and CentreY set. Blue outline shows original location.">
        <controls:SampleControl.SampleContent>
            <DataTemplate>
                <Grid
                    Width="300"
                    Height="300"
                    Background="Gray">
                    <Border
                        Width="100"
                        Height="100"
                        Background="Tomato"
                        Opacity="0.8">
                        <Border.RenderTransform>
                            <ScaleTransform CenterX="80" CenterY="80" ScaleX="1.5" ScaleY="1.5" />
                        </Border.RenderTransform>
                    </Border>
                    <Border
                        Width="100"
                        Height="100"
                        BorderBrush="Blue"
                        BorderThickness="1" />
                </Grid>
            </DataTemplate>
        </controls:SampleControl.SampleContent>
    </controls:SampleControl>
</UserControl>
