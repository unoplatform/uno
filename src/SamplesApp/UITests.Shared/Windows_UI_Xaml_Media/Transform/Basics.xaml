    <ScrollViewer>
        <StackPanel HorizontalAlignment="Stretch">

            <Border
                Padding="10"
                HorizontalAlignment="Stretch"
                Background="#FF0000">
                <TextBlock
                    FontSize="24"
                    Foreground="White"
                    Text="Rotate" />
            </Border>
            <Grid Padding="10" Background="#33FF0000">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Text="Origin" />
                <TextBox
                    x:Name="RedOrigin"
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    Text="0,0" />

                <Slider
                    x:Name="RedCenterX"
                    Grid.Row="1"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    Header="Center X"
                    Maximum="150"
                    Minimum="-150"
                    Value="50" />
                <TextBox
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    Text="{Binding ElementName=RedCenterX, Path=Value, Mode=TwoWay}" />

                <Slider
                    x:Name="RedCenterY"
                    Grid.Row="2"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    Header="Center Y"
                    Maximum="150"
                    Minimum="-150"
                    Value="50" />
                <TextBox
                    Grid.Row="2"
                    Grid.Column="1"
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    Text="{Binding ElementName=RedCenterY, Path=Value, Mode=TwoWay}" />

                <Slider
                    x:Name="RedAngle"
                    Grid.Row="3"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    Header="Angle"
                    Maximum="360"
                    Minimum="0"
                    Value="30" />
                <TextBox
                    Grid.Row="3"
                    Grid.Column="1"
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    Text="{Binding ElementName=RedAngle, Path=Value, Mode=TwoWay}" />

                <Border
                    Grid.RowSpan="4"
                    Grid.Column="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderBrush="Black"
                    BorderThickness="3">
                    <Rectangle
                        Width="100"
                        Height="100"
                        Fill="#FF0000"
                        RenderTransformOrigin="{Binding ElementName=RedOrigin, Path=Text}">
                        <Rectangle.RenderTransform>
                            <RotateTransform Angle="{Binding ElementName=RedAngle, Path=Value}" CenterX="{Binding ElementName=RedCenterX, Path=Value}" CenterY="{Binding ElementName=RedCenterY, Path=Value}" />
                        </Rectangle.RenderTransform>
                    </Rectangle>
                </Border>
            </Grid>

            <Border
