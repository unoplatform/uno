                        <Rectangle.RenderTransform>
                            <ScaleTransform CenterX="{Binding ElementName=GreenCenterX, Path=Value}" CenterY="{Binding ElementName=GreenCenterY, Path=Value}" ScaleX="{Binding ElementName=GreenScaleX, Path=Value}" ScaleY="{Binding ElementName=GreenScaleY, Path=Value}" />
                        </Rectangle.RenderTransform>
                    </Rectangle>
