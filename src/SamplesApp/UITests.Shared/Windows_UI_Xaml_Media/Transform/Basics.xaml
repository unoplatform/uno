                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    Text="0,0" />

                <Slider
                    x:Name="OrangeTranslateX"
                    Grid.Row="1"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    Header="Translate X"
                    Maximum="150"
                    Minimum="-150"
                    Value="15" />
                <TextBox
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    Text="{Binding ElementName=OrangeTranslateX, Path=Value, Mode=TwoWay}" />

                <Slider
                    x:Name="OrangeTranslateY"
                    Grid.Row="2"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    Header="Translate Y"
                    Maximum="150"
                    Minimum="-150"
                    Value="15" />
