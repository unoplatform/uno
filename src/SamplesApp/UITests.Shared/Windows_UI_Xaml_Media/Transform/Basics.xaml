                        Height="100"
                        Fill="#A000C0"
                        RenderTransformOrigin="{Binding ElementName=PurpleOrigin, Path=Text}">
                        <Rectangle.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform CenterX="{Binding ElementName=PurpleScaleCenterX, Path=Value}" CenterY="{Binding ElementName=PurpleScaleCenterY, Path=Value}" ScaleX="{Binding ElementName=PurpleScaleX, Path=Value}" ScaleY="{Binding ElementName=PurpleScaleY, Path=Value}" />
                                <SkewTransform AngleX="{Binding ElementName=PurpleSkewAngleX, Path=Value}" AngleY="{Binding ElementName=PurpleSkewAngleY, Path=Value}" CenterX="{Binding ElementName=PurpleSkewCenterX, Path=Value}" CenterY="{Binding ElementName=PurpleSkewCenterY, Path=Value}" />
                                <RotateTransform Angle="{Binding ElementName=PurpleRotateAngle, Path=Value}" CenterX="{Binding ElementName=PurpleRotateCenterX, Path=Value}" CenterY="{Binding ElementName=PurpleRotateCenterY, Path=Value}" />
                                <TranslateTransform X="{Binding ElementName=PurpleTranslateX, Path=Value}" Y="{Binding ElementName=PurpleTranslateY, Path=Value}" />
                            </TransformGroup>

                        </Rectangle.RenderTransform>
                    </Rectangle>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
