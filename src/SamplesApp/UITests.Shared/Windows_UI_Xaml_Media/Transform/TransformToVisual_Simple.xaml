<UserControl
    x:Class="SamplesApp.Wasm.Windows_UI_Xaml_Media.Transform.TransformToVisual_Simple"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <Grid
        x:Name="EnclosingView"
        Width="280"
        Height="400">
        <Border Margin="0,0,80,0">
            <ScrollViewer ViewChanged="ScrollViewer_ViewChanged">
                <Border Height="700">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="Beige" />
                            <GradientStop Offset="1" Color="Blue" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <!--  Wrap TextBlock in Border as workaround because it doesn't inherit from UIElement on iOS  -->
                    <Border x:Name="TargetView" VerticalAlignment="Center">
                        <TextBlock Text="Target text" />
                    </Border>
                </Border>
            </ScrollViewer>
        </Border>
        <Canvas>
            <Ellipse
                x:Name="TrackerView"
                Canvas.Left="200"
                Canvas.Top="340"
                Width="80"
                Height="20"
                Fill="PaleVioletRed" />
        </Canvas>
    </Grid>
</UserControl>
