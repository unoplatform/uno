<UserControl
    x:Class="Uno.UI.Samples.UITests.ImageBrushTestControl.PathImageBrushfill"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="using:Uno.UI.Samples.UITests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_ios="http://uno.ui/not_ios"
    xmlns:shapes="clr-namespace:Microsoft.UI.Xaml.Shapes;assembly=Uno"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">
    <StackPanel>
        <Border>
            <controls:SampleControl SampleDescription="Path-ImageBrushfill">
                <controls:SampleControl.SampleContent>
                    <DataTemplate>
                        <Grid>
                            <Path
                                Width="200"
                                Height="200"
                                Data="M 10,100.5 C 10,300 300,-200 300,100 Z"
                                Stroke="Green">
                                <Path.Fill>
                                    <ImageBrush ImageSource="http://lh5.ggpht.com/lxBMauupBiLIpgOgu5apeiX_YStXeHRLK1oneS4NfwwNt7fGDKMP0KpQIMwfjfL9GdHRVEavmg7gOrj5RYC4qwrjh3Y0jCWFDj83jzg" Stretch="Fill" />
                                </Path.Fill>
                            </Path>
                        </Grid>
                    </DataTemplate>
                </controls:SampleControl.SampleContent>
            </controls:SampleControl>
        </Border>
    </StackPanel>

</UserControl>