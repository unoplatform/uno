<UserControl
    x:Class="Uno.UI.Samples.UITests.ImageBrushTestControl.ImageBrushLocalAsset"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://nventive.com/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://nventive.com/ios"
    xmlns:local="Uno.UI.Samples.UITests.ImageBrushTestControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <controls:SampleControl SampleDescription="ImageBrush with local asset on Border">
        <controls:SampleControl.SampleContent>
            <DataTemplate>
                <Border
                    Width="200"
                    Height="200"
                    BorderBrush="Sienna"
                    BorderThickness="3"
                    CornerRadius="40">
                    <Border.Background>
                        <ImageBrush ImageSource="/Assets/Formats/uno-overalls.png" />
                    </Border.Background>
                </Border>
            </DataTemplate>
        </controls:SampleControl.SampleContent>
    </controls:SampleControl>
</UserControl>
