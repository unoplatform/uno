<UserControl x:Class="Uno.UI.Samples.UITests.ImageBrushTestControl.ImageBrushWithLateSource"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="Uno.UI.Samples.UITests.ImageBrushTestControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<controls:SampleControl SampleDescription="ImageBrush source is initially null, press button to set the source">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<StackPanel>
					<Button Command="{Binding [SetSource]}"
					    Content="Set image source" />
					<TextBlock Text="ImageBrush is set as background of Grid below" />
					<Border HorizontalAlignment="Center"
					    VerticalAlignment="Center"
					    Background="Firebrick"
					    BorderBrush="Azure"
					    BorderThickness="2">
						<Grid Width="400"
						    Height="200">
							<Grid.Background>
								<ImageBrush ImageSource="{Binding [SourceUri]}" />
							</Grid.Background>
						</Grid>
					</Border>
					<TextBlock Text="ImageBrush is set as background of Border below" />
					<Border HorizontalAlignment="Center"
					    VerticalAlignment="Center"
					    Background="SlateBlue"
					    BorderBrush="Azure"
					    BorderThickness="2">
						<Border Width="400"
						    Height="200">
							<Border.Background>
								<ImageBrush ImageSource="{Binding [SourceUri]}" />
							</Border.Background>
						</Border>
					</Border>
				</StackPanel>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>