<UserControl x:Class="Uno.UI.Samples.UITests.ImageBrushTestControl.ImageBrush_StreamSource"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="using:Uno.UI.Samples.UITests.ImageBrushTestControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<StackPanel Spacing="5">

		<StackPanel Orientation="Horizontal"
		    Spacing="5">
			<Border Width="150"
			    Height="80"
			    BorderBrush="Green"
			    BorderThickness="5"
			    CornerRadius="10">
				<Border.Background>
					<ImageBrush x:Name="imageBrush1"
					    AlignmentX="Left"
					    ImageSource="{x:Bind MySource, Mode=OneWay}"
					    Stretch="Uniform" />
				</Border.Background>
			</Border>
			<Border Width="150"
			    Height="80"
			    BorderBrush="Green"
			    BorderThickness="5"
			    CornerRadius="10">
				<Border.Background>
					<ImageBrush x:Name="imageBrush2"
					    AlignmentX="Center"
					    ImageSource="{x:Bind MySource, Mode=OneWay}"
					    Stretch="Uniform" />
				</Border.Background>
			</Border>
			<Border Width="150"
			    Height="80"
			    BorderBrush="Green"
			    BorderThickness="5"
			    CornerRadius="10">
				<Border.Background>
					<ImageBrush x:Name="imageBrush3"
					    AlignmentX="Right"
					    ImageSource="{x:Bind MySource, Mode=OneWay}"
					    Stretch="Uniform" />
				</Border.Background>
			</Border>
		</StackPanel>
		<StackPanel Orientation="Horizontal"
		    Spacing="5">
			<Border Width="150"
			    Height="80"
			    BorderBrush="Green"
			    BorderThickness="5"
			    CornerRadius="10">
				<Border.Background>
					<ImageBrush x:Name="imageBrush4"
					    AlignmentY="Top"
					    ImageSource="{x:Bind MySource, Mode=OneWay}"
					    Stretch="UniformToFill" />
				</Border.Background>
			</Border>
			<Border Width="150"
			    Height="80"
			    BorderBrush="Green"
			    BorderThickness="5"
			    CornerRadius="10">
				<Border.Background>
					<ImageBrush x:Name="imageBrush5"
					    AlignmentY="Center"
					    ImageSource="{x:Bind MySource, Mode=OneWay}"
					    Stretch="UniformToFill" />
				</Border.Background>
			</Border>
			<Border Width="150"
			    Height="80"
			    BorderBrush="Green"
			    BorderThickness="5"
			    CornerRadius="10">
				<Border.Background>
					<ImageBrush x:Name="imageBrush6"
					    AlignmentY="Bottom"
					    ImageSource="{x:Bind MySource, Mode=OneWay}"
					    Stretch="UniformToFill" />
				</Border.Background>
			</Border>
		</StackPanel>
	</StackPanel>
</UserControl>
