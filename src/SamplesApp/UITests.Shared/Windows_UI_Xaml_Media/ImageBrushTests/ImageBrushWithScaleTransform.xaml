<UserControl x:Class="Uno.UI.Samples.UITests.ImageBrushTestControl.ImageBrushWithScaleTransform"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://nventive.com/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://nventive.com/ios"
    xmlns:local="Uno.UI.Samples.UITests.ImageBrushTestControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<controls:SampleControl SampleDescription="ImageBrush with ScaleTransform: 1.5x scale">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<Grid>
					<Border Width="150"
					    Height="200">
						<Border.Background>
							<ImageBrush ImageSource="ms-appx:///Assets/ingredient2.png"
							    Stretch="UniformToFill">
								<ImageBrush.RelativeTransform>
									<ScaleTransform CenterX=".5" CenterY=".5" ScaleX="1.5" ScaleY="1.5" />
								</ImageBrush.RelativeTransform>
							</ImageBrush>
						</Border.Background>
					</Border>
				</Grid>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>
