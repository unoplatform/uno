<UserControl x:Class="Uno.UI.Samples.UITests.ImageBrushTestControl.Ellipse"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_ios="http://uno.ui/not_ios"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<StackPanel Spacing="12">
		<Ellipse Width="300"
		    Height="100"
		    Stroke="SteelBlue">
			<Ellipse.Fill>
				<ImageBrush x:Name="imageBrush1"
				    AlignmentX="Right"
				    AlignmentY="Bottom"
				    ImageSource="http://lh5.ggpht.com/lxBMauupBiLIpgOgu5apeiX_YStXeHRLK1oneS4NfwwNt7fGDKMP0KpQIMwfjfL9GdHRVEavmg7gOrj5RYC4qwrjh3Y0jCWFDj83jzg" />
			</Ellipse.Fill>
		</Ellipse>

		<Border Width="300"
		    Height="100"
		    BorderBrush="SteelBlue"
		    BorderThickness="3"
		    CornerRadius="35">
			<Border.Background>
				<ImageBrush x:Name="imageBrush2"
				    AlignmentX="Right"
				    AlignmentY="Bottom"
				    ImageSource="https://uno-assets.platform.uno/tests/images/uno-overalls.bmp"
				    Stretch="None" />
			</Border.Background>
		</Border>

	</StackPanel>

</UserControl>
