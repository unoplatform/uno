<UserControl x:Class="UITests.Windows_UI_Xaml_Media.BrushesTests.RevealBrush_Fallback"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Media.BrushesTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">
	<UserControl.Resources>
		<RevealBackgroundBrush x:Name="OrangeCrush"
		    Color="Orange"
		    FallbackColor="Orange" />
	</UserControl.Resources>

	<StackPanel>
		<Button x:Name="ChangeColorButton"
		    Click="ChangeColor"
		    Content="Change color" />
		<TextBlock x:Name="StatusTextBlock"
		    Text="Initial" />

		<Grid x:Name="RevealGrid"
		    Width="120"
		    Height="55"
		    Margin="10"
		    Background="{StaticResource OrangeCrush}" />
		<Grid x:Name="RevealGridCR"
		    Width="120"
		    Height="55"
		    Margin="10"
		    Background="{StaticResource OrangeCrush}"
		    CornerRadius="10" />

		<Border x:Name="RevealBorder"
		    Width="120"
		    Height="55"
		    Margin="10"
		    Background="{StaticResource OrangeCrush}" />
		<Border x:Name="RevealBorderCR"
		    Width="120"
		    Height="55"
		    Margin="10"
		    Background="{StaticResource OrangeCrush}"
		    CornerRadius="10" />

	</StackPanel>
</UserControl>
