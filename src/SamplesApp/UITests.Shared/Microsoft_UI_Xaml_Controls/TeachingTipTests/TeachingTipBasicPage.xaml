<Page x:Class="UITests.Microsoft_UI_Xaml_Controls.TeachingTipTests.TeachingTipBasicPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Microsoft_UI_Xaml_Controls.TeachingTipTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Grid>
		<StackPanel Margin="20"
		    Spacing="8">
			<Button x:Name="SaveButton"
			    Click="ShowTip"
			    Content="Save">
				<Button.Resources>
					<muxc:TeachingTip x:Name="AutoSaveTip"
					    Title="Save automatically"
					    Subtitle="When you save your file to OneDrive, we save your changes as you go - so you never have to."
					    Target="{x:Bind SaveButton}" />
				</Button.Resources>
			</Button>

			<Button x:Name="ThemeButton"
			    Click="TestButtonClick1"
			    Content="Show TeachingTip" />

			<Button Click="TestButtonClick2"
			    Content="Show TeachingTip" />

			<Button Click="TestButtonClick3"
			    Content="Show TeachingTip" />
		</StackPanel>


		<muxc:TeachingTip x:Name="ToggleThemeTeachingTip1"
		    Title="Change themes without hassle"
		    Subtitle="It's easier than ever to see control samples in both light and dark theme!"
		    Target="{x:Bind ThemeButton}">
			<muxc:TeachingTip.IconSource>
				<muxc:SymbolIconSource Symbol="Refresh" />
			</muxc:TeachingTip.IconSource>
		</muxc:TeachingTip>

		<muxc:TeachingTip x:Name="ToggleThemeTeachingTip2"
		    Title="Change themes without hassle"
		    ActionButtonContent="Toggle theme now"
		    CloseButtonContent="Got it!"
		    IsLightDismissEnabled="True"
		    PlacementMargin="20"
		    PreferredPlacement="Auto"
		    Subtitle="It's easier than ever to see control samples in both light and dark theme!" />

		<muxc:TeachingTip x:Name="ToggleThemeTeachingTip3"
		    Title="Change themes without hassle"
		    PreferredPlacement="Bottom"
		    Subtitle="It's easier than ever to see control samples in both light and dark theme!"
		    Target="{x:Bind ThemeButton}">
			<muxc:TeachingTip.HeroContent>
				<Border Height="100"
				    HorizontalAlignment="Stretch"
				    VerticalAlignment="Stretch"
				    Background="Red" />
				<!--<Image Source="ms-appx:///Assets/Formats/uno-overalls.png" Stretch="UniformToFill" AutomationProperties.Name="Sunset" />-->
			</muxc:TeachingTip.HeroContent>
			<muxc:TeachingTip.Content>
				<TextBlock Margin="0,16,0,0"
				    TextWrapping="WrapWholeWords">
					To change your desktop theme visit the<Hyperlink NavigateUri="ms-settings:colors">Settings app</Hyperlink>
					.</TextBlock>
			</muxc:TeachingTip.Content>
		</muxc:TeachingTip>
	</Grid>
</Page>
