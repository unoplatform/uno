							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>

						<TextBlock Grid.Row="0"
						    VerticalAlignment="Center"
						    Foreground="Red"
						    Text="IsOpen:" />
						<CheckBox x:Name="IsOpenCheckBox"
						    Grid.Row="0"
						    Grid.Column="1"
						    AutomationProperties.Name="IsOpenCheckBox"
						    IsChecked="False"
						    IsEnabled="False" />
						<TextBlock Grid.Row="1"
						    VerticalAlignment="Center"
						    Foreground="Red"
						    Text="IsIdle:" />
						<CheckBox x:Name="IsIdleCheckBox"
						    Grid.Row="1"
						    Grid.Column="1"
						    AutomationProperties.Name="IsIdleCheckBox"
						    IsChecked="True"
						    IsEnabled="False" />
						<TextBlock Grid.Row="2"
						    Foreground="Red"
						    Text="TargetBounds:" />
						<Button Grid.Row="2"
						    Grid.Column="1"
						    AutomationProperties.Name="GetTargetBoundsButton"
						    Click="OnGetTargetBoundsButtonClicked">
							Get
						</Button>
						<StackPanel Grid.Row="3"
						    Orientation="Horizontal">
							<TextBlock Text="X: " />
							<TextBlock x:Name="TargetXOffsetTextBlock"
							    AutomationProperties.Name="TargetXOffsetTextBlock" />
						</StackPanel>
						<StackPanel Grid.Row="3"
						    Grid.Column="1"
						    Orientation="Horizontal">
							<TextBlock Text="Y: " />
							<TextBlock x:Name="TargetYOffsetTextBlock"
							    AutomationProperties.Name="TargetYOffsetTextBlock" />
						</StackPanel>
						<StackPanel Grid.Row="4"
						    Orientation="Horizontal">
							<TextBlock Text="Width: " />
							<TextBlock x:Name="TargetWidthTextBlock"
							    AutomationProperties.Name="TargetWidthTextBlock" />
						</StackPanel>
						<StackPanel Grid.Row="4"
						    Grid.Column="1"
						    Orientation="Horizontal">
							<TextBlock Text="Height: " />
							<TextBlock x:Name="TargetHeightTextBlock"
							    AutomationProperties.Name="TargetHeightTextBlock" />
						</StackPanel>
						<TextBlock Grid.Row="5"
						    Foreground="Red"
						    Text="Popup Offset:" />
						<StackPanel Grid.Row="6"
						    Orientation="Horizontal">
							<TextBlock Text="Vert: " />
							<TextBlock x:Name="PopupVerticalOffsetTextBlock"
							    AutomationProperties.Name="PopupVerticalOffsetTextBlock" />
						</StackPanel>
						<StackPanel Grid.Row="6"
						    Grid.Column="1"
						    Orientation="Horizontal">
							<TextBlock Text="Hor: " />
							<TextBlock x:Name="PopupHorizontalOffsetTextBlock"
							    AutomationProperties.Name="PopupHorizontalOffsetTextBlock" />
						</StackPanel>
						<TextBlock Grid.Row="7"
						    Foreground="Red"
						    Text="Teaching Tip Info:" />
						<StackPanel Grid.Row="8"
						    Orientation="Horizontal">
							<TextBlock Text="Title Vis:" />
							<TextBlock x:Name="TitleVisibilityTextBlock"
							    AutomationProperties.Name="TitleVisibilityTextBlock" />
						</StackPanel>
						<StackPanel Grid.Row="8"
						    Grid.Column="1"
						    Orientation="Horizontal">
							<TextBlock Text="Subtitle Vis:" />
							<TextBlock x:Name="SubtitleVisibilityTextBlock"
							    AutomationProperties.Name="SubtitleVisibilityTextBlock" />
						</StackPanel>
						<StackPanel Grid.Row="9"
						    Orientation="Horizontal">
							<TextBlock Text="Height: " />
							<TextBlock x:Name="TipHeightTextBlock"
							    AutomationProperties.Name="TipHeightTextBlock" />
						</StackPanel>
						<StackPanel Grid.Row="9"
						    Grid.Column="1"
						    Orientation="Horizontal">
							<TextBlock Text="Width: " />
							<TextBlock x:Name="TipWidthTextBlock"
							    AutomationProperties.Name="TipWidthTextBlock" />
						</StackPanel>
						<TextBlock Grid.Row="10"
						    Text="Effective Placement:" />
						<TextBlock x:Name="EffectivePlacementTextBlock"
						    Grid.Row="10"
						    Grid.Column="1"
						    AutomationProperties.Name="EffectivePlacementTextBlock" />
						<TextBlock Grid.Row="11"
						    Text="Hero Placement:" />
						<TextBlock x:Name="EffectiveHeroContentPlacementTextBlock"
						    Grid.Row="11"
						    Grid.Column="1"
						    AutomationProperties.Name="EffectiveHeroContentPlacementTextBlock" />

						<TextBlock Grid.Row="12"
						    Grid.ColumnSpan="2"
						    Foreground="Red"
						    Text="----------ScrollViewer/Window Knobs----------" />
						<TextBlock Grid.Row="13"
						    Foreground="Red"
						    Text="ScrollViewerState" />
						<TextBlock x:Name="ScrollViewerStateTextBox"
						    Grid.Row="13"
						    Grid.Column="1"
						    AutomationProperties.Name="ScrollViewerStateTextBox"
						    Text="Idle" />
						<TextBlock Grid.Row="14"
						    Foreground="Red"
						    Text="ScrollViewerOffset:" />
						<TextBox x:Name="ScrollViewerOffsetTextBox"
						    Grid.Row="15"
						    AutomationProperties.Name="ScrollViewerOffsetTextBox"
						    Text="750" />
						<Button Grid.Row="15"
						    Grid.Column="1"
						    Margin="0,0,0,1"
						    AutomationProperties.Name="ScrollViewerOffsetButton"
						    Click="OnSetScrollViewerOffsetButtonClicked">
							Set
						</Button>
						<Button Grid.Row="16"
						    AutomationProperties.Name="BringTargetIntoViewButton"
						    Click="OnBringTargetIntoViewButtonClicked">
							BringIntoView
						</Button>
						<TextBlock Grid.Row="17"
						    Foreground="Red"
						    Text="ReturnTopForOutOfWindowPlacement:" />
						<CheckBox x:Name="ReturnTopForOutOfWindowPlacementCheckBox"
						    Grid.Row="17"
						    Grid.Column="1"
						    AutomationProperties.Name="ReturnTopForOutOfWindowPlacementCheckBox"
						    Checked="OnReturnTopForOutOfWindowPlacementCheckBoxChecked"
						    IsChecked="true"
						    Unchecked="OnReturnTopForOutOfWindowPlacementCheckBoxUnchecked" />
						<TextBlock Grid.Row="18"
						    Foreground="Red"
						    Text="UseTestWindowBounds:" />
						<CheckBox x:Name="UseTestWindowBoundsCheckBox"
						    Grid.Row="18"
						    Grid.Column="1"
						    AutomationProperties.Name="UseTestWindowBoundsCheckbox"
						    Checked="OnUseTestWindowBoundsCheckBoxChecked"
						    Unchecked="OnUseTestWindowBoundsCheckBoxUnchecked" />
						<StackPanel Grid.Row="19"
						    Orientation="Horizontal">
							<TextBlock VerticalAlignment="Center"
							    Text="X        :" />
							<TextBox x:Name="TestWindowBoundsXTextBox"
							    AutomationProperties.Name="TestWindowBoundsXTextBox"
							    Text="0" />
						</StackPanel>
						<StackPanel Grid.Row="19"
						    Grid.Column="1"
						    Orientation="Horizontal">
							<TextBlock VerticalAlignment="Center"
							    Text="Y         :" />
							<TextBox x:Name="TestWindowBoundsYTextBox"
							    AutomationProperties.Name="TestWindowBoundsYTextBox"
							    Text="0" />
						</StackPanel>
						<StackPanel Grid.Row="20"
						    Orientation="Horizontal">
							<TextBlock Text="Width:" />
							<TextBox x:Name="TestWindowBoundsWidthTextBox"
							    AutomationProperties.Name="TestWindowBoundsWidthTextBox"
							    Text="0" />
						</StackPanel>
						<StackPanel Grid.Row="20"
						    Grid.Column="1"
						    Orientation="Horizontal">
							<TextBlock Text="Height:" />
							<TextBox x:Name="TestWindowBoundsHeightTextBox"
							    AutomationProperties.Name="TestWindowBoundsHeightTextBox"
							    Text="0" />
						</StackPanel>
						<TextBlock Grid.Row="21"
						    Foreground="Red"
						    Text="UseTestScreenBounds:" />
						<CheckBox x:Name="UseTestScreenBoundsCheckBox"
						    Grid.Row="21"
						    Grid.Column="1"
						    AutomationProperties.Name="UseTestScreenBoundsCheckbox"
						    Checked="OnUseTestSreenBoundsCheckBoxChecked"
						    Unchecked="OnUseTestScreenBoundsCheckBoxUnchecked" />
						<StackPanel Grid.Row="22"
						    Orientation="Horizontal">
							<TextBlock VerticalAlignment="Center"
							    Text="X        :" />
							<TextBox x:Name="TestScreenBoundsXTextBox"
							    AutomationProperties.Name="TestScreenBoundsXTextBox"
							    Text="0" />
						</StackPanel>
						<StackPanel Grid.Row="22"
						    Grid.Column="1"
						    Orientation="Horizontal">
							<TextBlock VerticalAlignment="Center"
							    Text="Y         :" />
							<TextBox x:Name="TestScreenBoundsYTextBox"
							    AutomationProperties.Name="TestScreenBoundsYTextBox"
							    Text="0" />
						</StackPanel>
						<StackPanel Grid.Row="23"
						    Orientation="Horizontal">
							<TextBlock Text="Width:" />
							<TextBox x:Name="TestScreenBoundsWidthTextBox"
							    AutomationProperties.Name="TestScreenBoundsWidthTextBox"
							    Text="0" />
						</StackPanel>
						<StackPanel Grid.Row="23"
						    Grid.Column="1"
						    Orientation="Horizontal">
							<TextBlock Text="Height:" />
							<TextBox x:Name="TestScreenBoundsHeightTextBox"
							    AutomationProperties.Name="TestScreenBoundsHeightTextBox"
							    Text="0" />
						</StackPanel>
						<TextBlock Grid.Row="24"
						    Grid.ColumnSpan="2"
						    Foreground="Red"
						    Text="----------------Target Knobs---------------" />
						<TextBlock Grid.Row="25"
						    Foreground="Red"
						    Text="TipFollowsTarget:" />
						<CheckBox x:Name="TipFollowsTargetCheckBox"
						    Grid.Row="25"
						    Grid.Column="1"
						    AutomationProperties.Name="TipFollowsTargetCheckBox"
						    Checked="OnTipFollowsTargetCheckBoxChecked"
						    Unchecked="OnTipFollowsTargetCheckBoxUnchecked" />
						<TextBlock Grid.Row="26"
						    Foreground="Red"
						    Text="Target Vertical Alignment:" />
						<ComboBox x:Name="TargetVerticalAlignmentComboBox"
						    Grid.Row="27">
							<ComboBoxItem x:Name="TargetVerticalAlignmentTop">Top</ComboBoxItem>
							<ComboBoxItem x:Name="TargetVerticalAlignmentCenter">Center</ComboBoxItem>
							<ComboBoxItem x:Name="TargetVerticalAlignmentBottom">Bottom</ComboBoxItem>
						</ComboBox>
						<Button Grid.Row="27"
						    Grid.Column="1"
						    Click="OnSetTargetVerticalAlignmentButtonClicked">
							Set
						</Button>

						<TextBlock Grid.Row="28"
						    Foreground="Red"
						    Text="Target Horizontal Alignment:" />
						<ComboBox x:Name="TargetHorizontalAlignmentComboBox"
						    Grid.Row="29">
							<ComboBoxItem x:Name="TargetHorizontalAlignmentLeft">Left</ComboBoxItem>
							<ComboBoxItem x:Name="TargetHorizontalAlignmentCenter">Center</ComboBoxItem>
							<ComboBoxItem x:Name="TargetHorizontalAlignmentRight">Right</ComboBoxItem>
						</ComboBox>
						<Button Grid.Row="29"
						    Grid.Column="1"
						    Click="OnSetTargetHorizontalAlignmentButtonClicked">
							Set
						</Button>

						<TextBlock Grid.Row="30"
						    Grid.ColumnSpan="2"
						    Foreground="Red"
						    Text="---------------Animation Knobs---------------" />

						<TextBlock Grid.Row="31"
						    Foreground="Red"
						    Text="Expand Animation Curve:" />
						<TextBlock Grid.Row="32"
						    VerticalAlignment="Center"
						    Text="Control Point 1:" />
						<StackPanel Grid.Row="32"
						    Grid.Column="1"
						    Orientation="Horizontal">
							<TextBox x:Name="ExpandControlPoint1X"
							    Margin="2"
							    Text="0.1" />
							<TextBox x:Name="ExpandControlPoint1Y"
							    Margin="2"
							    Text="0.9" />
						</StackPanel>
						<TextBlock Grid.Row="33"
						    VerticalAlignment="Center"
						    Text="Control Point 2:" />
						<StackPanel Grid.Row="33"
						    Grid.Column="1"
						    Orientation="Horizontal">
							<TextBox x:Name="ExpandControlPoint2X"
							    Margin="2"
							    Text="0.2" />
							<TextBox x:Name="ExpandControlPoint2Y"
							    Margin="2"
							    Text="1.0" />
						</StackPanel>

						<TextBlock Grid.Row="34"
						    Foreground="Red"
						    Text="Contract Animation Curve:" />
						<TextBlock Grid.Row="35"
						    VerticalAlignment="Center"
						    Text="Control Point 1:" />
						<StackPanel Grid.Row="35"
						    Grid.Column="1"
						    Orientation="Horizontal">
							<TextBox x:Name="ContractControlPoint1X"
							    Margin="2"
							    Text="0.7" />
							<TextBox x:Name="ContractControlPoint1Y"
							    Margin="2"
							    Text="0.0" />
						</StackPanel>
						<TextBlock Grid.Row="36"
						    VerticalAlignment="Center"
						    Text="Control Point 2:" />
						<StackPanel Grid.Row="36"
						    Grid.Column="1"
						    Orientation="Horizontal">
							<TextBox x:Name="ContractControlPoint2X"
							    Margin="2"
							    Text="1.0" />
							<TextBox x:Name="ContractControlPoint2Y"
							    Margin="2"
							    Text="0.5" />
						</StackPanel>
						<Button Grid.Row="37"
						    Click="OnSetAnimationParametersButtonClicked">
							Set
						</Button>

						<TextBlock Grid.Row="38"
						    Foreground="Red"
						    Text="Animation Durations:" />
						<StackPanel Grid.Row="39"
						    Orientation="Horizontal">
							<TextBlock Margin="2"
							    Text="Expand: " />
							<TextBox x:Name="ExpandAnimationDuration"
							    Margin="2"
							    Text="300" />
						</StackPanel>
						<StackPanel Grid.Row="39"
						    Grid.Column="1"
						    Orientation="Horizontal">
							<TextBlock Margin="2"
							    Text="Contract: " />
							<TextBox x:Name="ContractAnimationDuration"
							    Margin="2"
							    Text="200" />
						</StackPanel>
						<Button Grid.Row="40"
						    Click="OnSetAnimationDurationsButtonClicked">
							Set
						</Button>


						<TextBlock Grid.Row="41"
						    Grid.ColumnSpan="2"
						    Foreground="Red"
						    Text="---------------Shadow Knobs----------------" />
						<TextBlock Grid.Row="42"
						    VerticalAlignment="Center"
						    Foreground="Red"
						    Text="Content Elevation" />
						<Slider Grid.Row="43"
						    Grid.ColumnSpan="2"
						    Maximum="50"
						    Minimum="0"
						    Value="32"
						    ValueChanged="ContentElevationSliderChanged" />
						<TextBlock Grid.Row="44"
						    VerticalAlignment="Center"
						    Foreground="Red"
						    Text="Has Shadow: " />
						<CheckBox Grid.Row="44"
						    Grid.Column="1"
						    Checked="OnTipShadowChecked"
						    IsChecked="True"
						    Unchecked="OnTipShadowUnchecked" />
						<TextBlock Grid.Row="45"
						    VerticalAlignment="Center"
						    Foreground="Red"
						    Text="Tail Elevation" />
						<Slider Grid.Row="46"
						    Grid.ColumnSpan="2"
						    Maximum="100"
						    Minimum="0"
						    Value="0"
						    ValueChanged="TailElevationSliderChanged" />

						<TextBlock Grid.Row="47"
						    VerticalAlignment="Center"
						    Foreground="Red"
						    Text="Is Page RTL" />
						<CheckBox Grid.Row="47"
						    Grid.Column="1"
						    IsChecked="{x:Bind IsPageRTL, Mode=TwoWay}" />
						<Button x:Name="RemoveTeachingTipButton"
						    Grid.Row="48"
						    Grid.Column="0"
						    Click="RemoveTeachingTipButton_Click">
							Remove tooltip from page
						</Button>
						<CheckBox x:Name="VisualTreeTeachingTipContentTextBlockUnloaded"
						    Grid.Row="48"
						    Grid.Column="1">
							Visual tree teachingtip unloaded
						</CheckBox>
						<Button x:Name="RemoveButtonFromVisualTreeButton"
						    Grid.Row="49"
						    Click="RemoveOpenButton_Click">
							Remove button from visual tree
						</Button>
						<StackPanel Grid.Row="50"
						    Orientation="Horizontal">
							<Button x:Name="GetEdgeTeachingTipOffset"
							    AutomationProperties.Name="GetEdgeTeachingTipOffset"
							    Click="GetEdgeTeachingTipOffset_Clicked">
								Get TeachingTip on edge offset
							</Button>
							<TextBlock x:Name="EdgeTeachingTipOffset"
							    AutomationProperties.Name="EdgeTeachingTipOffset">
								0;0
							</TextBlock>
						</StackPanel>
					</Grid>
				</ScrollViewer>

				<!--  Logging Output  -->
				<Grid MaxWidth="400"
				    Margin="5"
				    Padding="6"
				    Background="{ThemeResource SystemChromeLowColor}">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>

					<TextBlock Foreground="Red"
					    Text="TeachingTip Messages &amp; Events" />

					<StackPanel Grid.Row="1"
					    Orientation="Horizontal">
						<Button x:Name="btnClearTeachingTipEvents"
						    Margin="1"
						    AutomationProperties.Name="btnClearTeachingTipEvents"
						    Click="BtnClearTeachingTipEvents_Click"
						    Content="Clear" />
						<CheckBox x:Name="chkLogTeachingTipMessages"
						    Margin="1"
						    Content="Log TeachingTip Messages?" />
						<CheckBox x:Name="chkLogTeachingTipEvents"
						    Margin="1"
						    Content="Log TeachingTip Events?"
						    IsChecked="true" />
						<CheckBox x:Name="chkDisplayLogs"
						    Margin="1"
						    Content="Display Logs?" />
					</StackPanel>
					<ListBox x:Name="lstTeachingTipEvents"
					    Grid.Row="2"
					    Margin="1"
					    AutomationProperties.Name="lstTeachingTipEvents"
					    ScrollViewer.HorizontalScrollBarVisibility="Auto"
					    ScrollViewer.HorizontalScrollMode="Auto" />
				</Grid>

			</StackPanel>
		</ScrollViewer>

		<Grid Grid.Column="2">
			<Button x:Name="targetButtonRightEdge"
			    Width="100"
			    Height="40"
			    HorizontalAlignment="Right"
			    VerticalAlignment="Top"
			    AutomationProperties.Name="TargetButtonRightEdge"
			    Click="OnShowButtonClickedRightEdge">
				Click to open TeachingTip
				<Button.Resources>
					<muxc:TeachingTip x:Name="TeachingTipInResourcesOnEdge"
					    Title="We've Added Auto Saving!"
					    AutomationProperties.Name="TeachingTipInResourcesOnEdge"
					    Subtitle="Documents will now automatically save to OneDrive."
					    Target="{x:Bind targetButtonRightEdge}">
						<muxc:TeachingTip.IconSource>
							<muxc:SymbolIconSource Symbol="People" />
						</muxc:TeachingTip.IconSource>
						<muxc:TeachingTip.HeroContent>
							<Grid MinWidth="200"
							    MinHeight="200"
							    Background="red" />
						</muxc:TeachingTip.HeroContent>
						<muxc:TeachingTip.Content>
							<StackPanel Orientation="Horizontal">
								<TextBlock>Just some demo text</TextBlock>
							</StackPanel>
						</muxc:TeachingTip.Content>
					</muxc:TeachingTip>
				</Button.Resources>
			</Button>
		</Grid>
	</Grid>
</utilities:MUXTestPage>
