						    Grid.Column="1"
						    AutomationProperties.AutomationId="SetActionContentButton"
						    Click="OnSetActionButtonContentButtonClicked">
							Set
						</Button>

						<TextBlock Grid.Row="14"
						    Foreground="Red"
						    Text="CloseButtonContent:" />
						<ComboBox x:Name="CloseButtonContentComboBox"
						    Grid.Row="15"
						    AutomationProperties.Name="CloseButtonContentComboBox"
						    SelectedIndex="0">
							<ComboBoxItem x:Name="CloseButtonContentNo">No text</ComboBoxItem>
							<ComboBoxItem x:Name="CloseButtonContentSmall">Small text</ComboBoxItem>
							<ComboBoxItem x:Name="CloseButtonContentLong">Long text</ComboBoxItem>
							<ComboBoxItem x:Name="CloseButtonButton">Button</ComboBoxItem>
						</ComboBox>
						<Button Grid.Row="15"
						    Grid.Column="1"
						    AutomationProperties.Name="SetCloseButtonContentButton"
						    Click="OnSetCloseButtonContentButtonClicked">
							Set
						</Button>

						<TextBlock Grid.Row="16"
						    Foreground="Red"
						    Text="HeroContentPlacement:" />
						<ComboBox x:Name="HeroContentPlacementComboBox"
						    Grid.Row="17"
						    SelectedIndex="0">
							<ComboBoxItem x:Name="HeroContentPlacementAuto">Auto</ComboBoxItem>
							<ComboBoxItem x:Name="HeroContentPlacementTop">Top</ComboBoxItem>
							<ComboBoxItem x:Name="HeroContentPlacementBottom">Bottom</ComboBoxItem>
						</ComboBox>
						<Button Grid.Row="17"
						    Grid.Column="1"
						    Click="OnSetBleeingImagePlacementButtonClicked">
							Set
						</Button>
						<TextBlock Grid.Row="18"
						    Foreground="Red"
						    Text="PreferredPlacement:" />
						<ComboBox x:Name="PreferredPlacementComboBox"
						    Grid.Row="19"
						    AutomationProperties.Name="PreferredPlacementComboBox"
						    SelectedIndex="12">
							<ComboBoxItem x:Name="PlacementTop">Top</ComboBoxItem>
							<ComboBoxItem x:Name="PlacementBottom">Bottom</ComboBoxItem>
							<ComboBoxItem x:Name="PlacementLeft">Left</ComboBoxItem>
							<ComboBoxItem x:Name="PlacementRight">Right</ComboBoxItem>
							<ComboBoxItem x:Name="PlacementTopRight">TopRight</ComboBoxItem>
							<ComboBoxItem x:Name="PlacementTopLeft">TopLeft</ComboBoxItem>
							<ComboBoxItem x:Name="PlacementBottomRight">BottomRight</ComboBoxItem>
							<ComboBoxItem x:Name="PlacementBottomLeft">BottomLeft</ComboBoxItem>
							<ComboBoxItem x:Name="PlacementLeftTop">LeftTop</ComboBoxItem>
							<ComboBoxItem x:Name="PlacementLeftBottom">LeftBottom</ComboBoxItem>
							<ComboBoxItem x:Name="PlacementRightTop">RightTop</ComboBoxItem>
							<ComboBoxItem x:Name="PlacementRightBottom">RightBottom</ComboBoxItem>
							<ComboBoxItem x:Name="PlacementCenter">Center</ComboBoxItem>
							<ComboBoxItem x:Name="PlacementAuto">Auto</ComboBoxItem>
						</ComboBox>
						<Button Grid.Row="19"
						    Grid.Column="1"
						    AutomationProperties.Name="SetPreferredPlacementButton"
						    Click="OnSetPreferredPlacementButtonClicked">
							Set
						</Button>

						<TextBlock Grid.Row="20"
						    Foreground="Red"
						    Text="IsLightDismissEnabled:" />
						<ComboBox x:Name="IsLightDismissEnabledComboBox"
						    Grid.Row="21"
						    AutomationProperties.Name="IsLightDismissEnabledComboBox"
						    SelectedIndex="0">
							<ComboBoxItem x:Name="IsLightDismissFalse">False</ComboBoxItem>
							<ComboBoxItem x:Name="IsLightDismissTrue">True</ComboBoxItem>
						</ComboBox>
						<Button Grid.Row="21"
						    Grid.Column="1"
						    AutomationProperties.Name="IsLightDismissEnabledButton"
						    Click="OnSetIsLightDismissEnabledButtonClicked">
							Set
						</Button>

						<TextBlock Grid.Row="22"
						    Foreground="Red"
						    Text="PlacementMargin:" />
						<TextBox x:Name="PlacementMarginTextBox"
						    Grid.Row="23"
						    MaxWidth="100"
						    HorizontalAlignment="Left"
						    Text="0" />
						<Button Grid.Row="23"
						    Grid.Column="1"
						    Click="OnSetPlacementMarginButtonClicked">
							Set
						</Button>

						<TextBlock Grid.Row="24"
						    Foreground="Red"
						    Text="Tail Visibility:" />
						<ComboBox x:Name="TailVisibilityComboBox"
						    Grid.Row="25"
						    SelectedIndex="0">
							<ComboBoxItem x:Name="TailVisibilityAuto">Auto</ComboBoxItem>
							<ComboBoxItem x:Name="TailVisibilityVisible">Visible</ComboBoxItem>
							<ComboBoxItem x:Name="TailVisibilityCollapsed">Collapsed</ComboBoxItem>
						</ComboBox>
						<Button Grid.Row="25"
						    Grid.Column="1"
						    Click="OnSetTailVisibilityButtonClicked">
							Set
						</Button>

						<TextBlock Grid.Row="26"
						    Foreground="Red"
						    Text="ShouldConstrainToRootBounds:" />
						<ComboBox x:Name="ShouldConstrainToRootBoundsComboBox"
						    Grid.Row="27"
						    AutomationProperties.Name="ShouldConstrainToRootBoundsComboBox">
							<ComboBoxItem x:Name="ShouldConstrainToRootBoundsFalse">False</ComboBoxItem>
							<ComboBoxItem x:Name="ShouldConstrainToRootBoundsTrue">True</ComboBoxItem>
						</ComboBox>
						<Button Grid.Row="27"
						    Grid.Column="1"
						    AutomationProperties.Name="ShouldConstrainToRootBoundsButton"
						    Click="OnSetShouldConstrainToRootBoundsButtonClicked">
							Set
						</Button>

						<TextBlock Grid.Row="28"
						    Foreground="Red"
						    Text="Target:" />
						<Button Grid.Row="29"
						    AutomationProperties.Name="SetTargetButton"
						    Click="OnSetTargetButtonClicked">
							Target
						</Button>
						<Button Grid.Row="29"
						    Grid.Column="1"
						    AutomationProperties.Name="RemoveTargetButton"
						    Click="OnUntargetButtonClicked">
							Untarget
						</Button>

						<TextBlock Grid.Row="30"
						    Foreground="Red"
						    Text="Show:" />
						<Button Grid.Row="31"
						    AutomationProperties.Name="ShowButton"
						    Click="OnShowButtonClicked">
							Show
						</Button>
						<Button Grid.Row="31"
						    Grid.Column="1"
						    AutomationProperties.Name="CloseButton"
						    Click="OnCloseButtonClicked">
							Close
						</Button>
						<Button Grid.Row="32"
						    Click="OnShowAfterDelayButtonClicked">
							ShowAfterDelay
						</Button>

						<TextBlock Grid.Row="33"
						    Grid.ColumnSpan="2"
						    Foreground="Red"
						    Text="----------Automation Properties----------" />

						<TextBlock Grid.Row="34"
						    Foreground="Red"
						    Text="AutomationName:" />
						<!--<TextBlock Grid.Row="35" Grid.Column="0" Text="{x:Bind TeachingTipInVisualTree.(AutomationProperties.Name), Mode=OneWay}" FontSize="8"/>-->
						<!--<TextBlock Grid.Row="35" Grid.Column="1" Text="{x:Bind TeachingTipInResources.(AutomationProperties.Name), Mode=OneWay}" FontSize="8"/>-->
						<ComboBox x:Name="AutomationNameComboBox"
						    Grid.Row="36"
						    AutomationProperties.Name="AutomationNameComboBox"
						    SelectedIndex="0">
							<ComboBoxItem x:Name="AutomationNameVisualTree">TeachingTipInVisualTree</ComboBoxItem>
							<ComboBoxItem x:Name="AutomationNameResources">TeachingTipInResources</ComboBoxItem>
							<ComboBoxItem x:Name="AutomationNameNone">None</ComboBoxItem>
						</ComboBox>
						<Button Grid.Row="36"
						    Grid.Column="1"
						    AutomationProperties.Name="SetAutomationNameButton"
						    Click="OnSetAutomationNameButtonClicked">
							Set
						</Button>

						<ComboBox x:Name="PageThemeComboBox"
						    Grid.Row="37"
						    AutomationProperties.AutomationId="PageThemeComboBox"
						    Header="Page Theme:"
						    SelectedIndex="0"
						    SelectionChanged="OnPageThemeComboBoxSelectionChanged">
							<ComboBoxItem x:Name="Default">Default</ComboBoxItem>
							<ComboBoxItem x:Name="Light">Light</ComboBoxItem>
							<ComboBoxItem x:Name="Dark">Dark</ComboBoxItem>
						</ComboBox>

						<StackPanel Grid.Row="37"
						    Grid.Column="1"
						    Orientation="Vertical">
							<StackPanel Orientation="Horizontal">
								<TextBlock FontSize="8"
								    Text="ActionButton.Foreground:" />
								<TextBlock AutomationProperties.AutomationId="EffectiveForegroundOfTeachingTipButton"
								    FontSize="8"
								    Text="{x:Bind BrushToString(ActionButton.Foreground), Mode=OneWay}" />
							</StackPanel>
							<StackPanel Orientation="Horizontal">
								<TextBlock FontSize="8"
								    Text="CheckBox.Foreground:" />
								<TextBlock AutomationProperties.AutomationId="EffectiveForegroundOfTeachingTipContent"
								    FontSize="8"
								    Text="{x:Bind BrushToString(CurrentCancelClosesCheckBox.Foreground), Mode=OneWay}" />
							</StackPanel>
						</StackPanel>
					</Grid>
				</ScrollViewer>

				<ScrollViewer>
					<Grid MinWidth="300"
					    Margin="5"
					    Padding="6">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
