<local:TestPage
    x:Class="MUXControlsTestApp.SelectorBarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel
        Margin="40"
        HorizontalAlignment="Center"
        VerticalAlignment="Top"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto">
            <TextBlock
                Margin="2"
                VerticalAlignment="Center"
                Text="SelectorBar OutputDebugString Levels:" />
            <ComboBox
                x:Name="cmbSelectorBarOutputDebugStringLevel"
                Grid.Column="1"
                MinWidth="100"
                Margin="2"
                HorizontalAlignment="Stretch"
                SelectedIndex="0"
                SelectionChanged="CmbSelectorBarOutputDebugStringLevel_SelectionChanged">
                <ComboBoxItem>None</ComboBoxItem>
                <ComboBoxItem>Info</ComboBoxItem>
                <ComboBoxItem>Verbose</ComboBoxItem>
            </ComboBox>
            <StackPanel
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Orientation="Horizontal">
                <CheckBox
                    x:Name="chkSelectorBar"
                    Margin="2"
                    Content="SelectorBar"
                    IsChecked="True" />
                <CheckBox
                    x:Name="chkItemsView"
                    Margin="2"
                    Content="ItemsView"
                    IsChecked="True" />
                <CheckBox
                    x:Name="chkItemsRepeater"
                    Margin="2"
                    Content="ItemsRepeater"
                    IsChecked="True" />
                <CheckBox
                    x:Name="chkItemContainer"
                    Margin="2"
                    Content="ItemContainer" />
            </StackPanel>
        </Grid>
        <Button
            x:Name="navigateToSummary"
            Margin="2"
            HorizontalAlignment="Stretch"
            AutomationProperties.Name="navigateToSummary">
            SelectorBar in summary page
        </Button>
        <Button
            x:Name="navigateToSample"
            Margin="2"
            HorizontalAlignment="Stretch"
            AutomationProperties.Name="navigateToSample">
            SelectorBar in sample page
        </Button>
    </StackPanel>
</local:TestPage>
