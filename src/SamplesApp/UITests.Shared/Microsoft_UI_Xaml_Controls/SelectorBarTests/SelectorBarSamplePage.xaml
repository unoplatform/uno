<local:TestPage x:Class="MUXControlsTestApp.SelectorBarSamplePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataModel="using:MUXControlsTestApp.Samples.Model"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

	<Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
	    ColumnDefinitions="Auto"
	    RowDefinitions="Auto, Auto, Auto">
		<SelectorBar x:Name="selectorBar"
		    Margin="2"
		    AutomationProperties.Name="selectorBar"
		    SelectionChanged="SelectorBar_SelectionChanged">
			<SelectorBarItem x:Name="selectorBarItemDeleted"
			    Icon="Delete"
			    IsEnabled="False"
			    Text="Deleted" />
			<SelectorBarItem x:Name="selectorBarItemCut1"
			    Icon="Cut"
			    Text="Cut1"
			    Visibility="Collapsed" />
			<SelectorBarItem x:Name="selectorBarItemRemote"
			    AutomationProperties.Name="Remote Photos"
			    Icon="Remote"
			    Text="Remote" />
			<SelectorBarItem x:Name="selectorBarItemShared"
			    Icon="Share"
			    Text="Shared" />
			<SelectorBarItem x:Name="selectorBarItemCut2"
			    Icon="Cut"
			    Text="Cut2"
			    Visibility="Collapsed" />
			<SelectorBarItem x:Name="selectorBarItemFavorites"
			    Icon="Favorite"
			    IsSelected="True"
			    Text="Favorites" />
		</SelectorBar>

		<ItemsView x:Name="photos"
		    Grid.Row="1"
		    Width="500"
		    Height="500"
		    Margin="2"
		    AutomationProperties.Name="photos">
			<ItemsView.ItemTransitionProvider>
				<LinedFlowLayoutItemCollectionTransitionProvider />
			</ItemsView.ItemTransitionProvider>
			<ItemsView.Layout>
				<LinedFlowLayout ItemsStretch="Fill"
				    LineHeight="96"
				    LineSpacing="4"
				    MinItemSpacing="4" />
			</ItemsView.Layout>
			<ItemsView.ItemTemplate>
				<DataTemplate x:DataType="dataModel:Recipe">
					<ItemContainer Height="96"
					    MinWidth="72"
					    Background="Gray">
						<Image HorizontalAlignment="Center"
						    VerticalAlignment="Center"
						    Stretch="UniformToFill">
							<Image.Source>
								<BitmapImage DecodePixelHeight="96"
								    UriSource="{Binding ImageUri}" />
							</Image.Source>
						</Image>
					</ItemContainer>
				</DataTemplate>
			</ItemsView.ItemTemplate>
		</ItemsView>

		<StackPanel Grid.Row="2"
		    Margin="2"
		    Orientation="Horizontal">
			<TextBlock Margin="2"
			    Text="Selected SelectorBarItem:" />
			<TextBlock x:Name="tblSelectedSelectorBarItem"
			    Margin="2" />
		</StackPanel>
	</Grid>
</local:TestPage>
