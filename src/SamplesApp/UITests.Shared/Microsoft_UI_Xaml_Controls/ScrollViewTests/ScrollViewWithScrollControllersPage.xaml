<local:TestPage x:Class="MUXControlsTestApp.ScrollViewWithScrollControllersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:controlsPrimitives="using:Microsoft.UI.Xaml.Controls.Primitives"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:localUtilities="using:MUXControlsTestApp.Utilities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

	<local:TestPage.Resources>
		<Style x:Key="ScrollViewWithScrollControllers"
		    TargetType="controls:ScrollView">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="IsTabStop" Value="False" />
			<Setter Property="UseSystemFocusVisuals" Value="True" />
			<Setter Property="ContentOrientation" Value="Vertical" />
			<Setter Property="HorizontalScrollChainMode" Value="Auto" />
			<Setter Property="HorizontalScrollMode" Value="Enabled" />
			<Setter Property="HorizontalScrollRailMode" Value="Enabled" />
			<Setter Property="VerticalScrollChainMode" Value="Auto" />
			<Setter Property="VerticalScrollMode" Value="Enabled" />
			<Setter Property="VerticalScrollRailMode" Value="Enabled" />
			<Setter Property="ZoomChainMode" Value="Auto" />
			<Setter Property="ZoomMode" Value="Disabled" />
			<Setter Property="IgnoredInputKinds" Value="None" />
			<Setter Property="MinZoomFactor" Value="0.1" />
			<Setter Property="MaxZoomFactor" Value="10.0" />
			<Setter Property="HorizontalAnchorRatio" Value="0.0" />
			<Setter Property="VerticalAnchorRatio" Value="0.0" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="controls:ScrollView">
						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition Height="*" />
								<RowDefinition Height="Auto" />
							</Grid.RowDefinitions>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<controlsPrimitives:ScrollPresenter x:Name="PART_ScrollPresenter"
							    Grid.RowSpan="2"
							    Grid.ColumnSpan="2"
							    Margin="{TemplateBinding Padding}"
							    Background="{TemplateBinding Background}"
							    Content="{TemplateBinding Content}"
							    ContentOrientation="{TemplateBinding ContentOrientation}"
							    HorizontalAnchorRatio="{TemplateBinding HorizontalAnchorRatio}"
							    HorizontalScrollChainMode="{TemplateBinding HorizontalScrollChainMode}"
							    HorizontalScrollMode="{TemplateBinding HorizontalScrollMode}"
							    HorizontalScrollRailMode="{TemplateBinding HorizontalScrollRailMode}"
							    IgnoredInputKinds="{TemplateBinding IgnoredInputKinds}"
							    MaxZoomFactor="{TemplateBinding MaxZoomFactor}"
							    MinZoomFactor="{TemplateBinding MinZoomFactor}"
							    VerticalAnchorRatio="{TemplateBinding VerticalAnchorRatio}"
							    VerticalScrollChainMode="{TemplateBinding VerticalScrollChainMode}"
							    VerticalScrollMode="{TemplateBinding VerticalScrollMode}"
							    VerticalScrollRailMode="{TemplateBinding VerticalScrollRailMode}"
							    ZoomChainMode="{TemplateBinding ZoomChainMode}"
							    ZoomMode="{TemplateBinding ZoomMode}" />
							<localUtilities:CompositionScrollController x:Name="PART_HorizontalScrollBar"
							    Grid.Row="1"
							    Height="40"
							    HorizontalAlignment="Stretch"
							    IsEnabled="{TemplateBinding IsEnabled}"
							    Orientation="Horizontal"
							    Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" />
							<localUtilities:CompositionScrollController x:Name="PART_VerticalScrollBar"
							    Grid.Column="1"
							    Width="40"
							    VerticalAlignment="Stretch"
							    IsEnabled="{TemplateBinding IsEnabled}"
							    Orientation="Vertical"
							    Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
							<Rectangle x:Name="PART_ScrollBarsSeparator"
							    Grid.Row="1"
							    Grid.Column="1"
							    HorizontalAlignment="Stretch"
							    VerticalAlignment="Stretch"
							    Fill="Orange"
							    Visibility="Collapsed" />
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</local:TestPage.Resources>

	<Grid x:Name="rootGrid"
	    Margin="4"
	    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<StackPanel Grid.ColumnSpan="5"
		    Orientation="Horizontal">
			<CheckBox x:Name="chkScrollViewProperties"
			    Margin="2,0,0,0"
			    Checked="ChkScrollViewProperties_Checked"
			    Content="ScrollView Properties"
			    IsChecked="True"
			    IsThreeState="False"
			    Unchecked="ChkScrollViewProperties_Unchecked" />
			<CheckBox x:Name="chkScrollPresenterAttachedProperties"
			    Margin="2,0,0,0"
			    Checked="ChkScrollPresenterAttachedProperties_Checked"
			    Content="ScrollPresenter Attached Properties"
			    IsChecked="True"
			    IsThreeState="False"
			    Unchecked="ChkScrollPresenterAttachedProperties_Unchecked" />
			<CheckBox x:Name="chkContentProperties"
			    Margin="2,0,0,0"
			    Checked="ChkContentProperties_Checked"
			    Content="Content Properties"
			    IsChecked="True"
			    IsThreeState="False"
			    Unchecked="ChkContentProperties_Unchecked" />
			<CheckBox x:Name="chkLogs"
			    Margin="2,0,0,0"
			    Checked="ChkLogs_Checked"
			    Content="Logs"
			    IsChecked="True"
			    IsThreeState="False"
			    Unchecked="ChkLogs_Unchecked" />
		</StackPanel>

		<controls:ScrollView x:Name="markupScrollView"
		    Grid.Row="1"
		    Width="400"
		    Height="500"
		    Margin="1"
		    VerticalAlignment="Top"
		    Background="Aqua"
		    IsTabStop="True"
		    Style="{StaticResource ScrollViewWithScrollControllers}">
			<Image x:Name="img"
			    Width="900"
			    Height="900"
			    Source="Assets/ingredient8.png" />
		</controls:ScrollView>

		<ScrollViewer Grid.Row="1"
		    Grid.RowSpan="2"
		    Grid.Column="1"
		    HorizontalScrollBarVisibility="Visible">
			<StackPanel Orientation="Horizontal">
				<Grid x:Name="grdScrollViewProperties"
				    Margin="4,0,4,0"
				    Padding="6"
				    Background="{ThemeResource SystemListLowColor}">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

					<TextBlock Grid.Row="0"
					    Grid.ColumnSpan="4"
					    Foreground="Red"
					    Text="ScrollView Properties" />

					<TextBlock Grid.Row="1"
					    Grid.Column="0"
					    VerticalAlignment="Center"
					    Text="Width:" />
					<TextBox x:Name="txtWidth"
					    Grid.Row="1"
					    Grid.Column="1"
					    VerticalAlignment="Center" />
					<Button x:Name="btnGetWidth"
					    Grid.Row="1"
					    Grid.Column="2"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnGetWidth_Click"
					    Content="G" />
					<Button x:Name="btnSetWidth"
					    Grid.Row="1"
					    Grid.Column="3"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnSetWidth_Click"
					    Content="S" />

					<TextBlock Grid.Row="2"
					    Grid.Column="0"
					    VerticalAlignment="Center"
					    Text="Height:" />
					<TextBox x:Name="txtHeight"
					    Grid.Row="2"
					    Grid.Column="1"
					    VerticalAlignment="Center" />
					<Button x:Name="btnGetHeight"
					    Grid.Row="2"
					    Grid.Column="2"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnGetHeight_Click"
					    Content="G" />
					<Button x:Name="btnSetHeight"
					    Grid.Row="2"
					    Grid.Column="3"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnSetHeight_Click"
					    Content="S" />

					<TextBlock Grid.Row="3"
					    Grid.Column="0"
					    VerticalAlignment="Center"
					    Text="Padding:" />
					<TextBox x:Name="txtPadding"
					    Grid.Row="3"
					    Grid.Column="1"
					    HorizontalAlignment="Stretch"
					    VerticalAlignment="Center" />
					<Button x:Name="btnGetPadding"
					    Grid.Row="3"
					    Grid.Column="2"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnGetPadding_Click"
					    Content="G" />
					<Button x:Name="btnSetPadding"
					    Grid.Row="3"
					    Grid.Column="3"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnSetPadding_Click"
					    Content="S" />

					<TextBlock Grid.Row="4"
					    Grid.Column="0"
					    VerticalAlignment="Center"
					    Text="HorizontalScrollBarVisibility:" />
					<ComboBox x:Name="cmbHorizontalScrollBarVisibility"
					    Grid.Row="4"
					    Grid.Column="1"
					    Width="105"
					    Margin="0,1,0,1"
					    VerticalAlignment="Center">
						<ComboBoxItem>Auto</ComboBoxItem>
						<ComboBoxItem>Visible</ComboBoxItem>
						<ComboBoxItem>Hidden</ComboBoxItem>
					</ComboBox>
					<Button x:Name="btnGetHorizontalScrollBarVisibility"
					    Grid.Row="4"
					    Grid.Column="2"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnGetHorizontalScrollBarVisibility_Click"
					    Content="G" />
					<Button x:Name="btnSetHorizontalScrollBarVisibility"
					    Grid.Row="4"
					    Grid.Column="3"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnSetHorizontalScrollBarVisibility_Click"
					    Content="S" />

					<TextBlock Grid.Row="5"
					    Grid.Column="0"
					    VerticalAlignment="Center"
					    Text="VerticalScrollBarVisibility:" />
					<ComboBox x:Name="cmbVerticalScrollBarVisibility"
					    Grid.Row="5"
					    Grid.Column="1"
					    Width="105"
					    Margin="0,1,0,1"
					    VerticalAlignment="Center">
						<ComboBoxItem>Auto</ComboBoxItem>
						<ComboBoxItem>Visible</ComboBoxItem>
						<ComboBoxItem>Hidden</ComboBoxItem>
					</ComboBox>
					<Button x:Name="btnGetVerticalScrollBarVisibility"
					    Grid.Row="5"
					    Grid.Column="2"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnGetVerticalScrollBarVisibility_Click"
					    Content="G" />
					<Button x:Name="btnSetVerticalScrollBarVisibility"
					    Grid.Row="5"
					    Grid.Column="3"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnSetVerticalScrollBarVisibility_Click"
					    Content="S" />

					<CheckBox x:Name="chkIsEnabled"
					    Grid.Row="6"
					    Grid.ColumnSpan="4"
					    Checked="ChkIsEnabled_Checked"
					    Content="IsEnabled?"
					    Unchecked="ChkIsEnabled_Unchecked" />
					<CheckBox x:Name="chkIsTabStop"
					    Grid.Row="7"
					    Grid.ColumnSpan="4"
					    Checked="ChkIsTabStop_Checked"
					    Content="IsTabStop?"
					    Unchecked="ChkIsTabStop_Unchecked" />
				</Grid>

				<Grid x:Name="grdScrollPresenterAttachedProperties"
				    Grid.Row="1"
				    Grid.Column="2"
				    Margin="4,0,4,0"
				    Padding="6">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

					<TextBlock Grid.Row="0"
					    Grid.ColumnSpan="4"
					    Foreground="Red"
					    Text="ScrollPresenter Cloned Properties" />

					<TextBlock Grid.Row="1"
					    Grid.Column="0"
					    VerticalAlignment="Center"
					    Text="ContentOrientation:" />
					<ComboBox x:Name="cmbContentOrientation"
					    Grid.Row="1"
					    Grid.Column="1"
					    Width="105"
					    Margin="1"
					    VerticalAlignment="Center">
						<ComboBoxItem>Vertical</ComboBoxItem>
						<ComboBoxItem>Horizontal</ComboBoxItem>
						<ComboBoxItem>None</ComboBoxItem>
					</ComboBox>
					<Button x:Name="btnGetContentOrientation"
					    Grid.Row="1"
					    Grid.Column="2"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnGetContentOrientation_Click"
					    Content="G" />
					<Button x:Name="btnSetContentOrientation"
					    Grid.Row="1"
					    Grid.Column="3"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnSetContentOrientation_Click"
					    Content="S" />

					<TextBlock Grid.Row="3"
					    Grid.Column="0"
					    VerticalAlignment="Center"
					    Text="HorizontalScrollMode:" />
					<ComboBox x:Name="cmbHorizontalScrollMode"
					    Grid.Row="3"
					    Grid.Column="1"
					    Width="105"
					    Margin="1"
					    VerticalAlignment="Center">
						<ComboBoxItem>Enabled</ComboBoxItem>
						<ComboBoxItem>Disabled</ComboBoxItem>
						<ComboBoxItem>Auto</ComboBoxItem>
					</ComboBox>
					<Button x:Name="btnGetHorizontalScrollMode"
					    Grid.Row="3"
					    Grid.Column="2"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnGetHorizontalScrollMode_Click"
					    Content="G" />
					<Button x:Name="btnSetHorizontalScrollMode"
					    Grid.Row="3"
					    Grid.Column="3"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnSetHorizontalScrollMode_Click"
					    Content="S" />

					<TextBlock Grid.Row="4"
					    Grid.Column="0"
					    VerticalAlignment="Center"
					    Text="VerticalScrollMode:" />
					<ComboBox x:Name="cmbVerticalScrollMode"
					    Grid.Row="4"
					    Grid.Column="1"
					    Width="105"
					    Margin="1"
					    VerticalAlignment="Center">
						<ComboBoxItem>Enabled</ComboBoxItem>
						<ComboBoxItem>Disabled</ComboBoxItem>
						<ComboBoxItem>Auto</ComboBoxItem>
					</ComboBox>
					<Button x:Name="btnGetVerticalScrollMode"
					    Grid.Row="4"
					    Grid.Column="2"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnGetVerticalScrollMode_Click"
					    Content="G" />
					<Button x:Name="btnSetVerticalScrollMode"
					    Grid.Row="4"
					    Grid.Column="3"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnSetVerticalScrollMode_Click"
					    Content="S" />

					<TextBlock Grid.Row="5"
					    Grid.Column="0"
					    VerticalAlignment="Center"
					    Text="ZoomMode:" />
					<ComboBox x:Name="cmbZoomMode"
					    Grid.Row="5"
					    Grid.Column="1"
					    Width="105"
					    Margin="1"
					    VerticalAlignment="Center">
						<ComboBoxItem>Enabled</ComboBoxItem>
						<ComboBoxItem>Disabled</ComboBoxItem>
					</ComboBox>
					<Button x:Name="btnGetZoomMode"
					    Grid.Row="5"
					    Grid.Column="2"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnGetZoomMode_Click"
					    Content="G" />
					<Button x:Name="btnSetZoomMode"
					    Grid.Row="5"
					    Grid.Column="3"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnSetZoomMode_Click"
					    Content="S" />
				</Grid>

				<Grid x:Name="grdContentProperties"
				    Margin="4,0,4,0"
				    Padding="6"
				    Background="{ThemeResource SystemListLowColor}">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

					<TextBlock Grid.Row="0"
					    Grid.ColumnSpan="4"
					    Foreground="Red"
					    Text="Content Properties" />

					<TextBlock Grid.Row="1"
					    Grid.Column="0"
					    VerticalAlignment="Center"
					    Text="Width:" />
					<TextBox x:Name="txtContentWidth"
					    Grid.Row="1"
					    Grid.Column="1"
					    VerticalAlignment="Center" />
					<Button x:Name="btnGeContenttWidth"
					    Grid.Row="1"
					    Grid.Column="2"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnGetContentWidth_Click"
					    Content="G" />
					<Button x:Name="btnSetContentWidth"
					    Grid.Row="1"
					    Grid.Column="3"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnSetContentWidth_Click"
					    Content="S" />

					<TextBlock Grid.Row="2"
					    Grid.Column="0"
					    VerticalAlignment="Center"
					    Text="Height:" />
					<TextBox x:Name="txtContentHeight"
					    Grid.Row="2"
					    Grid.Column="1"
					    VerticalAlignment="Center" />
					<Button x:Name="btnGetContentHeight"
					    Grid.Row="2"
					    Grid.Column="2"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnGetContentHeight_Click"
					    Content="G" />
					<Button x:Name="btnSetContentHeight"
					    Grid.Row="2"
					    Grid.Column="3"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnSetContentHeight_Click"
					    Content="S" />

					<TextBlock Grid.Row="3"
					    Grid.Column="0"
					    VerticalAlignment="Center"
					    Text="Margin:" />
					<TextBox x:Name="txtContentMargin"
					    Grid.Row="3"
					    Grid.Column="1"
					    HorizontalAlignment="Stretch"
					    VerticalAlignment="Center" />
					<Button x:Name="btnGetContentMargin"
					    Grid.Row="3"
					    Grid.Column="2"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnGetContentMargin_Click"
					    Content="G" />
					<Button x:Name="btnSetContentMargin"
					    Grid.Row="3"
					    Grid.Column="3"
					    Margin="1"
					    VerticalAlignment="Center"
					    Click="BtnSetContentMargin_Click"
					    Content="S" />

					<CheckBox x:Name="chkIsContentEnabled"
					    Grid.Row="4"
					    Grid.ColumnSpan="4"
					    Checked="ChkIsContentEnabled_Checked"
					    Content="IsEnabled?"
					    Unchecked="ChkIsContentEnabled_Unchecked" />
					<CheckBox x:Name="chkIsContentTabStop"
					    Grid.Row="5"
					    Grid.ColumnSpan="4"
					    Checked="ChkIsContentTabStop_Checked"
					    Content="IsTabStop?"
					    Unchecked="ChkIsContentTabStop_Unchecked" />
				</Grid>

				<Grid x:Name="grdLogs"
				    Margin="4,0,4,0"
				    Padding="6">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>

					<TextBlock Foreground="Red"
					    Text="Logs" />

					<StackPanel Grid.Row="1"
					    Orientation="Horizontal">
						<Button x:Name="btnClearLogs"
						    Margin="1"
						    Click="BtnClearLogs_Click"
						    Content="Clear" />
						<CheckBox x:Name="chkLogScrollPresenterMessages"
						    Margin="1"
						    Checked="ChkLogScrollPresenterMessages_Checked"
						    Content="Log ScrollPresenter Messages?"
						    Unchecked="ChkLogScrollPresenterMessages_Unchecked" />
						<CheckBox x:Name="chkLogScrollViewMessages"
						    Margin="1"
						    Checked="ChkLogScrollViewMessages_Checked"
						    Content="Log ScrollView Messages?"
						    Unchecked="ChkLogScrollViewMessages_Unchecked" />
					</StackPanel>
					<ListBox x:Name="lstLogs"
					    Grid.Row="2"
					    Margin="1" />
				</Grid>
			</StackPanel>
		</ScrollViewer>

		<StackPanel Grid.Row="2"
		    Grid.ColumnSpan="5"
		    Orientation="Horizontal">
			<TextBlock Margin="2"
			    Text="Exception Report" />
			<Button x:Name="btnClearExceptionReport"
			    Margin="2"
			    Click="BtnClearExceptionReport_Click"
			    Content="Clear Exception Report" />
			<TextBox x:Name="txtExceptionReport"
			    Margin="2"
			    IsReadOnly="True" />
		</StackPanel>
	</Grid>
</local:TestPage>
