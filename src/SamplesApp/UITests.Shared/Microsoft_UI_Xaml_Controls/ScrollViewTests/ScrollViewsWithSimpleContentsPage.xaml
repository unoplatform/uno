<local:TestPage x:Class="MUXControlsTestApp.ScrollViewsWithSimpleContentsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

	<Grid x:Name="rootGrid"
	    Margin="4"
	    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
			<!--  These empty Auto columns cause 4 Star columns above to be narrow when only one ScrollView is displayed  -->
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
		</Grid.ColumnDefinitions>

		<StackPanel Grid.Row="0"
		    Grid.ColumnSpan="20"
		    Margin="2"
		    Orientation="Horizontal">
			<TextBlock Margin="2"
			    VerticalAlignment="Center"
			    Text="ScrollViews with simple contents." />
			<TextBlock Margin="6,2,2,2"
			    VerticalAlignment="Center"
			    Text="Show ScrollView:" />
			<ComboBox x:Name="cmbShowScrollView"
			    Width="140"
			    VerticalAlignment="Center"
			    AutomationProperties.Name="cmbShowScrollView"
			    SelectedIndex="0"
			    SelectionChanged="CmbShowScrollView_SelectionChanged">
				<ComboBoxItem>All</ComboBoxItem>
				<ComboBoxItem>scrollView_11</ComboBoxItem>
				<ComboBoxItem>scrollView_21</ComboBoxItem>
				<ComboBoxItem>scrollView_31</ComboBoxItem>
				<ComboBoxItem>scrollView_41</ComboBoxItem>
				<ComboBoxItem>scrollView_51</ComboBoxItem>
				<ComboBoxItem>scrollView_12</ComboBoxItem>
				<ComboBoxItem>scrollView_22</ComboBoxItem>
				<ComboBoxItem>scrollView_32</ComboBoxItem>
				<ComboBoxItem>scrollView_42</ComboBoxItem>
				<ComboBoxItem>scrollView_52</ComboBoxItem>
			</ComboBox>
			<TextBlock Margin="6,2,2,2"
			    VerticalAlignment="Center"
			    Text="State:" />
			<TextBox x:Name="txtScrollPresenterState"
			    Width="275"
			    VerticalAlignment="Center"
			    AutomationProperties.AutomationId="txtScrollPresenterState"
			    IsReadOnly="True"
			    IsTabStop="False" />
			<Button x:Name="btnResetViews"
			    Margin="6,2,2,2"
			    VerticalAlignment="Center"
			    AutomationProperties.Name="btnResetViews"
			    Click="btnResetViews_Click"
			    Content="Reset views" />
			<TextBox x:Name="txtResetStatus"
			    Width="125"
			    VerticalAlignment="Center"
			    AutomationProperties.AutomationId="txtResetStatus"
			    IsReadOnly="True"
			    IsTabStop="False" />
			<Button x:Name="btnGetFullLog"
			    Margin="6,2,2,2"
			    VerticalAlignment="Center"
			    AutomationProperties.AutomationId="btnGetFullLog"
			    Click="btnGetFullLog_Click"
			    Content="Get log" />
			<Button x:Name="btnClearFullLog"
			    Margin="0,2,2,2"
			    VerticalAlignment="Center"
			    AutomationProperties.AutomationId="btnClearFullLog"
			    Click="btnClearFullLog_Click"
			    Content="Clear log" />
			<ComboBox x:Name="cmbFullLog"
			    Width="175"
			    Margin="6,2,2,2"
			    VerticalAlignment="Center"
			    AutomationProperties.Name="cmbFullLog" />
			<CheckBox x:Name="chkLogUpdated"
			    Margin="6,2,2,2"
			    VerticalAlignment="Center"
			    AutomationProperties.Name="chkLogUpdated"
			    Content="Log Updated?"
			    IsChecked="True"
			    IsEnabled="False"
			    IsThreeState="False" />
			<CheckBox x:Name="chkLogCleared"
			    Margin="6,2,2,2"
			    VerticalAlignment="Center"
			    AutomationProperties.Name="chkLogCleared"
			    Content="Log Cleared?"
			    IsChecked="True"
			    IsEnabled="False"
			    IsThreeState="False" />
		</StackPanel>
		<StackPanel Grid.Row="1"
		    Grid.ColumnSpan="20"
		    Margin="2"
		    Orientation="Horizontal">
			<TextBlock Margin="6,2,2,2"
			    VerticalAlignment="Center"
			    Text="HorizontalOffset:" />
			<TextBox x:Name="txtScrollPresenterHorizontalOffset"
			    Width="175"
			    VerticalAlignment="Center"
			    AutomationProperties.AutomationId="txtScrollPresenterHorizontalOffset"
			    IsReadOnly="True"
			    IsTabStop="False" />
			<TextBlock Margin="6,2,2,2"
			    VerticalAlignment="Center"
			    Text="VerticalOffset:" />
			<TextBox x:Name="txtScrollPresenterVerticalOffset"
			    Width="175"
			    VerticalAlignment="Center"
			    AutomationProperties.AutomationId="txtScrollPresenterVerticalOffset"
			    IsReadOnly="True"
			    IsTabStop="False" />
			<TextBlock Margin="6,2,2,2"
			    VerticalAlignment="Center"
			    Text="ZoomFactor:" />
			<TextBox x:Name="txtScrollPresenterZoomFactor"
			    Width="175"
			    VerticalAlignment="Center"
			    AutomationProperties.AutomationId="txtScrollPresenterZoomFactor"
			    IsReadOnly="True"
			    IsTabStop="False" />
			<TextBlock Margin="6,2,2,2"
			    VerticalAlignment="Center"
			    Text="IgnoredInputKinds:" />
			<ComboBox x:Name="cmbIgnoredInputKinds"
			    Width="140"
			    VerticalAlignment="Center"
			    AutomationProperties.Name="cmbIgnoredInputKinds"
			    IsEnabled="False"
			    IsTabStop="False"
			    SelectedIndex="0"
			    SelectionChanged="CmbIgnoredInputKinds_SelectionChanged">
				<ComboBoxItem />
				<ComboBoxItem>None</ComboBoxItem>
				<ComboBoxItem>Touch</ComboBoxItem>
				<ComboBoxItem>Pen</ComboBoxItem>
				<ComboBoxItem>MouseWheel</ComboBoxItem>
				<ComboBoxItem>Keyboard</ComboBoxItem>
				<ComboBoxItem>Gamepad</ComboBoxItem>
				<ComboBoxItem>All</ComboBoxItem>
			</ComboBox>
			<CheckBox x:Name="chkLogScrollPresenterMessages"
			    Margin="6,2,2,2"
			    AutomationProperties.Name="chkLogScrollPresenterMessages"
			    Checked="ChkLogScrollPresenterMessages_Checked"
			    Content="Log ScrollPresenter Messages?"
			    Unchecked="ChkLogScrollPresenterMessages_Unchecked" />
			<CheckBox x:Name="chkLogScrollViewMessages"
			    Margin="6,2,2,2"
			    AutomationProperties.Name="chkLogScrollViewMessages"
			    Checked="ChkLogScrollViewMessages_Checked"
			    Content="Log ScrollView Messages?"
			    Unchecked="ChkLogScrollViewMessages_Unchecked" />
		</StackPanel>

		<Border Grid.Row="2"
		    Grid.Column="0"
		    Margin="1"
		    Background="Cyan">
			<controls:ScrollView x:Name="scrollView11"
			    Height="400"
			    AutomationProperties.Name="scrollView11"
			    ContentOrientation="None">
				<StackPanel Width="2000"
				    Height="2000">
					<StackPanel.Background>
						<LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
							<GradientStop Color="Blue" Offset="0.0" />
							<GradientStop Color="White" Offset="0.5" />
							<GradientStop Color="Red" Offset="1.0" />
						</LinearGradientBrush>
					</StackPanel.Background>
					<StackPanel Width="800"
					    Height="100"
					    HorizontalAlignment="Left"
					    Orientation="Horizontal">
						<Button Width="100"
						    Height="100"
						    AutomationProperties.AutomationId="buttonInScrollView11"
						    Content="Button 1" />
						<Button Width="100"
						    Height="100"
						    Content="Button 1B" />
						<Rectangle Width="300"
						    Height="100"
						    HorizontalAlignment="Left"
						    Fill="Red"
						    Stroke="Black"
						    StrokeThickness="5" />
						<Button Width="100"
						    Height="100"
						    Content="Button 1C" />
					</StackPanel>

					<Button Width="100"
					    Height="100"
					    Content="Button 2" />
					<Rectangle Width="100"
					    Height="300"
					    HorizontalAlignment="Left"
					    Fill="Red"
					    Stroke="Black"
					    StrokeThickness="5" />
					<Button Width="100"
					    Height="100"
					    Content="Button 3" />
					<Rectangle Width="100"
					    Height="600"
					    HorizontalAlignment="Left"
					    Fill="Red"
					    Stroke="Black"
					    StrokeThickness="5" />
					<Button Width="100"
					    Height="100"
					    Content="Button 4" />
					<Button Width="100"
					    Height="100"
					    Content="Button 5" />
				</StackPanel>
			</controls:ScrollView>
		</Border>
		<Border Grid.Row="2"
		    Grid.Column="1"
		    Margin="1"
		    Background="LightBlue">
			<controls:ScrollView x:Name="scrollView21"
			    AutomationProperties.Name="scrollView21">
				<Image x:Name="img21"
				    AutomationProperties.Name="img21"
				    Source="Assets/ingredient7.png" />
			</controls:ScrollView>
		</Border>
		<Border Grid.Row="2"
		    Grid.Column="2"
		    Margin="1"
		    Background="AliceBlue">
			<controls:ScrollView x:Name="scrollView31"
			    AutomationProperties.Name="scrollView31"
			    ContentOrientation="None"
			    IsTabStop="True"
			    VerticalScrollMode="Disabled">
				<Image x:Name="img31"
				    MinWidth="900"
				    MinHeight="900"
				    AutomationProperties.Name="img31"
				    Source="Assets/ingredient8.png" />
			</controls:ScrollView>
		</Border>
		<Border Grid.Row="2"
		    Grid.Column="3"
		    Margin="1"
		    Background="BlueViolet">
			<controls:ScrollView x:Name="scrollView41"
			    AutomationProperties.Name="scrollView41"
			    HorizontalScrollMode="Disabled">
				<Image x:Name="img41"
				    AutomationProperties.Name="img41"
				    Source="Assets/ingredient6.png" />
			</controls:ScrollView>
		</Border>
		<Border Grid.Row="2"
		    Grid.Column="4"
		    Margin="1"
		    Background="CadetBlue">
			<controls:ScrollView x:Name="scrollView51"
			    AutomationProperties.Name="scrollView51"
			    ContentOrientation="None"
			    HorizontalScrollRailMode="Disabled"
			    IsTabStop="True"
			    VerticalScrollRailMode="Disabled">
				<Image x:Name="img51"
				    Width="800"
				    Height="800"
				    AutomationProperties.Name="img51"
				    Source="Assets/ingredient5.png" />
			</controls:ScrollView>
		</Border>

		<Border Grid.Row="3"
		    Grid.Column="0"
		    Margin="1"
		    Background="Cyan">
			<controls:ScrollView x:Name="scrollView12"
			    AutomationProperties.Name="scrollView12"
			    ContentOrientation="None"
			    MaxZoomFactor="2.0"
			    MinZoomFactor="0.5"
			    ZoomMode="Enabled">
				<Rectangle x:Name="rect2"
				    Width="500"
				    Height="700">
					<Rectangle.Fill>
						<LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
							<GradientStop Color="Blue" Offset="0.0" />
							<GradientStop Color="White" Offset="0.5" />
							<GradientStop Color="Red" Offset="1.0" />
						</LinearGradientBrush>
					</Rectangle.Fill>
				</Rectangle>
			</controls:ScrollView>
		</Border>
		<Border Grid.Row="3"
		    Grid.Column="1"
		    Margin="1"
		    Background="LightBlue">
			<controls:ScrollView x:Name="scrollView22"
			    AutomationProperties.Name="scrollView22"
			    ZoomMode="Enabled">
				<Image x:Name="img22"
				    AutomationProperties.Name="img22"
				    Source="Assets/ingredient7.png" />
			</controls:ScrollView>
		</Border>
		<Border Grid.Row="3"
		    Grid.Column="2"
		    Margin="1"
		    Background="AliceBlue">
			<controls:ScrollView x:Name="scrollView32"
			    AutomationProperties.Name="scrollView32"
			    ContentOrientation="None"
			    FlowDirection="RightToLeft"
			    IsTabStop="True"
			    VerticalScrollMode="Disabled"
			    ZoomMode="Enabled">
				<Image x:Name="img32"
				    MinWidth="900"
				    MinHeight="900"
				    AutomationProperties.Name="img32"
				    Source="Assets/ingredient8.png" />
			</controls:ScrollView>
		</Border>
		<Border Grid.Row="3"
		    Grid.Column="3"
		    Margin="1"
		    Background="BlueViolet">
			<controls:ScrollView x:Name="scrollView42"
			    AutomationProperties.Name="scrollView42"
			    HorizontalScrollMode="Disabled"
			    ZoomMode="Enabled">
				<Image x:Name="img42"
				    AutomationProperties.Name="img42"
				    Source="Assets/ingredient6.png" />
			</controls:ScrollView>
		</Border>
		<Border Grid.Row="3"
		    Grid.Column="4"
		    Margin="1"
		    Background="CadetBlue">
			<controls:ScrollView x:Name="scrollView52"
			    AutomationProperties.Name="scrollView52"
			    ContentOrientation="None"
			    HorizontalScrollRailMode="Disabled"
			    VerticalScrollRailMode="Disabled"
			    ZoomMode="Enabled">
				<Image x:Name="img52"
				    Width="800"
				    Height="800"
				    AutomationProperties.Name="img52"
				    Source="Assets/ingredient5.png" />
			</controls:ScrollView>
		</Border>
	</Grid>
</local:TestPage>
