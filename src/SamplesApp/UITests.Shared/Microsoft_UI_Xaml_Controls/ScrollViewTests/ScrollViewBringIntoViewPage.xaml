<local:TestPage x:Class="MUXControlsTestApp.ScrollViewBringIntoViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

	<Grid x:Name="rootGrid"
	    Margin="4"
	    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<StackPanel Grid.ColumnSpan="4"
		    Orientation="Horizontal">
			<CheckBox x:Name="chkBringIntoViewUI"
			    Margin="2,0,0,0"
			    Checked="ChkBringIntoViewUI_Checked"
			    Content="BringIntoView test UI"
			    IsChecked="True"
			    IsThreeState="False"
			    Unchecked="ChkBringIntoViewUI_Unchecked" />
			<CheckBox x:Name="chkLogs"
			    Margin="2,0,0,0"
			    Checked="ChkLogs_Checked"
			    Content="Logs"
			    IsChecked="True"
			    IsThreeState="False"
			    Unchecked="ChkLogs_Unchecked" />
		</StackPanel>

		<controls:ScrollView x:Name="scrollView"
		    Grid.Row="1"
		    Width="300"
		    Height="400"
		    Margin="1"
		    Padding="25"
		    VerticalAlignment="Top"
		    Background="AliceBlue">
			<Rectangle x:Name="rectangle"
			    Width="900"
			    Height="200"
			    Margin="0,750,1000,0">
				<Rectangle.Fill>
					<LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
						<GradientStop Color="Blue" Offset="0.0" />
						<GradientStop Color="Yellow" Offset="0.5" />
						<GradientStop Color="Red" Offset="1.0" />
					</LinearGradientBrush>
				</Rectangle.Fill>
			</Rectangle>
		</controls:ScrollView>

		<Grid x:Name="grdBringIntoViewUI"
		    Grid.Row="1"
		    Grid.RowSpan="2"
		    Grid.Column="1"
		    Margin="2"
		    Background="LightYellow">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<TextBlock Grid.ColumnSpan="2"
			    Foreground="Red"
			    Text="BringIntoViewOptions" />

			<TextBlock Grid.Row="1"
			    VerticalAlignment="Center"
			    Text="AnimationDesired:" />
			<ComboBox x:Name="cmbAnimationDesired"
			    Grid.Row="1"
			    Grid.Column="1"
			    Width="100"
			    Margin="1"
			    SelectedIndex="0">
				<ComboBoxItem>True</ComboBoxItem>
				<ComboBoxItem>False</ComboBoxItem>
			</ComboBox>

			<TextBlock Grid.Row="2"
			    VerticalAlignment="Center"
			    Text="HorizontalAlignmentRatio:" />
			<TextBox x:Name="txtHorizontalAlignmentRatio"
			    Grid.Row="2"
			    Grid.Column="1"
			    Margin="1"
			    Text="NaN" />

			<TextBlock Grid.Row="3"
			    VerticalAlignment="Center"
			    Text="VerticalAlignmentRatio:" />
			<TextBox x:Name="txtVerticalAlignmentRatio"
			    Grid.Row="3"
			    Grid.Column="1"
			    Margin="1"
			    Text="NaN" />

			<TextBlock Grid.Row="4"
			    VerticalAlignment="Center"
			    Text="HorizontalOffset:" />
			<TextBox x:Name="txtHorizontalOffset"
			    Grid.Row="4"
			    Grid.Column="1"
			    Margin="1"
			    Text="0" />

			<TextBlock Grid.Row="5"
			    VerticalAlignment="Center"
			    Text="VerticalOffset:" />
			<TextBox x:Name="txtVerticalOffset"
			    Grid.Row="5"
			    Grid.Column="1"
			    Margin="1"
			    Text="0" />

			<TextBlock Grid.Row="6"
			    VerticalAlignment="Center"
			    Text="TargetElement:" />
			<ComboBox x:Name="cmbTargetElement"
			    Grid.Row="6"
			    Grid.Column="1"
			    Margin="1"
			    SelectedIndex="0">
				<ComboBoxItem>rectangle</ComboBoxItem>
				<ComboBoxItem>scrollView</ComboBoxItem>
			</ComboBox>

			<TextBlock Grid.Row="7"
			    Margin="0,4,0,0"
			    VerticalAlignment="Center"
			    Text="Duration overrides (msec):" />
			<StackPanel Grid.Row="8"
			    Grid.Column="1"
			    VerticalAlignment="Center"
			    Orientation="Horizontal">
				<TextBox x:Name="txtStockOffsetsChangeDuration"
				    Margin="1"
				    IsReadOnly="True" />
				<TextBox x:Name="txtOverriddenOffsetsChangeDuration"
				    Margin="1" />
			</StackPanel>

			<CheckBox x:Name="chkCancelOperationInBringingIntoView"
			    Grid.Row="9"
			    Grid.ColumnSpan="2"
			    Content="Cancel Operation in BringingIntoView?" />

			<Button x:Name="btnStartBringIntoView"
			    Grid.Row="10"
			    Grid.ColumnSpan="2"
			    Margin="1,4,1,1"
			    HorizontalAlignment="Stretch"
			    Click="BtnStartBringIntoView_Click"
			    Content="StartBringIntoView" />
		</Grid>

		<Grid x:Name="grdLogs"
		    Grid.Row="1"
		    Grid.RowSpan="2"
		    Grid.Column="2"
		    Margin="2">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<TextBlock Foreground="Red"
			    Text="Logs" />

			<StackPanel Grid.Row="1"
			    Orientation="Horizontal">
				<Button x:Name="btnClearLogs"
				    Margin="1"
				    Click="BtnClearLogs_Click"
				    Content="Clear" />
				<StackPanel>
					<StackPanel Orientation="Horizontal">
						<CheckBox x:Name="chkLogScrollPresenterEvents"
						    Margin="1"
						    Checked="ChkLogScrollPresenterEvents_Checked"
						    Content="Log ScrollPresenter Events?"
						    Unchecked="ChkLogScrollPresenterEvents_Unchecked" />
						<CheckBox x:Name="chkLogScrollViewEvents"
						    Margin="1"
						    Checked="ChkLogScrollViewEvents_Checked"
						    Content="Log ScrollView Events?"
						    IsChecked="True"
						    Unchecked="ChkLogScrollViewEvents_Unchecked" />
					</StackPanel>
					<StackPanel Orientation="Horizontal">
						<CheckBox x:Name="chkLogScrollPresenterMessages"
						    Margin="1"
						    Checked="ChkLogScrollPresenterMessages_Checked"
						    Content="Log ScrollPresenter Messages?"
						    Unchecked="ChkLogScrollPresenterMessages_Unchecked" />
						<CheckBox x:Name="chkLogScrollViewMessages"
						    Margin="1"
						    Checked="ChkLogScrollViewMessages_Checked"
						    Content="Log ScrollView Messages?"
						    Unchecked="ChkLogScrollViewMessages_Unchecked" />
					</StackPanel>
				</StackPanel>
			</StackPanel>
			<ListBox x:Name="lstLogs"
			    Grid.Row="2"
			    Margin="1" />
		</Grid>

		<StackPanel Grid.Row="3"
		    Grid.ColumnSpan="4"
		    Orientation="Horizontal">
			<TextBlock Margin="2"
			    VerticalAlignment="Center"
			    Text="Exception Report" />
			<Button x:Name="btnClearExceptionReport"
			    Margin="2"
			    Click="BtnClearExceptionReport_Click"
			    Content="Clear Exception Report" />
			<TextBox x:Name="txtExceptionReport"
			    Margin="2"
			    IsReadOnly="True" />
		</StackPanel>
	</Grid>
</local:TestPage>
