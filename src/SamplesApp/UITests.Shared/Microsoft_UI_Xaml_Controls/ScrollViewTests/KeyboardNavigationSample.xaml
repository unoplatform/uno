<Page x:Class="UITests.Microsoft_UI_Xaml_Controls.ScrollViewTests.KeyboardNavigationSample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:local="using:UITests.Microsoft_UI_Xaml_Controls.ScrollViewTests">

	<Grid x:Name="root"
	    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
	    ColumnDefinitions="Auto, Auto, *"
	    RowDefinitions="Auto, *">

		<TextBlock Margin="2"
		    Foreground="Red"
		    Text="ItemsRepeater" />

		<StackPanel Grid.Row="1">
			<Button x:Name="btnBefore"
			    Width="140"
			    Margin="1"
			    Content="Before Button" />

			<ScrollView x:Name="scrollView"
			    Width="300"
			    Height="400"
			    Margin="1">
				<ItemsRepeater x:Name="itemsRepeater"
				    Margin="1">
					<ItemsRepeater.ItemTemplate>
						<DataTemplate>
							<ContentControl Margin="1"
							    Content="{Binding}"
							    UseSystemFocusVisuals="True" />
						</DataTemplate>
					</ItemsRepeater.ItemTemplate>
				</ItemsRepeater>
			</ScrollView>

			<Button x:Name="btnAfter"
			    Width="140"
			    Margin="1"
			    Content="After Button" />
		</StackPanel>

		<TextBlock Grid.Column="1"
		    Margin="2"
		    Foreground="Red"
		    Text="Test UI" />

		<StackPanel Grid.Row="1"
		    Grid.Column="1">
			<Button x:Name="btnSetItemsSource"
			    Width="140"
			    Margin="1"
			    Click="BtnSetItemsSource_Click"
			    Content="Set ItemsSource" />
			<Button x:Name="btnResetItemsSource"
			    Width="140"
			    Margin="1"
			    Click="BtnResetItemsSource_Click"
			    Content="Reset ItemsSource" />
			<StackPanel Orientation="Horizontal">
				<TextBlock Width="200"
				    VerticalAlignment="Center"
				    Text="ScrollView TabNavigation:" />
				<ComboBox x:Name="cmbScrollViewTabNavigation"
				    Width="155"
				    VerticalAlignment="Center"
				    SelectedIndex="0"
				    SelectionChanged="CmbScrollViewTabNavigation_SelectionChanged">
					<ComboBoxItem>Local</ComboBoxItem>
					<ComboBoxItem>Cycle</ComboBoxItem>
					<ComboBoxItem>Once</ComboBoxItem>
				</ComboBox>
			</StackPanel>
			<StackPanel Orientation="Horizontal">
				<TextBlock Width="200"
				    VerticalAlignment="Center"
				    Text="NavView TabFocusNavigation:" />
				<ComboBox x:Name="cmbItemsRepeaterTabFocusNavigation"
				    Width="155"
				    VerticalAlignment="Center"
				    SelectedIndex="2"
				    SelectionChanged="CmbItemsRepeaterTabFocusNavigation_SelectionChanged">
					<ComboBoxItem>Local</ComboBoxItem>
					<ComboBoxItem>Cycle</ComboBoxItem>
					<ComboBoxItem>Once</ComboBoxItem>
				</ComboBox>
			</StackPanel>
		</StackPanel>

		<TextBlock Grid.Column="2"
		    Margin="2"
		    Foreground="Red"
		    Text="Logs" />

		<Grid Grid.Row="1"
		    Grid.Column="2"
		    RowDefinitions="Auto, *">
			<Button x:Name="btnClearLogs"
			    Width="140"
			    Margin="1"
			    Click="BtnClearLogs_Click"
			    Content="Clear" />
			<ListView x:Name="lvLogs"
			    Grid.Row="1"
			    Margin="1"
			    ScrollViewer.HorizontalScrollBarVisibility="Auto"
			    ScrollViewer.HorizontalScrollMode="Auto">
				<ListView.ItemsPanel>
					<ItemsPanelTemplate>
						<ItemsStackPanel ItemsUpdatingScrollMode="KeepLastItemInView" />
					</ItemsPanelTemplate>
				</ListView.ItemsPanel>
			</ListView>
		</Grid>
	</Grid>
</Page>
