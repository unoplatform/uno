<Page
    x:Class="UITests.Microsoft_UI_Xaml_Controls.WebView2Tests.WebView2_LifecycleEvents"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Microsoft_UI_Xaml_Controls.WebView2Tests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            FontSize="18"
            FontWeight="SemiBold"
            Text="CoreWebView2 lifecycle events" />

        <TextBlock
            Grid.Row="1"
            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
            Text="Logs NavigationStarting, ContentLoading, DOMContentLoaded, NavigationCompleted, PermissionRequested, DownloadStarting, ContextMenuRequested, ServerCertificateErrorDetected, FrameCreated as they fire. Wiring is Win32-first; other platforms surface a subset."
            TextWrapping="Wrap" />

        <StackPanel
            Grid.Row="2"
            Orientation="Horizontal"
            Spacing="6">
            <Button Click="OnVisitClick" Content="Visit platform.uno" />
            <Button Click="OnVisitBadClick" Content="Visit bad cert" />
            <Button Click="OnClearClick" Content="Clear log" />
        </StackPanel>

        <ListView
            x:Name="EventLog"
            Grid.Row="3"
            FontFamily="Consolas, Courier New, monospace" />

        <controls:WebView2
            x:Name="WebView"
            Grid.Row="4"
            Source="https://platform.uno" />
    </Grid>
</Page>
