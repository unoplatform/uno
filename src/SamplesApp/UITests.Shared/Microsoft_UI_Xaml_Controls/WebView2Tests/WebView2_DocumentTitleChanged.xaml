<UserControl x:Class="SamplesApp.Microsoft_UI_Xaml_Controls.WebView2Tests.WebView2_DocumentTitleChanged"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SamplesApp.Microsoft_UI_Xaml_Controls.WebView2Tests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mux="using:Microsoft.UI.Xaml.Controls"
    xmlns:not_win="http://uno.ui/not_win"
    d:DesignHeight="400"
    d:DesignWidth="600"
    mc:Ignorable="d not_win">

	<not_win:Grid Padding="16"
	    RowSpacing="12">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<TextBlock Text="This sample wires CoreWebView2.DocumentTitleChanged and uses CoreWebView2.DocumentTitle for the new value." />

		<StackPanel Grid.Row="1"
		    Orientation="Horizontal"
		    Spacing="8">
			<TextBlock FontWeight="SemiBold"
			    Text="Current title:" />
			<TextBlock x:Name="TitleText"
			    Text="(waiting for navigation)" />
		</StackPanel>

		<TextBlock x:Name="StatusText"
		    Grid.Row="2"
		    Text="Status: waiting for CoreWebView2"
		    TextWrapping="WrapWholeWords" />

		<Grid Grid.Row="3"
		    RowSpacing="12">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<StackPanel Orientation="Horizontal"
			    Spacing="8">
				<TextBox x:Name="AddressBar"
				    Width="320"
				    Text="https://platform.uno/" />
				<Button Click="OnNavigateClicked"
				    Content="Navigate" />
				<Button Click="OnReloadClicked"
				    Content="Reload" />
			</StackPanel>

			<mux:WebView2 x:Name="SampleWebView"
			    Grid.Row="1"
			    HorizontalAlignment="Stretch"
			    VerticalAlignment="Stretch"
			    Source="https://platform.uno/" />
		</Grid>
	</not_win:Grid>
</UserControl>
