<utilities:MUXTestPage x:Class="UITests.Shared.Microsoft_UI_Xaml_Controls.TreeViewTests.TreeViewLateDataInitTest"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUX.UITests.Shared.Microsoft_UI_Xaml_Controls.TreeViewTests"
    xmlns:local1="using:UITests.Shared.Microsoft_UI_Xaml_Controls.TreeViewTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxcontrols="using:Microsoft.UI.Xaml.Controls"
    xmlns:utilities="using:MUXControlsTestApp.Utilities"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<StackPanel>
		<Button Name="InitializeItemsSource"
		    AutomationProperties.Name="InitializeItemsSource"
		    Click="InitializeItemsSource_Click"
		    Content="Initialize ItemsSource" />
		<muxcontrols:TreeView Name="TestTreeView"
		    ItemsSource="{x:Bind TestTreeViewItemsSource, Mode=OneWay}">
			<muxcontrols:TreeView.ItemTemplate>
				<DataTemplate x:DataType="local1:TreeViewItemSource">
					<muxcontrols:TreeViewItem Content="{x:Bind Content}"
					    ItemsSource="{x:Bind Children, Mode=OneWay}" />
				</DataTemplate>
			</muxcontrols:TreeView.ItemTemplate>
		</muxcontrols:TreeView>
	</StackPanel>

</utilities:MUXTestPage>
