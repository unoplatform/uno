<local:TestPage x:Class="MUXControlsTestApp.RefreshContainerOnImagePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxcontrols="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

	<ScrollViewer>
		<StackPanel Margin="100"
		    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
			<Button x:Name="AdaptButton"
			    Width="200"
			    Margin="2"
			    AutomationProperties.Name="AdaptButton"
			    Content="Adapt" />
			<StackPanel Orientation="Horizontal">
				<Button x:Name="RefreshOnContainerButton"
				    Width="200"
				    Margin="2"
				    AutomationProperties.Name="RefreshOnContainerButton"
				    Content="Refresh On Container" />
				<Button x:Name="RefreshOnVisualizerButton"
				    Width="200"
				    Margin="2"
				    AutomationProperties.Name="RefreshOnVisualizerButton"
				    Content="Refresh On Visualizer" />
			</StackPanel>
			<StackPanel Orientation="Horizontal">
				<Button x:Name="RotateButton"
				    Width="200"
				    Margin="2"
				    AutomationProperties.Name="RotateButton"
				    Content="Rotate Visualizer Location" />
				<Button x:Name="AddOrRemoveRefreshDelay"
				    Width="200"
				    Margin="2"
				    AutomationProperties.Name="AddOrRemoveRefreshDelay"
				    Content="Add/Remove Refresh Delay" />
			</StackPanel>
			<StackPanel Orientation="Horizontal">
				<Button x:Name="ChangeAlignment"
				    Width="200"
				    Margin="2"
				    AutomationProperties.Name="ChangeAlignment"
				    Content="Change Alignment" />
				<Button x:Name="ChangeRefreshRequested"
				    Width="200"
				    Margin="2"
				    AutomationProperties.Name="ChangeRefreshRequested"
				    Content="Change Refresh Requested Handler" />
			</StackPanel>
			<!--  Adding a left margin here eliminates a test reliability issue on phone where there is not space to perform the needed gesture  -->
			<Grid Height="300">
				<muxcontrols:RefreshContainer x:Name="RefreshContainer"
				    Margin="100,0,0,0"
				    HorizontalAlignment="Center"
				    VerticalAlignment="Center"
				    PullDirection="TopToBottom"
				    RefreshRequested="RefreshContainer_RefreshRequested">
					<Grid Width="100"
					    Height="100"
					    Background="Red">
						<Image x:Name="Image"
						    Width="50"
						    Height="50"
						    AutomationProperties.Name="Image"
						    Source="Assets/ingredient1.png" />
					</Grid>
				</muxcontrols:RefreshContainer>
			</Grid>
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="175" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
				</Grid.RowDefinitions>
				<TextBlock Grid.Row="0"
				    Grid.Column="0"
				    VerticalAlignment="Center"
				    Text="State:" />
				<TextBlock Grid.Row="1"
				    Grid.Column="0"
				    VerticalAlignment="Center"
				    Text="Interaction Ratio:" />
				<TextBlock Grid.Row="2"
				    Grid.Column="0"
				    VerticalAlignment="Center"
				    Text="Refresh Count:" />
				<ComboBox x:Name="States"
				    Grid.Row="0"
				    Grid.Column="1"
				    HorizontalAlignment="Stretch" />
				<ComboBox x:Name="InteractionRatios"
				    Grid.Row="1"
				    Grid.Column="1"
				    HorizontalAlignment="Stretch" />
				<TextBox x:Name="RefreshCount"
				    Grid.Row="2"
				    Grid.Column="1"
				    AutomationProperties.Name="RefreshCount"
				    IsReadOnly="True" />
				<Button x:Name="ResetStates"
				    Grid.Row="0"
				    Grid.Column="2"
				    Content="Reset" />
				<Button x:Name="ResetInteractionRatios"
				    Grid.Row="1"
				    Grid.Column="2"
				    Content="Reset" />
			</Grid>
		</StackPanel>
	</ScrollViewer>
</local:TestPage>
