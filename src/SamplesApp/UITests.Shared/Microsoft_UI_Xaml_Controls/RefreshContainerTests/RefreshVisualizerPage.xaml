<local:TestPage x:Class="MUXControlsTestApp.RefreshVisualizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:contract5Present="http://schemas.microsoft.com/winfx/2006/xaml/presentation?IsApiContractPresent(Windows.Foundation.UniversalApiContract, 5)"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxcontrols="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

	<StackPanel Padding="20"
	    VerticalAlignment="Center"
	    contract5Present:Spacing="10"
	    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
	    Orientation="Vertical">
		<muxcontrols:RefreshVisualizer x:Name="RefreshVisualizer" />
		<StackPanel HorizontalAlignment="Center"
		    Orientation="Horizontal">
			<Button x:Name="RefreshButton"
			    Margin="15"
			    Content="Refresh" />
		</StackPanel>
		<Slider x:Name="Slider"
		    Maximum="100"
		    Minimum="0"
		    TickFrequency="2"
		    TickPlacement="BottomRight" />
		<ComboBox x:Name="OrientationComboBox" />
		<TextBox x:Name="StateText" />
		<Button x:Name="InsertIcon"
		    Content="InsertIcon" />
		<Button x:Name="InsertGrid"
		    Content="InsertGrid" />
		<Button x:Name="ChangeBackground"
		    Content="ChangeBackground" />
		<Button x:Name="ChangeForeground"
		    Content="ChangeForeground" />
		<Slider x:Name="MarginSlider"
		    Maximum="50"
		    Minimum="-10"
		    TickFrequency="2"
		    TickPlacement="BottomRight" />
		<Slider x:Name="MySizeSlider"
		    Maximum="50"
		    Minimum="2"
		    TickFrequency="2"
		    TickPlacement="BottomRight" />
	</StackPanel>
</local:TestPage>
