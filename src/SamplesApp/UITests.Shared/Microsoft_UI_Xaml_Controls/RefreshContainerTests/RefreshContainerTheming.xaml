<Page
    x:Class="UITests.Microsoft_UI_Xaml_Controls.RefreshContainerTests.RefreshContainerTheming"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Microsoft_UI_Xaml_Controls.RefreshContainerTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mux="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="300" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Click="ChangeColors_Click">Change colors</Button>
            <Button Click="RequestRefresh_Click">Request refresh</Button>
        </StackPanel>
        <mux:RefreshContainer
            x:Name="RefreshContainer"
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <ListView
                x:Name="listView"
                Width="400"
                Height="300"
                AutomationProperties.Name="listView"
                BorderBrush="Cyan"
                BorderThickness="2">
                <ListView.Header>
                    <StackPanel Background="Red">
                        <TextBlock Text="ListView header" />
                    </StackPanel>
                </ListView.Header>
                <ListViewItem
                    AutomationProperties.Name="listViewItem1"
                    Content="One"
                    FontSize="50" />
                <ListViewItem
                    AutomationProperties.Name="listViewItem2"
                    Content="Two"
                    FontSize="50" />
                <ListViewItem
                    AutomationProperties.Name="listViewItem3"
                    Content="Three"
                    FontSize="50" />
                <ListViewItem
                    AutomationProperties.Name="listViewItem4"
                    Content="Four"
                    FontSize="50" />
                <ListViewItem
                    AutomationProperties.Name="listViewItem5"
                    Content="Five"
                    FontSize="50" />
                <ListViewItem
                    AutomationProperties.Name="listViewItem6"
                    Content="Six"
                    FontSize="50" />
                <ListViewItem
                    AutomationProperties.Name="listViewItem7"
                    Content="Seven"
                    FontSize="50" />
                <ListViewItem
                    AutomationProperties.Name="listViewItem8"
                    Content="Eight"
                    FontSize="50" />
                <ListViewItem
                    AutomationProperties.Name="listViewItem9"
                    Content="Nine"
                    FontSize="50" />
                <ListViewItem
                    AutomationProperties.Name="listViewItem10"
                    Content="Ten"
                    FontSize="50" />
            </ListView>
        </mux:RefreshContainer>
    </Grid>
</Page>
