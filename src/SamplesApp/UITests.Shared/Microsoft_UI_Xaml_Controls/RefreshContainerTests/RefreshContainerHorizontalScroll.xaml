<Page x:Class="UITests.Microsoft_UI_Xaml_Controls.RefreshContainerTests.RefreshContainerHorizontalScroll"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Microsoft_UI_Xaml_Controls.RefreshContainerTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mux="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Grid Padding="20"
	    RowSpacing="8">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="300" />
			<RowDefinition Height="300" />
		</Grid.RowDefinitions>
		<StackPanel Orientation="Horizontal"
		    Spacing="8">
			<Button Click="RequestRefresh_Click">Request refresh</Button>
		</StackPanel>
		<mux:RefreshContainer x:Name="RefreshContainer"
		    Grid.Row="1"
		    Width="300"
		    HorizontalAlignment="Center"
		    VerticalAlignment="Center">
			<ScrollViewer Width="250"
			    HorizontalScrollBarVisibility="Auto"
			    HorizontalScrollMode="Enabled"
			    VerticalScrollMode="Disabled">
				<StackPanel Orientation="Horizontal">
					<Rectangle Width="300"
					    Height="100"
					    Fill="Red" />
					<Rectangle Width="100"
					    Height="100"
					    Fill="Orange" />
					<Rectangle Width="100"
					    Height="100"
					    Fill="Green" />
				</StackPanel>
			</ScrollViewer>
		</mux:RefreshContainer>
		<ListView Grid.Row="2"
		    MinHeight="150"
		    MaxHeight="160"
		    Padding="24,0"
		    IsItemClickEnabled="True"
		    SelectionMode="None">
			<ListView.ItemsPanel>
				<ItemsPanelTemplate>
					<ItemsStackPanel Orientation="Horizontal" />
				</ItemsPanelTemplate>
			</ListView.ItemsPanel>
			<ListViewItem AutomationProperties.Name="listViewItem1"
			    Content="One"
			    FontSize="50" />
			<ListViewItem AutomationProperties.Name="listViewItem2"
			    Content="Two"
			    FontSize="50" />
			<ListViewItem AutomationProperties.Name="listViewItem3"
			    Content="Three"
			    FontSize="50" />
			<ListViewItem AutomationProperties.Name="listViewItem4"
			    Content="Four"
			    FontSize="50" />
			<ListViewItem AutomationProperties.Name="listViewItem5"
			    Content="Five"
			    FontSize="50" />
			<ListViewItem AutomationProperties.Name="listViewItem6"
			    Content="Six"
			    FontSize="50" />
			<ListViewItem AutomationProperties.Name="listViewItem7"
			    Content="Seven"
			    FontSize="50" />
			<ListViewItem AutomationProperties.Name="listViewItem8"
			    Content="Eight"
			    FontSize="50" />
			<ListViewItem AutomationProperties.Name="listViewItem9"
			    Content="Nine"
			    FontSize="50" />
			<ListViewItem AutomationProperties.Name="listViewItem10"
			    Content="Ten"
			    FontSize="50" />
		</ListView>
	</Grid>
</Page>
