<local:TestPage
    x:Class="MUXControlsTestApp.HierarchicalNavigationViewMarkup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxcontrols="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid>
        <muxcontrols:NavigationView
            x:Name="navview"
            Collapsed="OnItemCollapsed"
            Expanding="OnItemExpanding"
            IsSettingsVisible="False"
            ItemInvoked="{x:Bind ClickedItem}"
            PaneDisplayMode="Left">
            <muxcontrols:NavigationView.MenuItems>
                <muxcontrols:NavigationViewItem
                    x:Name="MI1"
                    Content="Menu Item 1"
                    Icon="Home"
                    SelectsOnInvoked="False">
                    <muxcontrols:NavigationViewItem.MenuItems>
                        <muxcontrols:NavigationViewItem
                            x:Name="MI2"
                            Content="Menu Item 2"
                            Icon="Save"
                            SelectsOnInvoked="False">
                            <muxcontrols:NavigationViewItem.MenuItems>
                                <muxcontrols:NavigationViewItem
                                    x:Name="MI4"
                                    Content="Menu Item 4"
                                    Icon="Cut" />
                                <muxcontrols:NavigationViewItemSeparator />
                                <muxcontrols:NavigationViewItem
                                    x:Name="MI5"
                                    Content="Menu Item 5"
                                    Icon="Paste" />
                            </muxcontrols:NavigationViewItem.MenuItems>
                        </muxcontrols:NavigationViewItem>
                        <muxcontrols:NavigationViewItem
                            x:Name="MI3"
                            Content="Menu Item 3"
                            Icon="Save" />
                        <muxcontrols:NavigationViewItemHeader Content="HEADER 2" />
                        <muxcontrols:NavigationViewItem
                            x:Name="MIA"
                            Content="Menu Item A"
                            Icon="Cut" />
                        <muxcontrols:NavigationViewItemSeparator />
                        <muxcontrols:NavigationViewItem
                            x:Name="MIB"
                            Content="Menu Item B"
                            Icon="Paste" />
                    </muxcontrols:NavigationViewItem.MenuItems>
                </muxcontrols:NavigationViewItem>
                <muxcontrols:NavigationViewItemHeader Content="HEADER 1" />
                <muxcontrols:NavigationViewItem
                    x:Name="MI6"
                    Content="Menu Item 6 (Selectable)"
                    Icon="Cut"
                    SelectsOnInvoked="True">
                    <muxcontrols:NavigationViewItem.MenuItems>
                        <muxcontrols:NavigationViewItem
                            x:Name="MI7"
                            Content="Menu Item 7 (Selectable)"
                            SelectsOnInvoked="True">
                            <muxcontrols:NavigationViewItem.MenuItems>
                                <muxcontrols:NavigationViewItem x:Name="MI8" Content="Menu Item 8" />
                                <muxcontrols:NavigationViewItem x:Name="MI9" Content="Menu Item 9" />
                            </muxcontrols:NavigationViewItem.MenuItems>
                        </muxcontrols:NavigationViewItem>
                    </muxcontrols:NavigationViewItem.MenuItems>
                </muxcontrols:NavigationViewItem>
                <muxcontrols:NavigationViewItem
                    x:Name="MI10"
                    Content="Menu Item 10"
                    Icon="Save" />
                <muxcontrols:NavigationViewItem
                    x:Name="MI11"
                    Content="Menu Item 11"
                    Icon="Paste"
                    SelectsOnInvoked="False">
                    <muxcontrols:NavigationViewItem.MenuItems>
                        <muxcontrols:NavigationViewItem
                            x:Name="MI12"
                            Content="Menu Item 12"
                            Icon="Save"
                            SelectsOnInvoked="False">
                            <muxcontrols:NavigationViewItem.MenuItems>
                                <muxcontrols:NavigationViewItem
                                    x:Name="MI13"
                                    Content="Menu Item 13"
                                    Icon="Cut" />
                                <muxcontrols:NavigationViewItem
                                    x:Name="MI14"
                                    Content="Menu Item 14"
                                    Icon="Paste" />
                            </muxcontrols:NavigationViewItem.MenuItems>
                        </muxcontrols:NavigationViewItem>
                    </muxcontrols:NavigationViewItem.MenuItems>
                </muxcontrols:NavigationViewItem>
                <muxcontrols:NavigationViewItem
                    x:Name="MI15"
                    Content="Menu Item 15"
                    Icon="Shuffle"
                    SelectsOnInvoked="False">
                    <muxcontrols:NavigationViewItem.MenuItems>
                        <muxcontrols:NavigationViewItem
                            x:Name="MI16"
                            Content="Menu Item 16"
                            Icon="Save" />
                        <muxcontrols:NavigationViewItem
                            x:Name="MI17"
                            Content="Menu Item 17"
                            Icon="Cut" />
                        <muxcontrols:NavigationViewItem
                            x:Name="MI18"
                            Content="Menu Item 18"
                            Icon="Paste" />
                    </muxcontrols:NavigationViewItem.MenuItems>
                </muxcontrols:NavigationViewItem>
                <muxcontrols:NavigationViewItem
                    x:Name="MI19"
                    Content="Menu Item 19"
                    SelectsOnInvoked="True" />
                <muxcontrols:NavigationViewItem
                    x:Name="MI20"
                    Content="Menu Item 20"
                    SelectsOnInvoked="True" />
                <muxcontrols:NavigationViewItem
                    x:Name="MI21"
                    Content="Menu Item 21"
                    SelectsOnInvoked="True" />
                <muxcontrols:NavigationViewItem
                    x:Name="MI22"
                    Content="Menu Item 22"
                    SelectsOnInvoked="True" />
                <muxcontrols:NavigationViewItem
                    x:Name="MI23"
                    Content="Menu Item 23"
                    SelectsOnInvoked="True" />
                <muxcontrols:NavigationViewItem
                    x:Name="MI24"
                    Content="Menu Item 24"
                    SelectsOnInvoked="True" />
                <muxcontrols:NavigationViewItem
                    x:Name="MI25"
                    Content="Menu Item 25"
                    SelectsOnInvoked="True" />
                <muxcontrols:NavigationViewItem
                    x:Name="MI26"
                    Content="Menu Item 26"
                    SelectsOnInvoked="True" />
                <muxcontrols:NavigationViewItem
                    x:Name="MI27"
                    Content="Menu Item 27"
                    SelectsOnInvoked="True" />
                <muxcontrols:NavigationViewItem
                    x:Name="MI28"
                    Content="Menu Item 28"
                    SelectsOnInvoked="True" />
                <muxcontrols:NavigationViewItem
                    x:Name="MI29"
                    Content="Menu Item 29 (Selectable)"
                    SelectsOnInvoked="True">
                    <muxcontrols:NavigationViewItem.MenuItems>
                        <muxcontrols:NavigationViewItem
                            x:Name="MI30"
                            Content="Menu Item 30 (Selectable)"
                            Icon="Save">
                            <muxcontrols:NavigationViewItem.MenuItems>
                                <muxcontrols:NavigationViewItem
                                    x:Name="MI31"
                                    Content="Menu Item 31"
                                    Icon="Cut" />
                                <muxcontrols:NavigationViewItem
                                    x:Name="MI32"
                                    Content="Menu Item 32"
                                    Icon="Paste" />
                            </muxcontrols:NavigationViewItem.MenuItems>
                        </muxcontrols:NavigationViewItem>
                    </muxcontrols:NavigationViewItem.MenuItems>
                </muxcontrols:NavigationViewItem>

            </muxcontrols:NavigationView.MenuItems>
            <StackPanel Margin="10,10,0,0">
                <TextBlock
                    x:Name="SelectedItemLabel"
                    AutomationProperties.Name="SelectedItemLabel"
                    Text="uninitialized" />
                <Button
                    x:Name="GetSelectedItemLabelButton"
                    AutomationProperties.Name="GetSelectedItemLabelButton"
                    Click="PrintSelectedItem"
                    Content="Get Selected Item Label" />
                <Button Click="CollapseSelectedItem" Content="Collapse Selected Item" />
                <Button Click="RemoveSecondMenuItem" Content="Remove Second MenuItem" />
                <TextBlock
                    x:Name="IsChildSelectedLabel"
                    AutomationProperties.Name="IsChildSelectedLabel"
                    Text="uninitialized" />
                <Button
                    AutomationProperties.Name="PrintTopLevelIsChildSelectedItemsButton"
                    Click="PrintTopLevelIsChildSelectedItems"
                    Content="Print TopLevel IsChildSelected Items" />
                <Button Click="SelectSecondItem" Content="Select Second Item" />
                <!--  Components that get updated when item is expanded or collapsed  -->
                <StackPanel x:Name="ExpandCollapseRelatedComponents" Margin="0,10,0,10">
                    <Grid x:Name="ExpandingEventStates">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Margin="0,0,5,0"
                            VerticalAlignment="Center">
                            Last Expanding:
                        </TextBlock>
                        <TextBlock
                            x:Name="TextBlockExpandingItem"
                            Grid.Column="1"
                            Margin="0,0,10,0"
                            AutomationProperties.Name="TextBlockExpandingItem"
                            Text="N/A" />
                        <TextBlock
                            Grid.Column="2"
                            Margin="0,0,5,0"
                            VerticalAlignment="Center">
                            Expanding Item and Container match:
                        </TextBlock>
                        <TextBlock
                            x:Name="TextblockExpandingItemAndContainerMatch"
                            Grid.Column="3"
                            AutomationProperties.Name="TextblockExpandingItemAndContainerMatch"
                            Text="N/A" />
                    </Grid>
                    <Grid x:Name="CollapsedEventStates">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Margin="0,0,5,0"
                            VerticalAlignment="Center">
                            Last Collapsed:
                        </TextBlock>
                        <TextBlock
                            x:Name="TextBlockCollapsedItem"
                            Grid.Column="1"
                            Margin="0,0,10,0"
                            AutomationProperties.Name="TextBlockCollapsedItem"
                            Text="N/A" />
                        <TextBlock
                            Grid.Column="2"
                            Margin="0,0,5,0"
                            VerticalAlignment="Center">
                            Collapsed Item and Container match:
                        </TextBlock>
                        <TextBlock
                            x:Name="TextblockCollapsedItemAndContainerMatch"
                            Grid.Column="3"
                            AutomationProperties.Name="TextblockCollapsedItemAndContainerMatch"
                            Text="N/A" />
                    </Grid>
                </StackPanel>

                <!--  NavigationViewItem children flyout corner radius test components  -->
                <StackPanel Margin="0,10,0,10">
                    <StackPanel Orientation="Horizontal">
                        <Button
                            x:Name="GetMenuItem1ChildrenFlyoutCornerRadiusButton"
                            AutomationProperties.Name="GetMenuItem1ChildrenFlyoutCornerRadiusButton"
                            Click="GetMenuItem1ChildrenFlyoutCornerRadiusButton_Click"
                            Content="GetMenuItem1ChildrenFlyoutCornerRadius" />
                        <TextBlock
                            Margin="5"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            CornerRadius:
                        </TextBlock>
                        <TextBlock
                            x:Name="MenuItem1ChildrenFlyoutCornerRadiusTextBlock"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="MenuItem1ChildrenFlyoutCornerRadiusTextBlock">
                            -
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!--  Combobox used to switch pane display modes  -->
                <ComboBox
                    x:Name="PaneDisplayModeCombobox"
                    Margin="5"
                    AutomationProperties.Name="PaneDisplayModeCombobox"
                    Header="PaneDisplayMode"
                    SelectionChanged="PaneDisplayModeCombobox_SelectionChanged">
                    <ComboBoxItem Content="Auto" Tag="Auto" />
                    <ComboBoxItem Content="Left" Tag="Left" />
                    <ComboBoxItem Content="Top" Tag="Top" />
                    <ComboBoxItem Content="LeftCompact" Tag="LeftCompact" />
                    <ComboBoxItem Content="LeftMinimal" Tag="LeftMinimal" />
                </ComboBox>
            </StackPanel>
        </muxcontrols:NavigationView>

    </Grid>
</local:TestPage>
