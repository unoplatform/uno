<local:TestPage x:Class="MUXControlsTestApp.NavigationViewInitPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

	<Grid Background="Plum">
		<StackPanel>
			<controls:NavigationView x:Name="NavView"
			    AlwaysShowHeader="False"
			    AutomationProperties.AutomationId="NavView"
			    AutomationProperties.Name="NavView"
			    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
			    CompactModeThresholdWidth="480"
			    IsPaneToggleButtonVisible="False"
			    IsSettingsVisible="False"
			    ItemInvoked="NavView_ItemInvoked"
			    SelectionChanged="NavView_SelectionChanged">

				<StackPanel Margin="8,0,0,0"
				    Orientation="Vertical">
					<TextBlock Margin="0,8"
					    Text="This tests the initial state of the control, and the ItemsSource property." />
					<Button x:Name="AddItemButton"
					    AutomationProperties.Name="AddItemButton"
					    Click="AddButton_Click"
					    Content="Add Item" />
					<Button x:Name="RemoveItemButton"
					    AutomationProperties.Name="RemoveItemButton"
					    Click="RemoveButton_Click"
					    Content="Remove Item" />
					<Button x:Name="AddFooterItemButton"
					    AutomationProperties.Name="AddFooterItemButton"
					    Click="AddFooterButton_Click"
					    Content="Add Footer Item" />
					<Button x:Name="RemoveFooterItemButton"
					    AutomationProperties.Name="RemoveFooterItemButton"
					    Click="RemoveFooterButton_Click"
					    Content="Remove Footer Item" />
					<Button x:Name="ChangeToIEnumerableButton"
					    AutomationProperties.Name="ChangeToIEnumerableButton"
					    Click="ChangeToIEnumerableButton_Clicks"
					    Content="Make it IEnumerable" />
					<Button x:Name="FlipOrientation"
					    AutomationProperties.Name="FlipOrientationButton"
					    Click="FlipOrientation_Click"
					    Content="Flip Orientation" />

					<StackPanel>
						<Button x:Name="SwitchFrame"
						    AutomationProperties.Name="SwitchFrame"
						    Click="SwitchFrame_Click"
						    Content="SwitchFrame" />
						<TextBlock x:Name="MyLocationResult"
						    AutomationProperties.Name="MyLocationResult"
						    Text="Unknown" />

						<StackPanel Orientation="Horizontal">
							<Frame x:Name="Frame1"
							    Width="200"
							    Height="200">
								<controls:NavigationView x:Name="NavView2"
								    IsBackButtonVisible="Collapsed"
								    IsSettingsVisible="False"
								    ItemInvoked="NavView2_ItemInvoked"
								    PaneDisplayMode="Top">
									<controls:NavigationView.MenuItems>
										<controls:NavigationViewItem AutomationProperties.Name="MyLocation"
										    Content="MyLocation"
										    Icon="Accept" />
									</controls:NavigationView.MenuItems>
								</controls:NavigationView>
							</Frame>
							<Frame x:Name="Frame2"
							    Width="200"
							    Height="200" />
						</StackPanel>
					</StackPanel>

					<StackPanel Orientation="Vertical">
						<StackPanel Orientation="Horizontal">
							<TextBlock Margin="5"
							    HorizontalAlignment="Center"
							    VerticalAlignment="Center">
								ItemInvoked Arguments (InvokedItem | InvokedItemContainer):
							</TextBlock>
							<TextBox x:Name="ItemInvokedItemType"
							    Margin="42,0,0,0"
							    AutomationProperties.Name="ItemInvokedItemType"
							    Text="N/A" />
							<TextBox x:Name="ItemInvokedItemContainerType"
							    AutomationProperties.Name="ItemInvokedItemContainerType"
							    Text="N/A" />
						</StackPanel>
						<StackPanel Orientation="Horizontal">
							<TextBlock Margin="5"
							    HorizontalAlignment="Center"
							    VerticalAlignment="Center">
								SelectionChanged Arguments (SelectedItem | SelectedItemContainer):
							</TextBlock>
							<TextBox x:Name="SelectionChangedItemType"
							    AutomationProperties.Name="SelectionChangedItemType"
							    Text="N/A" />
							<TextBox x:Name="SelectionChangedItemContainerType"
							    AutomationProperties.Name="SelectionChangedItemContainerType"
							    Text="N/A" />
						</StackPanel>
					</StackPanel>
				</StackPanel>
			</controls:NavigationView>
			<controls:NavigationView x:Name="NavView3"
			    AutomationProperties.AutomationId="NavView3"
			    AutomationProperties.Name="NavView3">
				<controls:NavigationView.MenuItems>
					<controls:NavigationViewItem Content="Collection" />
					<controls:NavigationViewItem Content="Albums"
					    IsSelected="True" />
					<controls:NavigationViewItem Content="People"
					    IsSelected="True" />
				</controls:NavigationView.MenuItems>
			</controls:NavigationView>
			<controls:NavigationView x:Name="NavView4"
			    IsPaneVisible="False">
				<controls:NavigationView.MenuItems>
					<controls:NavigationViewItem AutomationProperties.Name="PaneIsVisibleItem"
					    Content="123" />
				</controls:NavigationView.MenuItems>
				<Button AutomationProperties.Name="ChangePaneVisible"
				    Click="ChangePaneVisibleButton_Click"
				    Content="Change IsPaneVisible Flag" />
			</controls:NavigationView>
		</StackPanel>
	</Grid>

</local:TestPage>
