<local:TestPage x:Class="MUXControlsTestApp.NavigationViewMinimalPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxcontrols="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">
	<!--  This page contains a NavigationView control that is in LeftMinimal mode on initial load  -->
	<StackPanel>
		<StackPanel Orientation="Horizontal">
			<muxcontrols:NavigationView x:Name="NavView"
			    Margin="10,0"
			    AutomationProperties.AutomationId="NavView"
			    AutomationProperties.Name="NavView"
			    Header="LeftMinimal"
			    IsBackEnabled="True"
			    PaneDisplayMode="LeftMinimal">
				<StackPanel>
					<TextBlock x:Name="NavViewActiveVisualStatesResult"
					    AutomationProperties.Name="NavViewActiveVisualStatesResult" />
					<Button x:Name="GetNavViewActiveVisualStates"
					    AutomationProperties.Name="GetNavViewActiveVisualStates"
					    Click="GetNavViewActiveVisualStates_Click"
					    Content="GetNavViewActiveVisualStates" />
				</StackPanel>
			</muxcontrols:NavigationView>
			<muxcontrols:NavigationView x:Name="NavViewLeftCompact"
			    AutomationProperties.AutomationId="NavViewLeftCompact"
			    AutomationProperties.Name="NavView"
			    Header="LeftCompact"
			    IsBackEnabled="True"
			    PaneDisplayMode="LeftCompact">
				<StackPanel />
			</muxcontrols:NavigationView>
			<muxcontrols:NavigationView x:Name="NavViewAuto"
			    Width="250"
			    Height="300"
			    AutomationProperties.AutomationId="NavView"
			    AutomationProperties.Name="NavView"
			    Header="Auto"
			    IsBackEnabled="True">
				<StackPanel />
			</muxcontrols:NavigationView>
		</StackPanel>
		<StackPanel>
			<CheckBox x:Name="IsLeftMinimalPaneOpenCheckBox"
			    AutomationProperties.Name="IsLeftMinimalPaneOpenCheckBox"
			    IsChecked="{Binding IsPaneOpen, ElementName=NavView, Mode=TwoWay}">
				Toggle LeftMinimal pane open
			</CheckBox>
			<CheckBox x:Name="IsLeftCompactPaneOpenCheckBox"
			    AutomationProperties.Name="IsLeftCompactPaneOpenCheckBox"
			    IsChecked="{Binding IsPaneOpen, ElementName=NavViewLeftCompact, Mode=TwoWay}">
				Toggle LeftCompact pane open
			</CheckBox>
			<CheckBox x:Name="IsAutoPaneOpenCheckBox"
			    AutomationProperties.Name="IsPaneOpenCheckBox"
			    IsChecked="{Binding IsPaneOpen, ElementName=NavViewAuto, Mode=TwoWay}">
				Toggle auto pane open
			</CheckBox>
		</StackPanel>
	</StackPanel>
</local:TestPage>
