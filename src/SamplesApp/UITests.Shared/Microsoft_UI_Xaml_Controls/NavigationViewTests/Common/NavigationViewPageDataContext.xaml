<local:TestPage x:Class="MUXControlsTestApp.NavigationViewPageDataContext"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxcontrols="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

	<StackPanel Orientation="Horizontal">

		<muxcontrols:NavigationView x:Name="NavView"
		    AutomationProperties.AutomationId="NavView"
		    AutomationProperties.Name="NavView"
		    PaneDisplayMode="Left"
		    SelectionChanged="NavView_SelectionChanged">
			<StackPanel>
				<StackPanel Margin="0,5"
				    Orientation="Horizontal">
					<TextBlock Margin="5"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Center">
						DataContext of SelectedItem:
					</TextBlock>
					<TextBlock x:Name="NavViewSelectedDataContext"
					    VerticalAlignment="Center"
					    AutomationProperties.Name="NavViewSelectedDataContext" />
				</StackPanel>
				<StackPanel Margin="0,5"
				    Orientation="Horizontal">
					<Button x:Name="GetNavViewActiveVisualStates"
					    AutomationProperties.Name="GetNavViewActiveVisualStates"
					    Click="GetNavViewActiveVisualStates_Click"
					    Content="GetNavViewActiveVisualStates" />
					<TextBlock Margin="5"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Center">
						NavView Active VisualStates:
					</TextBlock>
					<TextBlock x:Name="NavViewActiveVisualStatesResult"
					    VerticalAlignment="Center"
					    AutomationProperties.Name="NavViewActiveVisualStatesResult" />
				</StackPanel>
			</StackPanel>
		</muxcontrols:NavigationView>

		<muxcontrols:NavigationView Width="400"
		    ItemInvoked="NavigationView_ItemInvoked"
		    MenuItemsSource="{x:Bind Pages, Mode=OneWay}"
		    PaneDisplayMode="Left">
			<muxcontrols:NavigationView.MenuItemTemplate>
				<DataTemplate>
					<muxcontrols:NavigationViewItem AutomationProperties.Name="{Binding Name}"
					    Content="{Binding Name}" />
				</DataTemplate>
			</muxcontrols:NavigationView.MenuItemTemplate>

			<TextBlock Text="{Binding SelectedPage.Name}" />
		</muxcontrols:NavigationView>
	</StackPanel>

</local:TestPage>
