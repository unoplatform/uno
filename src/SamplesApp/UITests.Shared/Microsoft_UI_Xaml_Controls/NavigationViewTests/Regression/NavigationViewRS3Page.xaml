<local:TestPage x:Class="MUXControlsTestApp.NavigationViewRS3Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:media="using:Microsoft.UI.Xaml.Media"
    xmlns:muxcontrols="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">
	<Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
		<Grid.RowDefinitions>
			<RowDefinition x:Name="MainGridRow"
			    Height="*" />
		</Grid.RowDefinitions>
		<muxcontrols:NavigationView x:Name="NavView"
		    HorizontalAlignment="Left"
		    VerticalAlignment="Top"
		    AccessKey="H"
		    AutomationProperties.AutomationId="NavView"
		    AutomationProperties.Name="NavView"
		    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
		    ExpandedModeThresholdWidth="1"
		    Header="Home"
		    IsSettingsVisible="false"
		    PaneTitle="NavView theme resource test">
			<ScrollViewer Margin="8,0,0,0">
				<StackPanel>
					<CheckBox x:Name="IsPaneOpenCheckBox"
					    Margin="5"
					    AutomationProperties.Name="IsPaneOpenCheckBox"
					    Content="IsPaneOpen"
					    IsChecked="{Binding IsPaneOpen, ElementName=NavView, Mode=TwoWay}" />
					<CheckBox x:Name="TestFrameCheckbox"
					    Margin="5"
					    AutomationProperties.Name="TestFrameCheckbox"
					    Checked="TestFrameCheckbox_Checked"
					    Content="Show Test Frame"
					    IsChecked="False"
					    Unchecked="TestFrameCheckbox_Unchecked" />
					<Button x:Name="GetTopPaddingHeight"
					    AutomationProperties.Name="GetTopPaddingHeight"
					    Click="GetTopPaddingHeight_Click"
					    Content="GetTopPaddingHeight" />
					<Button x:Name="GetToggleButtonRowHeight"
					    AutomationProperties.Name="GetToggleButtonRowHeight"
					    Click="GetToggleButtonRowHeight_Click"
					    Content="GetToggleButtonRowHeight" />
					<TextBox x:Name="TestResult"
					    AutomationProperties.AutomationId="TestResult"
					    AutomationProperties.Name="TestResult"
					    IsReadOnly="True" />
				</StackPanel>
			</ScrollViewer>
		</muxcontrols:NavigationView>
	</Grid>
</local:TestPage>
