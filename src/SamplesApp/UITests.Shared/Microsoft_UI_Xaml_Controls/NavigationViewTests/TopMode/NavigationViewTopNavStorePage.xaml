<local:TestPage x:Class="MUXControlsTestApp.NavigationViewTopNavStorePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

	<Grid>
		<controls:NavigationView x:Name="NavView"
		    AlwaysShowHeader="False"
		    AutomationProperties.AutomationId="NavView"
		    AutomationProperties.Name="NavView"
		    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
		    CompactModeThresholdWidth="480"
		    IsBackButtonVisible="Visible"
		    IsPaneToggleButtonVisible="False"
		    IsSettingsVisible="False"
		    ItemInvoked="OnNavItemInvoked"
		    PaneDisplayMode="Top"
		    ShoulderNavigationEnabled="WhenSelectionFollowsFocus">

			<controls:NavigationView.PaneHeader>
				<CommandBar>
					<AppBarToggleButton Click="AppBarButton_Click"
					    Icon="Shuffle"
					    Label="Shuffle" />
					<CommandBar.SecondaryCommands>
						<AppBarButton Click="AppBarButton_Click"
						    Label="Like" />
					</CommandBar.SecondaryCommands>
				</CommandBar>
			</controls:NavigationView.PaneHeader>

			<controls:NavigationView.PaneCustomContent>
				<CommandBar>
					<AppBarToggleButton Click="AppBarButton_Click"
					    Icon="Like"
					    Label="Like" />
				</CommandBar>
			</controls:NavigationView.PaneCustomContent>

			<controls:NavigationView.PaneFooter>
				<CommandBar>
					<AppBarToggleButton Click="AppBarButton_Click"
					    Icon="Shuffle"
					    Label="Shuffle" />
					<AppBarToggleButton Click="AppBarButton_Click"
					    Icon="RepeatAll"
					    Label="Repeat" />
					<AppBarSeparator />
					<AppBarButton Click="AppBarButton_Click"
					    Icon="Play"
					    Label="Play" />

					<CommandBar.SecondaryCommands>
						<AppBarButton Click="AppBarButton_Click"
						    Label="Like" />
						<AppBarButton Click="AppBarButton_Click"
						    Label="Dislike" />
					</CommandBar.SecondaryCommands>
				</CommandBar>
			</controls:NavigationView.PaneFooter>

			<controls:NavigationView.AutoSuggestBox>
				<AutoSuggestBox AutomationProperties.Name="PaneAutoSuggestBox"
				    QueryIcon="Find" />
			</controls:NavigationView.AutoSuggestBox>

			<StackPanel Background="BurlyWood">
				<ScrollViewer x:Name="ContentScrollViewer"
				    VerticalAlignment="Top">
					<StackPanel x:Name="ContentStackPanel"
					    Orientation="Vertical">
						<StackPanel Orientation="Horizontal">
							<Button x:Name="MoveContentUnderTopnav"
							    Margin="1"
							    AutomationProperties.Name="MoveContentUnderTopnavButton"
							    Click="MoveContentUnderTopnav_Click"
							    Content="Move/Remove content under Top nav + Scrollviewer checkup" />
							<Button x:Name="MoveContentUnderTopnavTitleBar"
							    Margin="1"
							    AutomationProperties.Name="MoveContentUnderTopnavTitleBarButton"
							    Click="MoveContentUnderTopnavTitleBar_Click"
							    Content="Move/Remove content under Top nav + Scrollviewer checkup + Titlebar take over" />
							<Button x:Name="GetTopPaddingHeightButton"
							    Margin="1"
							    AutomationProperties.Name="GetTopPaddingHeightButton"
							    Click="GetTopPaddingHeightButton_Click"
							    Content="Get top padding height" />
						</StackPanel>
						<StackPanel Orientation="Horizontal">
							<Button x:Name="AddItemButton"
							    Margin="1"
							    AutomationProperties.Name="AddItemButton"
							    Click="AddButton_Click"
							    Content="Add Item" />
							<Button x:Name="AddItemSuppressSelectionButton"
							    Margin="1"
							    AutomationProperties.Name="AddItemSuppressSelectionButton"
							    Click="AddButtonSuppressSelection_Click"
							    Content="Add Item with SupppressSelection" />
							<Button x:Name="RemoveItemButton"
							    Margin="1"
							    AutomationProperties.Name="RemoveItemButton"
							    Click="RemoveButton_Click"
							    Content="Remove Item" />
							<Button x:Name="ChangeToIEnumerableButton"
							    Margin="1"
							    AutomationProperties.Name="ChangeToIEnumerableButton"
							    Click="ChangeToIEnumerableButton_Clicks"
							    Content="Make it IEnumerable" />
							<Button x:Name="FlipIsTitleBarAutoPaddingEnabledButton"
							    Margin="1"
							    AutomationProperties.Name="FlipIsTitleBarAutoPaddingEnabledButton"
							    Click="FlipIsTitleBarAutoPaddingEnabledButton_Click"
							    Content="Flip IsTitleBarAutoPaddingEnabled" />
						</StackPanel>
						<StackPanel Orientation="Horizontal">
							<Button x:Name="FlipOrientation"
							    Margin="1"
							    AutomationProperties.Name="FlipOrientationButton"
							    Click="FlipOrientation_Click"
							    Content="Flip Orientation" />
							<Button x:Name="AddRemoveContentOverlay"
							    Margin="1"
							    AutomationProperties.Name="AddRemoveContentOverlayButton"
							    Click="AddRemoveContentOverlay_Click"
							    Content="Add/Remove Content Overlay (top nav)" />
							<Button x:Name="ChangeContentOverlayVisibility"
							    Margin="1"
							    AutomationProperties.Name="ChangeContentOverlayVisibilityButton"
							    Click="ChangeContentOverlayVisibility_Click"
							    Content="Change Content Overlay Visibility (top nav)" />
							<Button x:Name="ChangeTopNavVisibility"
							    Margin="1"
							    AutomationProperties.Name="ChangeTopNavVisibilityButton"
							    Click="ChangeTopNavVisibility_Click"
							    Content="Change Top Nav Visibility" />
							<Button x:Name="ChangeSelectionInCode"
							    Margin="1"
							    AutomationProperties.Name="ChangeSelectionInCodeButton"
							    Click="ChangeSelectionInCode_Click"
							    Content="Change Selection In Code" />
						</StackPanel>
						<StackPanel Orientation="Horizontal">
							<Button x:Name="EnableSelectionFollowsFocusButton"
							    Margin="1"
							    AutomationProperties.Name="EnableSelectionFollowsFocusButton"
							    Click="EnableSelectionFollowsFocus_Click"
							    Content="Enable Selection Follows Focus" />
							<Button x:Name="GetActiveVisualState"
							    Margin="1"
							    AutomationProperties.Name="GetActiveVisualState"
							    Click="GetActiveVisualState_Click"
							    Content="Get Active VisualState" />
							<Button x:Name="GetNavItemActiveVisualState"
							    Margin="1"
							    AutomationProperties.Name="GetNavItemActiveVisualState"
							    Click="GetNavItemActiveNavItemVisualState_Click"
							    Content="Get Selected NavItem Active VisualState" />
							<Button x:Name="ClearItemInvokedTextButton"
							    Margin="1"
							    AutomationProperties.Name="ClearItemInvokedTextButton"
							    Click="ClearItemInvokedTextButton_Click"
							    Content="Clear Item Invoked Text" />
						</StackPanel>
					</StackPanel>
				</ScrollViewer>
				<TextBlock Text="Active NavigationItem Visual States: " />
				<TextBlock x:Name="ActiveVisualStates"
				    AutomationProperties.Name="ActiveVisualStates" />
				<TextBlock x:Name="NavItemActiveVisualStates"
				    AutomationProperties.Name="NavItemActiveVisualStates" />
				<TextBlock Text="NavView.IsTitleBarAutoPaddingEnabled: " />
				<TextBlock x:Name="NavViewIsTitleBarAutoPaddingEnabled" />
				<TextBlock Text="Top padding Height: " />
				<TextBlock x:Name="TopPaddingRenderedValue" />
				<TextBlock Text="TitleBar.IsVisible: " />
				<TextBlock x:Name="TitleBarIsVisible" />
				<TextBlock Text="Item invoked: " />
				<TextBlock x:Name="ItemInvokedText" />
			</StackPanel>
		</controls:NavigationView>
	</Grid>
</local:TestPage>
