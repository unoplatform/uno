<Page
    x:Class="UITests.Microsoft_UI_Xaml_Controls.NavigationViewTests.NavigationViewBasicPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Microsoft_UI_Xaml_Controls.NavigationViewTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mux="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid>
        <mux:NavigationView x:Name="NavigationViewControl">
            <mux:NavigationView.MenuItems>
                <mux:NavigationViewItem
                    x:Name="A"
                    Content="A"
                    IsSelected="True" />
                <mux:NavigationViewItem x:Name="B" Content="B" />
                <mux:NavigationViewItem x:Name="C" Content="C" />
            </mux:NavigationView.MenuItems>
        </mux:NavigationView>
    </Grid>
</Page>
