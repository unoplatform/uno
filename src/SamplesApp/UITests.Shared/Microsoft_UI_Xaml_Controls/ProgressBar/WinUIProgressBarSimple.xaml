<Page x:Class="UITests.Microsoft_UI_Xaml_Controls.ProgressBar.WinUIProgressBarSimple"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:progressBar="using:UITests.Microsoft_UI_Xaml_Controls.ProgressBar"
    xmlns:winui="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Page.Resources>
		<progressBar:DoubleToThicknessConverter x:Key="doubleToThickness" />
	</Page.Resources>

	<Grid Margin="15"
	    ColumnSpacing="10"
	    RowSpacing="10">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="Auto"
			    MinWidth="46" />
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"
			    MinHeight="120" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<TextBlock Grid.Row="0"
		    Grid.Column="0"
		    FontSize="15"
		    FontWeight="Bold">
			Control--&gt;
		</TextBlock>
		<winui:ProgressBar x:Name="progressBar"
		    Grid.Row="0"
		    Grid.Column="1"
		    MinHeight="{Binding Value, ElementName=minHeight}"
		    Padding="{Binding Value, ElementName=padding, Converter={StaticResource doubleToThickness}}"
		    IsIndeterminate="{Binding IsChecked, ElementName=isIndeterminate}"
		    ShowError="{Binding IsChecked, ElementName=showError}"
		    ShowPaused="{Binding IsChecked, ElementName=showPaused}"
		    Value="{Binding Value, ElementName=slider}" />

		<TextBlock Grid.Row="1"
		    Grid.Column="0"
		    FontSize="15">
			Value:
		</TextBlock>
		<Slider x:Name="slider"
		    Grid.Row="1"
		    Grid.Column="1"
		    Maximum="110"
		    Minimum="-10" />
		<TextBlock Grid.Row="1"
		    Grid.Column="2"
		    FontSize="25"
		    Text="{Binding Value, ElementName=slider}" />

		<TextBlock Grid.Row="2"
		    Grid.Column="0"
		    FontSize="15">
			Padding:
		</TextBlock>
		<Slider x:Name="padding"
		    Grid.Row="2"
		    Grid.Column="1"
		    Maximum="60"
		    Minimum="-10"
		    StepFrequency="0.5" />
		<TextBlock Grid.Row="2"
		    Grid.Column="2"
		    FontSize="25"
		    Text="{Binding Value, ElementName=padding}" />

		<TextBlock Grid.Row="3"
		    Grid.Column="0"
		    FontSize="15">
			MinHeight:
		</TextBlock>
		<Slider x:Name="minHeight"
		    Grid.Row="3"
		    Grid.Column="1"
		    Maximum="60"
		    Minimum="0"
		    StepFrequency="0.5"
		    Value="4" />
		<TextBlock Grid.Row="3"
		    Grid.Column="2"
		    FontSize="25"
		    Text="{Binding Value, ElementName=minHeight}" />

		<StackPanel Grid.Row="4"
		    Grid.Column="1"
		    Orientation="Horizontal"
		    Spacing="10">
			<ToggleButton x:Name="isIndeterminate">IsIndeterminate</ToggleButton>
			<ToggleButton x:Name="showError">ShowError</ToggleButton>
			<ToggleButton x:Name="showPaused">ShowPaused</ToggleButton>
		</StackPanel>

		<TextBlock Grid.Row="5"
		    Grid.Column="0"
		    FontSize="15">
			States:
		</TextBlock>

		<ScrollViewer Grid.Row="5"
		    Grid.Column="1">
			<TextBlock x:Name="states"
			    FontFamily="Monospace"
			    FontSize="9" />
		</ScrollViewer>

	</Grid>
</Page>
