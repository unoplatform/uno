<Page
    x:Class="UITests.Microsoft_UI_Xaml_Controls.ParallaxViewTests.ParallaxViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Microsoft_UI_Xaml_Controls.ParallaxViewTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxcontrols="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

    <ScrollViewer Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <StackPanel Margin="20">
            <!--  Header  -->
            <TextBlock
                Margin="4,4,4,12"
                FontSize="18"
                FontWeight="SemiBold"
                Text="ParallaxView samples" />

            <!--  Horizontal parallaxing with ScrollViewer source  -->
            <TextBlock Margin="4" Text="Horizontal parallaxing - a Rectangle parallaxed based on another Rectangle in a ScrollViewer." />
            <StackPanel Orientation="Horizontal">
                <ScrollViewer
                    x:Name="sv"
                    Width="500"
                    Height="300"
                    Margin="4"
                    Background="Cyan"
                    HorizontalScrollBarVisibility="Visible"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Visible"
                    VerticalScrollMode="Enabled"
                    ZoomMode="Disabled">
                    <Rectangle
                        x:Name="rectSVContent"
                        Width="1000"
                        Height="900">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0.0" Color="Blue" />
                                <GradientStop Offset="0.5" Color="Yellow" />
                                <GradientStop Offset="1.0" Color="Red" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </ScrollViewer>

                <Border Margin="4" Background="Cyan">
                    <muxcontrols:ParallaxView
                        x:Name="parallaxView1"
                        Width="300"
                        Height="300"
                        AutomationProperties.Name="parallaxView1"
                        HorizontalShift="200"
                        MaxHorizontalShiftRatio="0.25"
                        Source="{x:Bind sv}">
                        <Rectangle
                            x:Name="rectParallax1"
                            Width="500"
                            Height="300">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0.0" Color="Brown" />
                                    <GradientStop Offset="1.0" Color="Orange" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </muxcontrols:ParallaxView>
                </Border>

                <Border Margin="4" Background="Cyan">
                    <muxcontrols:ParallaxView
                        x:Name="parallaxView2"
                        Width="300"
                        Height="300"
                        AutomationProperties.Name="parallaxView2"
                        HorizontalShift="100"
                        HorizontalSourceEndOffset="500"
                        HorizontalSourceOffsetKind="Absolute"
                        HorizontalSourceStartOffset="0"
                        Source="{x:Bind sv}">
                        <Rectangle
                            x:Name="rectParallax2"
                            Width="500"
                            Height="300">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0.0" Color="Blue" />
                                    <GradientStop Offset="0.5" Color="White" />
                                    <GradientStop Offset="1.0" Color="Red" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </muxcontrols:ParallaxView>
                </Border>
            </StackPanel>

            <!--  Vertical parallaxing inside a ScrollViewer  -->
            <TextBlock Margin="4,24,4,4" Text="Vertical parallaxing - a ParallaxView used as a header inside a ScrollViewer." />
            <ScrollViewer
                x:Name="svHeader"
                Width="400"
                Height="400"
                Margin="4"
                HorizontalAlignment="Left"
                Background="LightGray"
                HorizontalScrollMode="Disabled"
                VerticalScrollBarVisibility="Visible"
                VerticalScrollMode="Enabled">
                <StackPanel>
                    <muxcontrols:ParallaxView
                        x:Name="parallaxViewHeader"
                        Width="400"
                        Height="200"
                        AutomationProperties.Name="parallaxViewHeader"
                        IsVerticalShiftClamped="True"
                        Source="{x:Bind svHeader}"
                        VerticalShift="150"
                        VerticalSourceOffsetKind="Relative">
                        <Rectangle
                            x:Name="rectHeader"
                            Width="400"
                            Height="350">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0.0" Color="DarkBlue" />
                                    <GradientStop Offset="0.5" Color="Purple" />
                                    <GradientStop Offset="1.0" Color="Pink" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </muxcontrols:ParallaxView>

                    <TextBlock
                        Margin="20"
                        FontSize="14"
                        Text="Scroll vertically to see the ParallaxView above parallax its child rectangle. Items below are regular content so you have something to scroll." />

                    <StackPanel x:Name="itemsStack">
                        <!--  filled from code-behind  -->
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!--  Actions  -->
            <TextBlock Margin="4,24,4,4" Text="Actions" />
            <StackPanel Orientation="Horizontal">
                <Button
                    x:Name="btnClearParallaxViewChild"
                    Margin="4"
                    AutomationProperties.Name="ClearParallaxViewChild"
                    Click="btnClearParallaxViewChild_Click"
                    Content="Clear parallaxView1.Child" />
                <Button
                    x:Name="btnSetParallaxViewChild"
                    Margin="4"
                    AutomationProperties.Name="SetParallaxViewChild"
                    Click="btnSetParallaxViewChild_Click"
                    Content="Restore parallaxView1.Child" />
                <Button
                    x:Name="btnRefreshOffsets"
                    Margin="4"
                    AutomationProperties.Name="RefreshOffsets"
                    Click="btnRefreshOffsets_Click"
                    Content="RefreshAutomaticOffsets" />
                <TextBlock
                    x:Name="tbStatus"
                    Margin="4"
                    VerticalAlignment="Center"
                    AutomationProperties.AutomationId="tbStatus"
                    Text="" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
