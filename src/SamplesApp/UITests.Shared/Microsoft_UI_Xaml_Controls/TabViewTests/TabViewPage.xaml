<local:TestPage x:Class="MUXControlsTestApp.TabViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="TabViewTestPage"
    mc:Ignorable="d">

	<Grid x:Name="BackgroundGrid"
	    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<ScrollViewer>
				<StackPanel Width="250"
				    Padding="12">
					<TextBlock Style="{ThemeResource StandardGroupHeader}"
					    Text="Options" />
					<CheckBox x:Name="IsClosableCheckBox"
					    AutomationProperties.Name="IsClosableCheckBox"
					    Checked="IsClosableCheckBox_CheckChanged"
					    Content="IsClosable on first tab"
					    IsChecked="True"
					    Unchecked="IsClosableCheckBox_CheckChanged" />
					<CheckBox x:Name="HandleTabCloseRequestedCheckBox"
					    AutomationProperties.Name="HandleTabCloseRequestedCheckBox"
					    Content="Handle TabView tab close"
					    IsChecked="True" />
					<CheckBox x:Name="HandleTabItemCloseRequestedCheckBox"
					    AutomationProperties.Name="HandleTabItemCloseRequestedCheckBox"
					    Content="Handle TabViewItem close" />
					<CheckBox x:Name="IsAddButtonVisibleCheckBox"
					    AutomationProperties.Name="IsAddButtonVisibleCheckBox"
					    Content="Add button visible"
					    IsChecked="{x:Bind Tabs.IsAddTabButtonVisible, Mode=TwoWay}" />
					<CheckBox x:Name="IsDisabledTabVisibleCheckBox"
					    AutomationProperties.Name="IsDisabledTabVisibleCheckBox"
					    Checked="IsDisabledTabVisibleCheckBox_CheckChanged"
					    Content="Disabled tab visible"
					    IsChecked="True"
					    Unchecked="IsDisabledTabVisibleCheckBox_CheckChanged" />
					<StackPanel Margin="0,0,0,8"
					    Orientation="Horizontal">
						<TextBlock VerticalAlignment="Center">Tab Width:</TextBlock>
						<ComboBox x:Name="TabWidthComboBox"
						    Margin="4,0,0,0"
						    AutomationProperties.Name="TabWidthComboBox"
						    SelectedIndex="0"
						    SelectionChanged="TabWidthComboBox_SelectionChanged">
							<ComboBoxItem Content="Equal" />
							<ComboBoxItem Content="SizeToContent" />
							<ComboBoxItem Content="Compact" />
						</ComboBox>
					</StackPanel>
					<TextBlock Text="Closebutton overlay mode:" />
					<ComboBox x:Name="CloseButtonOverlayModeCombobox"
					    Margin="0,4,0,0"
					    AutomationProperties.Name="CloseButtonOverlayModeCombobox"
					    SelectedIndex="2"
					    SelectionChanged="CloseButtonOverlayModeCombobox_SelectionChanged">
						<ComboBoxItem Content="Auto" />
						<ComboBoxItem Content="OnPointerOver" />
						<ComboBoxItem Content="Always" />
					</ComboBox>

					<Border Height="3"
					    Margin="0,8,0,8"
					    HorizontalAlignment="Stretch"
					    Background="{ThemeResource SystemChromeGrayColor}" />

					<TextBlock Style="{ThemeResource StandardGroupHeader}"
					    Text="Actions" />
					<Button x:Name="RemoveTabButton"
					    Margin="0,0,0,8"
					    AutomationProperties.Name="RemoveTabButton"
					    Click="RemoveTabButton_Click"
					    Content="Remove Tab" />
					<Button x:Name="SelectItemButton"
					    Margin="0,0,0,8"
					    AutomationProperties.Name="SelectItemButton"
					    Click="SelectItemButton_Click"
					    Content="Select Item 1" />
					<Button x:Name="SelectIndexButton"
					    Margin="0,0,0,8"
					    AutomationProperties.Name="SelectIndexButton"
					    Click="SelectIndexButton_Click"
					    Content="Select Index 2" />
					<Button x:Name="ChangeShopTextButton"
					    Margin="0,0,0,8"
					    AutomationProperties.Name="ChangeShopTextButton"
					    Click="ChangeShopTextButton_Click"
					    Content="Change Shop text" />
					<Button x:Name="CustomTooltipButton"
					    Margin="0,0,0,8"
					    AutomationProperties.Name="CustomTooltipButton"
					    Click="CustomTooltipButton_Click"
					    Content="Custom Tooltip" />
					<Button x:Name="SetTabViewWidth"
					    Margin="0,0,0,8"
					    AutomationProperties.Name="SetTabViewWidth"
					    Click="SetTabViewWidth_Click"
					    Content="Set Width" />
					<Button x:Name="ScrollTabViewToTheLeft"
					    Margin="0,0,0,8"
					    AutomationProperties.Name="ScrollTabViewToTheLeft"
					    Click="TabViewScrollToTheLeftButton_Click"
					    Content="Scroll TabView To the Left" />
					<Button x:Name="ScrollTabViewToTheMiddle"
					    Margin="0,0,0,8"
					    AutomationProperties.Name="ScrollTabViewToTheMiddle"
					    Click="TabViewScrollToTheMiddleButton_Click"
					    Content="Scroll TabView To the Middle" />
					<Button x:Name="ScrollTabViewToTheRight"
					    Margin="0,0,0,8"
					    AutomationProperties.Name="ScrollTabViewToTheRight"
					    Click="TabViewScrollToTheRightButton_Click"
					    Content="Scroll TabView To the Right" />

					<Button x:Name="ShortLongTextButton"
					    Margin="0,0,0,8"
					    AutomationProperties.Name="ShortLongTextButton"
					    Click="ShortLongTextButton_Click"
					    Content="Short/Long Text" />
					<Button x:Name="HomeTabOverlapCheck"
					    Margin="0,0,0,8"
					    AutomationProperties.Name="HomeTabOverlapCheck"
					    Click="HomeTabOverlapCheck_Click"
					    Content="Set HomeTabOverlapCheck" />
					<Button x:Name="SetActiveTabTransparent"
					    Margin="0,0,0,8"
					    AutomationProperties.Name="SetActiveTabTransparent"
					    Click="SetActiveTabTransparent_Click"
					    Content="Set ActiveTab Transparent" />
					<Button x:Name="SetActiveContentTransparent"
					    Margin="0,0,0,8"
					    AutomationProperties.Name="SetActiveContentTransparent"
					    Click="SetActiveContentTransparent_Click"
					    Content="Set ActiveContent Transparent" />
					<Button x:Name="ClearOverlapCheck"
					    Margin="0,0,0,8"
					    AutomationProperties.Name="ClearOverlapCheck"
					    Click="ClearOverlapCheck_Click"
					    Content="Clear OverlapCheck" />

					<StackPanel Orientation="Horizontal">
						<Button Click="SetColorsButton_Click"
						    Content="Set Colors" />
						<Button Click="ClearColorsButton_Click"
						    Content="Clear Colors" />
					</StackPanel>

					<Border Height="3"
					    Margin="0,8,0,8"
					    HorizontalAlignment="Stretch"
					    Background="{ThemeResource SystemChromeGrayColor}" />

					<TextBlock Style="{ThemeResource StandardGroupHeader}"
					    Text="Results" />
					<StackPanel Margin="0,0,0,8"
					    Orientation="Horizontal">
						<TextBlock Margin="0,0,4,0"
						    VerticalAlignment="Center"
						    Text="Scroll buttons visible:" />
						<TextBlock x:Name="ScrollButtonsVisible"
						    VerticalAlignment="Center"
						    AutomationProperties.Name="ScrollButtonsVisible"
						    Text="False" />
						<Button x:Name="GetScrollButtonsVisible"
						    Margin="4,0,0,0"
						    AutomationProperties.Name="GetScrollButtonsVisible"
						    Click="GetScrollButtonsVisible_Click"
						    Content="Get" />
					</StackPanel>

					<StackPanel Margin="0,0,0,8"
					    Orientation="Horizontal">
						<TextBlock Margin="0,0,4,0"
						    VerticalAlignment="Center"
						    Text="DecreaseButton enabled:" />
						<TextBlock x:Name="ScrollDecreaseButtonEnabled"
						    VerticalAlignment="Center"
						    AutomationProperties.Name="ScrollDecreaseButtonEnabled"
						    Text="False" />
						<Button x:Name="GetScrollDecreaseButtonEnabled"
						    Margin="4,0,0,0"
						    AutomationProperties.Name="GetScrollDecreaseButtonEnabled"
						    Click="GetScrollDecreaseButtonEnabled_Click"
						    Content="Get" />
					</StackPanel>

					<StackPanel Margin="0,0,0,8"
					    Orientation="Horizontal">
						<TextBlock Margin="0,0,4,0"
						    VerticalAlignment="Center"
						    Text="IncreaseButton enabled:" />
						<TextBlock x:Name="ScrollIncreaseButtonEnabled"
						    VerticalAlignment="Center"
						    AutomationProperties.Name="ScrollIncreaseButtonEnabled"
						    Text="False" />
						<Button x:Name="GetScrollIncreaseButtonEnabled"
						    Margin="4,0,0,0"
						    AutomationProperties.Name="GetScrollIncreaseButtonEnabled"
						    Click="GetScrollIncreaseButtonEnabled_Click"
						    Content="Get" />
					</StackPanel>

					<StackPanel Margin="0,0,0,8"
					    Orientation="Horizontal">
						<TextBlock>Selected Index:</TextBlock>
						<TextBlock x:Name="SelectedIndexTextBlock"
						    Margin="4,0,0,0"
						    AutomationProperties.Name="SelectedIndexTextBlock"
						    Text="0" />
					</StackPanel>

					<StackPanel Margin="0,0,0,8"
					    Orientation="Horizontal">
						<TextBlock>Tab dropped out:</TextBlock>
						<TextBlock x:Name="TabDroppedOutsideTextBlock"
						    Margin="4,0,0,0"
						    AutomationProperties.Name="TabDroppedOutsideTextBlock"
						    Text="" />
					</StackPanel>

					<StackPanel Margin="0,0,0,8"
					    Orientation="Horizontal">
						<Button x:Name="GetTab0ToolTipButton"
						    AutomationProperties.Name="GetTab0ToolTipButton"
						    Click="GetTab0ToolTipButton_Click"
						    Content="Tooltip0" />
						<TextBlock x:Name="Tab0ToolTipTextBlock"
						    Margin="4,0,0,0"
						    AutomationProperties.Name="Tab0ToolTipTextBlock"
						    Text="" />
					</StackPanel>

					<StackPanel Margin="0,0,0,8"
					    Orientation="Horizontal">
						<Button x:Name="GetTab1ToolTipButton"
						    AutomationProperties.Name="GetTab1ToolTipButton"
						    Click="GetTab1ToolTipButton_Click"
						    Content="Tooltip1" />
						<TextBlock x:Name="Tab1ToolTipTextBlock"
						    Margin="4,0,0,0"
						    AutomationProperties.Name="Tab1ToolTipTextBlock"
						    Text="" />
					</StackPanel>

					<StackPanel Margin="0,0,0,8"
					    Orientation="Horizontal">
						<Button x:Name="GetFirstTabLocationButton"
						    AutomationProperties.Name="GetFirstTabLocationButton"
						    Click="GetFirstTabLocationButton_Click"
						    Content="FirstTab" />
						<TextBlock x:Name="FirstTabLocationTextBlock"
						    Margin="4,0,0,0"
						    AutomationProperties.Name="FirstTabLocationTextBlock"
						    Text="" />
					</StackPanel>

					<StackPanel Margin="0,0,0,8"
					    Orientation="Horizontal">
						<Button x:Name="GetScrollDecreaseButtonToolTipButton"
						    AutomationProperties.Name="GetScrollDecreaseButtonToolTipButton"
						    Click="GetScrollDecreaseButtonToolTipButton_Click"
						    Content="TooltipScrollDecreaseButton" />
						<TextBlock x:Name="ScrollDecreaseButtonToolTipTextBlock"
						    Margin="4,0,0,0"
						    AutomationProperties.Name="ScrollDecreaseButtonToolTipTextBlock"
						    Text="" />
					</StackPanel>

					<StackPanel Margin="0,0,0,8"
					    Orientation="Horizontal">
						<Button x:Name="GetScrollIncreaseButtonToolTipButton"
						    AutomationProperties.Name="GetScrollIncreaseButtonToolTipButton"
						    Click="GetScrollIncreaseButtonToolTipButton_Click"
						    Content="TooltipScrollIncreaseButton" />
						<TextBlock x:Name="ScrollIncreaseButtonToolTipTextBlock"
						    Margin="4,0,0,0"
						    AutomationProperties.Name="ScrollIncreaseButtonToolTipTextBlock"
						    Text="" />
					</StackPanel>

					<StackPanel Margin="0,0,0,8"
					    Orientation="Horizontal">
						<TextBlock x:Name="TabsItemChangedEventArgsTextBlock"
						    Margin="4,0,0,0"
						    AutomationProperties.Name="TabsItemChangedEventArgsTextBlock"
						    Text="" />
						<TextBlock x:Name="TabsItemChangedEventArgsIndexTextBlock"
						    Margin="4,0,0,0"
						    AutomationProperties.Name="TabsItemChangedEventArgsIndexTextBlock"
						    Text="" />
					</StackPanel>
				</StackPanel>
			</ScrollViewer>

			<Grid Grid.Column="1">
				<Grid.RowDefinitions>
					<RowDefinition Height="*" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>

				<controls:TabView x:Name="Tabs"
				    AddTabButtonClick="AddButtonClick"
				    CanDragTabs="True"
				    CanTearOutTabs="True"
				    SelectionChanged="TabViewSelectionChanged"
				    TabCloseRequested="TabViewTabCloseRequested"
				    TabDragStarting="OnTabDragStarting"
				    TabDroppedOutside="TabViewTabDroppedOutside"
				    TabStripDragOver="OnTabStripDragOver"
				    TabStripDrop="OnTabStripDrop"
				    TabWidthMode="Equal">

					<controls:TabView.Resources>
						<ResourceDictionary>
							<SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected"
							    Color="AliceBlue" />
						</ResourceDictionary>
					</controls:TabView.Resources>

					<controls:TabView.TabStripFooter>
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0"
							    Margin="6,3,6,0"
							    VerticalAlignment="Center"
							    FontSize="14"
							    Text="Middle" />
							<TextBlock Grid.Column="2"
							    Margin="6,3,6,0"
							    VerticalAlignment="Center"
							    FontSize="14"
							    Text="Right" />
						</Grid>
					</controls:TabView.TabStripFooter>

					<controls:TabViewItem x:Name="FirstTab"
					    AutomationProperties.Name="FirstTab"
					    CloseRequested="FirstTab_CloseRequested"
					    Header="Home"
					    ToolTipService.ToolTip="Custom Tooltip">
						<controls:TabViewItem.IconSource>
							<controls:SymbolIconSource Symbol="Home" />
						</controls:TabViewItem.IconSource>

						<StackPanel x:Name="FirstTabContent"
						    AutomationProperties.Name="FirstTabContent"
						    Background="{ThemeResource TabViewItemHeaderBackgroundSelected}">
							<Button x:Name="FirstTabButton"
							    Margin="8"
							    AutomationProperties.Name="FirstTabButton"
							    FontSize="20">
								Home Button
							</Button>
							<StackPanel>
								<Button x:Name="TabViewSizingPageButton"
								    Margin="4"
								    AutomationProperties.Name="TabViewSizingPageButton"
								    Click="TabViewSizingPageButton_Click"
								    FontSize="20">
									TabView Sizing Page
								</Button>
								<Button x:Name="TabViewTabClosingBehaviorButton"
								    Margin="4"
								    AutomationProperties.Name="TabViewTabClosingBehaviorButton"
								    Click="TabViewTabClosingBehaviorButton_Click"
								    FontSize="20">
									TabView Tab Closing behavior Page
								</Button>
								<Button x:Name="TabViewTabItemsSourcePageButton"
								    Margin="4"
								    AutomationProperties.Name="TabViewTabItemsSourcePageButton"
								    Click="TabViewTabItemsSourcePageButton_Click"
								    FontSize="20">
									TabView TabItemsSource Page
								</Button>
							</StackPanel>
						</StackPanel>
					</controls:TabViewItem>

					<controls:TabViewItem x:Name="SecondTab"
					    Header="SecondTab"
					    IsClosable="True">
						<controls:TabViewItem.IconSource>
							<controls:SymbolIconSource Symbol="Shop" />
						</controls:TabViewItem.IconSource>

						<StackPanel Padding="16"
						    Background="{ThemeResource TabViewItemHeaderBackgroundSelected}">
							<TextBlock>Shop text</TextBlock>
							<Button AutomationProperties.Name="SecondTabButton"
							    Content="SecondTabButton" />
							<controls:ProgressRing IsActive="True" />
						</StackPanel>
					</controls:TabViewItem>

					<controls:TabViewItem x:Name="LongHeaderTab"
					    AutomationProperties.Name="LongHeaderTab"
					    Header="Long Header No Icon">
						<StackPanel Padding="16"
						    Background="{ThemeResource TabViewItemHeaderBackgroundSelected}">
							<TextBlock>Emoji text</TextBlock>
							<Button Content="Button 3" />
							<controls:ProgressRing IsActive="True" />
						</StackPanel>
					</controls:TabViewItem>

					<controls:TabViewItem x:Name="NotCloseableTab"
					    AutomationProperties.Name="NotCloseableTab"
					    Header="Video"
					    IsClosable="False">
						<controls:TabViewItem.IconSource>
							<controls:SymbolIconSource Symbol="Video" />
						</controls:TabViewItem.IconSource>

						<StackPanel Background="{ThemeResource TabViewItemHeaderBackgroundSelected}">
							<TextBlock Padding="16">This tab can't be closed.</TextBlock>
						</StackPanel>
					</controls:TabViewItem>

					<controls:TabViewItem x:Name="DisabledTab"
					    AutomationProperties.Name="DisabledTab"
					    Header="Disabled"
					    IsEnabled="False">
						<controls:TabViewItem.IconSource>
							<controls:SymbolIconSource Symbol="Admin" />
						</controls:TabViewItem.IconSource>

						<StackPanel Background="{ThemeResource TabViewItemHeaderBackgroundSelected}">
							<TextBlock Padding="16">This tab can't be selected.</TextBlock>
						</StackPanel>
					</controls:TabViewItem>

					<controls:TabViewItem x:Name="LastTab"
					    AutomationProperties.Name="LastTab"
					    Header="Contact">
						<controls:TabViewItem.IconSource>
							<controls:SymbolIconSource Symbol="Contact" />
						</controls:TabViewItem.IconSource>

						<StackPanel Background="{ThemeResource TabViewItemHeaderBackgroundSelected}">
							<TextBlock x:Name="LastTabContent"
							    Padding="16"
							    AutomationProperties.Name="LastTabContent">
								Contact text
							</TextBlock>
						</StackPanel>
					</controls:TabViewItem>

				</controls:TabView>

				<Grid Grid.Row="1">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="3" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>

					<controls:TabView x:Name="DataBindingTabView"
					    Background="#66336699"
					    IsAddTabButtonVisible="false"
					    SelectedIndex="2">
						<controls:TabView.Resources>
							<ResourceDictionary>
								<StaticResource x:Key="TabViewItemHeaderBackgroundSelected"
								    ResourceKey="SystemAccentColor" />
							</ResourceDictionary>
						</controls:TabView.Resources>

						<controls:TabView.TabItemTemplate>
							<DataTemplate x:DataType="local:TabDataItem">
								<controls:TabViewItem Content="{x:Bind Content}"
								    Header="{x:Bind Header}"
								    IconSource="{x:Bind IconSource}">
									<controls:TabViewItem.ContentTemplate>
										<DataTemplate>
											<Grid Margin="16">
												<TextBlock Foreground="Purple"
												    Text="{Binding}" />
											</Grid>
										</DataTemplate>
									</controls:TabViewItem.ContentTemplate>
								</controls:TabViewItem>
							</DataTemplate>
						</controls:TabView.TabItemTemplate>
					</controls:TabView>

					<Border Grid.Column="1"
					    Background="Gray" />

					<controls:TabView x:Name="SecondTabView"
					    Grid.Column="2"
					    CanDragTabs="True"
					    IsAddTabButtonVisible="false"
					    TabDragStarting="OnTabDragStarting"
					    TabStripDragOver="OnTabStripDragOver"
					    TabStripDrop="OnTabStripDrop">

						<controls:TabView.TabItems>

							<controls:TabViewItem x:Name="TabInSecondTabView"
							    AutomationProperties.Name="TabInSecondTabView"
							    Header="Hello">
								<controls:TabViewItem.IconSource>
									<controls:SymbolIconSource Symbol="Placeholder" />
								</controls:TabViewItem.IconSource>

								<TextBlock Padding="16"
								    Text="Content" />
							</controls:TabViewItem>

						</controls:TabView.TabItems>
					</controls:TabView>
				</Grid>

			</Grid>
		</Grid>
	</Grid>
</local:TestPage>
