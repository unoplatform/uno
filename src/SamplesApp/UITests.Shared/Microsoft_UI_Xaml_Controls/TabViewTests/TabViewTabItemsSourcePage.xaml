<Page
    x:Class="UITests.Microsoft_UI_Xaml_Controls.TabViewTests.TabViewTabItemsSourcePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Microsoft_UI_Xaml_Controls.TabViewTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <controls:TabView
            x:Name="TabViewItemsSourceSample"
            MinHeight="200"
            Margin="5"
            AddTabButtonClick="TabViewItemsSourceSample_AddTabButtonClick"
            SelectedIndex="0"
            TabCloseRequested="TabViewItemsSourceSample_TabCloseRequested"
            TabItemsSource="{x:Bind myDatas, Mode=OneWay}">
            <controls:TabView.TabItemTemplate>
                <DataTemplate x:DataType="local:MyData">
                    <controls:TabViewItem
                        Content="{x:Bind DataContent}"
                        Header="{x:Bind DataHeader}"
                        IconSource="{x:Bind DataIconSource}" />
                </DataTemplate>
            </controls:TabView.TabItemTemplate>
        </controls:TabView>
        <StackPanel Grid.Row="1" Margin="5">
            <CheckBox
                x:Name="chkCanDragItems"
                Checked="ChkCanDragItems_Checked"
                Content="ListView.CanDragItems?"
                IsChecked="False"
                Unchecked="ChkCanDragItems_Unchecked" />
            <CheckBox
                x:Name="chkCanReorderItems"
                Checked="ChkCanReorderItems_Checked"
                Content="ListView.CanReorderItems?"
                IsChecked="True"
                Unchecked="ChkCanReorderItems_Unchecked" />
            <CheckBox
                x:Name="chkCanDrag"
                Checked="ChkCanDrag_Checked"
                Content="ListView.CanDrag?"
                IsChecked="False"
                Unchecked="ChkCanDrag_Unchecked" />
            <CheckBox
                x:Name="chkAllowDrop"
                Checked="ChkAllowDrop_Checked"
                Content="ListView.AllowDrop?"
                IsChecked="True"
                Unchecked="ChkAllowDrop_Unchecked" />
            <StackPanel Orientation="Horizontal">
                <TextBlock Margin="2" Text="Last TabItemsChanged Info - " />
                <TextBlock Margin="2" Text="CollectionChange:" />
                <TextBlock
                    x:Name="tblIVectorChangedEventArgsCollectionChange"
                    Margin="2"
                    AutomationProperties.Name="tblIVectorChangedEventArgsCollectionChange"
                    Text="-" />
                <TextBlock Margin="2" Text=", Index:" />
                <TextBlock
                    x:Name="tblIVectorChangedEventArgsIndex"
                    Margin="2"
                    AutomationProperties.Name="tblIVectorChangedEventArgsIndex"
                    Text="-" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
