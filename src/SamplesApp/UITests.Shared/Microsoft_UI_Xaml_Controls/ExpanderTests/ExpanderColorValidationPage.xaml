<utilities:MUXTestPage x:Class="UITests.Shared.Microsoft_UI_Xaml_Controls.ExpanderTests.ExpanderColorValidationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Microsoft_UI_Xaml_Controls.ExpanderTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utilities="using:MUXControlsTestApp.Utilities"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Grid>
		<Grid.Resources>
			<SolidColorBrush x:Key="ExpanderContentBackground"
			    Color="#7FFF0000" />
			<SolidColorBrush x:Key="ExpanderHeaderBackground"
			    Color="#0000FF" />
		</Grid.Resources>
		<controls:Expander x:Name="ExpanderWithColor"
		    Width="{ThemeResource FlyoutThemeMaxWidth}"
		    Margin="12"
		    AutomationProperties.AutomationId="ColorfulExpander"
		    AutomationProperties.Name="ColorfulExpander"
		    IsExpanded="True">
			<controls:Expander.Header>
				<TextBlock Margin="0,12,0,13"
				    Text="This expander is color coded to detect when clipping fails"
				    TextWrapping="Wrap" />
			</controls:Expander.Header>
			<TextBlock AutomationProperties.AutomationId="ColorfulExpanderContent">Content</TextBlock>
		</controls:Expander>
	</Grid>
</utilities:MUXTestPage>
