<Page x:Class="UITests.Microsoft_UI_Xaml_Controls.ItemsViewTests.ItemsViewSummaryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataModel="using:MUXControlsTestApp.Samples.Model"
    xmlns:local="using:UITests.Microsoft_UI_Xaml_Controls.ItemsViewTests"
    xmlns:localUtilities="using:MUXControlsTestApp.Utilities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Page.Resources>
		<DataTemplate x:Key="recipeTemplate1"
		    x:DataType="dataModel:Recipe">
			<ItemContainer Height="96"
			    MinWidth="72"
			    Background="Gray">
				<Grid x:Name="itemPanel">
					<Image x:Name="image"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Center"
					    Stretch="UniformToFill">
						<Image.Source>
							<BitmapImage DecodePixelHeight="96"
							    UriSource="{Binding ImageUri}" />
						</Image.Source>
					</Image>
					<TextBlock MaxWidth="68"
					    MaxHeight="48"
					    Margin="4"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Bottom"
					    FontSize="14"
					    Foreground="Yellow"
					    Text="{Binding Id}"
					    TextWrapping="Wrap" />
				</Grid>
			</ItemContainer>
		</DataTemplate>

		<DataTemplate x:Key="recipeTemplate2"
		    x:DataType="dataModel:Recipe">
			<ItemContainer MinWidth="40"
			    MinHeight="40"
			    Background="Gray">
				<Image x:Name="image"
				    HorizontalAlignment="Center"
				    VerticalAlignment="Center"
				    Stretch="UniformToFill">
					<Image.Source>
						<BitmapImage DecodePixelHeight="40"
						    UriSource="{Binding ImageUri}" />
					</Image.Source>
				</Image>
			</ItemContainer>
		</DataTemplate>

		<DataTemplate x:Key="recipeTemplate3"
		    x:DataType="dataModel:Recipe">
			<ItemContainer MinHeight="120"
			    Background="Gray">
				<Image x:Name="image"
				    HorizontalAlignment="Center"
				    VerticalAlignment="Center"
				    Stretch="UniformToFill">
					<Image.Source>
						<BitmapImage UriSource="{Binding ImageUri}" />
					</Image.Source>
				</Image>
			</ItemContainer>
		</DataTemplate>

		<DataTemplate x:Key="recipeTemplate4"
		    x:DataType="dataModel:Recipe">
			<ItemContainer Height="120"
			    MinWidth="40"
			    Background="Gray">
				<Image x:Name="image"
				    Stretch="UniformToFill">
					<Image.Source>
						<BitmapImage DecodePixelHeight="120"
						    UriSource="{Binding ImageUri}" />
					</Image.Source>
				</Image>
			</ItemContainer>
		</DataTemplate>

		<DataTemplate x:Key="recipeTemplate5"
		    x:DataType="dataModel:Recipe">
			<ItemContainer Width="100"
			    Height="100">
				<Image x:Name="image"
				    Stretch="UniformToFill">
					<Image.Source>
						<BitmapImage DecodePixelHeight="100"
						    UriSource="{Binding ImageUri}" />
					</Image.Source>
				</Image>
			</ItemContainer>
		</DataTemplate>

		<DataTemplate x:Key="recipeTemplate6"
		    x:DataType="dataModel:Recipe">
			<ItemContainer>
				<Grid MinWidth="96"
				    MinHeight="96">
					<Rectangle Fill="DarkGray" />
					<TextBlock MaxWidth="72"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Bottom"
					    FontSize="16"
					    Foreground="White"
					    Text="{Binding Id}"
					    TextWrapping="Wrap" />
				</Grid>
			</ItemContainer>
		</DataTemplate>

		<DataTemplate x:Key="recipeTemplate7"
		    x:DataType="dataModel:Recipe">
			<ItemContainer>
				<Grid MinWidth="126"
				    MinHeight="96">
					<Rectangle Fill="DarkGray" />
					<TextBlock MaxWidth="72"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Bottom"
					    FontSize="16"
					    Foreground="White"
					    Text="{Binding Id}"
					    TextWrapping="Wrap" />
				</Grid>
			</ItemContainer>
		</DataTemplate>

		<DataTemplate x:Key="recipeTemplate8"
		    x:DataType="dataModel:Recipe">
			<Image x:Name="image"
			    MinWidth="40"
			    MinHeight="40"
			    HorizontalAlignment="Center"
			    VerticalAlignment="Center"
			    Stretch="UniformToFill">
				<Image.Source>
					<BitmapImage DecodePixelHeight="40"
					    UriSource="{Binding ImageUri}" />
				</Image.Source>
			</Image>
		</DataTemplate>

		<DataTemplate x:Key="recipeTemplate9"
		    x:DataType="dataModel:Recipe">
			<Image x:Name="image"
			    Height="120"
			    MinWidth="40"
			    HorizontalAlignment="Center"
			    VerticalAlignment="Center"
			    Stretch="UniformToFill">
				<Image.Source>
					<BitmapImage DecodePixelHeight="120"
					    UriSource="{Binding ImageUri}" />
				</Image.Source>
			</Image>
		</DataTemplate>

		<DataTemplate x:Key="recipeTemplate10"
		    x:DataType="dataModel:Recipe">
			<Image x:Name="image"
			    Width="100"
			    Height="100"
			    HorizontalAlignment="Center"
			    VerticalAlignment="Center"
			    Stretch="UniformToFill">
				<Image.Source>
					<BitmapImage DecodePixelHeight="100"
					    UriSource="{Binding ImageUri}" />
				</Image.Source>
			</Image>
		</DataTemplate>

		<DataTemplate x:Key="recipeTemplate11"
		    x:DataType="dataModel:Recipe">
			<Grid CornerRadius="4">
				<Rectangle MinWidth="96"
				    MinHeight="96"
				    Fill="DarkGray" />
				<TextBlock MaxWidth="72"
				    HorizontalAlignment="Center"
				    VerticalAlignment="Bottom"
				    FontSize="16"
				    Foreground="White"
				    Text="{Binding Id}"
				    TextWrapping="Wrap" />
			</Grid>
		</DataTemplate>

		<DataTemplate x:Key="recipeTemplate12"
		    x:DataType="dataModel:Recipe">
			<Grid MinWidth="126"
			    MinHeight="96"
			    CornerRadius="4">
				<Rectangle Fill="DarkGray" />
				<TextBlock MaxWidth="72"
				    HorizontalAlignment="Center"
				    VerticalAlignment="Bottom"
				    FontSize="16"
				    Foreground="White"
				    Text="{Binding Id}"
				    TextWrapping="Wrap" />
			</Grid>
		</DataTemplate>

		<DataTemplate x:Key="recipeTemplate13"
		    x:DataType="dataModel:Recipe">
			<localUtilities:LoggingContentControl UseSystemFocusVisuals="True">
				<StackPanel x:Name="itemPanel">
					<Image x:Name="image"
					    Width="32"
					    Height="32">
						<Image.Source>
							<BitmapImage DecodePixelHeight="32"
							    UriSource="{Binding ImageUri}" />
						</Image.Source>
					</Image>
					<TextBlock MaxWidth="48"
					    MaxHeight="48"
					    Margin="2"
					    FontSize="8"
					    Foreground="Yellow"
					    Text="{Binding Description}"
					    TextWrapping="Wrap" />
				</StackPanel>
			</localUtilities:LoggingContentControl>
		</DataTemplate>

		<DataTemplate x:Key="recipeTemplate14"
		    x:DataType="dataModel:Recipe">
			<localUtilities:LoggingContentControl UseSystemFocusVisuals="True">
				<StackPanel x:Name="itemPanel">
					<Image x:Name="image"
					    Width="100"
					    Height="100">
						<Image.Source>
							<BitmapImage DecodePixelHeight="100"
							    UriSource="{Binding ImageUri}" />
						</Image.Source>
					</Image>
					<TextBlock MaxWidth="200"
					    Margin="2"
					    FontSize="12"
					    Foreground="Yellow"
					    Text="{Binding Description}"
					    TextWrapping="Wrap" />
				</StackPanel>
			</localUtilities:LoggingContentControl>
		</DataTemplate>

		<DataTemplate x:Key="recipeTemplate15"
		    x:DataType="dataModel:Recipe">
			<localUtilities:LoggingContentControl UseSystemFocusVisuals="True">
				<StackPanel x:Name="itemPanel">
					<Image x:Name="image"
					    Width="192"
					    Height="192">
						<Image.Source>
							<BitmapImage DecodePixelHeight="192"
							    UriSource="{Binding ImageUri}" />
						</Image.Source>
					</Image>
					<TextBlock MaxWidth="384"
					    Margin="2"
					    FontSize="16"
					    Foreground="Yellow"
					    Text="{Binding Description}"
					    TextWrapping="Wrap" />
				</StackPanel>
			</localUtilities:LoggingContentControl>
		</DataTemplate>

		<DataTemplate x:Key="recipeTemplate16"
		    x:DataType="dataModel:Recipe">
			<localUtilities:LoggingContentControl MinWidth="32"
			    UseSystemFocusVisuals="True">
				<Border Margin="4"
				    Background="Red"
				    CornerRadius="4">
					<Image x:Name="image"
					    Height="92"
					    Stretch="Uniform">
						<Image.Source>
							<BitmapImage DecodePixelHeight="92"
							    UriSource="{Binding ImageUri}" />
						</Image.Source>
					</Image>
				</Border>
			</localUtilities:LoggingContentControl>
		</DataTemplate>

		<DataTemplate x:Key="recipeTemplate17"
		    x:DataType="dataModel:Recipe">
			<localUtilities:LoggingContentControl MinWidth="32"
			    UseSystemFocusVisuals="True">
				<Grid MinWidth="96"
				    MinHeight="96"
				    CornerRadius="4">
					<Rectangle Fill="DarkGray" />
					<TextBlock MaxWidth="72"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Bottom"
					    FontSize="16"
					    Foreground="White"
					    Text="{Binding Id}"
					    TextWrapping="Wrap" />
				</Grid>
			</localUtilities:LoggingContentControl>
		</DataTemplate>

		<StackLayout x:Key="stackLayout"
		    Orientation="Vertical"
		    Spacing="10" />

		<FlowLayout x:Key="flowLayout"
		    MinColumnSpacing="10"
		    MinRowSpacing="10"
		    Orientation="Vertical" />

		<UniformGridLayout x:Key="uniformGridLayout"
		    MaximumRowsOrColumns="4"
		    MinColumnSpacing="10"
		    MinItemHeight="150"
		    MinItemWidth="100"
		    MinRowSpacing="10" />

		<LinedFlowLayout x:Key="linedFlowLayout" />
	</Page.Resources>

	<Grid x:Name="root"
	    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
	    ColumnDefinitions="Auto, Auto, Auto, Auto, *, Auto, Auto"
	    RowDefinitions="Auto, *, Auto">

		<StackPanel Grid.ColumnSpan="7"
		    Orientation="Horizontal">
			<CheckBox x:Name="chkItemsViewProperties"
			    Margin="2,0,0,0"
			    Checked="ChkItemsViewProperties_Checked"
			    Content="ItemsView Properties"
			    IsChecked="True"
			    IsThreeState="False"
			    Unchecked="ChkItemsViewProperties_Unchecked" />
			<CheckBox x:Name="chkChildrenProperties"
			    Margin="2,0,0,0"
			    Checked="ChkChildrenProperties_Checked"
			    Content="Children Properties"
			    IsChecked="True"
			    IsThreeState="False"
			    Unchecked="ChkChildrenProperties_Unchecked" />
			<CheckBox x:Name="chkItemsViewMethods"
			    Margin="2,0,0,0"
			    Checked="ChkItemsViewMethods_Checked"
			    Content="ItemsView Methods"
			    IsChecked="True"
			    IsThreeState="False"
			    Unchecked="ChkItemsViewMethods_Unchecked" />
			<CheckBox x:Name="chkLogs"
			    Margin="2,0,0,0"
			    Checked="ChkLogs_Checked"
			    Content="Logs"
			    IsChecked="True"
			    IsThreeState="False"
			    Unchecked="ChkLogs_Unchecked" />
			<CheckBox x:Name="chkPageMethods"
			    Margin="2,0,0,0"
			    Checked="ChkPageMethods_Checked"
			    Content="Page Methods"
			    IsChecked="False"
			    IsThreeState="False"
			    Unchecked="ChkPageMethods_Unchecked" />
			<CheckBox x:Name="chkItemsViewDataSource"
			    Margin="2,0,0,0"
			    Checked="ChkItemsViewDataSource_Checked"
			    Content="ItemsView Data Source"
			    IsChecked="True"
			    IsThreeState="False"
			    Unchecked="ChkItemsViewDataSource_Unchecked" />
		</StackPanel>

		<ItemsView x:Name="markupItemsView"
		    Grid.Row="1"
		    Width="500"
		    Height="800"
		    Margin="1"
		    VerticalAlignment="Top"
		    AutomationProperties.Name="markupItemsView">
			<ItemsView.ItemTransitionProvider>
				<LinedFlowLayoutItemCollectionTransitionProvider />
			</ItemsView.ItemTransitionProvider>
		</ItemsView>

		<Canvas x:Name="canvasLinedFlowLayoutLockedItems"
		    Grid.Row="1"
		    Width="500"
		    Height="800"
		    Margin="1"
		    VerticalAlignment="Top"
		    Visibility="Collapsed" />

		<Border x:Name="bdrCurrentElement"
		    Grid.Row="1"
		    HorizontalAlignment="Left"
		    VerticalAlignment="Top"
		    BorderBrush="Red"
		    BorderThickness="2"
		    CornerRadius="4"
		    Visibility="Collapsed" />

		<Rectangle x:Name="rectVerticalKeyboardNavigationReferenceOffset"
		    Grid.Row="1"
		    Width="4"
		    Height="800"
		    HorizontalAlignment="Left"
		    VerticalAlignment="Top"
		    Fill="Red"
		    Visibility="Collapsed" />
		<Rectangle x:Name="rectHorizontalKeyboardNavigationReferenceOffset"
		    Grid.Row="1"
		    Width="500"
		    Height="4"
		    HorizontalAlignment="Left"
		    VerticalAlignment="Top"
		    Fill="Red"
		    Visibility="Collapsed" />

		<ScrollViewer x:Name="svItemsViewProperties"
		    Grid.Row="1"
		    Grid.Column="1">
			<Grid Margin="4,0,4,0"
			    Padding="6"
			    Background="{ThemeResource SystemListLowColor}"
			    BorderBrush="{ThemeResource SystemChromeGrayColor}"
			    BorderThickness="1"
			    ColumnDefinitions="Auto, Auto, Auto, Auto, Auto"
			    RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto"
			    Tag="SUT">

				<TextBlock Grid.ColumnSpan="5"
				    Foreground="Red"
				    Text="ItemsView Properties" />
				<TextBlock Grid.Row="1"
				    Grid.ColumnSpan="5"
				    Foreground="DarkOrange"
				    Text="Specific" />

				<TextBlock Grid.Row="2"
				    VerticalAlignment="Center"
				    Text="ItemTemplate:" />
				<ComboBox x:Name="cmbItemTemplate"
				    Grid.Row="2"
				    Grid.Column="1"
				    Grid.ColumnSpan="4"
				    Width="240"
				    Margin="1"
				    HorizontalAlignment="Left"
				    VerticalAlignment="Center"
				    SelectedIndex="0"
				    SelectionChanged="CmbItemTemplate_SelectionChanged">
					<ComboBoxItem>null</ComboBoxItem>
					<ComboBoxItem>Fixed-Height ItemContainer          (Image + TextBlock)</ComboBoxItem>
					<ComboBoxItem>ItemContainer                       (Image)</ComboBoxItem>
					<ComboBoxItem>ItemContainer without MinWidth      (Image)</ComboBoxItem>
					<ComboBoxItem>Fixed-Height ItemContainer          (Image)</ComboBoxItem>
					<ComboBoxItem>Square ItemContainer                (Image)</ComboBoxItem>
					<ComboBoxItem>Lightweight Square ItemContainer    (Rectangle + TextBlock)</ComboBoxItem>
					<ComboBoxItem>Lightweight Rectangle ItemContainer (Rectangle + TextBlock)</ComboBoxItem>
					<ComboBoxItem>Image                               (Image)</ComboBoxItem>
					<ComboBoxItem>Fixed-Height Image                  (Image)</ComboBoxItem>
					<ComboBoxItem>Square Image                        (Image)</ComboBoxItem>
					<ComboBoxItem>Lightweight Square                  (Rectangle + TextBlock)</ComboBoxItem>
					<ComboBoxItem>Lightweight Rectangle               (Rectangle + TextBlock)</ComboBoxItem>
					<ComboBoxItem>LoggingContentControl               (Small)</ComboBoxItem>
					<ComboBoxItem>LoggingContentControl               (Medium)</ComboBoxItem>
					<ComboBoxItem>LoggingContentControl               (Large)</ComboBoxItem>
					<ComboBoxItem>LoggingContentControl               (Image)</ComboBoxItem>
					<ComboBoxItem>LoggingContentControl               (Rectangle + TextBlock)</ComboBoxItem>
				</ComboBox>

				<TextBlock Grid.Row="3"
				    VerticalAlignment="Center"
				    Text="ItemsSource:" />
				<ComboBox x:Name="cmbItemsSource"
				    Grid.Row="3"
				    Grid.Column="1"
				    Grid.ColumnSpan="4"
				    Width="240"
				    Margin="1"
				    HorizontalAlignment="Left"
				    VerticalAlignment="Center"
				    SelectedIndex="0"
				    SelectionChanged="CmbItemsSource_SelectionChanged">
					<ComboBoxItem>null</ComboBoxItem>
					<ComboBoxItem>List&lt;Recipe&gt;</ComboBoxItem>
					<ComboBoxItem>Small ObservableCollection&lt;Recipe&gt;</ComboBoxItem>
					<ComboBoxItem>Small Uniform ObservableCollection&lt;Recipe&gt;</ComboBoxItem>
					<ComboBoxItem>ObservableCollection&lt;Recipe&gt;</ComboBoxItem>
					<ComboBoxItem>Small ObservableCollection&lt;ItemContainer&gt;</ComboBoxItem>
					<ComboBoxItem>Small ObservableCollection&lt;Image&gt;</ComboBoxItem>
				</ComboBox>

				<TextBlock Grid.Row="4"
				    VerticalAlignment="Center"
				    Text="Layout:" />
				<ComboBox x:Name="cmbLayout"
				    Grid.Row="4"
				    Grid.Column="1"
				    Grid.ColumnSpan="4"
				    Width="240"
				    Margin="1"
				    HorizontalAlignment="Left"
				    VerticalAlignment="Center"
				    SelectionChanged="CmbLayout_SelectionChanged">
					<ComboBoxItem>null</ComboBoxItem>
					<ComboBoxItem>FlowLayout</ComboBoxItem>
					<ComboBoxItem>LinedFlowLayout</ComboBoxItem>
					<ComboBoxItem>StackLayout</ComboBoxItem>
					<ComboBoxItem>UniformGridLayout</ComboBoxItem>
				</ComboBox>

				<TextBlock Grid.Row="5"
				    VerticalAlignment="Center"
				    Text="SelectionMode:" />
				<ComboBox x:Name="cmbSelectionMode"
				    Grid.Row="5"
				    Grid.Column="1"
				    Grid.ColumnSpan="4"
				    Width="240"
				    Margin="1"
				    HorizontalAlignment="Left"
				    VerticalAlignment="Center"
				    SelectionChanged="CmbSelectionMode_SelectionChanged">
					<ComboBoxItem>None</ComboBoxItem>
					<ComboBoxItem>Single</ComboBoxItem>
					<ComboBoxItem>Multiple</ComboBoxItem>
					<ComboBoxItem>Extended</ComboBoxItem>
				</ComboBox>

				<TextBlock Grid.Row="6"
				    VerticalAlignment="Center"
				    Text="CurrentItemIndex:" />
				<TextBox x:Name="txtCurrentItemIndex"
				    Grid.Row="6"
				    Grid.Column="1"
				    Grid.ColumnSpan="3"
				    HorizontalAlignment="Stretch"
				    VerticalAlignment="Center"
				    IsReadOnly="True" />
				<Button x:Name="btnGetCurrentItemIndex"
				    Grid.Row="6"
				    Grid.Column="4"
				    Margin="1"
				    VerticalAlignment="Center"
				    Click="BtnGetCurrentItemIndex_Click"
				    Content="G" />

				<TextBlock Grid.Row="7"
				    VerticalAlignment="Center"
				    Text="IsItemInvokedEnabled:" />
				<CheckBox x:Name="chkIsItemInvokedEnabled"
				    Grid.Row="7"
				    Grid.Column="1"
				    Grid.ColumnSpan="4"
				    Margin="2,0,0,0"
				    HorizontalAlignment="Left"
				    VerticalAlignment="Center"
				    Checked="ChkIsItemInvokedEnabled_Checked"
				    Content="IsItemInvokedEnabled"
				    IsChecked="False"
				    IsThreeState="False"
				    Unchecked="ChkIsItemInvokedEnabled_Unchecked" />

				<TextBlock Grid.Row="8"
				    Grid.ColumnSpan="5"
				    Foreground="DarkOrange"
				    Text="Inherited" />

				<TextBlock Grid.Row="9"
				    VerticalAlignment="Center"
				    Text="Background:" />
				<ComboBox x:Name="cmbBackground"
				    Grid.Row="9"
				    Grid.Column="1"
				    Margin="1"
				    HorizontalAlignment="Stretch"
				    VerticalAlignment="Center"
				    SelectionChanged="CmbBackground_SelectionChanged">
					<ComboBoxItem>null</ComboBoxItem>
					<ComboBoxItem>Transparent</ComboBoxItem>
					<ComboBoxItem>AliceBlue</ComboBoxItem>
					<ComboBoxItem>Aqua</ComboBoxItem>
				</ComboBox>

				<TextBlock Grid.Row="10"
				    VerticalAlignment="Center"
				    Text="BorderBrush:" />
				<ComboBox x:Name="cmbBorderBrush"
				    Grid.Row="10"
				    Grid.Column="1"
				    Margin="1"
				    HorizontalAlignment="Stretch"
				    VerticalAlignment="Center"
				    SelectionChanged="CmbBorderBrush_SelectionChanged">
					<ComboBoxItem>null</ComboBoxItem>
					<ComboBoxItem>Transparent</ComboBoxItem>
					<ComboBoxItem>Blue</ComboBoxItem>
					<ComboBoxItem>Green</ComboBoxItem>
				</ComboBox>

				<TextBlock Grid.Row="11"
				    VerticalAlignment="Center"
				    Text="BorderThickness:" />
				<TextBox x:Name="txtBorderThickness"
				    Grid.Row="11"
				    Grid.Column="1"
				    HorizontalAlignment="Stretch"
				    VerticalAlignment="Center" />
				<Button x:Name="btnGetBorderThickness"
				    Grid.Row="11"
				    Grid.Column="2"
				    Margin="1"
				    VerticalAlignment="Center"
				    Click="BtnGetBorderThickness_Click"
				    Content="G" />
				<Button x:Name="btnSetBorderThickness"
				    Grid.Row="11"
				    Grid.Column="3"
				    Margin="1"
				    VerticalAlignment="Center"
				    Click="BtnSetBorderThickness_Click"
				    Content="S" />

				<TextBlock Grid.Row="12"
				    VerticalAlignment="Center"
				    Text="Margin:" />
				<TextBox x:Name="txtMargin"
				    Grid.Row="12"
				    Grid.Column="1"
				    HorizontalAlignment="Stretch"
				    VerticalAlignment="Center" />
				<Button x:Name="btnGetMargin"
				    Grid.Row="12"
				    Grid.Column="2"
				    Margin="1"
				    VerticalAlignment="Center"
				    Click="BtnGetMargin_Click"
				    Content="G" />
				<Button x:Name="btnSetMargin"
				    Grid.Row="12"
				    Grid.Column="3"
				    Margin="1"
				    VerticalAlignment="Center"
				    Click="BtnSetMargin_Click"
				    Content="S" />

				<TextBlock Grid.Row="13"
				    VerticalAlignment="Center"
				    Text="Padding:" />
				<TextBox x:Name="txtPadding"
				    Grid.Row="13"
				    Grid.Column="1"
				    HorizontalAlignment="Stretch"
				    VerticalAlignment="Center" />
				<Button x:Name="btnGetPadding"
				    Grid.Row="13"
				    Grid.Column="2"
				    Margin="1"
				    VerticalAlignment="Center"
				    Click="BtnGetPadding_Click"
				    Content="G" />
				<Button x:Name="btnSetPadding"
				    Grid.Row="13"
				    Grid.Column="3"
				    Margin="1"
				    VerticalAlignment="Center"
				    Click="BtnSetPadding_Click"
				    Content="S" />

				<TextBlock Grid.Row="14"
				    VerticalAlignment="Center"
				    Text="Width:" />
				<TextBox x:Name="txtWidth"
				    Grid.Row="14"
				    Grid.Column="1"
				    HorizontalAlignment="Stretch"
				    VerticalAlignment="Center" />
				<Button x:Name="btnGetWidth"
				    Grid.Row="14"
				    Grid.Column="2"
				    Margin="1"
				    VerticalAlignment="Center"
				    Click="BtnGetWidth_Click"
				    Content="G" />
				<Button x:Name="btnSetWidth"
				    Grid.Row="14"
				    Grid.Column="3"
				    Margin="1"
				    VerticalAlignment="Center"
				    Click="BtnSetWidth_Click"
				    Content="S" />
				<Button x:Name="btnQueueWidth"
				    Grid.Row="14"
				    Grid.Column="4"
				    Margin="1"
				    VerticalAlignment="Center"
				    Click="BtnQueueWidth_Click"
				    Content="Q" />

				<TextBlock Grid.Row="15"
				    VerticalAlignment="Center"
				    Text="Height:" />
				<TextBox x:Name="txtHeight"
				    Grid.Row="15"
				    Grid.Column="1"
				    HorizontalAlignment="Stretch"
				    VerticalAlignment="Center" />
				<Button x:Name="btnGetHeight"
				    Grid.Row="15"
				    Grid.Column="2"
				    Margin="1"
				    VerticalAlignment="Center"
				    Click="BtnGetHeight_Click"
				    Content="G" />
				<Button x:Name="btnSetHeight"
				    Grid.Row="15"
				    Grid.Column="3"
				    Margin="1"
				    VerticalAlignment="Center"
