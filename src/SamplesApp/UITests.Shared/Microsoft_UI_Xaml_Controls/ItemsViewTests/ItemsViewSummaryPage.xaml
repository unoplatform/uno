			<Button x:Name="btnDiscardQueuedOperations"
			    Grid.Row="12"
			    Margin="2"
			    HorizontalAlignment="Stretch"
			    Click="BtnDiscardQueuedOperations_Click"
			    Content="Discard Queued Operations" />

			<CheckBox x:Name="chkShowCurrentElement"
			    Grid.Row="13"
			    Margin="2"
			    Checked="ChkShowCurrentElement_Checked"
			    Content="Show Current Element?"
			    Unchecked="ChkShowCurrentElement_Unchecked" />
			<CheckBox x:Name="chkShowKeyboardNavigationReferenceOffset"
			    Grid.Row="14"
			    Margin="2"
			    Checked="ChkShowKeyboardNavigationReferenceOffset_Checked"
			    Content="Show Keyboard Navigation Reference Offset?"
			    Unchecked="ChkShowKeyboardNavigationReferenceOffset_Unchecked" />
			<CheckBox x:Name="chkProvideDesiredAspectRatioItemsInfo"
			    Grid.Row="15"
			    Margin="2"
			    Content="Provide DesiredAspectRatio ItemsInfo?"
			    IsChecked="True" />
			<CheckBox x:Name="chkProvideExtraDesiredAspectRatioItemsInfo"
			    Grid.Row="16"
			    Margin="24,2,2,2"
			    Content="Provide Extra DesiredAspectRatio ItemsInfo?"
			    IsChecked="True" />
			<CheckBox x:Name="chkProvideTemporaryDesiredAspectRatioItemsInfo"
			    Grid.Row="17"
			    Margin="24,2,2,2"
			    Content="Provide Temporary DesiredAspectRatio ItemsInfo?"
			    IsChecked="False" />
			<StackPanel Grid.Row="18"
			    Margin="52,0,2,2"
			    Orientation="Horizontal">
				<TextBlock VerticalAlignment="Center"
				    Text="Temporary aspect ratio:" />
				<TextBox x:Name="txtTemporaryAspectRatio"
				    Margin="2,0,0,0"
				    VerticalAlignment="Center"
				    Text="1.0" />
			</StackPanel>
			<CheckBox x:Name="chkProvideMinSizeItemsInfo"
			    Grid.Row="19"
			    Margin="2"
			    Content="Provide MinSize ItemsInfo?"
			    IsChecked="True" />
			<CheckBox x:Name="chkProvideMinSizeArrayItemsInfo"
			    Grid.Row="20"
			    Margin="24,2,2,2"
			    Content="Provide MinSize Array ItemsInfo?" />
			<CheckBox x:Name="chkProvideMaxSizeItemsInfo"
			    Grid.Row="21"
			    Margin="2"
			    Content="Provide MaxSize ItemsInfo?"
			    IsChecked="True" />
			<CheckBox x:Name="chkProvideMaxSizeArrayItemsInfo"
			    Grid.Row="22"
			    Margin="24,2,2,2"
			    Content="Provide MaxSize Array ItemsInfo?" />
		</Grid>

		<Grid x:Name="grdItemsViewDataSource"
		    Grid.Row="1"
		    Grid.Column="6"
		    Margin="4,0,4,0"
		    Padding="6"
		    BorderBrush="{ThemeResource SystemChromeGrayColor}"
		    BorderThickness="1"
		    ColumnDefinitions="Auto, Auto, Auto, Auto"
		    RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto">

			<TextBlock Grid.ColumnSpan="4"
			    Foreground="Red"
			    Text="ItemsView Data Source" />

			<TextBlock Grid.Row="1"
			    VerticalAlignment="Center"
			    Text="ItemCount:" />
			<TextBox x:Name="txtDataSourceItemCount"
			    Grid.Row="1"
			    Grid.Column="1"
			    HorizontalAlignment="Stretch"
			    VerticalAlignment="Center"
			    Text="0" />
			<Button x:Name="btnDataSourceGetItemCount"
			    Grid.Row="1"
			    Grid.Column="2"
			    Margin="1"
			    HorizontalAlignment="Stretch"
			    VerticalAlignment="Center"
			    Click="BtnDataSourceGetItemCount_Click"
			    Content="G" />
			<Button x:Name="btnDataSourceSetItemCount"
			    Grid.Row="1"
			    Grid.Column="3"
			    Margin="1"
			    HorizontalAlignment="Stretch"
			    VerticalAlignment="Center"
			    Click="BtnDataSourceSetItemCount_Click"
			    Content="S" />

			<Button x:Name="btnDataSourceAddItem"
			    Grid.Row="2"
			    Grid.ColumnSpan="2"
			    Margin="1"
			    HorizontalAlignment="Stretch"
			    VerticalAlignment="Center"
			    Click="BtnDataSourceAddItem_Click"
			    Content="Add Item" />
			<Button x:Name="btnQueueDataSourceAddItem"
			    Grid.Row="2"
			    Grid.Column="2"
			    Margin="1"
			    VerticalAlignment="Center"
			    Click="BtnQueueDataSourceAddItem_Click"
			    Content="Q" />
			<Button x:Name="btnDataSourceRemoveAllItems"
			    Grid.Row="3"
			    Grid.ColumnSpan="2"
			    Margin="1"
			    HorizontalAlignment="Stretch"
			    VerticalAlignment="Center"
			    Click="BtnDataSourceRemoveAllItems_Click"
			    Content="Remove All Items" />
			<Button x:Name="btnQueueDataSourceRemoveAllItems"
			    Grid.Row="3"
			    Grid.Column="2"
			    Margin="1"
			    VerticalAlignment="Center"
			    Click="BtnQueueDataSourceRemoveAllItems_Click"
			    Content="Q" />

			<TextBlock Grid.Row="4"
			    Margin="0,4,0,0"
			    VerticalAlignment="Center"
			    Text="ItemIndex:" />
			<TextBox x:Name="txtDataSourceItemIndex"
			    Grid.Row="4"
			    Grid.Column="1"
			    HorizontalAlignment="Stretch"
			    VerticalAlignment="Center"
			    Text="0" />

			<Button x:Name="btnDataSourceReplaceItem"
			    Grid.Row="5"
			    Grid.ColumnSpan="2"
			    Margin="1,7,1,1"
			    HorizontalAlignment="Stretch"
			    VerticalAlignment="Center"
			    Click="BtnDataSourceReplaceItem_Click"
			    Content="Replace Item" />
			<Button x:Name="btnQueueDataSourceReplaceItem"
			    Grid.Row="5"
			    Grid.Column="2"
			    Margin="1,7,1,1"
			    VerticalAlignment="Center"
			    Click="BtnQueueDataSourceReplaceItem_Click"
			    Content="Q" />
			<Button x:Name="btnDataSourceInsertItem"
			    Grid.Row="6"
			    Grid.ColumnSpan="2"
			    Margin="1"
			    HorizontalAlignment="Stretch"
			    VerticalAlignment="Center"
			    Click="BtnDataSourceInsertItem_Click"
			    Content="Insert Item" />
			<Button x:Name="btnQueueDataSourceInsertItem"
			    Grid.Row="6"
			    Grid.Column="2"
			    Margin="1"
			    VerticalAlignment="Center"
			    Click="BtnQueueDataSourceInsertItem_Click"
			    Content="Q" />
			<Button x:Name="btnDataSourceRemoveItem"
			    Grid.Row="7"
			    Grid.ColumnSpan="2"
			    Margin="1"
			    HorizontalAlignment="Stretch"
			    VerticalAlignment="Center"
			    Click="BtnDataSourceRemoveItem_Click"
			    Content="Remove Item" />
			<Button x:Name="btnQueueDataSourceRemoveItem"
			    Grid.Row="7"
			    Grid.Column="2"
			    Margin="1"
			    VerticalAlignment="Center"
			    Click="BtnQueueDataSourceRemoveItem_Click"
			    Content="Q" />

			<Button x:Name="btnDataSourceReplaceItemContent"
			    Grid.Row="8"
			    Grid.ColumnSpan="2"
			    Margin="1,7,1,1"
			    HorizontalAlignment="Stretch"
			    VerticalAlignment="Center"
			    Click="BtnDataSourceReplaceItemContent_Click"
			    Content="Replace Item Content" />
		</Grid>

		<StackPanel Grid.Row="2"
		    Grid.ColumnSpan="7"
		    Orientation="Horizontal">
			<TextBlock Margin="2"
			    VerticalAlignment="Center"
			    Text="Exception Report" />
			<Button x:Name="btnClearExceptionReport"
			    Margin="2"
			    Click="BtnClearExceptionReport_Click"
			    Content="Clear Exception Report" />
			<TextBox x:Name="txtExceptionReport"
			    Margin="2"
			    IsReadOnly="True" />
		</StackPanel>
	</Grid>

</Page>
