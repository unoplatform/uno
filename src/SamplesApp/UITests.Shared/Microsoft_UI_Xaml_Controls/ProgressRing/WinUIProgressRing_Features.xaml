<Page x:Class="UITests.Microsoft_UI_Xaml_Controls.ProgressRing.WinUIProgressRing_Features"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lottie="using:CommunityToolkit.WinUI.Lottie"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    xmlns:winui="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d not_win">

	<Page.Resources>
		<lottie:LottieVisualSource x:Key="CustomIndeterminateSource"
		    UriSource="ms-appx:///Assets/Animations/custom-indeterminate.json" />
		<lottie:LottieVisualSource x:Key="CustomDeterminateSource"
		    UriSource="ms-appx:///Assets/Animations/custom-determinate.json" />

		<Style TargetType="winui:ProgressRing">
			<Setter Property="Width" Value="60" />
			<Setter Property="Height" Value="60" />
		</Style>
	</Page.Resources>

	<StackPanel Spacing="4">
		<TextBlock>Indeterminate mode:</TextBlock>
		<StackPanel Orientation="Horizontal"
		    Spacing="4">
			<winui:ProgressRing x:Name="indeterminate0"
			    Foreground="Violet"
			    IsIndeterminate="True" />
			<winui:ProgressRing x:Name="indeterminate10"
			    Foreground="Indigo"
			    IsIndeterminate="True" />
			<winui:ProgressRing x:Name="indeterminate30"
			    Foreground="Blue"
			    IsIndeterminate="True" />
			<winui:ProgressRing x:Name="indeterminate50"
			    Foreground="Green"
			    IsIndeterminate="True" />
			<winui:ProgressRing x:Name="indeterminate60"
			    Foreground="Yellow"
			    IsIndeterminate="True" />
			<winui:ProgressRing x:Name="indeterminate99"
			    Foreground="Orange"
			    IsIndeterminate="True" />
			<winui:ProgressRing x:Name="indeterminate100"
			    Foreground="Red"
			    IsIndeterminate="True" />
			<winui:ProgressRing x:Name="indeterminateCustom"
			    not_win:IndeterminateSource="{StaticResource CustomIndeterminateSource}"
			    IsIndeterminate="True" />
		</StackPanel>
		<TextBlock>Static Determinate mode:</TextBlock>
		<StackPanel Orientation="Horizontal"
		    Spacing="4">
			<winui:ProgressRing x:Name="determinate0"
			    Foreground="Violet"
			    IsIndeterminate="False"
			    Value="0" />
			<winui:ProgressRing x:Name="determinate10"
			    Foreground="Indigo"
			    IsIndeterminate="False"
			    Value="10" />
			<winui:ProgressRing x:Name="determinate30"
			    Foreground="Blue"
			    IsIndeterminate="False"
			    Value="30" />
			<winui:ProgressRing x:Name="determinate50"
			    Foreground="Green"
			    IsIndeterminate="False"
			    Value="50" />
			<winui:ProgressRing x:Name="determinate60"
			    Foreground="Yellow"
			    IsIndeterminate="False"
			    Value="60" />
			<winui:ProgressRing x:Name="determinate99"
			    Foreground="Orange"
			    IsIndeterminate="False"
			    Value="99" />
			<winui:ProgressRing x:Name="determinate100"
			    Foreground="Red"
			    IsIndeterminate="False"
			    Value="100" />
			<winui:ProgressRing x:Name="determinateCustom"
			    Width="80"
			    not_win:DeterminateSource="{StaticResource CustomDeterminateSource}"
			    IsIndeterminate="False"
			    Value="75" />
		</StackPanel>
		<TextBlock>Dynamic Determinate mode:</TextBlock>
		<Slider x:Name="dynamicValue"
		    Maximum="100"
		    Minimum="0"
		    Value="50" />
		<TextBlock Text="{Binding Value, ElementName=dynamicValue}" />
		<StackPanel Orientation="Horizontal"
		    Spacing="4">
			<winui:ProgressRing x:Name="dyn1"
			    Foreground="Violet"
			    IsIndeterminate="False"
			    Value="{Binding Value, ElementName=dynamicValue}" />
			<winui:ProgressRing x:Name="dyn2"
			    Foreground="Indigo"
			    IsIndeterminate="False"
			    Value="{Binding Value, ElementName=dynamicValue}" />
			<winui:ProgressRing x:Name="dyn3"
			    Foreground="Blue"
			    IsIndeterminate="False"
			    Value="{Binding Value, ElementName=dynamicValue}" />
			<winui:ProgressRing x:Name="dyn4"
			    Foreground="Green"
			    IsIndeterminate="False"
			    Value="{Binding Value, ElementName=dynamicValue}" />
			<winui:ProgressRing x:Name="dyn5"
			    Foreground="Yellow"
			    IsIndeterminate="False"
			    Value="{Binding Value, ElementName=dynamicValue}" />
			<winui:ProgressRing x:Name="dyn6"
			    Foreground="Orange"
			    IsIndeterminate="False"
			    Value="{Binding Value, ElementName=dynamicValue}" />
			<winui:ProgressRing x:Name="dyn7"
			    Foreground="Red"
			    IsIndeterminate="False"
			    Value="{Binding Value, ElementName=dynamicValue}" />
			<winui:ProgressRing x:Name="dyn8"
			    Width="80"
			    not_win:DeterminateSource="{StaticResource CustomDeterminateSource}"
			    IsIndeterminate="False"
			    Value="{Binding Value, ElementName=dynamicValue}" />
		</StackPanel>


		<TextBlock>
			Lottie files are coming from LottieFiles.<LineBreak />
			Indeterminate is from Ника Зенкевич https://lottiefiles.com/40332-hrundel<LineBreak />
			Determinate is from Neha Naghate https://lottiefiles.com/28278-water-loader</TextBlock>
	</StackPanel>
</Page>
