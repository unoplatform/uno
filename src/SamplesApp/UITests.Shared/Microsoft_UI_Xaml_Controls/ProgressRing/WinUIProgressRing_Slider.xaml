<Page
    x:Class="UITests.Microsoft_UI_Xaml_Controls.ProgressRing.WinUIProgressRing_Slider"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Microsoft_UI_Xaml_Controls.ProgressRing"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winui="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel Margin="0,50,0,0">
        <Grid>
            <winui:ProgressRing
                Width="200"
                Height="200"
                IsIndeterminate="False"
                Value="{Binding Value, ElementName=slider}" />
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="25"
                Foreground="Black"
                Text="{Binding Value, ElementName=slider}" />

        </Grid>
        <TextBlock FontSize="15">Value:</TextBlock>
        <Slider
            x:Name="slider"
            Width="400"
            HorizontalAlignment="Center"
            Background="Gray"
            Maximum="100"
            Minimum="0" />
    </StackPanel>
</Page>
