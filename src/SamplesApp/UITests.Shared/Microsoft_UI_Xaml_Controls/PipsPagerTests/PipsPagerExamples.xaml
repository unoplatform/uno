<!--  MUX reference PipsPagerExamples.xaml, commit 3a84856  -->
<Page x:Class="MUXControlsTestApp.PipsPagerExamples"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Windows10FallCreatorsUpdate="http://schemas.microsoft.com/winfx/2006/xaml/presentation?IsApiContractPresent(Windows.Foundation.UniversalApiContract, 5)"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="PipsPagerExamplesPage"
    mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="100" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="100" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
		</Grid.ColumnDefinitions>

		<StackPanel Windows10FallCreatorsUpdate:Spacing="20">
			<TextBlock HorizontalAlignment="Center"
			    VerticalAlignment="Top"
			    FontSize="20"
			    Text="ListView Example" />

			<ListView x:Name="PersonInfoList"
			    MaxHeight="210">
				<ListView.ItemTemplate>
					<DataTemplate x:DataType="local:PersonInfo">
						<StackPanel Margin="0,10,0,10"
						    Windows10FallCreatorsUpdate:Spacing="10"
						    Orientation="Horizontal">
							<TextBlock VerticalAlignment="Center"
							    Text="{x:Bind FullName}" />
						</StackPanel>
					</DataTemplate>
				</ListView.ItemTemplate>
			</ListView>
		</StackPanel>

		<controls:PipsPager x:Name="PersonInfoListPager"
		    Grid.Column="1"
		    Margin="50,0,0,0"
		    VerticalAlignment="Center"
		    AutomationProperties.Name="ListViewPager"
		    NextButtonVisibility="Visible"
		    Orientation="Vertical"
		    PreviousButtonVisibility="Visible"
		    SelectedIndexChanged="PersonInfoListPager_SelectedIndexChanged" />

		<StackPanel Grid.Row="2"
		    Windows10FallCreatorsUpdate:Spacing="20">
			<TextBlock HorizontalAlignment="Center"
			    VerticalAlignment="Top"
			    FontSize="20"
			    Text="ItemsRepeater Example" />

			<ScrollViewer x:Name="ButtonListScrollViewer"
			    Width="250"
			    Height="224"
			    ViewChanged="ButtonListScrollViewer_ViewChanged">
				<controls:ItemsRepeater x:Name="ButtonListRepeater"
				    VerticalCacheLength="4">
					<controls:ItemsRepeater.Layout>
						<controls:UniformGridLayout ItemsJustification="Start"
						    ItemsStretch="None"
						    MinColumnSpacing="8"
						    MinRowSpacing="{x:Bind MinRowSpacing}"
						    Orientation="Horizontal" />
					</controls:ItemsRepeater.Layout>
					<controls:ItemsRepeater.ItemTemplate>
						<DataTemplate>
							<StackPanel>
								<Image Width="50"
								    Height="50"
								    Source="{Binding}" />
							</StackPanel>
						</DataTemplate>
					</controls:ItemsRepeater.ItemTemplate>
				</controls:ItemsRepeater>
			</ScrollViewer>
		</StackPanel>

		<controls:PipsPager x:Name="ButtonListPager"
		    Grid.Row="2"
		    Grid.Column="1"
		    Margin="50,0,0,0"
		    VerticalAlignment="Center"
		    AutomationProperties.Name="ItemsRepeaterPager"
		    NextButtonVisibility="VisibleOnPointerOver"
		    Orientation="Vertical"
		    PreviousButtonVisibility="VisibleOnPointerOver"
		    SelectedIndexChanged="ButtonListPager_SelectedIndexChanged" />

		<StackPanel Grid.Column="3"
		    Windows10FallCreatorsUpdate:Spacing="20">
			<TextBlock HorizontalAlignment="Center"
			    VerticalAlignment="Top"
			    FontSize="20"
			    Text="FlipView Example" />

			<FlipView x:Name="Gallery"
			    Width="250"
			    Height="250"
			    ItemsSource="{x:Bind Pictures}">
				<FlipView.ItemTemplate>
					<DataTemplate>
						<Grid>
							<Image Source="{Binding}"
							    Stretch="UniformToFill" />
						</Grid>
					</DataTemplate>
				</FlipView.ItemTemplate>
			</FlipView>
		</StackPanel>

		<controls:PipsPager x:Name="FlipViewPipsPager"
		    Grid.Column="4"
		    Margin="50,0,0,0"
		    VerticalAlignment="Center"
		    AutomationProperties.Name="FlipViewPipsPager"
		    NextButtonVisibility="VisibleOnPointerOver"
		    NumberOfPages="{x:Bind Pictures.Count}"
		    PreviousButtonVisibility="VisibleOnPointerOver"
		    SelectedPageIndex="{Binding ElementName=Gallery, Path=SelectedIndex, Mode=TwoWay}" />
	</Grid>
</Page>
