<!--  MUX reference PipsPagerPage.xaml, tag winui3/release/1.8-stable  -->

<Page x:Class="MUXControlsTestApp.PipsPagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    x:Name="PipsPagerTestPage"
    mc:Ignorable="d">

	<Grid Background="Transparent">
		<Grid.RowDefinitions>
			<RowDefinition Height="400" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
		</Grid.ColumnDefinitions>

		<muxc:PipsPager x:Name="TestPipsPager"
		    Margin="0,0,100,0"
		    HorizontalAlignment="Left"
		    VerticalAlignment="Center"
		    AutomationProperties.Name="TestPipsPager"
		    SelectedIndexChanged="OnSelectedIndexChanged" />

		<StackPanel Grid.Column="1"
		    Orientation="Vertical">
			<ComboBox x:Name="PreviousPageButtonVisibilityComboBox"
			    Header="Previous Page Button Visibility"
			    SelectedIndex="2">
				<ComboBoxItem x:Name="VisiblePreviousButton"
				    AutomationProperties.Name="VisiblePreviousButton">
					Visible
				</ComboBoxItem>
				<ComboBoxItem x:Name="VisibleOnPointerOverPreviousButton"
				    AutomationProperties.Name="VisibleOnPointerOverPreviousButton">
					VisibleOnPointerOver
				</ComboBoxItem>
				<ComboBoxItem x:Name="CollapsedPreviousButton"
				    AutomationProperties.Name="CollapsedPreviousButton">
					Collapsed
				</ComboBoxItem>
			</ComboBox>
			<ComboBox x:Name="NextPageButtonVisibilityComboBox"
			    Header="Next Page Button Visibility"
			    SelectedIndex="2">
				<ComboBoxItem x:Name="VisibleNextButton"
				    AutomationProperties.Name="VisibleNextButton">
					Visible
				</ComboBoxItem>
				<ComboBoxItem x:Name="VisibleOnPointerOverNextButton"
				    AutomationProperties.Name="VisibleOnPointerOverNextButton">
					VisibleOnPointerOver
				</ComboBoxItem>
				<ComboBoxItem x:Name="CollapsedNextButton"
				    AutomationProperties.Name="CollapsedNextButton">
					Collapsed
				</ComboBoxItem>
			</ComboBox>
			<ComboBox x:Name="TestPipsPagerNumberOfPagesComboBox"
			    Header="Number of pages"
			    SelectedIndex="5">
				<ComboBoxItem x:Name="ZeroNumberOfPages"
				    AutomationProperties.Name="ZeroNumberOfPages">
					0 Pages
				</ComboBoxItem>
				<ComboBoxItem x:Name="OneNumberOfPages"
				    AutomationProperties.Name="OneNumberOfPages">
					1 Page
				</ComboBoxItem>
				<ComboBoxItem x:Name="FiveNumberOfPages"
				    AutomationProperties.Name="FiveNumberOfPages">
					5 Pages
				</ComboBoxItem>
				<ComboBoxItem x:Name="TenNumberOfPages"
				    AutomationProperties.Name="TenNumberOfPages">
					10 Pages
				</ComboBoxItem>
				<ComboBoxItem x:Name="TwentyNumberOfPages"
				    AutomationProperties.Name="TwentyNumberOfPages">
					20 Pages
				</ComboBoxItem>
				<ComboBoxItem x:Name="InfiniteNumberOfPages"
				    AutomationProperties.Name="InfiniteNumberOfPages">
					Inifinite NumberOfPages
				</ComboBoxItem>
			</ComboBox>
			<ComboBox x:Name="TestPipsPagerMaxVisiblePipsComboBox"
			    Header="Maximum displayed number of pages"
			    SelectedIndex="2">
				<ComboBoxItem x:Name="ZeroMaxVisiblePips"
				    AutomationProperties.Name="ZeroMaxVisiblePips">
					0 Pages
				</ComboBoxItem>
				<ComboBoxItem x:Name="OneMaxVisiblePips"
				    AutomationProperties.Name="OneMaxVisiblePips">
					1 Page
				</ComboBoxItem>
				<ComboBoxItem x:Name="FiveMaxVisiblePips"
				    AutomationProperties.Name="FiveMaxVisiblePips">
					5 Pages
				</ComboBoxItem>
				<ComboBoxItem x:Name="TenMaxVisiblePips"
				    AutomationProperties.Name="TenMaxVisiblePips">
					10 Pages
				</ComboBoxItem>
			</ComboBox>
			<!--  get the materialized items inside the pips pager / compare with unmaterialized directly inside the itemsrepeater control  -->
			<ComboBox x:Name="TestPipsPagerOrientationComboBox"
			    Header="Orentation"
			    SelectedIndex="1">
				<ComboBoxItem x:Name="VerticalOrientation"
				    AutomationProperties.Name="VerticalOrientation">
					Vertical
				</ComboBoxItem>
				<ComboBoxItem x:Name="HorizontalOrientation"
				    AutomationProperties.Name="HorizontalOrientation">
					Horizontal
				</ComboBoxItem>
			</ComboBox>
			<ComboBox x:Name="TestPipsPagerWrapModeComboBox"
			    Header="WrapMode"
			    SelectedIndex="0">
				<ComboBoxItem x:Name="None"
				    AutomationProperties.Name="None">
					None
				</ComboBoxItem>
				<ComboBoxItem x:Name="Wrap"
				    AutomationProperties.Name="Wrap">
					Wrap
				</ComboBoxItem>
			</ComboBox>
		</StackPanel>
		<StackPanel Grid.Column="2"
		    Margin="100,0,0,0"
		    Orientation="Vertical">
			<TextBlock Text="Previous Page Button" />
			<StackPanel Orientation="Horizontal">
				<TextBlock VerticalAlignment="Center"
				    Text="IsVisible" />
				<CheckBox x:Name="PreviousPageButtonIsVisibleCheckBox"
				    AutomationProperties.Name="PreviousPageButtonIsVisibleCheckBox"
				    IsChecked="False"
				    IsEnabled="False" />
			</StackPanel>
			<StackPanel Orientation="Horizontal">
				<TextBlock VerticalAlignment="Center"
				    Text="IsEnabled" />
				<CheckBox x:Name="PreviousPageButtonIsEnabledCheckBox"
				    AutomationProperties.Name="PreviousPageButtonIsEnabledCheckBox"
				    IsChecked="False"
				    IsEnabled="False" />
			</StackPanel>
			<TextBlock Text="Next Page Button" />
			<StackPanel Orientation="Horizontal">
				<TextBlock VerticalAlignment="Center"
				    Text="IsVisible" />
				<CheckBox x:Name="NextPageButtonIsVisibleCheckBox"
				    AutomationProperties.Name="NextPageButtonIsVisibleCheckBox"
				    IsChecked="False"
				    IsEnabled="False" />
			</StackPanel>
			<StackPanel Orientation="Horizontal">
				<TextBlock VerticalAlignment="Center"
				    Text="IsEnabled" />
				<CheckBox x:Name="NextPageButtonIsEnabledCheckBox"
				    AutomationProperties.Name="NextPageButtonIsEnabledCheckBox"
				    IsChecked="False"
				    IsEnabled="False" />
			</StackPanel>
			<TextBlock x:Name="CurrentPageIndexTextBlock" />
			<TextBlock x:Name="CurrentNumberOfPagesTextBlock" />
			<TextBlock x:Name="CurrentMaxVisiblePipsTextBlock" />
			<TextBlock x:Name="FocusedPageIndexTextBlock"
			    Text="Current focused page index: " />
			<TextBlock x:Name="CurrentOrientationTextBlock" />
			<StackPanel Orientation="Horizontal">
				<Button Click="SkipToLastPage"
				    Content="Skip To Last Page" />
				<Button Click="SkipToFirstPage"
				    Content="Skip To First Page" />
			</StackPanel>
		</StackPanel>

		<StackPanel Grid.Row="1"
		    Grid.Column="1"
		    Orientation="Vertical">
			<StackPanel>
				<StackPanel Orientation="Horizontal">
					<TextBlock Text="Horizontal Orientation PipsPager ButtonWidth:" />
					<TextBlock x:Name="HorizontalOrientationPipsPagerButtonWidthTextBlock"
					    Margin="10,0,0,0"
					    AutomationProperties.Name="HorizontalOrientationPipsPagerButtonWidthTextBlock"
					    Text="0" />
				</StackPanel>
				<StackPanel Orientation="Horizontal">
					<TextBlock Text="Horizontal Orientation PipsPager ButtonHeight:" />
					<TextBlock x:Name="HorizontalOrientationPipsPagerButtonHeightTextBlock"
					    Margin="10,0,0,0"
					    AutomationProperties.Name="HorizontalOrientationPipsPagerButtonHeightTextBlock"
					    Text="0" />
				</StackPanel>
				<StackPanel Orientation="Horizontal">
					<TextBlock Text="Vertical Orientation PipsPager ButtonWidth:" />
					<TextBlock x:Name="VerticalOrientationPipsPagerButtonWidthTextBlock"
					    Margin="10,0,0,0"
					    AutomationProperties.Name="VerticalOrientationPipsPagerButtonWidthTextBlock"
					    Text="0" />
				</StackPanel>
				<StackPanel Orientation="Horizontal">
					<TextBlock Text="Vertical Orientation PipsPager ButtonHeight:" />
					<TextBlock x:Name="VerticalOrientationPipsPagerButtonHeightTextBlock"
					    Margin="10,0,0,0"
					    AutomationProperties.Name="VerticalOrientationPipsPagerButtonHeightTextBlock"
					    Text="0" />
				</StackPanel>
			</StackPanel>
			<Button x:Name="GetPipsPagersButtonSizesButton"
			    Width="150"
			    Height="50"
			    Margin="0,20,0,0"
			    HorizontalAlignment="Left"
			    AutomationProperties.Name="GetPipsPagersButtonSizesButton"
			    Click="OnGetPipsPagerButtonSizesClicked"
			    Content="Get Sizes" />
		</StackPanel>

		<muxc:PipsPager x:Name="TestPipsPagerVerticalOrientation"
		    Grid.Row="1"
		    Margin="0,0,100,0"
		    HorizontalAlignment="Left"
		    AutomationProperties.Name="TestPipsPagerVerticalOrientation"
		    Orientation="Vertical" />

		<Button x:Name="GoToExamplesPageButton"
		    Grid.Row="1"
		    Grid.Column="1"
		    Margin="0,200,0,0"
		    Click="GoToExamplesPage"
		    Content="Open PipsPager Examples" />
	</Grid>
</Page>
