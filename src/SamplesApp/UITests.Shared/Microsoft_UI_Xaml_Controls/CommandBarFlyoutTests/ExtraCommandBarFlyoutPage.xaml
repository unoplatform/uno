<!--  MUX Reference controls\dev\CommandBarFlyout\TestUI\ExtraCommandBarFlyoutPage.xaml, commit b91b3ce6f25c587a9e18c4e122f348f51331f18b  -->
<local:TestPage x:Class="MUXControlsTestApp.ExtraCommandBarFlyoutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:muxcp="using:Microsoft.UI.Xaml.Controls.Primitives"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Page.Resources>
		<muxc:TextCommandBarFlyout x:Name="TextCommandBarContextFlyout" />
		<muxc:TextCommandBarFlyout x:Name="TextCommandBarSelectionFlyout" />
	</Page.Resources>

	<StackPanel Margin="12">
		<TextBlock Style="{ThemeResource StandardGroupHeader}"
		    Text="Demo controls" />
		<StackPanel Orientation="Horizontal">
			<TextBox x:Name="TextBox1"
			    MinWidth="200"
			    AutomationProperties.AutomationId="TextBox"
			    ContextFlyout="{x:Bind TextCommandBarContextFlyout}" />
			<RichTextBlock x:Name="RichTextBlock1"
			    Width="100"
			    Height="50"
			    Margin="10"
			    HorizontalAlignment="Center"
			    AutomationProperties.AutomationId="RichTextBlock"
			    ContextFlyout="{x:Bind TextCommandBarContextFlyout}"
			    OverflowContentTarget="{x:Bind RichTextBlockOverflow1}">
				<RichTextBlock.Blocks>
					<Paragraph>
						<Run>This is a very, very long string that cannot possibly fit within the RichTextBlock's bounds, so it overflows.</Run>
					</Paragraph>
				</RichTextBlock.Blocks>
			</RichTextBlock>
			<RichTextBlockOverflow x:Name="RichTextBlockOverflow1"
			    Margin="10"
			    HorizontalAlignment="Center"
			    AutomationProperties.AutomationId="RichTextBlockOverflow" />
			<Button Content="Click for a CommandBarFlyout with many items">
				<Button.Flyout>
					<muxc:CommandBarFlyout>
						<AppBarButton Icon="Favorite"
						    Label="Item 1" />
						<AppBarButton Icon="Favorite"
						    Label="Item 2" />
						<AppBarButton Icon="Favorite"
						    Label="Item 3" />
						<AppBarButton Icon="Favorite"
						    Label="Item 4" />
						<AppBarButton Icon="Favorite"
						    Label="Item 5" />
						<AppBarButton Icon="Favorite"
						    Label="Item 6" />
						<AppBarButton Icon="Favorite"
						    Label="Item 7" />
						<AppBarButton Icon="Favorite"
						    Label="Item 8" />
						<AppBarButton Icon="Favorite"
						    Label="Item 9" />
						<AppBarButton Icon="Favorite"
						    Label="Item 10" />
						<AppBarButton Icon="Favorite"
						    Label="Item 11" />
						<AppBarButton Icon="Favorite"
						    Label="Item 12" />
						<AppBarButton Icon="Favorite"
						    Label="Item 13" />
						<AppBarButton Icon="Favorite"
						    Label="Item 14" />
						<AppBarButton Icon="Favorite"
						    Label="Item 15" />
						<AppBarButton Icon="Favorite"
						    Label="Item 16" />
						<AppBarButton Icon="Favorite"
						    Label="Item 17" />
						<AppBarButton Icon="Favorite"
						    Label="Item 18" />
						<AppBarButton Icon="Favorite"
						    Label="Item 19" />
						<AppBarButton Icon="Favorite"
						    Label="Item 20" />
					</muxc:CommandBarFlyout>
				</Button.Flyout>
			</Button>
		</StackPanel>
		<TextBlock Margin="0,24,0,8"
		    Style="{ThemeResource StandardGroupHeader}"
		    Text="Actions" />
		<Button AutomationProperties.AutomationId="ClearClipboardContentsButton"
		    Click="OnClearClipboardContentsClicked"
		    Content="Clear clipboard" />
		<TextBox x:Name="tb"
		    AutomationProperties.Name="TextBoxWithAdditionalItems"
		    Loaded="tbloaded"
		    Unloaded="tbunloaded" />

		<TextBlock Margin="0,24,0,8"
		    Style="{ThemeResource StandardGroupHeader}"
		    Text="Status" />
		<StackPanel Orientation="Horizontal">
			<Button Margin="0,0,8,0"
			    AutomationProperties.AutomationId="CountPopupsButton"
			    Click="OnCountPopupsClicked"
			    Content="Count popups" />
			<TextBox x:Name="PopupCountTextBox"
			    AutomationProperties.AutomationId="PopupCountTextBox"
			    IsReadOnly="True" />
			<TextBox x:Name="CustomButtonsOpenCount"
			    AutomationProperties.AutomationId="CustomButtonsOpenCount"
			    IsReadOnly="True" />
		</StackPanel>
	</StackPanel>
</local:TestPage>
