<!--  MUX Reference controls\dev\CommandBarFlyout\TestUI\TextCommandBarFlyoutPage.xaml, tag winui3/release/1.5.2, commit b91b3ce6f25c587a9e18c4e122f348f51331f18b  -->
<local:TestPage x:Class="MUXControlsTestApp.TextCommandBarFlyoutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

	<Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
		<Grid.RowDefinitions>
			<RowDefinition />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<ScrollViewer>
			<StackPanel>
				<StackPanel.Resources>
					<muxc:TextCommandBarFlyout x:Name="TextControlContextFlyout" />
					<muxc:TextCommandBarFlyout x:Name="TextControlSelectionFlyout" />
				</StackPanel.Resources>
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>
					<TextBox x:Name="TextBox1"
					    Margin="10"
					    AutomationProperties.AutomationId="TextBox"
					    Text="Lorem ipsum ergo sum" />
					<TextBlock x:Name="TextBlock1"
					    Grid.Row="1"
					    Margin="10"
					    AutomationProperties.AutomationId="TextBlock"
					    IsTextSelectionEnabled="True"
					    Text="Lorem ipsum ergo sum" />
					<RichEditBox x:Name="RichEditBox1"
					    Grid.Row="2"
					    Margin="10"
					    AutomationProperties.AutomationId="RichEditBox" />
					<RichTextBlock x:Name="RichTextBlock1"
					    Grid.Row="3"
					    Margin="10"
					    AutomationProperties.AutomationId="RichTextBlock"
					    IsTextSelectionEnabled="True">
						<Paragraph>
							<Bold>
								<Italic>
									<Underline>Lorem ipsum ergo sum</Underline>
								</Italic>
							</Bold>
						</Paragraph>
					</RichTextBlock>
					<PasswordBox x:Name="PasswordBox1"
					    Grid.Row="4"
					    Margin="10"
					    AutomationProperties.AutomationId="PasswordBox"
					    Password="Lorem ipsum ergo sum" />
					<Button x:Name="TextBoxSelectAllButton"
					    Grid.Column="1"
					    AutomationProperties.AutomationId="TextBoxSelectAllButton"
					    Click="OnTextBoxSelectAllClicked"
					    Content="Select all" />
					<Button x:Name="TextBlockSelectAllButton"
					    Grid.Row="1"
					    Grid.Column="1"
					    AutomationProperties.AutomationId="TextBlockSelectAllButton"
					    Click="OnTextBlockSelectAllClicked"
					    Content="Select all" />
					<Button x:Name="RichEditBoxSelectAllButton"
					    Grid.Row="2"
					    Grid.Column="1"
					    AutomationProperties.AutomationId="RichEditBoxSelectAllButton"
					    Click="OnRichEditBoxSelectAllClicked"
					    Content="Select all" />
					<Button x:Name="RichTextBlockSelectAllButton"
					    Grid.Row="3"
					    Grid.Column="1"
					    AutomationProperties.AutomationId="RichTextBlockSelectAllButton"
					    Click="OnRichTextBlockSelectAllClicked"
					    Content="Select all" />
					<Button x:Name="TextBoxClearSelectionButton"
					    Grid.Column="2"
					    AutomationProperties.AutomationId="TextBoxClearSelectionButton"
					    Click="OnTextBoxClearSelectionClicked"
					    Content="Clear selection" />
					<Button x:Name="TextBlockClearSelectionButton"
					    Grid.Row="1"
					    Grid.Column="2"
					    AutomationProperties.AutomationId="TextBlockClearSelectionButton"
					    Click="OnTextBlockClearSelectionClicked"
					    Content="Clear selection" />
					<Button x:Name="RichEditBoxClearSelectionButton"
					    Grid.Row="2"
					    Grid.Column="2"
					    AutomationProperties.AutomationId="RichEditBoxClearSelectionButton"
					    Click="OnRichEditBoxClearSelectionClicked"
					    Content="Clear selection" />
					<Button x:Name="RichTextBlockClearSelectionButton"
					    Grid.Row="3"
					    Grid.Column="2"
					    AutomationProperties.AutomationId="RichTextBlockClearSelectionButton"
					    Click="OnRichTextBlockClearSelectionClicked"
					    Content="Clear selection" />
					<Button x:Name="TextBoxFillWithTextButton"
					    Grid.Column="3"
					    AutomationProperties.AutomationId="TextBoxFillWithTextButton"
					    Click="OnTextBoxFillWithTextClicked"
					    Content="Fill with text" />
					<Button x:Name="RichEditBoxFillWithTextButton"
					    Grid.Row="2"
					    Grid.Column="3"
					    AutomationProperties.AutomationId="RichEditBoxFillWithTextButton"
					    Click="OnRichEditBoxFillWithTextClicked"
					    Content="Fill with text" />
				</Grid>
				<TextBlock HorizontalAlignment="Center"
				    Text="Show TextCommandBarFlyout in transient mode on..." />
				<VariableSizedWrapGrid Orientation="Horizontal">
					<Button x:Name="ShowTextControlFlyoutOnTextBoxButton"
					    Width="150"
					    Margin="5"
					    AutomationProperties.AutomationId="ShowTextControlFlyoutOnTextBoxButton"
					    Click="OnShowTextControlFlyoutOnTextBoxClicked"
					    Content="TextBox" />
					<Button x:Name="ShowTextControlFlyoutOnTextBlockButton"
					    Width="150"
					    Margin="5"
					    AutomationProperties.AutomationId="ShowTextControlFlyoutOnTextBlockButton"
					    Click="OnShowTextControlFlyoutOnTextBlockClicked"
					    Content="TextBlock" />
					<Button x:Name="ShowTextControlFlyoutOnRichEditBoxButton"
					    Width="150"
					    Margin="5"
					    AutomationProperties.AutomationId="ShowTextControlFlyoutOnRichEditBoxButton"
					    Click="OnShowTextControlFlyoutOnRichEditBoxClicked"
					    Content="RichEditBox" />
					<Button x:Name="ShowTextControlFlyoutOnRichTextBlockButton"
					    Width="150"
					    Margin="5"
					    AutomationProperties.AutomationId="ShowTextControlFlyoutOnRichTextBlockButton"
					    Click="OnShowTextControlFlyoutOnRichTextBlockClicked"
					    Content="RichTextBlock" />
					<Button x:Name="ShowTextControlFlyoutOnPasswordBoxButton"
					    Width="150"
					    Margin="5"
					    AutomationProperties.AutomationId="ShowTextControlFlyoutOnPasswordBoxButton"
					    Click="OnShowTextControlFlyoutOnPasswordBoxClicked"
					    Content="PasswordBox" />
				</VariableSizedWrapGrid>
				<TextBlock HorizontalAlignment="Center"
				    Text="Show TextControlCommandBarFlyout in standard mode on..." />
				<VariableSizedWrapGrid Orientation="Horizontal">
					<Button x:Name="ShowStandardTextControlFlyoutOnTextBoxButton"
					    Width="150"
					    Margin="5"
					    AutomationProperties.AutomationId="ShowStandardTextControlFlyoutOnTextBoxButton"
					    Click="OnShowStandardTextControlFlyoutOnTextBoxClicked"
					    Content="TextBox" />
					<Button x:Name="ShowStandardTextControlFlyoutOnTextBlockButton"
					    Width="150"
					    Margin="5"
					    AutomationProperties.AutomationId="ShowStandardTextControlFlyoutOnTextBlockButton"
					    Click="OnShowStandardTextControlFlyoutOnTextBlockClicked"
					    Content="TextBlock" />
					<Button x:Name="ShowStandardTextControlFlyoutOnRichEditBoxButton"
					    Width="150"
					    Margin="5"
					    AutomationProperties.AutomationId="ShowStandardTextControlFlyoutOnRichEditBoxButton"
					    Click="OnShowStandardTextControlFlyoutOnRichEditBoxClicked"
					    Content="RichEditBox" />
					<Button x:Name="ShowStandardTextControlFlyoutOnRichTextBlockButton"
					    Width="150"
					    Margin="5"
					    AutomationProperties.AutomationId="ShowStandardTextControlFlyoutOnRichTextBlockButton"
					    Click="OnShowStandardTextControlFlyoutOnRichTextBlockClicked"
					    Content="RichTextBlock" />
					<Button x:Name="ShowStandardTextControlFlyoutOnPasswordBoxButton"
					    Width="150"
					    Margin="5"
					    AutomationProperties.AutomationId="ShowStandardTextControlFlyoutOnPasswordBoxButton"
					    Click="OnShowStandardTextControlFlyoutOnPasswordBoxClicked"
					    Content="PasswordBox" />
				</VariableSizedWrapGrid>
				<Button x:Name="ClearClipboardContentsButton"
				    AutomationProperties.AutomationId="ClearClipboardContentsButton"
				    Click="OnClearClipboardContentsClicked"
				    Content="Clear clipboard contents" />
				<Button x:Name="SetClipboardContentsButton"
				    AutomationProperties.AutomationId="SetClipboardContentsButton"
				    Click="OnSetClipboardContentsClicked"
				    Content="Set clipboard contents" />
				<Button x:Name="GetRichEditBoxRtfContentButton"
				    AutomationProperties.AutomationId="GetRichEditBoxRtfContentButton"
				    Click="OnGetRichEditBoxRtfContentClicked"
				    Content="Get RichEditBox RTF content" />
			</StackPanel>
		</ScrollViewer>
		<TextBox x:Name="StatusReportingTextBox"
		    Grid.Row="1"
		    Margin="10"
		    AcceptsReturn="True"
		    AutomationProperties.AutomationId="StatusReportingTextBox"
		    IsReadOnly="True" />
	</Grid>
</local:TestPage>
