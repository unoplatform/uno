<local:TestPage
    x:Class="MUXControlsTestApp.CommandBarFlyoutMainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <StackPanel>
            <Button
                Margin="10"
                Click="OnCommandBarFlyoutTestsClicked"
                Content="Base CommandBarFlyout Tests" />
            <Button
                Margin="10"
                Click="OnTextCommandBarFlyoutTestsClicked"
                Content="TextCommandBarFlyout Tests" />
            <Button
                Margin="10"
                Click="OnExtraCommandBarFlyoutTestsClicked"
                Content="Extra CommandBarFlyout Tests" />

            <TextBlock
                Margin="10,10,10,1"
                VerticalAlignment="Center"
                Text="CommandBarFlyout OutputDebugString Level:" />
            <ComboBox
                x:Name="cmbCommandBarFlyoutOutputDebugStringLevel"
                Margin="10,1,10,10"
                HorizontalAlignment="Left"
                AutomationProperties.Name="cmbCommandBarFlyoutOutputDebugStringLevel"
                SelectedIndex="0"
                SelectionChanged="CmbCommandBarFlyoutOutputDebugStringLevel_SelectionChanged">
                <ComboBoxItem>None</ComboBoxItem>
                <ComboBoxItem>Info</ComboBoxItem>
                <ComboBoxItem>Verbose</ComboBoxItem>
            </ComboBox>
        </StackPanel>
    </Grid>
</local:TestPage>
