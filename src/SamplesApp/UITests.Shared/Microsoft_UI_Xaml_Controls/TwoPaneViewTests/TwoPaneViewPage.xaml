<Page
    x:Class="UITests.Shared.Microsoft_UI_Xaml_Controls.TwoPaneViewTests.TwoPaneViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Microsoft_UI_Xaml_Controls.TwoPaneViewTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxcontrols="using:Microsoft.UI.Xaml.Controls"
    xmlns:not_win="http://uno.ui/not_win"
    x:Name="TwoPaneViewTestPage"
    mc:Ignorable="d not_win">

    <Page.Resources>
        <SolidColorBrush
            x:Key="ContentBorderBrush"
            Opacity="0.25"
            Color="Gray" />
    </Page.Resources>

    <not_win:Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer>
            <StackPanel
                x:Name="PropertiesPanel"
                MinWidth="250"
                Padding="12"
                AutomationProperties.Name="PropertiesPanel"
                Background="{ThemeResource SystemChromeLowColor}"
                Orientation="Vertical">
                <TextBlock Style="{ThemeResource StandardGroupHeader}" Text="Options" />
                <TextBlock Text="Width:" />
                <ComboBox
                    x:Name="WidthComboBox"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="WidthComboBox"
                    SelectedIndex="0"
                    SelectionChanged="WidthComboBox_SelectionChanged">
                    <x:String>Default</x:String>
                    <x:String>Wide</x:String>
                    <x:String>Narrow</x:String>
                </ComboBox>

                <TextBlock Margin="0,12,0,0" Text="Height:" />
                <ComboBox
                    x:Name="HeightComboBox"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="HeightComboBox"
                    SelectedIndex="0"
                    SelectionChanged="HeightComboBox_SelectionChanged">
                    <x:String>Default</x:String>
                    <x:String>Tall</x:String>
                    <x:String>Short</x:String>
                </ComboBox>

                <TextBlock Margin="0,12,0,0" Text="Pane Priority:" />
                <ComboBox
                    x:Name="PanePriorityComboBox"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="PanePriorityComboBox"
                    SelectedIndex="0"
                    SelectionChanged="PanePriorityComboBox_SelectionChanged">
                    <x:String>Pane1</x:String>
                    <x:String>Pane2</x:String>
                </ComboBox>

                <TextBlock Margin="0,12,0,0" Text="Pane1Length:" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        x:Name="Pane1LengthTextBox"
                        AutomationProperties.Name="Pane1LengthTextBox"
                        Text="1"
                        TextChanged="Pane1LengthTextBox_TextChanged" />
                    <ComboBox
                        x:Name="Pane1LengthComboBox"
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        AutomationProperties.Name="Pane1LengthComboBox"
                        SelectedIndex="0"
                        SelectionChanged="Pane1LengthComboBox_SelectionChanged">
                        <x:String>Auto</x:String>
                        <x:String>Pixel</x:String>
                        <x:String>Star</x:String>
                    </ComboBox>
                </Grid>

                <TextBlock Margin="0,12,0,0" Text="Pane2Length:" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        x:Name="Pane2LengthTextBox"
                        AutomationProperties.Name="Pane2LengthTextBox"
                        Text="1"
                        TextChanged="Pane2LengthTextBox_TextChanged" />
                    <ComboBox
                        x:Name="Pane2LengthComboBox"
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        AutomationProperties.Name="Pane2LengthComboBox"
                        SelectedIndex="2"
                        SelectionChanged="Pane2LengthComboBox_SelectionChanged">
                        <x:String>Auto</x:String>
                        <x:String>Pixel</x:String>
                        <x:String>Star</x:String>
                    </ComboBox>
                </Grid>

                <TextBlock Margin="0,12,0,0" Text="Wide Configuration:" />
                <ComboBox
                    x:Name="WideModeConfigurationComboBox"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="WideModeConfigurationComboBox"
                    SelectedIndex="0"
                    SelectionChanged="WideModeConfigurationComboBox_SelectionChanged">
                    <x:String>LeftRight</x:String>
                    <x:String>RightLeft</x:String>
                    <x:String>SinglePane</x:String>
                </ComboBox>

                <TextBlock Margin="0,12,0,0" Text="Tall Configuration:" />
                <ComboBox
                    x:Name="TallModeConfigurationComboBox"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="TallModeConfigurationComboBox"
                    SelectedIndex="0"
                    SelectionChanged="TallModeConfigurationComboBox_SelectionChanged">
                    <x:String>TopBottom</x:String>
                    <x:String>BottomTop</x:String>
                    <x:String>SinglePane</x:String>
                </ComboBox>

                <TextBlock Margin="0,12,0,0" Text="Min Wide Width:" />
                <TextBox
                    x:Name="MinWideModeWidthTextBox"
                    AutomationProperties.Name="MinWideModeWidthTextBox"
                    Text="641"
                    TextChanged="MinWideModeWidthTextBox_TextChanged" />

                <TextBlock Margin="0,12,0,0" Text="Min Tall Height:" />
                <TextBox
                    x:Name="MinTallModeHeightTextBox"
                    AutomationProperties.Name="MinTallModeHeightTextBox"
                    Text="641"
                    TextChanged="MinTallModeHeightTextBox_TextChanged" />

                <TextBlock Margin="0,12,0,0" Text="Simulate regions:" />
                <ComboBox
                    x:Name="SimulateComboBox"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="SimulateComboBox"
                    SelectedIndex="0"
                    SelectionChanged="SimulateComboBox_SelectionChanged">
                    <x:String>None</x:String>
                    <x:String>LeftRight</x:String>
                    <x:String>TopBottom</x:String>
                </ComboBox>

                <CheckBox
                    x:Name="AddMarginCheckBox"
                    Margin="0,12,0,0"
                    AutomationProperties.Name="AddMarginCheckBox"
                    Checked="AddMarginCheckBox_Checked"
                    Content="Add margin"
                    Unchecked="AddMarginCheckBox_Unchecked" />
                <CheckBox
                    x:Name="OneSideCheckBox"
                    Margin="0,12,0,0"
                    AutomationProperties.Name="OneSideCheckBox"
                    Checked="OneSideCheckBox_Checked"
                    Content="One side only"
                    Unchecked="OneSideCheckBox_Unchecked" />

                <Border
                    Height="3"
                    Margin="0,8,0,8"
                    HorizontalAlignment="Stretch"
                    Background="{ThemeResource SystemChromeGrayColor}" />

                <TextBlock Style="{ThemeResource StandardGroupHeader}" Text="Reports" />

                <TextBlock Margin="0,12,0,0" Text="Mode:" />
                <TextBlock x:Name="ConfigurationTextBlock" AutomationProperties.Name="ConfigurationTextBlock" />

                <TextBlock
                    x:Name="SpacingTextBox"
                    Margin="0,12,0,0"
                    AutomationProperties.Name="SpacingTextBox" />

                <TextBlock x:Name="ControlWidthText" AutomationProperties.Name="ControlWidthText" />
                <TextBlock x:Name="ControlHeightText" AutomationProperties.Name="ControlHeightText" />

                <Border
                    Height="3"
                    Margin="0,8,0,8"
                    HorizontalAlignment="Stretch"
                    Background="{ThemeResource SystemChromeGrayColor}" />

                <TextBlock Style="{ThemeResource StandardGroupHeader}" Text="Small control sample" />
                <StackPanel Margin="0,8,0,0" Background="{ThemeResource SystemListMediumColor}">
                    <TextBlock Text="Small TwoPaneView with pane priority set" />
                    <muxcontrols:TwoPaneView
                        x:Name="TwoPaneViewSmall"
                        Width="200"
                        Height="200"
                        Margin="0,12,0,0"
                        PanePriority="Pane2">
                        <muxcontrols:TwoPaneView.Pane1>
                            <TextBlock
                                x:Name="SmallContent1"
                                AutomationProperties.Name="SmallContent1"
                                Text="I should NOT be seen" />
                        </muxcontrols:TwoPaneView.Pane1>

                        <muxcontrols:TwoPaneView.Pane2>
                            <TextBlock
                                x:Name="SmallContent2"
                                AutomationProperties.Name="SmallContent2"
                                Text="I should be seen" />
                        </muxcontrols:TwoPaneView.Pane2>
                    </muxcontrols:TwoPaneView>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Column="1" Margin="12">
            <Grid
                x:Name="SimulatedWindow"
                Grid.Column="1"
                AutomationProperties.Name="SimulatedWindow"
                Background="Gray">

                <muxcontrols:TwoPaneView
                    x:Name="TwoPaneView"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    SizeChanged="TwoPaneView_SizeChanged">
                    <muxcontrols:TwoPaneView.Pane1>
                        <Grid
                            x:Name="Pane1Content"
                            AutomationProperties.Name="Pane1Content"
                            Background="{ThemeResource SystemChromeDisabledHighColor}"
                            SizeChanged="PaneSizeChanged">

                            <Border
                                x:Name="Content1Border"
                                MinWidth="250"
                                MinHeight="250"
                                Padding="7"
                                AutomationProperties.Name="Content1Border"
                                BorderBrush="{StaticResource ContentBorderBrush}"
                                BorderThickness="5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Vertical">
                                        <TextBlock
                                            x:Name="Content1"
                                            AutomationProperties.Name="Content1"
                                            Text="Content 1" />
                                        <TextBlock x:Name="WidthText1" AutomationProperties.Name="WidthText1" />
                                        <TextBlock x:Name="HeightText1" AutomationProperties.Name="HeightText1" />
                                    </StackPanel>

                                    <TextBox
                                        x:Name="Pane1TextBox"
                                        Grid.Row="1"
                                        Width="100"
                                        HorizontalAlignment="Left"
                                        AutomationProperties.Name="Pane1TextBox" />
                                </Grid>
                            </Border>

                        </Grid>
                    </muxcontrols:TwoPaneView.Pane1>

                    <muxcontrols:TwoPaneView.Pane2>
                        <Grid
                            x:Name="Pane2Content"
                            AutomationProperties.Name="Pane2Content"
                            Background="{ThemeResource SystemListMediumColor}"
                            SizeChanged="PaneSizeChanged">
                            <Border
                                x:Name="Content2Border"
                                Padding="7"
                                AutomationProperties.Name="Content2Border"
                                BorderBrush="{StaticResource ContentBorderBrush}"
                                BorderThickness="5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Vertical">
                                        <TextBlock
                                            x:Name="Content2"
                                            AutomationProperties.Name="Content2"
                                            Text="Content 2" />
                                        <TextBlock x:Name="WidthText2" AutomationProperties.Name="WidthText2" />
                                        <TextBlock x:Name="HeightText2" AutomationProperties.Name="HeightText2" />
                                    </StackPanel>

                                    <TextBox
                                        x:Name="Pane2TextBox"
                                        Grid.Row="1"
                                        Width="100"
                                        HorizontalAlignment="Left"
                                        AutomationProperties.Name="Pane2TextBox" />
                                </Grid>
                            </Border>
                        </Grid>
                    </muxcontrols:TwoPaneView.Pane2>
                </muxcontrols:TwoPaneView>

            </Grid>
        </Grid>
    </not_win:Grid>
</Page>
