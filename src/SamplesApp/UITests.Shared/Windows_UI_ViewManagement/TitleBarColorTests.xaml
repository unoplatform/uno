<UserControl x:Class="UITests.Shared.Windows_UI_ViewManagement.TitleBarColorTests"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_ViewManagement"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<StackPanel>
		<TextBox x:Name="BackgroundColorTextBox"
		    Header="Color"
		    Text="#FF0000" />
		<StackPanel Orientation="Horizontal">
			<Button Click="SetColor_Click">Set color</Button>
			<Button Margin="4,0,0,0"
			    Click="ResetDefault_Click">
				Reset default
			</Button>
		</StackPanel>
		<TextBlock x:Name="ErrorMessage"
		    Foreground="Red"
		    Text="" />
	</StackPanel>
</UserControl>
