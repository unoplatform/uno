<Page
    x:Class="UITests.Windows_UI_ViewManagement.SoftInputTests_FocusChange"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <!--
        Test: Multiple TextBoxes with focus changes while keyboard is showing.
        Expected: Tap bottom TextBox (keyboard shows, page scrolls down),
        then tap top TextBox (page scrolls back up to show it).
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Padding="12"
            Spacing="4">
            <TextBlock
                FontSize="18"
                FontWeight="Bold"
                Text="Soft Input: Focus Change" />
            <TextBlock Text="Tap the bottom TextBox first (keyboard appears, page scrolls). Then tap the top TextBox without dismissing keyboard - page should scroll back up." TextWrapping="Wrap" />
            <TextBlock x:Name="StatusText" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
        </StackPanel>

        <TextBox
            Grid.Row="1"
            Margin="12,8"
            PlaceholderText="Top TextBox - tap second" />

        <Border
            Grid.Row="2"
            Margin="12,8"
            Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Text="(Spacer between TextBoxes)" />
        </Border>

        <TextBox
            Grid.Row="3"
            Margin="12,8"
            PlaceholderText="Bottom TextBox - tap first" />
    </Grid>
</Page>
