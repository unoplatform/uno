<Page
    x:Class="UITests.Windows_UI_Composition.VisualRotationSample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Composition"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel>
        <Grid
            Width="500"
            Height="500"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="Blue">
            <Border
                x:Name="myBorder"
                Width="150"
                Height="150"
                Background="Red" />
        </Grid>

        <Button Click="Button1_Click" Content="Rotate 45deg around center" />
        <Button Click="Button2_Click" Content="Rotate 45deg around origin" />
    </StackPanel>
</Page>
