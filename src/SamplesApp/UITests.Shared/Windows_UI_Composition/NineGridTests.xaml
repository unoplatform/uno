<UserControl
    x:Class="UITests.Shared.Windows_UI_Composition.NineGridTests"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_Composition"
    xmlns:lottie="using:CommunityToolkit.WinUI.Lottie"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winui="using:Microsoft.UI.Xaml.Controls"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <StackPanel
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Orientation="Vertical"
        Spacing="20">
        <StackPanel
            HorizontalAlignment="Center"
            Orientation="Horizontal"
            Spacing="70">
            <TextBlock
                Width="100"
                Margin="50,0,0,0"
                FontSize="27"
                FontWeight="Light"
                Text="Source"
                TextAlignment="Center" />
            <TextBlock
                Width="200"
                FontSize="27"
                FontWeight="Light"
                Text="NineGrid"
                TextAlignment="Center" />
        </StackPanel>
        <StackPanel
            HorizontalAlignment="Center"
            Orientation="Horizontal"
            Spacing="70">
            <Image
                x:Name="img"
                Width="100"
                Height="100"
                Margin="50,0,0,0"
                Source="ms-appx:///Assets/test_image_125_125.png"
                Stretch="UniformToFill" />
            <Canvas
                x:Name="canvas"
                Width="200"
                Height="200" />
        </StackPanel>
        <StackPanel
            HorizontalAlignment="Center"
            Orientation="Horizontal"
            Spacing="20">
            <Canvas
                x:Name="canvas1"
                Width="200"
                Height="200" />
            <Grid>
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="20"
                    FontWeight="Light"
                    Text="IsCenterHollow"
                    TextAlignment="Center" />
                <Canvas
                    x:Name="canvas2"
                    Width="200"
                    Height="200" />
            </Grid>
        </StackPanel>
    </StackPanel>
</UserControl>
