<Page
	x:Class="UITests.Shared.Windows_UI_Xaml_Input.ContextMenu.TextBox_ContextMenu_Flyout"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<Grid Padding="12">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<!-- Header -->
		<StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
			<TextBlock Text="TextBox Context Menu (TextCommandBarFlyout) Issues" FontSize="18" FontWeight="SemiBold" />
			<TextBlock Text="Repro scenarios for TextCommandBarFlyout visual and behavioral bugs on Skia (kahua-private#436)."
					   TextWrapping="Wrap" Foreground="Gray" />
		</StackPanel>

		<!-- Test Areas -->
		<ScrollViewer Grid.Row="1">
			<StackPanel Spacing="16">

				<!-- Issue 1: DropShadow incorrect size -->
				<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
						CornerRadius="8" Padding="16">
					<StackPanel Spacing="8">
						<TextBlock Text="1. DropShadow Incorrect Size" FontWeight="SemiBold" />
						<TextBlock TextWrapping="Wrap" Foreground="Gray"
								   Text="Right-click the TextBox to open the context menu. Observe the drop shadow behind the flyout — it should match the flyout dimensions exactly. Bug: shadow may be too large or offset." />
						<TextBox x:Name="ShadowSizeTextBox"
								 Text="Right-click me to check drop shadow size"
								 Width="400" HorizontalAlignment="Left" />
					</StackPanel>
				</Border>

				<!-- Issue 2: Scrollbar appearing in context menu -->
				<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
						CornerRadius="8" Padding="16">
					<StackPanel Spacing="8">
						<TextBlock Text="2. Scrollbar Appearing in Context Menu" FontWeight="SemiBold" />
						<TextBlock TextWrapping="Wrap" Foreground="Gray"
								   Text="Right-click the TextBox. The context menu flyout should NOT show a scrollbar. Bug: a vertical scrollbar erroneously appears inside the CommandBarFlyout." />
						<TextBox x:Name="ScrollbarTextBox"
								 Text="Right-click me to check for spurious scrollbar"
								 Width="400" HorizontalAlignment="Left" />
					</StackPanel>
				</Border>

				<!-- Issue 3: DropShadow remains after submenu command execution -->
				<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
						CornerRadius="8" Padding="16">
					<StackPanel Spacing="8">
						<TextBlock Text="3. DropShadow Remains After Submenu Command" FontWeight="SemiBold" />
						<TextBlock TextWrapping="Wrap" Foreground="Gray"
								   Text="Right-click the TextBox, expand a submenu (e.g. click the '...' overflow), then execute a command from the submenu. After the flyout closes, the drop shadow artifact should NOT remain on screen." />
						<TextBox x:Name="ShadowRemainTextBox"
								 Text="Select some text, right-click, use submenu, then check for leftover shadow"
								 Width="400" HorizontalAlignment="Left" />
						<TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="12"
								   Text="Steps: 1) Select text above 2) Right-click 3) Click overflow '...' to see secondary commands 4) Execute a command 5) Check if shadow artifact remains" />
					</StackPanel>
				</Border>

				<!-- Issue 4: Mouse-over submenu causes unintended behavior -->
				<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
						CornerRadius="8" Padding="16">
					<StackPanel Spacing="8">
						<TextBlock Text="4. Mouse-Over Submenu Unintended Behavior" FontWeight="SemiBold" />
						<TextBlock TextWrapping="Wrap" Foreground="Gray"
								   Text="Right-click the TextBox, then hover the mouse over submenu items WITHOUT clicking. Bug: merely hovering over submenu items may cause unexpected navigation, flickering, or erroneous selection." />
						<TextBox x:Name="HoverSubmenuTextBox"
								 Text="Right-click, then hover over submenu items without clicking"
								 Width="400" HorizontalAlignment="Left" />
					</StackPanel>
				</Border>

				<!-- Issue 5: Clipboard commands intermittently missing (PrimaryCommands = 0) -->
				<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
						CornerRadius="8" Padding="16">
					<StackPanel Spacing="8">
						<TextBlock Text="5. Clipboard Commands Intermittently Missing" FontWeight="SemiBold" />
						<TextBlock TextWrapping="Wrap" Foreground="Gray"
								   Text="Right-click the TextBox repeatedly (try 10+ times). Sometimes the flyout briefly flashes and disappears with 0 PrimaryCommands (Cut/Copy/Paste missing). Click 'Inspect Flyout' after right-clicking to check command counts." />
						<TextBox x:Name="MissingCommandsTextBox"
								 Text="Select this text, then right-click repeatedly to repro intermittent missing commands"
								 Width="400" HorizontalAlignment="Left" />
						<StackPanel Orientation="Horizontal" Spacing="8">
							<Button x:Name="InspectFlyoutButton"
									Content="Inspect Flyout"
									Click="OnInspectFlyoutClick" />
							<Button x:Name="SelectAllAndInspectButton"
									Content="Select All + Inspect"
									Click="OnSelectAllAndInspectClick" />
						</StackPanel>
						<TextBlock x:Name="FlyoutInspectResult" TextWrapping="Wrap" Foreground="Gray" FontFamily="Consolas" FontSize="12"
								   Text="Click 'Inspect Flyout' to see command counts..." />
					</StackPanel>
				</Border>

				<!-- Issue 5b: Multiple TextBoxes to test rapid context switching -->
				<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
						CornerRadius="8" Padding="16">
					<StackPanel Spacing="8">
						<TextBlock Text="5b. Rapid Context Menu Switching Between TextBoxes" FontWeight="SemiBold" />
						<TextBlock TextWrapping="Wrap" Foreground="Gray"
								   Text="Right-click TextBox A, then quickly right-click TextBox B before the first flyout fully closes. This can trigger the PrimaryCommands=0 bug more reliably." />
						<TextBox x:Name="RapidSwitchTextBoxA"
								 Text="TextBox A - Right-click me first"
								 Width="400" HorizontalAlignment="Left" />
						<TextBox x:Name="RapidSwitchTextBoxB"
								 Text="TextBox B - Then quickly right-click me"
								 Width="400" HorizontalAlignment="Left" />
						<TextBox x:Name="RapidSwitchTextBoxC"
								 Text="TextBox C - And then right-click me"
								 Width="400" HorizontalAlignment="Left" />
					</StackPanel>
				</Border>

				<!-- Additional: TextBox states that may affect commands -->
				<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
						CornerRadius="8" Padding="16">
					<StackPanel Spacing="8">
						<TextBlock Text="6. TextBox States Affecting Context Menu" FontWeight="SemiBold" />
						<TextBlock TextWrapping="Wrap" Foreground="Gray"
								   Text="Right-click each TextBox below. Different states (empty, read-only, with selection) should show appropriate commands. Verify no empty/broken flyouts." />

						<TextBlock Text="Empty TextBox:" FontSize="12" />
						<TextBox x:Name="EmptyTextBox"
								 PlaceholderText="I'm empty — right-click me"
								 Width="400" HorizontalAlignment="Left" />

						<TextBlock Text="ReadOnly TextBox:" FontSize="12" />
						<TextBox x:Name="ReadOnlyTextBox"
								 Text="I am read-only — only Copy and Select All should appear"
								 IsReadOnly="True"
								 Width="400" HorizontalAlignment="Left" />

						<TextBlock Text="TextBox with pre-selected text:" FontSize="12" />
						<TextBox x:Name="PreSelectedTextBox"
								 Text="This text should be selected"
								 Width="400" HorizontalAlignment="Left"
								 Loaded="OnPreSelectedTextBoxLoaded" />

						<TextBlock Text="Multi-line TextBox:" FontSize="12" />
						<TextBox x:Name="MultiLineTextBox"
								 Text="Line 1&#x0a;Line 2&#x0a;Line 3&#x0a;Right-click to test context menu on multi-line"
								 AcceptsReturn="True"
								 Height="100"
								 Width="400" HorizontalAlignment="Left" />
					</StackPanel>
				</Border>

			</StackPanel>
		</ScrollViewer>

		<!-- Event Log -->
		<Border Grid.Row="2"
				Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
				CornerRadius="8" Padding="12" Margin="0,12,0,0"
				MaxHeight="200">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>

				<Grid Grid.Row="0" Margin="0,0,0,8">
					<TextBlock Text="Event Log" FontWeight="SemiBold" VerticalAlignment="Center" />
					<Button Content="Clear" Click="OnClearLogClick" HorizontalAlignment="Right" Padding="8,4" />
				</Grid>

				<ScrollViewer Grid.Row="1" x:Name="LogScrollViewer">
					<TextBlock x:Name="EventLogText"
							   Text="Events will be logged here..."
							   TextWrapping="Wrap"
							   FontFamily="Consolas"
							   FontSize="12" />
				</ScrollViewer>
			</Grid>
		</Border>
	</Grid>
</Page>
