<Page
	x:Class="UITests.Shared.Windows_UI_Xaml_Input.ContextMenu.TextBox_ContextMenu_Compositor"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<Grid Padding="12">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<!-- Header -->
		<StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,12">
			<TextBlock Text="TextBox Context Menu Compositor Pattern" FontSize="18" FontWeight="SemiBold" />
			<TextBlock Text="Repro for TextCommandBarFlyout issues when dynamically adding custom AppBarButtons with MenuFlyout submenus to SecondaryCommands."
					   TextWrapping="Wrap" Foreground="Gray" />
		</StackPanel>

		<!-- Test Areas -->
		<ScrollViewer Grid.Row="1">
			<StackPanel Spacing="16">

				<!-- Scenario 1: Paste Special Submenu -->
				<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
						CornerRadius="8" Padding="16">
					<StackPanel Spacing="8">
						<TextBlock Text="1. Paste Special Submenu (AppBarButton + MenuFlyout)" FontWeight="SemiBold" />
						<TextBlock TextWrapping="Wrap" Foreground="Gray"
								   Text="Right-click the TextBox. The context menu should show standard commands (Cut/Copy/Paste) plus a custom 'Paste Special' AppBarButton in secondary commands with a submenu containing 3 items. Check: shadow size, scrollbar, submenu hover behavior." />
						<TextBox x:Name="PasteSpecialTextBox"
								 Text="Right-click me to see Paste Special submenu"
								 Width="400" HorizontalAlignment="Left" />
						<StackPanel Orientation="Horizontal" Spacing="8">
							<Button x:Name="InspectPasteSpecialButton"
									Content="Inspect Flyout"
									Click="OnInspectPasteSpecialClick" />
						</StackPanel>
						<TextBlock x:Name="PasteSpecialInspectResult" TextWrapping="Wrap" Foreground="Gray" FontFamily="Consolas" FontSize="12"
								   Text="Click 'Inspect Flyout' after right-clicking..." />
					</StackPanel>
				</Border>

				<!-- Scenario 2: Many Custom Items (Overflow) -->
				<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
						CornerRadius="8" Padding="16">
					<StackPanel Spacing="8">
						<TextBlock Text="2. Many Custom Items (Overflow / Scrollbar Test)" FontWeight="SemiBold" />
						<TextBlock TextWrapping="Wrap" Foreground="Gray"
								   Text="Right-click the TextBox. The compositor adds 6 custom AppBarButtons to SecondaryCommands in addition to system commands. Bug: a vertical scrollbar may erroneously appear inside the CommandBarFlyout." />
						<TextBox x:Name="OverflowTextBox"
								 Text="Right-click me to test overflow with many custom items"
								 Width="400" HorizontalAlignment="Left" />
						<Button Content="Inspect Flyout"
								Click="OnInspectOverflowClick" />
						<TextBlock x:Name="OverflowInspectResult" TextWrapping="Wrap" Foreground="Gray" FontFamily="Consolas" FontSize="12"
								   Text="Click 'Inspect Flyout' after right-clicking..." />
					</StackPanel>
				</Border>

				<!-- Scenario 3: Separator Between System and Custom Commands -->
				<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
						CornerRadius="8" Padding="16">
					<StackPanel Spacing="8">
						<TextBlock Text="3. AppBarSeparator Between System and Custom Commands" FontWeight="SemiBold" />
						<TextBlock TextWrapping="Wrap" Foreground="Gray"
								   Text="Right-click the TextBox. An AppBarSeparator should visually separate the system commands (Undo/Redo/SelectAll) from custom items. Check shadow sizing accounts for the separator." />
						<TextBox x:Name="SeparatorTextBox"
								 Text="Right-click me to test separator between system and custom commands"
								 Width="400" HorizontalAlignment="Left" />
					</StackPanel>
				</Border>

				<!-- Scenario 4: Rapid Context Switching with Static Shared Items -->
				<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
						CornerRadius="8" Padding="16">
					<StackPanel Spacing="8">
						<TextBlock Text="4. Rapid Context Switching (Static Shared Items)" FontWeight="SemiBold" />
						<TextBlock TextWrapping="Wrap" Foreground="Gray"
								   Text="These 4 TextBoxes share the same static AppBarButton instances (matching the client pattern for 1000s of TextBoxes). Rapidly right-click between them. Bug: PrimaryCommands=0 can occur because static items may still be parented to the previous flyout when the next one opens." />
						<TextBox x:Name="RapidSwitchA"
								 Text="TextBox A - Right-click me first"
								 Width="400" HorizontalAlignment="Left" />
						<TextBox x:Name="RapidSwitchB"
								 Text="TextBox B - Then quickly right-click me"
								 Width="400" HorizontalAlignment="Left" />
						<TextBox x:Name="RapidSwitchC"
								 Text="TextBox C - And then right-click me"
								 Width="400" HorizontalAlignment="Left" />
						<TextBox x:Name="RapidSwitchD"
								 Text="TextBox D - Keep switching rapidly"
								 Width="400" HorizontalAlignment="Left" />
						<TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="12"
								   Text="Note: Subscribe pattern uses GettingFocus/LosingFocus (matching client). Static shared items means the same AppBarButton instance is reused across all 4 flyouts." />
					</StackPanel>
				</Border>

				<!-- Scenario 5: Submenu Command Execution and Shadow Cleanup -->
				<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
						CornerRadius="8" Padding="16">
					<StackPanel Spacing="8">
						<TextBlock Text="5. Submenu Command Execution + Shadow Cleanup" FontWeight="SemiBold" />
						<TextBlock TextWrapping="Wrap" Foreground="Gray"
								   Text="Right-click, expand the 'Paste Special' submenu, then click an item. The flyout and submenu should close, and no shadow artifact should remain on screen." />
						<TextBox x:Name="ShadowCleanupTextBox"
								 Text="Select text, right-click, use submenu item, check for leftover shadow"
								 Width="400" HorizontalAlignment="Left" />
						<TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="12"
								   Text="Steps: 1) Select text 2) Right-click 3) Click '...' overflow 4) Click 'Paste Special' to expand submenu 5) Click a submenu item 6) Verify no shadow artifact remains" />
					</StackPanel>
				</Border>

			</StackPanel>
		</ScrollViewer>

		<!-- Event Log -->
		<Border Grid.Row="2"
				Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
				CornerRadius="8" Padding="12" Margin="0,12,0,0"
				MaxHeight="200">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>

				<Grid Grid.Row="0" Margin="0,0,0,8">
					<TextBlock Text="Event Log" FontWeight="SemiBold" VerticalAlignment="Center" />
					<Button Content="Clear" Click="OnClearLogClick" HorizontalAlignment="Right" Padding="8,4" />
				</Grid>

				<ScrollViewer Grid.Row="1" x:Name="LogScrollViewer">
					<TextBlock x:Name="EventLogText"
							   Text="Events will be logged here..."
							   TextWrapping="Wrap"
							   FontFamily="Consolas"
							   FontSize="12" />
				</ScrollViewer>
			</Grid>
		</Border>
	</Grid>
</Page>
