<Page x:Class="UITests.Toolkit.ElevationView_Clipping"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Toolkit"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:Uno.UI.Toolkit"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Page.Resources>
		<Style x:Key="style1"
		    TargetType="ContentControl">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ContentControl">
						<toolkit:ElevatedView Background="{TemplateBinding Background}"
						    Elevation="15"
						    ShadowColor="Chartreuse">
							<ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
							    VerticalAlignment="{TemplateBinding VerticalAlignment}"
							    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
							    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
							    Content="{TemplateBinding Content}"
							    ContentTemplate="{TemplateBinding ContentTemplate}" />
						</toolkit:ElevatedView>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Page.Resources>

	<StackPanel Spacing="10">
		<TextBlock>The following rectangles should have the same drop shadow...</TextBlock>

		<StackPanel Orientation="Horizontal"
		    Spacing="15">
			<toolkit:ElevatedView Background="Blue"
			    Elevation="15"
			    ShadowColor="Chartreuse">
				<Border Width="40"
				    Height="40"
				    Background="Red" />
			</toolkit:ElevatedView>

			<ContentControl>
				<toolkit:ElevatedView Elevation="15"
				    ShadowColor="Chartreuse">
					<Border Width="40"
					    Height="40"
					    Background="Red" />
				</toolkit:ElevatedView>
			</ContentControl>

			<Border>
				<toolkit:ElevatedView Elevation="15"
				    ShadowColor="Chartreuse">
					<Border Width="40"
					    Height="40"
					    Background="Red" />
				</toolkit:ElevatedView>
			</Border>

			<ContentControl Style="{StaticResource style1}">
				<Border Width="40"
				    Height="40"
				    Background="Red" />
			</ContentControl>

			<ContentControl Width="40"
			    Height="40"
			    Background="Red"
			    Style="{StaticResource style1}">
				<Border />
			</ContentControl>

			<ContentControl Width="40"
			    Height="40"
			    Background="Red"
			    Style="{StaticResource style1}">
				<Border Width="40"
				    Height="40"
				    Background="Red" />
			</ContentControl>

			<ContentControl Style="{StaticResource style1}">
				<Border Width="40"
				    Height="40"
				    Background="Red" />
			</ContentControl>
		</StackPanel>

	</StackPanel>
</Page>
