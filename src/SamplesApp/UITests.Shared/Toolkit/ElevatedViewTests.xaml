<Page x:Class="UITests.Toolkit.ElevatedViewTests"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:Uno.UI.Toolkit"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Grid Margin="15"
	    RowSpacing="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<StackPanel Spacing="10">
			<Slider x:Name="elevation1"
			    Maximum="50"
			    Minimum="0"
			    Value="10" />
			<StackPanel Orientation="Horizontal"
			    Spacing="10">
				<Button x:Name="noElevation"
				    Click="SetElevationClick"
				    Tag="0">
					NO ELEVATION
				</Button>
				<Button x:Name="lowElevation"
				    Click="SetElevationClick"
				    Tag="4">
					LOW ELEVATION (4)
				</Button>
				<Button x:Name="highElevation"
				    Click="SetElevationClick"
				    Tag="20">
					HIGH ELEVATION (20)
				</Button>
			</StackPanel>
		</StackPanel>
		<ScrollViewer Grid.Row="1"
		    VerticalScrollMode="Enabled">
			<StackPanel Spacing="10">
				<TextBlock>
					ElevatedView With Default Color
				</TextBlock>
				<Grid Padding="16">
					<toolkit:ElevatedView Background="Orange"
					    Elevation="{Binding Value, ElementName=elevation1}">
						<Rectangle Width="60"
						    Height="60"
						    Fill="Red" />
					</toolkit:ElevatedView>
				</Grid>
				<StackPanel Orientation="Horizontal"
				    Spacing="10">
					<Button x:Name="blackColor"
					    Background="Black"
					    Click="SetColor"
					    Foreground="White"
					    Tag="Black">
						BLACK SHADOW
					</Button>
					<Button x:Name="yellowColor"
					    Background="Yellow"
					    Click="SetColor"
					    Tag="Yellow">
						YELLOW SHADOW
					</Button>
					<Button x:Name="redColor"
					    Background="Red"
					    Click="SetColor"
					    Tag="Red">
						RED SHADOW
					</Button>
					<Button x:Name="blueColor"
					    Background="Blue"
					    Click="SetColor"
					    Foreground="White"
					    Tag="Blue">
						BLUE SHADOW
					</Button>
				</StackPanel>
				<TextBlock FontSize="15">
					ElevatedView, some with rounded corners...
				</TextBlock>
				<StackPanel Orientation="Horizontal"
				    Spacing="10">
					<toolkit:ElevatedView Width="60"
					    Height="60"
					    Background="Orange"
					    Elevation="{Binding Value, ElementName=elevation1}"
					    ShadowColor="{Binding Tag, ElementName=elevation1}" />
					<toolkit:ElevatedView Width="60"
					    Height="60"
					    Background="Orange"
					    Elevation="{Binding Value, ElementName=elevation1}"
					    ShadowColor="{Binding Tag, ElementName=elevation1}">
						<Rectangle Fill="Red" />
					</toolkit:ElevatedView>
					<toolkit:ElevatedView Width="60"
					    Height="60"
					    Background="Orange"
					    CornerRadius="20"
					    Elevation="{Binding Value, ElementName=elevation1}"
					    ShadowColor="{Binding Tag, ElementName=elevation1}">
						<Rectangle Fill="Red"
						    Stroke="Blue"
						    StrokeThickness="6" />
					</toolkit:ElevatedView>
					<toolkit:ElevatedView Width="60"
					    Height="60"
					    Background="Orange"
					    CornerRadius="10,5,10,35"
					    Elevation="{Binding Value, ElementName=elevation1}"
					    ShadowColor="{Binding Tag, ElementName=elevation1}">
						<Rectangle Fill="Red"
						    Stroke="Blue"
						    StrokeThickness="6" />
					</toolkit:ElevatedView>
				</StackPanel>
				<TextBlock FontSize="15">
					ElevatedView with Button in them...
				</TextBlock>
				<StackPanel Orientation="Horizontal"
				    Spacing="10">
					<toolkit:ElevatedView VerticalAlignment="Top"
					    Background="Orange"
					    Elevation="{Binding Value, ElementName=elevation1}"
					    ShadowColor="{Binding Tag, ElementName=elevation1}">
						<Button>Nice Elevated Button</Button>
					</toolkit:ElevatedView>
					<toolkit:ElevatedView Background="White"
					    Elevation="{Binding Value, ElementName=elevation1}"
					    ShadowColor="{Binding Tag, ElementName=elevation1}">
						<Button Width="120"
						    Height="120">
							BIG BUTTON
						</Button>
					</toolkit:ElevatedView>
				</StackPanel>
				<TextBlock FontSize="15">
					ElevatedView Without background (shouldn't be elevated)
				</TextBlock>
				<StackPanel Orientation="Horizontal"
				    Spacing="10">
					<toolkit:ElevatedView Width="60"
					    Height="60"
					    Elevation="{Binding Value, ElementName=elevation1}"
					    ShadowColor="{Binding Tag, ElementName=elevation1}">
						<Rectangle Fill="Red" />
					</toolkit:ElevatedView>
					<toolkit:ElevatedView Width="60"
					    Height="60"
					    CornerRadius="10,5,10,35"
					    Elevation="{Binding Value, ElementName=elevation1}"
					    ShadowColor="{Binding Tag, ElementName=elevation1}">
						<Rectangle Fill="Red" />
					</toolkit:ElevatedView>
					<toolkit:ElevatedView VerticalAlignment="Top"
					    Elevation="{Binding Value, ElementName=elevation1}"
					    ShadowColor="{Binding Tag, ElementName=elevation1}">
						<Button>Nice Elevated Button</Button>
					</toolkit:ElevatedView>
					<toolkit:ElevatedView Elevation="{Binding Value, ElementName=elevation1}"
					    ShadowColor="{Binding Tag, ElementName=elevation1}">
						<Button Width="120"
						    Height="120">
							BIG BUTTON
						</Button>
					</toolkit:ElevatedView>
				</StackPanel>
			</StackPanel>
		</ScrollViewer>
	</Grid>
</Page>
