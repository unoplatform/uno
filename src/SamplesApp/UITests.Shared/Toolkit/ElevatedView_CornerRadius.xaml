<Page x:Class="UITests.Toolkit.ElevatedView_CornerRadius"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:Uno.UI.Toolkit"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<StackPanel Margin="12"
	    Spacing="10">
		<Slider x:Name="elevation"
		    Maximum="50"
		    Minimum="0"
		    Value="10" />
		<Slider x:Name="radius"
		    Maximum="50"
		    Minimum="0"
		    Value="25" />
		<TextBlock FontSize="15">Those elevated views should all be identical</TextBlock>

		<StackPanel Orientation="Horizontal"
		    Spacing="15">
			<toolkit:ElevatedView Width="120"
			    Height="120"
			    Margin="0,30"
			    Background="Transparent"
			    CornerRadius="{Binding Value, ElementName=radius}"
			    Elevation="{Binding Value, ElementName=elevation}">
				<Rectangle Width="120"
				    Height="120"
				    Fill="Orange" />
			</toolkit:ElevatedView>
			<toolkit:ElevatedView Width="120"
			    Height="120"
			    Margin="0,30"
			    Background="Orange"
			    CornerRadius="{Binding Value, ElementName=radius}"
			    Elevation="{Binding Value, ElementName=elevation}" />
			<StackPanel Margin="0,30">
				<toolkit:ElevatedView Width="120"
				    Height="120"
				    Background="Orange"
				    CornerRadius="{Binding Value, ElementName=radius}"
				    Elevation="{Binding Value, ElementName=elevation}" />
			</StackPanel>
			<ScrollViewer Padding="30">
				<toolkit:ElevatedView Width="120"
				    Height="120"
				    Background="Orange"
				    CornerRadius="{Binding Value, ElementName=radius}"
				    Elevation="{Binding Value, ElementName=elevation}" />
			</ScrollViewer>
			<ScrollViewer>
				<toolkit:ElevatedView Width="120"
				    Height="120"
				    Margin="0,30"
				    Background="Orange"
				    CornerRadius="{Binding Value, ElementName=radius}"
				    Elevation="8" />
			</ScrollViewer>
		</StackPanel>

	</StackPanel>
</Page>
