<Page x:Class="UITests.Uno_Web.Http.CookieManagerTests"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Toolkit.Web"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wasm="http://uno.ui/wasm"
    xmlns:winui="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d wasm">

	<wasm:StackPanel Padding="12"
	    Spacing="8">
		<TextBox x:Name="NameTextBox"
		    Header="Name"
		    Text="{x:Bind ViewModel.Name, Mode=TwoWay}" />
		<TextBox x:Name="VlaueTextBox"
		    Header="Value"
		    Text="{x:Bind ViewModel.Value, Mode=TwoWay}" />
		<TextBox Header="Path"
		    Text="{x:Bind ViewModel.Path, Mode=TwoWay}" />
		<TextBox Header="Domain"
		    Text="{x:Bind ViewModel.Domain, Mode=TwoWay}" />
		<DatePicker Date="{x:Bind ViewModel.Expires, Mode=TwoWay}"
		    Header="Expires" />
		<winui:NumberBox Header="Max age"
		    Maximum="1000000"
		    Minimum="-1"
		    SpinButtonPlacementMode="Inline"
		    Value="{x:Bind ViewModel.MaxAge, Mode=TwoWay}" />
		<CheckBox Content="Secure"
		    IsChecked="{x:Bind ViewModel.Secure, Mode=TwoWay}" />
		<ComboBox Header="Same site"
		    ItemsSource="{x:Bind ViewModel.SameSiteOptions}"
		    SelectedItem="{x:Bind ViewModel.SameSite, Mode=TwoWay}" />
		<Button x:Name="SetCookieButton"
		    Command="{x:Bind ViewModel.SetCommand}">
			Set cookie
		</Button>
		<Button x:Name="DeleteCookieButton"
		    Command="{x:Bind ViewModel.DeleteCommand}">
			Delete cookie
		</Button>
		<Button x:Name="GetCookiesButton"
		    Command="{x:Bind ViewModel.GetCommand}">
			Get cookies
		</Button>
		<TextBlock x:Name="CookiesTextBlock"
		    Text="{x:Bind ViewModel.CookiesText, Mode=OneWay}" />
	</wasm:StackPanel>
</Page>
