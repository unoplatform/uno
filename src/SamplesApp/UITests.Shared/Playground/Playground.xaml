<UserControl
    x:Class="UITests.Playground.Playground"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Playground"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:monaco="using:Monaco"
    xmlns:not_wasm="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:wasm="http://uno.ui/wasm"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d wasm">

    <Grid Padding="8" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Button HorizontalAlignment="Center" Click="{x:Bind OnApply}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <SymbolIcon Symbol="Play" />
                <TextBlock Text="Apply" />
            </StackPanel>
        </Button>

        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <wasm:Grid x:Name="MonacoContainer" />
            <not_wasm:Grid>
                <TextBox
                    x:Name="xamlText"
                    AcceptsReturn="True"
                    FontFamily="ms-appx:///Assets/Fonts/CascadiaCode-Regular.ttf" />
            </not_wasm:Grid>

            <ContentControl x:Name="renderSurface" Grid.Column="1" />
        </Grid>
    </Grid>
</UserControl>
