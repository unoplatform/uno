<UserControl x:Class="UITests.Shared.Windows_Devices.AccelerometerTests"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_Devices"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:valueconverters="using:UITests.ValueConverters"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<UserControl.Resources>
		<valueconverters:BoolNegationValueConverter x:Key="BoolNegation" />
	</UserControl.Resources>

	<ContentControl IsEnabled="{Binding AccelerometerAvailable}">
		<StackPanel>
			<TextBlock Text="{Binding SensorStatus}" />

			<Button Command="{Binding AttachReadingChangedCommand}"
			    Content="Attach ReadingChanged"
			    IsEnabled="{Binding ReadingChangedAttached, Converter={StaticResource BoolNegation}}" />
			<Button Command="{Binding DetachReadingChangedCommand}"
			    Content="Detach ReadingChanged"
			    IsEnabled="{Binding ReadingChangedAttached}" />

			<TextBlock Style="{ThemeResource SubtitleTextBlockStyle}"
			    Text="Last reading" />
			<TextBlock>
				<Run FontWeight="Bold">AccelerationX:</Run>
				<Run Text="{Binding AccelerationX}" />
			</TextBlock>
			<TextBlock>
				<Run FontWeight="Bold">AccelerationY:</Run>
				<Run Text="{Binding AccelerationY}" />
			</TextBlock>
			<TextBlock>
				<Run FontWeight="Bold">AccelerationZ:</Run>
				<Run Text="{Binding AccelerationZ}" />
			</TextBlock>
			<TextBlock>
				<Run FontWeight="Bold">Timestamp:</Run>
				<Run Text="{Binding ReadingTimestamp}" />
			</TextBlock>
			<Button Margin="0,20,0,0"
			    Command="{Binding AttachShakenCommand}"
			    Content="Attach Shaken"
			    IsEnabled="{Binding ShakenAttached, Converter={StaticResource BoolNegation}}" />
			<Button Command="{Binding DetachShakenCommand}"
			    Content="Detach Shaken"
			    IsEnabled="{Binding ShakenAttached}" />
			<TextBlock Style="{ThemeResource SubtitleTextBlockStyle}"
			    Text="Last shaken" />
			<TextBlock>
				<Run FontWeight="Bold">Timestamp:</Run>
				<Run Text="{Binding ShakenTimestamp}" />
			</TextBlock>
		</StackPanel>
	</ContentControl>
</UserControl>
