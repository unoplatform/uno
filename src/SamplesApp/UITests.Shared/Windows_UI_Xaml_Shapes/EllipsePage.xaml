<Page x:Class="SamplesApp.Windows_UI_Xaml_Shapes.EllipsePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Page.Resources>
		<ResourceDictionary>

			<SolidColorBrush x:Key="LightGreyBrush"
			    Color="#000000"
			    Opacity="0.38" />
		</ResourceDictionary>
	</Page.Resources>


	<StackPanel Spacing="5">
		<TextBlock FontSize="22">This is an ellipse</TextBlock>
		<Ellipse x:Name="ellipse0"
		    Width="150"
		    Height="125"
		    HorizontalAlignment="Left"
		    Stroke="Black"
		    StrokeThickness="5" />

		<TextBlock FontSize="22">Those 3 ellipses should be identical (you should not see 4 ellipses!)</TextBlock>
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="175" />
				<ColumnDefinition Width="20" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="20" />
				<ColumnDefinition Width="175" />
				<ColumnDefinition Width="20" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>
			<Grid Grid.Column="0"
			    Width="175"
			    Height="125">
				<Rectangle Stroke="Brown"
				    StrokeDashArray="2.5,1"
				    StrokeThickness="3" />
				<Ellipse x:Name="ellipse1"
				    Width="175"
				    Height="125"
				    Fill="DarkSalmon" />
			</Grid>
			<Grid Grid.Column="2"
			    Width="175"
			    Height="125">
				<Rectangle Stroke="Brown"
				    StrokeDashArray="2.5,1"
				    StrokeThickness="3" />
				<Ellipse x:Name="ellipse2"
				    Fill="DarkSalmon" />
			</Grid>
			<Grid Grid.Column="4">
				<Rectangle Stroke="Brown"
				    StrokeDashArray="2.5,1"
				    StrokeThickness="3" />
				<Ellipse x:Name="ellipse3"
				    Height="125"
				    Fill="DarkSalmon" />
			</Grid>
			<Grid Grid.Column="6"
			    MaxWidth="175"
			    HorizontalAlignment="Left">
				<Rectangle Stroke="Brown"
				    StrokeDashArray="2.5,1"
				    StrokeThickness="3" />
				<Ellipse x:Name="ellipse4"
				    Height="125"
				    Fill="DarkGreen" />
			</Grid>
		</Grid>

		<TextBlock FontSize="22">This is an ellipse that has a fill with opacity</TextBlock>
		<Ellipse x:Name="ellipse5"
		    Width="150"
		    Height="125"
		    HorizontalAlignment="Left"
		    Stroke="Black"
		    StrokeThickness="5" />

		<TextBlock FontSize="22">This is an ellipse that has a stroke opacity</TextBlock>
		<Ellipse x:Name="ellipse6"
		    Width="150"
		    Height="125"
		    HorizontalAlignment="Left"
		    Stroke="Black"
		    StrokeThickness="5" />
	</StackPanel>
</Page>
