<Page x:Class="UITests.Windows_UI_Xaml_Shapes.Path_ClearData"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Shapes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<StackPanel Background="White">

		<TextBlock Text="You should see only one pink D (but 3 blue containers)" />

		<Border x:Name="ControlDataParent"
		    Width="150"
		    Height="150"
		    Margin="5"
		    Background="White"
		    BorderBrush="DeepSkyBlue"
		    BorderThickness="3">
			<Path Width="150"
			    Height="150"
			    Data="M25,25 L25,125 L75,125 C125,125 125,25 75,25 L25,25 Z"
			    Fill="Green" />
		</Border>

		<Border x:Name="ClearedDataParent"
		    Width="150"
		    Height="150"
		    Margin="5"
		    Background="White"
		    BorderBrush="DeepSkyBlue"
		    BorderThickness="3">
			<Path x:Name="ClearedData"
			    Width="100"
			    Height="150"
			    Data="M25,25 L25,125 L75,125 C125,125 125,25 75,25 L25,25 Z"
			    Fill="Red"
			    Loaded="ClearData" />
		</Border>

		<Border x:Name="NoDataShape"
		    Width="150"
		    Height="150"
		    Margin="5"
		    Background="White"
		    BorderBrush="DeepSkyBlue"
		    BorderThickness="3">
			<Path Width="100"
			    Height="150"
			    Fill="Red"
			    Loaded="ClearData" />
		</Border>
	</StackPanel>
</Page>
