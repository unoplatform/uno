<Page x:Class="SamplesApp.Windows_UI_Xaml_Shapes.LinePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<StackPanel Spacing="5">
		<TextBlock Text="This is a horizontal black line - Should be aligned with the red one" />
		<Line x:Name="DLinePage"
		    HorizontalAlignment="Left"
		    Stroke="Black"
		    StrokeThickness="5"
		    X1="20"
		    X2="400" />
		<Rectangle Width="380"
		    Height="5"
		    Margin="20,0,0,0"
		    HorizontalAlignment="Left"
		    Fill="Red" />

		<TextBlock Text="This is a vertical black line - Should be aligned with the red one" />
		<StackPanel Margin="25,0,0,0"
		    Orientation="Horizontal"
		    Spacing="5">
			<Line x:Name="DLinePage2"
			    VerticalAlignment="Top"
			    Stroke="Black"
			    StrokeThickness="5"
			    Y1="25"
			    Y2="100" />
			<Rectangle Width="5"
			    Height="75"
			    Margin="0,25,0,0"
			    VerticalAlignment="Top"
			    Fill="Red" />
		</StackPanel>
	</StackPanel>
</Page>
