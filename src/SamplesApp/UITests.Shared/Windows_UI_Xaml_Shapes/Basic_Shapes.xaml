<Page x:Class="UITests.Windows_UI_Xaml_Shapes.Basic_Shapes"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    x:Name="_basicShapesTestRoot"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<StackPanel Orientation="Horizontal">
			<Button Content="Settings">
				<Button.Flyout>
					<Flyout Closed="SettingsUpdated">
						<ScrollViewer>
							<StackPanel Width="550">
								<TextBlock Text="Shapes" />
								<StackPanel x:Name="_shapesConfig" />

								<TextBlock Margin="0,10,0,0"
								    Text="Stretch" />
								<StackPanel x:Name="_stretchesConfig" />

								<TextBlock Margin="0,10,0,0"
								    Text="Sizes" />
								<StackPanel x:Name="_sizesConfig" />
							</StackPanel>
						</ScrollViewer>
					</Flyout>
				</Button.Flyout>
			</Button>
			<Button Margin="5,0,0,0"
			    Click="GenerateScreenshots"
			    Content="Generate screenshots" />
			<TextBox x:Name="_idInput"
			    Margin="5,0,0,0" />
			<Button x:Name="_renderId"
			    Click="RenderById"
			    Content="Render ID" />
			<TextBlock x:Name="_runningTest"
			    Margin="5,0,0,0" />
		</StackPanel>

		<ScrollViewer x:Name="_root"
		    Grid.Row="1"
		    HorizontalScrollBarVisibility="Visible"
		    HorizontalScrollMode="Auto"
		    VerticalScrollBarVisibility="Visible"
		    VerticalScrollMode="Auto"
		    ZoomMode="Enabled" />
		<ScrollViewer Grid.Row="1"
		    HorizontalScrollBarVisibility="Visible"
		    HorizontalScrollMode="Auto"
		    VerticalScrollBarVisibility="Visible"
		    VerticalScrollMode="Auto"
		    ZoomMode="Enabled">
			<Border x:Name="_testZone"
			    HorizontalAlignment="Left"
			    VerticalAlignment="Top" />
		</ScrollViewer>
	</Grid>
</Page>
