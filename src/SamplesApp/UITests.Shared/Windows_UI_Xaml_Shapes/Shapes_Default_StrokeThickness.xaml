<UserControl
    x:Class="UITests.Windows_UI_Xaml_Shapes.Shapes_Default_StrokeThickness"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Shapes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="using:Uno.UI.Samples.Converters"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <UserControl.Resources>
        <uc:FromNullableBoolToVisibilityConverter x:Key="FromNullableBoolToVisibilityConverter" VisibilityIfTrue="Visible" />
    </UserControl.Resources>
    <StackPanel Margin="20" HorizontalAlignment="Center">
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <RadioButton
                    x:Name="MyLineSelector"
                    Content="MyLine"
                    GroupName="ShapeSelector" />
                <RadioButton
                    x:Name="MyRectSelector"
                    Content="MyRect"
                    GroupName="ShapeSelector" />
                <RadioButton
                    x:Name="MyPolylineSelector"
                    Content="MyPolyline"
                    GroupName="ShapeSelector" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <RadioButton
                    x:Name="MyPolygonSelector"
                    Content="MyPolygon"
                    GroupName="ShapeSelector" />
                <RadioButton
                    x:Name="MyEllipseSelector"
                    Content="MyEllipse"
                    GroupName="ShapeSelector" />
                <RadioButton
                    x:Name="MyPathSelector"
                    Content="MyPath"
                    GroupName="ShapeSelector" />
            </StackPanel>
            <Button x:Name="StrokeThicknessButton" Content="Set StrokeThickness" />
        </StackPanel>

        <Grid
            x:Name="TestZone"
            Width="300"
            Height="300"
            Background="White"
            BorderBrush="HotPink"
            BorderThickness="1">
            <Grid
                x:Name="MyLineGrid"
                Width="100"
                Height="10"
                Visibility="{Binding IsChecked, ElementName=MyLineSelector, Converter={StaticResource FromNullableBoolToVisibilityConverter}}">
                <Line
                    x:Name="MyLine"
                    Stroke="Red"
                    X1="0"
                    X2="100"
                    Y1="5"
                    Y2="5" />
                <Border
                    x:Name="MyLineTarget"
                    Width="10"
                    Height="10"
                    BorderBrush="Green"
                    BorderThickness="1" />
            </Grid>
            <Grid
                x:Name="MyRectGrid"
                Width="100"
                Height="100"
                Visibility="{Binding IsChecked, ElementName=MyRectSelector, Converter={StaticResource FromNullableBoolToVisibilityConverter}}">
                <Rectangle
                    x:Name="MyRect"
                    Width="100"
                    Height="100"
                    Fill="Blue"
                    Stroke="Red" />
            </Grid>
            <Grid
                x:Name="MyPolylineGrid"
                Width="101"
                Height="101"
                Visibility="{Binding IsChecked, ElementName=MyPolylineSelector, Converter={StaticResource FromNullableBoolToVisibilityConverter}}">
                <Polyline
                    x:Name="MyPolyline"
                    Points="2,2, 100,2, 100,100, 2,100, 2,2"
                    Stroke="Red" />
            </Grid>

            <Grid
                x:Name="MyPolygonGrid"
                Width="101"
                Height="101"
                Visibility="{Binding IsChecked, ElementName=MyPolygonSelector, Converter={StaticResource FromNullableBoolToVisibilityConverter}}">
                <Polygon
                    x:Name="MyPolygon"
                    Points="2,2, 100,2, 100,100, 2,100, 2,2"
                    Stroke="Red" />
            </Grid>

            <Grid
                x:Name="MyEllipseGrid"
                Width="100"
                Height="100"
                Visibility="{Binding IsChecked, ElementName=MyEllipseSelector, Converter={StaticResource FromNullableBoolToVisibilityConverter}}">
                <Ellipse
                    x:Name="MyEllipse"
                    Width="100"
                    Height="100"
                    Stroke="Red" />
            </Grid>

            <Grid x:Name="MyPathGrid" Visibility="{Binding IsChecked, ElementName=MyPathSelector, Converter={StaticResource FromNullableBoolToVisibilityConverter}}">
                <Path
                    x:Name="MyPath"
                    Data="M 10,100 C 10,300 100,-200 300,100"
                    Stroke="Red" />
                <Border
                    x:Name="MyPathTarget"
                    Width="3"
                    Height="3"
                    Margin="20,-3,0,0"
                    HorizontalAlignment="Left"
                    BorderBrush="Green"
                    BorderThickness="1" />
            </Grid>
        </Grid>
    </StackPanel>
</UserControl>
