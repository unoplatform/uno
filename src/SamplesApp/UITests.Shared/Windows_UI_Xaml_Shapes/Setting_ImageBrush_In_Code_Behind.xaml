<Page x:Class="UITests.Windows_UI_Xaml_Shapes.Setting_ImageBrush_In_Code_Behind"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Shapes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<StackPanel>
		<Button x:Name="AssignBothImagesButton"
		    Click="Button_Click"
		    Content="Test assigning and observing image brush" />
		<Border Width="150"
		    Height="150">
			<Rectangle x:Name="myShape1"
			    Width="250"
			    Height="150" />
		</Border>

		<Border Width="150"
		    Height="150">
			<Rectangle x:Name="myShape2"
			    Width="250"
			    Height="150" />
		</Border>
	</StackPanel>
</Page>
