<Page
    x:Class="UITests.Windows_UI_Xaml_Shapes.LineStretchModes"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Spacing="10">
            <TextBlock FontWeight="ExtraBold">None</TextBlock>
            <Slider
                x:Name="sliderNone"
                Maximum="300"
                Minimum="15"
                Value="50" />
            <StackPanel Orientation="Horizontal">
                <Border
                    HorizontalAlignment="Center"
                    Background="DarkSeaGreen"
                    BorderBrush="BlueViolet"
                    BorderThickness="3">
                    <Line
                        x:Name="None1"
                        Width="100"
                        Height="{Binding Value, ElementName=sliderNone}"
                        Fill="Cornsilk"
                        Stretch="None"
                        Stroke="Blue"
                        StrokeThickness="10"
                        X1="10"
                        X2="10"
                        Y1="10"
                        Y2="100" />
                </Border>
                <Border
                    HorizontalAlignment="Center"
                    Background="DarkSeaGreen"
                    BorderBrush="BlueViolet"
                    BorderThickness="3">
                    <Line
                        x:Name="None2"
                        Width="100"
                        Height="{Binding Value, ElementName=sliderNone}"
                        Fill="Cornsilk"
                        Stretch="None"
                        Stroke="Blue"
                        StrokeThickness="10"
                        X1="10"
                        X2="100"
                        Y1="10"
                        Y2="100" />
                </Border>
                <Border
                    HorizontalAlignment="Center"
                    Background="DarkSeaGreen"
                    BorderBrush="BlueViolet"
                    BorderThickness="3">
                    <Line
                        x:Name="None3"
                        Width="100"
                        Height="{Binding Value, ElementName=sliderNone}"
                        Fill="Cornsilk"
                        Stretch="None"
                        Stroke="Blue"
                        StrokeThickness="10"
                        X1="10"
                        X2="100"
                        Y1="10"
                        Y2="10" />
                </Border>
            </StackPanel>
            <TextBlock FontWeight="ExtraBold">Fill</TextBlock>
            <Slider
                x:Name="sliderFillNormal"
                Maximum="300"
                Minimum="10"
                Value="45" />
            <StackPanel Orientation="Horizontal">
                <Border
                    HorizontalAlignment="Center"
                    Background="DarkSeaGreen"
                    BorderBrush="BlueViolet"
                    BorderThickness="3">
                    <Line
                        x:Name="Fill1"
                        Width="100"
                        Height="{Binding Value, ElementName=sliderFillNormal}"
                        Fill="Cornsilk"
                        Stretch="Fill"
                        Stroke="Blue"
                        StrokeThickness="10"
                        X1="10"
                        X2="10"
                        Y1="10"
                        Y2="100" />
                </Border>
                <Border
                    HorizontalAlignment="Center"
                    Background="DarkSeaGreen"
                    BorderBrush="BlueViolet"
                    BorderThickness="3">
                    <Line
                        x:Name="Fill2"
                        Width="100"
                        Height="{Binding Value, ElementName=sliderFillNormal}"
                        Fill="Cornsilk"
                        Stretch="Fill"
                        Stroke="Blue"
                        StrokeThickness="10"
                        X1="10"
                        X2="100"
                        Y1="10"
                        Y2="100" />
                </Border>
                <Border
                    HorizontalAlignment="Center"
                    Background="DarkSeaGreen"
                    BorderBrush="BlueViolet"
                    BorderThickness="3">
                    <Line
                        x:Name="Fill3"
                        Width="100"
                        Height="{Binding Value, ElementName=sliderFillNormal}"
                        Fill="Cornsilk"
                        Stretch="Fill"
                        Stroke="Blue"
                        StrokeThickness="10"
                        X1="10"
                        X2="100"
                        Y1="10"
                        Y2="10" />
                </Border>
            </StackPanel>
            <TextBlock FontWeight="ExtraBold">UniformToFill</TextBlock>
            <Slider
                x:Name="sliderUniformToFillNormal"
                Maximum="300"
                Minimum="5"
                Value="125" />
            <StackPanel Orientation="Horizontal">
                <Border
                    HorizontalAlignment="Center"
                    Background="DarkSeaGreen"
                    BorderBrush="BlueViolet"
                    BorderThickness="3">
                    <Line
                        x:Name="UniformToFill1"
                        Width="100"
                        Height="{Binding Value, ElementName=sliderUniformToFillNormal}"
                        Fill="Cornsilk"
                        Stretch="UniformToFill"
                        Stroke="Blue"
                        StrokeThickness="10"
                        X1="10"
                        X2="10"
                        Y1="10"
                        Y2="100" />
                </Border>
                <Border
                    HorizontalAlignment="Center"
                    Background="DarkSeaGreen"
                    BorderBrush="BlueViolet"
                    BorderThickness="3">
                    <Line
                        x:Name="UniformToFill2"
                        Width="100"
                        Height="{Binding Value, ElementName=sliderUniformToFillNormal}"
                        Fill="Cornsilk"
                        Stretch="UniformToFill"
                        Stroke="Blue"
                        StrokeThickness="10"
                        X1="10"
                        X2="100"
                        Y1="10"
                        Y2="100" />
                </Border>
                <Border
                    HorizontalAlignment="Center"
                    Background="DarkSeaGreen"
                    BorderBrush="BlueViolet"
                    BorderThickness="3">
                    <Line
                        x:Name="UniformToFill3"
                        Width="100"
                        Height="{Binding Value, ElementName=sliderUniformToFillNormal}"
                        Fill="Cornsilk"
                        Stretch="UniformToFill"
                        Stroke="Blue"
                        StrokeThickness="10"
                        X1="10"
                        X2="100"
                        Y1="10"
                        Y2="10" />
                </Border>
            </StackPanel>
            <TextBlock FontWeight="ExtraBold">Uniform</TextBlock>
            <Slider
                x:Name="sliderUniformNormal"
                Maximum="300"
                Minimum="20"
                Value="150" />
            <StackPanel Orientation="Horizontal">
                <Border
                    HorizontalAlignment="Center"
                    Background="DarkSeaGreen"
                    BorderBrush="BlueViolet"
                    BorderThickness="3">
                    <Line
                        x:Name="Uniform1"
                        Width="100"
                        Height="{Binding Value, ElementName=sliderUniformNormal}"
                        Fill="Cornsilk"
                        Stretch="Uniform"
                        Stroke="Blue"
                        StrokeThickness="10"
                        X1="10"
                        X2="10"
                        Y1="10"
                        Y2="100" />
                </Border>
                <Border
                    HorizontalAlignment="Center"
                    Background="DarkSeaGreen"
                    BorderBrush="BlueViolet"
                    BorderThickness="3">
                    <Line
                        x:Name="Uniform2"
                        Width="100"
                        Height="{Binding Value, ElementName=sliderUniformNormal}"
                        Fill="Cornsilk"
                        Stretch="Uniform"
                        Stroke="Blue"
                        StrokeThickness="10"
                        X1="10"
                        X2="100"
                        Y1="10"
                        Y2="100" />
                </Border>
                <Border
                    HorizontalAlignment="Center"
                    Background="DarkSeaGreen"
                    BorderBrush="BlueViolet"
                    BorderThickness="3">
                    <Line
                        x:Name="Uniform3"
                        Width="100"
                        Height="{Binding Value, ElementName=sliderUniformNormal}"
                        Fill="Cornsilk"
                        Stretch="Uniform"
                        Stroke="Blue"
                        StrokeThickness="10"
                        X1="10"
                        X2="100"
                        Y1="10"
                        Y2="10" />
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
