<Page
    x:Class="UITests.Windows_UI_Xaml_Shapes.PathTestsControl.Path_FillRule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Shapes.PathTestsControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid
        HorizontalAlignment="Center"
        ColumnSpacing="5"
        RowSpacing="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="1">
            Path data
        </TextBlock>
        <TextBlock Grid.Row="0" Grid.Column="2">
            PathFigures
        </TextBlock>
        <TextBlock Grid.Row="0" Grid.Column="3">
            GeometryGroup
        </TextBlock>

        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            VerticalAlignment="Center"
            Foreground="Green">
            FillRule=EvenOdd
        </TextBlock>
        <TextBlock
            Grid.Row="2"
            Grid.Column="0"
            VerticalAlignment="Center"
            Foreground="Blue">
            FillRule=NonZero
        </TextBlock>

        <Grid
            Grid.Row="1"
            Grid.Column="1"
            Margin="5"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="Beige"
            BorderBrush="Brown"
            BorderThickness="1">
            <Border
                x:Name="MainTargetEvenOdd"
                Width="91"
                Height="91" />
            <Border
                x:Name="LeftTargetEvenOdd"
                Width="30"
                Height="91"
                HorizontalAlignment="Left" />
            <Border
                x:Name="RightTargetEvenOdd"
                Width="30"
                Height="91"
                HorizontalAlignment="Right" />
            <Path
                x:Name="EvenOddPath"
                Data="F0M0,0L0,60 90,60 90,30 30,30 30,90 60,90 60,0z M10,10 L20,10 20,80 10,80Z"
                Fill="Green"
                Stroke="Black"
                StrokeThickness="1" />
        </Grid>

        <Grid
            Grid.Row="2"
            Grid.Column="1"
            Margin="5"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="Beige"
            BorderBrush="Brown"
            BorderThickness="1">
            <Border
                x:Name="MainTargetNonZero"
                Width="91"
                Height="91" />
            <Border
                x:Name="LeftTargetNonZero"
                Width="30"
                Height="91"
                HorizontalAlignment="Left" />
            <Border
                x:Name="RightTargetNonZero"
                Width="30"
                Height="91"
                HorizontalAlignment="Right" />
            <Path
                x:Name="NonZeroPath"
                Data="F1M0,0L0,60 90,60 90,30 30,30 30,90 60,90 60,0z M10,10 L20,10 20,80 10,80Z"
                Fill="Blue"
                Stroke="Black"
                StrokeThickness="1" />
        </Grid>

        <Grid
            Grid.Row="1"
            Grid.Column="2"
            Margin="5"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="Beige"
            BorderBrush="Brown"
            BorderThickness="1">
            <Border
                x:Name="MainTargetEvenOdd2"
                Width="91"
                Height="91" />
            <Border
                x:Name="LeftTargetEvenOdd2"
                Width="30"
                Height="91"
                HorizontalAlignment="Left" />
            <Border
                x:Name="RightTargetEvenOdd2"
                Width="30"
                Height="91"
                HorizontalAlignment="Right" />
            <Path
                x:Name="EvenOddPath2"
                Fill="Green"
                Stroke="Black"
                StrokeThickness="1">
                <Path.Data>
                    <PathGeometry FillRule="EvenOdd">
                        <PathGeometry.Figures>
                            <PathFigure IsClosed="True" StartPoint="0,0">
                                <PathFigure.Segments>
                                    <PolyLineSegment Points="0,60 90,60 90,30 30,30 30,90 60,90 60,0" />
                                </PathFigure.Segments>
                            </PathFigure>
                            <PathFigure IsClosed="True" StartPoint="10,10">
                                <PathFigure.Segments>
                                    <PolyLineSegment Points="20,10 20,80 10,80" />
                                </PathFigure.Segments>
                            </PathFigure>
                        </PathGeometry.Figures>
                    </PathGeometry>
                </Path.Data>
            </Path>
        </Grid>

        <Grid
            Grid.Row="2"
            Grid.Column="2"
            Margin="5"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="Beige"
            BorderBrush="Brown"
            BorderThickness="1">
            <Border
                x:Name="MainTargetNonZero2"
                Width="91"
                Height="91" />
            <Border
                x:Name="LeftTargetNonZero2"
                Width="30"
                Height="91"
                HorizontalAlignment="Left" />
            <Border
                x:Name="RightTargetNonZero2"
                Width="30"
                Height="91"
                HorizontalAlignment="Right" />
            <Path
                x:Name="NonZeroPath2"
                Fill="Blue"
                Stroke="Black"
                StrokeThickness="1">
                <Path.Data>
                    <PathGeometry FillRule="NonZero">
                        <PathGeometry.Figures>
                            <PathFigure IsClosed="True" StartPoint="0,0">
                                <PathFigure.Segments>
                                    <PolyLineSegment Points="0,60 90,60 90,30 30,30 30,90 60,90 60,0" />
                                </PathFigure.Segments>
                            </PathFigure>
                            <PathFigure IsClosed="True" StartPoint="10,10">
                                <PathFigure.Segments>
                                    <PolyLineSegment Points="20,10 20,80 10,80" />
                                </PathFigure.Segments>
                            </PathFigure>
                        </PathGeometry.Figures>
                    </PathGeometry>
                </Path.Data>
            </Path>
        </Grid>

        <Grid
            Grid.Row="1"
            Grid.Column="3"
            Margin="5"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="Beige"
            BorderBrush="Brown"
            BorderThickness="1">
            <Border
                x:Name="MainTargetEvenOdd3"
                Width="91"
                Height="91" />
            <Border
                x:Name="LeftTargetEvenOdd3"
                Width="30"
                Height="91"
                HorizontalAlignment="Left" />
            <Border
                x:Name="RightTargetEvenOdd3"
                Width="30"
                Height="91"
                HorizontalAlignment="Right" />
            <Path
                x:Name="EvenOddPath3"
                Fill="Green"
                Stroke="Black"
                StrokeThickness="1">
                <Path.Data>
                    <GeometryGroup FillRule="EvenOdd">
                        <PathGeometry>
                            <PathGeometry.Figures>
                                <PathFigure IsClosed="True" StartPoint="0,0">
                                    <PathFigure.Segments>
                                        <PolyLineSegment Points="0,60 90,60 90,30 30,30 30,90 60,90 60,0" />
                                    </PathFigure.Segments>
                                </PathFigure>
                            </PathGeometry.Figures>
                        </PathGeometry>
                        <PathGeometry>
                            <PathGeometry.Figures>
                                <PathFigure IsClosed="True" StartPoint="10,10">
                                    <PathFigure.Segments>
                                        <PolyLineSegment Points="20,10 20,80 10,80" />
                                    </PathFigure.Segments>
                                </PathFigure>
                            </PathGeometry.Figures>
                        </PathGeometry>
                    </GeometryGroup>
                </Path.Data>
            </Path>
        </Grid>

        <Grid
            Grid.Row="2"
            Grid.Column="3"
            Margin="5"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="Beige"
            BorderBrush="Brown"
            BorderThickness="1">
            <Border
                x:Name="MainTargetNonZero3"
                Width="91"
                Height="91" />
            <Border
                x:Name="LeftTargetNonZero3"
                Width="30"
                Height="91"
                HorizontalAlignment="Left" />
            <Border
                x:Name="RightTargetNonZero3"
                Width="30"
                Height="91"
                HorizontalAlignment="Right" />
            <Path
                x:Name="NonZeroPath3"
                Fill="Blue"
                Stroke="Black"
                StrokeThickness="1">
                <Path.Data>
                    <GeometryGroup FillRule="NonZero">
                        <PathGeometry>
                            <PathGeometry.Figures>
                                <PathFigure IsClosed="True" StartPoint="0,0">
                                    <PathFigure.Segments>
                                        <PolyLineSegment Points="0,60 90,60 90,30 30,30 30,90 60,90 60,0" />
                                    </PathFigure.Segments>
                                </PathFigure>
                            </PathGeometry.Figures>
                        </PathGeometry>
                        <PathGeometry>
                            <PathGeometry.Figures>
                                <PathFigure IsClosed="True" StartPoint="10,10">
                                    <PathFigure.Segments>
                                        <PolyLineSegment Points="20,10 20,80 10,80" />
                                    </PathFigure.Segments>
                                </PathFigure>
                            </PathGeometry.Figures>
                        </PathGeometry>
                    </GeometryGroup>
                </Path.Data>
            </Path>
        </Grid>
    </Grid>
</Page>
