<UserControl x:Class="UITests.Windows_UI_Xaml_Shapes.PathTestsControl.Path_LineGeometry"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Shapes.PathTestsControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<Grid>
		<Border x:Name="HostBorder"
		    Margin="5"
		    HorizontalAlignment="Center"
		    VerticalAlignment="Center"
		    Background="Yellow">
			<Path Stroke="Green"
			    StrokeThickness="20">
				<Path.Data>
					<LineGeometry EndPoint="50,10"
					    StartPoint="10,10" />
				</Path.Data>
			</Path>
		</Border>
	</Grid>
</UserControl>
