<UserControl x:Class="SamplesApp.Windows_UI_Xaml_Shapes.PathTestsControl.Path_Geometry"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<StackPanel>

		<Border Margin="10"
		    HorizontalAlignment="Left"
		    BorderBrush="Red"
		    BorderThickness="2">
			<Grid Width="100"
			    Height="100"
			    BorderBrush="Red"
			    BorderThickness="0">
				<Path Fill="Transparent"
				    Stroke="{ThemeResource SystemControlBackgroundBaseLowBrush}"
				    StrokeDashCap="Flat"
				    StrokeThickness="10">
					<Path.Data>
						<PathGeometry>
							<PathGeometry.Figures>
								<PathFigureCollection>
									<PathFigure x:Name="OutlineFigurePart"
									    StartPoint="50,5">
										<PathFigure.Segments>
											<PathSegmentCollection>
												<ArcSegment x:Name="OutlineArcPart"
												    IsLargeArc="True"
												    Point="49.99,5"
												    Size="45,45"
												    SweepDirection="Clockwise" />
											</PathSegmentCollection>
										</PathFigure.Segments>
									</PathFigure>
								</PathFigureCollection>
							</PathGeometry.Figures>
						</PathGeometry>
					</Path.Data>
				</Path>
				<!--  Progress Bar  -->
				<Path Fill="Transparent"
				    Stroke="{ThemeResource SystemControlHighlightAccentBrush}"
				    StrokeDashCap="Flat"
				    StrokeThickness="10">
					<Path.Data>
						<PathGeometry>
							<PathGeometry.Figures>
								<PathFigureCollection>
									<PathFigure x:Name="BarFigurePart"
									    StartPoint="50,5">
										<PathFigure.Segments>
											<PathSegmentCollection>
												<ArcSegment x:Name="BarArcPart"
												    IsLargeArc="False"
												    Point="95,50"
												    Size="45,45"
												    SweepDirection="Clockwise" />
											</PathSegmentCollection>
										</PathFigure.Segments>
									</PathFigure>
								</PathFigureCollection>
							</PathGeometry.Figures>
						</PathGeometry>
					</Path.Data>
				</Path>
			</Grid>
		</Border>

		<Border Margin="10"
		    HorizontalAlignment="Left"
		    BorderBrush="Red"
		    BorderThickness="2">
			<Path Fill="#CCCCFF"
			    Stroke="Black"
			    StrokeThickness="1">
				<Path.Data>
					<GeometryGroup>
						<!--<RectangleGeometry Rect="50,5 100,10" />
					<RectangleGeometry Rect="5,5 95,180" />
					<EllipseGeometry Center="100, 100" RadiusX="20" RadiusY="30"/>
					<RectangleGeometry Rect="50,175 100,10" />-->
						<PathGeometry>
							<PathGeometry.Figures>
								<PathFigureCollection>
									<PathFigure IsClosed="true"
									    StartPoint="50,50">
										<PathFigure.Segments>
											<PathSegmentCollection>
												<BezierSegment Point1="75,300"
												    Point2="125,100"
												    Point3="150,50" />
												<BezierSegment Point1="125,300"
												    Point2="75,100"
												    Point3="50,50" />
											</PathSegmentCollection>
										</PathFigure.Segments>
									</PathFigure>
								</PathFigureCollection>
							</PathGeometry.Figures>
						</PathGeometry>
					</GeometryGroup>
				</Path.Data>
			</Path>
		</Border>

	</StackPanel>

</UserControl>
