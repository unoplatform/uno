<Page x:Class="UITests.Shared.Wasm.Wasm_CustomEvent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

	<StackPanel Margin="10"
	    Spacing="8">
		<TextBlock TextWrapping="Wrap">This test is for the WASM target only. Don't do anything on other platforms.</TextBlock>
		<Border x:Name="genericEvent"
		    Height="100"
		    Background="BurlyWood">
			<TextBlock>Tap here to generate a generic html event</TextBlock>
		</Border>
		<Border x:Name="customEventString"
		    Height="100"
		    Background="Cyan">
			<TextBlock>Tap here to generate a custom html event with string payload</TextBlock>
		</Border>
		<Border x:Name="customEventJson"
		    Height="100"
		    Background="BurlyWood">
			<TextBlock>Tap here to generate a custom html event with json payload</TextBlock>
		</Border>
		<TextBlock x:Name="tapResult"
		    FontSize="25"
		    FontWeight="Bold" />
		<TextBlock x:Name="result">Result here...</TextBlock>

	</StackPanel>
</Page>
