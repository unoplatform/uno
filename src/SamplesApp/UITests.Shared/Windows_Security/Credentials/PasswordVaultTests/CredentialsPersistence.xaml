<UserControl
    x:Class="UITests.Shared.Windows_Security_Credentials.PasswordVaultTests.CredentialsPersistence"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_Security_Credentials.PasswordVaultTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <StackPanel>
        <Button Content="Load all credentials from the vault" Tapped="LoadFromVault" />
        <Button Content="Write basic credentials to the vault" Tapped="WriteToVault" />
        <TextBlock x:Name="_output" />
    </StackPanel>
</UserControl>
