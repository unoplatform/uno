<Page
    x:Class="SamplesApp.UITests.Windows_Security_Authentication_Web.AuthenticationBroker_Demo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SamplesApp.UITests.Windows_Security_Authentication_Web"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel Spacing="6">
        <StackPanel Orientation="Horizontal">
            <Button
                x:Name="btnSignin"
                Click="SignIn_Clicked"
                IsEnabled="False">
                Sign In
            </Button>
            <Button
                x:Name="btnSignout"
                Click="SignOut_Clicked"
                IsEnabled="False">
                Sign Out
            </Button>
        </StackPanel>
        <TextBlock x:Name="resultTxt" />
    </StackPanel>
</Page>
