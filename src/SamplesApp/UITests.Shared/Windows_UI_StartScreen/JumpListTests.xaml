<UserControl
    x:Class="UITests.Shared.Windows_UI_StartScreen.JumpListTests"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_StartScreen"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:startScreen="using:Windows.UI.StartScreen"
    d:DesignHeight="800"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel>
            <CheckBox
                Content="IsSupported"
                IsChecked="{x:Bind Model.IsSupported}"
                IsEnabled="False" />
            <Button
                Command="{x:Bind Model.LoadCurrentCommand}"
                Content="Load current"
                IsEnabled="{x:Bind Model.IsSupported}" />
            <ListView ItemsSource="{x:Bind Model.Items, Mode=OneWay}" SelectedItem="{x:Bind Model.SelectedItem, Mode=TwoWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="startScreen:JumpListItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{x:Bind DisplayName}" />
                            <TextBlock
                                Grid.Row="1"
                                Opacity="0.8"
                                Text="{x:Bind Description}" />
                        </Grid>

                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <Button Command="{x:Bind Model.RemoveItemCommand}" IsEnabled="{x:Bind Model.ItemSelected, Mode=OneWay}">
                Remove item
            </Button>
            <ContentControl Margin="0,12" IsEnabled="{x:Bind Model.IsLoaded, Mode=OneWay}">
                <StackPanel
                    Width="240"
                    Padding="12"
                    BorderBrush="Gray"
                    BorderThickness="2"
                    Orientation="Vertical"
                    Spacing="6">
                    <TextBox Header="Arguments" Text="{Binding NewItem.Arguments, Mode=TwoWay}" />
                    <TextBox Header="Display name" Text="{Binding NewItem.DisplayName, Mode=TwoWay}" />
                    <TextBox Header="Description" Text="{Binding NewItem.Description, Mode=TwoWay}" />
                    <TextBox Header="Logo" Text="{Binding NewItem.Logo, Mode=TwoWay}" />
                    <Button Command="{x:Bind Model.AddItemCommand}" IsEnabled="{x:Bind Model.IsLoaded, Mode=OneWay}">
                        Add item
                    </Button>
                </StackPanel>

            </ContentControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
