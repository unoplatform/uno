<Page x:Class="UITests.Shared.Windows_Graphics_Display.DisplayInformationTests"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">
	<Grid RowSpacing="8">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<StackPanel Spacing="8">
			<Button Command="{Binding RefreshCommand}"
			    Content="Refresh all" />
			<ToggleButton Command="{Binding ObserveOrientationChangesCommand}"
			    Content="Observe orientation changes"
			    IsChecked="{Binding OrientationChangesOn, Mode=TwoWay}" />
			<TextBlock>
				<Run Text="Last orientation change: " />
				<Run Text="{Binding LastOrientationChangeInfo}" />
			</TextBlock>
			<ToggleButton Command="{Binding ObserveDpiChangesCommand}"
			    Content="Observe DPI changes"
			    IsChecked="{Binding DpiChangesOn, Mode=TwoWay}" />
			<TextBlock>
				<Run Text="Last DPI change: " />
				<Run Text="{Binding LastDpiChangeInfo}" />
			</TextBlock>
		</StackPanel>
		<ListView x:Name="PropertyListView"
		    Grid.Row="1"
		    ItemsSource="{Binding Properties}">
			<ListView.ItemTemplate>
				<DataTemplate>
					<Grid Padding="4">
						<Grid.RowDefinitions>
							<RowDefinition />
							<RowDefinition />
						</Grid.RowDefinitions>
						<TextBlock FontWeight="Bold"
						    Text="{Binding Name}" />
						<TextBlock Grid.Row="1"
						    Text="{Binding Value}" />
					</Grid>
				</DataTemplate>
			</ListView.ItemTemplate>
		</ListView>
	</Grid>

</Page>
