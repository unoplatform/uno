<UserControl x:Class="Uno.UI.Samples.Content.UITests.TextBlockControl.SimpleText_MaxLines_Two_with_Different_Fonts"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<Border Width="250">
		<TextBlock android:FontFamily="sans-serif"
		    ios:FontFamily="sans-serif"
		    win:FontFamily="Segoe"
		    FontSize="20"
		    MaxLines="2">
			<Run Text="ItemDescriptionKey :" />
			<Run android:FontFamily="sans-serif-light"
			    ios:FontFamily="sans-serif-light"
			    win:FontFamily="Comic Sans MS"
			    Text="Item description value with is a very very very very very very very very very long text that should wrap" />
		</TextBlock>
	</Border>

</UserControl>
