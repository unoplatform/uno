<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.TextBlockControl.TextBlockTimespan"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Uno.UI.Samples.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    xmlns:u="using:Uno.UI.Samples.Controls"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d not_win">

    <UserControl.Resources>
        <converters:StringFormatConverter x:Key="stringFormatConverter" />
    </UserControl.Resources>

    <TextBlock Foreground="Red" Text="{Binding [RandomTimeSpan], Converter={StaticResource stringFormatConverter}, ConverterParameter='\{0:h\\:mm}'}" />

</UserControl>
