<Page x:Class="Uno.UI.Samples.Content.UITests.TextBlockControl.SimpleText_MaxLines_Two_With_Wrap"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:wasm="http://uno.ui/wasm"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d ios android not_win wasm">

	<StackPanel>
		<TextBlock>
			Container Width<Run Text="{Binding Value, ElementName=slider}" />
			:</TextBlock>
		<Slider x:Name="slider"
		    Maximum="1600"
		    Minimum="10"
		    Value="350" />

		<TextBlock>
			Container Height<Run Text="{Binding Value, ElementName=sliderV}" />
			:</TextBlock>
		<Slider x:Name="sliderV"
		    Maximum="300"
		    Minimum="5"
		    Value="70" />

		<TextBlock>
			Font Size<Run Text="{Binding Value, ElementName=fontsize}" />
			:</TextBlock>
		<Slider x:Name="fontsize"
		    Maximum="170"
		    Minimum="5"
		    Value="20" />

		<TextBlock>
			Line Height<Run Text="{Binding Value, ElementName=lineheight}" />
			:</TextBlock>
		<Slider x:Name="lineheight"
		    Maximum="170"
		    Minimum="5"
		    Value="20" />

		<wasm:TextBlock>
			(WASM ONLY) Cache: Hits=<Run x:Name="hits">0</Run>
			, Misses=<Run x:Name="misses">0</Run>
			.</wasm:TextBlock>

		<Border Name="border1"
		    Width="{Binding Value, ElementName=slider}"
		    Height="{Binding Value, ElementName=sliderV}"
		    Background="Cyan">
			<TextBlock x:Name="textwrap"
			    FontSize="{Binding Value, ElementName=fontsize}"
			    LineHeight="{Binding Value, ElementName=lineheight}"
			    MaxLines="2"
			    TextWrapping="Wrap">
				<Run FontWeight="Bold">WRAPPING (Wrap)/MaxLines=2</Run>
				This is a very very very very long text that *should* wrap because it goes out of the screen</TextBlock>
		</Border>
		<Border x:Name="border2"
		    Width="{Binding Value, ElementName=slider}"
		    Height="{Binding Value, ElementName=sliderV}"
		    Background="Yellow">
			<TextBlock x:Name="textwrapwords"
			    FontSize="{Binding Value, ElementName=fontsize}"
			    LineHeight="{Binding Value, ElementName=lineheight}"
			    MaxLines="2"
			    TextWrapping="WrapWholeWords">
				<Run FontWeight="Bold">WRAPPING (WrapWholeWords)/MaxLines=2</Run>
				This is a very very very very long text that *should* wrap because it goes out of the screen</TextBlock>
		</Border>
		<Border x:Name="border3"
		    Width="{Binding Value, ElementName=slider}"
		    Height="{Binding Value, ElementName=sliderV}"
		    Background="Cyan">
			<TextBlock x:Name="textwrapellipsis"
			    FontSize="{Binding Value, ElementName=fontsize}"
			    LineHeight="{Binding Value, ElementName=lineheight}"
			    MaxLines="2"
			    TextTrimming="CharacterEllipsis"
			    TextWrapping="Wrap">
				<Run FontWeight="Bold">WRAPPING (Wrap/CharacterEllipsis)/MaxLines=2</Run>
				This is a very very very very long text that *should* wrap because it goes out of the screen</TextBlock>
		</Border>
		<Border x:Name="border4"
		    Width="{Binding Value, ElementName=slider}"
		    Height="{Binding Value, ElementName=sliderV}"
		    Background="Yellow">
			<TextBlock x:Name="textwrapwordsellipsis"
			    FontSize="{Binding Value, ElementName=fontsize}"
			    LineHeight="{Binding Value, ElementName=lineheight}"
			    MaxLines="2"
			    TextTrimming="CharacterEllipsis"
			    TextWrapping="WrapWholeWords">
				<Run FontWeight="Bold">WRAPPING (WrapWholeWords/CharacterEllipsis)/MaxLines=2</Run>
				This is a very very very very long text that *should* wrap because it goes out of the screen</TextBlock>
		</Border>
	</StackPanel>

</Page>
