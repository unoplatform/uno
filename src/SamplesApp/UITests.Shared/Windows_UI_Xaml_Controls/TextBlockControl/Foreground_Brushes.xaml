<Page x:Class="UITests.Shared.Windows_UI_Xaml_Controls.TextBlockControl.Foreground_Brushes"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_Xaml_Controls.TextBlockControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Page.Resources>
		<LinearGradientBrush x:Key="BrandColor" EndPoint="1,1" StartPoint="0,0">
			<GradientStop Color="Blue" Offset="0.0" />
			<GradientStop Color="Red" Offset="1.0" />
		</LinearGradientBrush>
		<LinearGradientBrush x:Key="BrandColor2" EndPoint="1,1" StartPoint="0,0">
			<GradientStop Color="Red" Offset="0.1" />
			<GradientStop Color="Green" Offset="0.2" />
			<GradientStop Color="Yellow" Offset="0.4" />
			<GradientStop Color="Blue" Offset="0.5" />
			<GradientStop Color="Black" Offset="1.0" />
		</LinearGradientBrush>
		<SolidColorBrush x:Key="SolidRed"
		    Color="Red" />
	</Page.Resources>
	<StackPanel>
		<SymbolIcon Foreground="{StaticResource BrandColor}"
		    Symbol="FourBars" />
		<TextBlock x:Name="test1"
		    FontSize="30"
		    Foreground="{StaticResource BrandColor}"
		    Text="■■■■■■■■■■■■" />
		<TextBlock x:Name="test2"
		    FontSize="30"
		    Foreground="{StaticResource BrandColor}"
		    Text="■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■" />

		<Border BorderBrush="Red"
		    BorderThickness="2">
			<TextBlock x:Name="test3"
			    FontSize="30"
			    Foreground="{StaticResource BrandColor}"
			    Text="■■■■■■■■■■■■" />
		</Border>

		<Border BorderBrush="Red"
		    BorderThickness="2">
			<TextBlock x:Name="test4"
			    FontSize="30"
			    Foreground="{StaticResource BrandColor}"
			    Text="■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■" />
		</Border>

		<!--  This doesn't render correctly currently  -->
		<TextBlock>
			<Run Foreground="{StaticResource BrandColor}"
			    Text="■■■■■■■■■■■■" />
			<Run Foreground="{StaticResource BrandColor2}"
			    Text="■■■■■■■■■■■■■■■■■■■■■■■■" />
			<Run Foreground="{StaticResource SolidRed}"
			    Text="■■■■■■■■■■■■" />
		</TextBlock>
	</StackPanel>
</Page>
