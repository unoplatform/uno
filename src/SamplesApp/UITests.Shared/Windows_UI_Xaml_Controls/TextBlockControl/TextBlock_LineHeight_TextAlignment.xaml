<UserControl x:Class="Uno.UI.Samples.Content.UITests.TextBlockControl.TextBlock_LineHeight_TextAlignment"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d ios android not_win">

	<StackPanel>
		<Border Background="Tomato">
			<TextBlock Width="300"
			    FontSize="40"
			    FontWeight="Bold"
			    LineHeight="200"
			    Text="Center Text"
			    TextAlignment="Center" />
		</Border>
		<Border Background="Cornsilk">
			<TextBlock Width="300"
			    FontSize="40"
			    FontWeight="Bold"
			    LineHeight="200"
			    Text="Left Text"
			    TextAlignment="Left" />
		</Border>
		<Border Background="Violet">
			<TextBlock Width="300"
			    FontSize="40"
			    FontWeight="Bold"
			    LineHeight="200"
			    Text="Right Text"
			    TextAlignment="Right" />
		</Border>
		<Border Background="CornflowerBlue">
			<TextBlock Width="300"
			    FontSize="40"
			    FontWeight="Bold"
			    LineHeight="200"
			    Text="Default Text" />
		</Border>
	</StackPanel>

</UserControl>
