<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.TextBlockControl.Attributed_text_Supserscript"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="using:Uno.UI.Samples.Content.UITests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d ios android not_win">

    <TextBlock>
        <Run
            android:FontFamily="sans-serif"
            ios:FontFamily="sans-serif"
            win:FontFamily="Segoe"
            FontSize="30"
            Text="Hello world" />
        <Run
            android:BaseLineAlignment="Superscript"
            android:FontFamily="sans-serif"
            ios:BaseLineAlignment="Superscript"
            ios:FontFamily="sans-serif"
            win:FontFamily="Segoe"
            FontSize="17"
            Text="md" />
    </TextBlock>

</UserControl>
