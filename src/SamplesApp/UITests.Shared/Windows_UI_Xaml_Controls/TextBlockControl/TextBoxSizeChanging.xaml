<UserControl x:Class="Uno.UI.Samples.Content.UITests.TextBlockControl.TextBoxSizeChanging"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Uno.UI.Samples.Content.UITests.TextBlockControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<TextBlock Width="{Binding [IncreasingSize]}"
	    FontSize="20"
	    MaxLines="0"
	    Text="This is a very long text that should wrap progressively even though it container size changes"
	    TextWrapping="Wrap" />

</UserControl>
