<UserControl x:Class="Uno.UI.Samples.Controls.SimpleText_MaxWidth_NaN"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:converters="using:Uno.UI.Samples.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<UserControl.Resources>
		<converters:FromNullableBoolToDefaultValueConverter x:Key="DummyConverter"
		    NullOrFalseValue="NaN"
		    TrueValue="NaN" />
	</UserControl.Resources>

	<StackPanel>
		<TextBlock MaxWidth="{Binding Converter={StaticResource DummyConverter}}"
		    HorizontalAlignment="Left"
		    Text="This is my Text that should not wrap" />
	</StackPanel>

</UserControl>
