<UserControl x:Class="Uno.UI.Samples.Content.UITests.TextBlockControl.TextBlock_FontWeight"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<StackPanel>

		<TextBlock Text="Normal:" />
		<TextBlock FontSize="20"
		    FontWeight="ExtraBlack"
		    Text="ExtraBlack" />
		<TextBlock FontSize="20"
		    FontWeight="Black"
		    Text="Black" />
		<TextBlock FontSize="20"
		    FontWeight="ExtraBold"
		    Text="ExtraBold" />
		<TextBlock FontSize="20"
		    FontWeight="Bold"
		    Text="Bold" />
		<TextBlock FontSize="20"
		    FontWeight="SemiBold"
		    Text="SemiBold" />
		<TextBlock FontSize="20"
		    FontWeight="Medium"
		    Text="Medium" />
		<TextBlock FontSize="20"
		    FontWeight="Normal"
		    Text="Normal" />
		<TextBlock FontSize="20"
		    FontWeight="Light"
		    Text="Light" />
		<TextBlock FontSize="20"
		    FontWeight="SemiLight"
		    Text="SemiLight" />
		<TextBlock FontSize="20"
		    FontWeight="ExtraLight"
		    Text="ExtraLight" />
		<TextBlock FontSize="20"
		    FontWeight="Thin"
		    Text="Thin" />

		<TextBlock Text="Italic:" />
		<TextBlock FontSize="20"
		    FontStyle="Italic"
		    FontWeight="ExtraBlack"
		    Text="ExtraBlack" />
		<TextBlock FontSize="20"
		    FontStyle="Italic"
		    FontWeight="Black"
		    Text="Black" />
		<TextBlock FontSize="20"
		    FontStyle="Italic"
		    FontWeight="ExtraBold"
		    Text="ExtraBold" />
		<TextBlock FontSize="20"
		    FontStyle="Italic"
		    FontWeight="Bold"
		    Text="Bold" />
		<TextBlock FontSize="20"
		    FontStyle="Italic"
		    FontWeight="SemiBold"
		    Text="SemiBold" />
		<TextBlock FontSize="20"
		    FontStyle="Italic"
		    FontWeight="Medium"
		    Text="Medium" />
		<TextBlock FontSize="20"
		    FontStyle="Italic"
		    FontWeight="Normal"
		    Text="Normal" />
		<TextBlock FontSize="20"
		    FontStyle="Italic"
		    FontWeight="Light"
		    Text="Light" />
		<TextBlock FontSize="20"
		    FontStyle="Italic"
		    FontWeight="SemiLight"
		    Text="SemiLight" />
		<TextBlock FontSize="20"
		    FontStyle="Italic"
		    FontWeight="ExtraLight"
		    Text="ExtraLight" />
		<TextBlock FontSize="20"
		    FontStyle="Italic"
		    FontWeight="Thin"
		    Text="Thin" />

	</StackPanel>

</UserControl>
