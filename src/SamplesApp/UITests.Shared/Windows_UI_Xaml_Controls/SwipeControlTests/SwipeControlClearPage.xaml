<Page
    x:Class="MUXControlsTestApp.SwipeControlClearPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">


    <Grid>
        <Grid.Resources>
            <muxc:SwipeItems x:Name="DefaultSwipeItemsHorizontal">
                <muxc:SwipeItem Background="Orange" BehaviorOnInvoked="RemainOpen" />
            </muxc:SwipeItems>
            <muxc:SwipeItem
                x:Name="DefaultSwipeItemHorizontal"
                Background="Orange"
                BehaviorOnInvoked="RemainOpen" />
            <muxc:SwipeItems x:Name="DefaultSwipeItemsVertical">
                <muxc:SwipeItem Background="Orange" BehaviorOnInvoked="RemainOpen" />
            </muxc:SwipeItems>
            <muxc:SwipeItem
                x:Name="DefaultSwipeItemVertical"
                Background="Orange"
                BehaviorOnInvoked="RemainOpen" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid
            Grid.Row="0"
            Grid.Column="0"
            Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="100" />
                <RowDefinition Height="20" />
                <RowDefinition Height="100" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="120" />
            </Grid.ColumnDefinitions>
            <ListView
                x:Name="leftSwipe"
                Grid.Row="0"
                Grid.Column="0"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <muxc:SwipeControl LeftItems="{StaticResource DefaultSwipeItemsHorizontal}">
                            <Grid
                                Width="100"
                                Height="100"
                                Background="#F25022" />
                        </muxc:SwipeControl>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <ListView
                x:Name="topSwipe"
                Grid.Row="0"
                Grid.Column="2"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <muxc:SwipeControl TopItems="{StaticResource DefaultSwipeItemsVertical}">
                            <Grid
                                Width="100"
                                Height="100"
                                Background="#7FBA00" />
                        </muxc:SwipeControl>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <ListView
                x:Name="rightSwipe"
                Grid.Row="2"
                Grid.Column="0"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <muxc:SwipeControl RightItems="{StaticResource DefaultSwipeItemsHorizontal}">
                            <Grid
                                Width="100"
                                Height="100"
                                Background="#00A4EF" />
                        </muxc:SwipeControl>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <ListView
                x:Name="bottomSwipe"
                Grid.Row="2"
                Grid.Column="2"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <muxc:SwipeControl BottomItems="{StaticResource DefaultSwipeItemsVertical}">
                            <Grid
                                Width="100"
                                Height="100"
                                Background="#FFB900" />
                        </muxc:SwipeControl>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>



        </Grid>

        <StackPanel Grid.Row="0" Grid.Column="1">
            <Button
                x:Name="AddItemsButton"
                Margin="0,0,0,8"
                AutomationProperties.Name="AddItemsButton"
                Click="AddSwipeItemsButton_Click">
                Add SwipeItems
            </Button>
            <Button
                x:Name="ClearItemsButton"
                Margin="0,0,0,8"
                AutomationProperties.Name="ClearItemsButton"
                Click="ClearSwipeItemsButton_Click">
                Clear SwipeItems
            </Button>
            <TextBlock x:Name="SwipeItemsChildSum" AutomationProperties.Name="SwipeItemsChildSum" />
        </StackPanel>

    </Grid>
</Page>
