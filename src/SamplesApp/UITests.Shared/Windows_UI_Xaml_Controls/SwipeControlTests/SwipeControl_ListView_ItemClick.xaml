<Page x:Class="UITests.Windows_UI_Xaml_Controls.SwipeControlTests.SwipeControl_ListView_ItemClick"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.SwipeControlTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Page.Resources>
		<muxc:FontIconSource x:Name="Icon"
		    Glyph="&#xE710;" />
	</Page.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition />
		</Grid.RowDefinitions>

		<ListView x:Name="SUT"
		    IsItemClickEnabled="True"
		    ItemClick="ItemClicked"
		    ItemsSource="012"
		    SelectionChanged="ItemSelected">
			<ListView.ItemTemplate>
				<DataTemplate>
					<muxc:SwipeControl Width="400"
					    Height="75">
						<muxc:SwipeControl.LeftItems>
							<muxc:SwipeItems Mode="Execute">
								<muxc:SwipeItem IconSource="{StaticResource Icon}"
								    Invoked="SwipeItemInvoked"
								    Text="Left_1" />
							</muxc:SwipeItems>
						</muxc:SwipeControl.LeftItems>
						<muxc:SwipeControl.RightItems>
							<muxc:SwipeItems Mode="Reveal">
								<muxc:SwipeItem IconSource="{StaticResource Icon}"
								    Invoked="SwipeItemInvoked"
								    Text="Right_1" />
								<muxc:SwipeItem IconSource="{StaticResource Icon}"
								    Invoked="SwipeItemInvoked"
								    Text="Right_2" />
								<muxc:SwipeItem IconSource="{StaticResource Icon}"
								    Invoked="SwipeItemInvoked"
								    Text="Right_3" />
							</muxc:SwipeItems>
						</muxc:SwipeControl.RightItems>
						<Border Background="OrangeRed">
							<TextBlock HorizontalAlignment="Center"
							    VerticalAlignment="Center">
								<Run Text="Swipe control #" />
								<Run Text="{Binding}" />
							</TextBlock>
						</Border>
					</muxc:SwipeControl>
				</DataTemplate>
			</ListView.ItemTemplate>
		</ListView>

		<StackPanel Grid.Row="1"
		    Margin="0,20"
		    VerticalAlignment="Top">
			<StackPanel Orientation="Horizontal">
				<TextBlock Text="Last item clicked: " />
				<TextBlock x:Name="LastClicked"
				    Text="** none **" />
			</StackPanel>
			<StackPanel Orientation="Horizontal">
				<TextBlock Text="Last item selected: " />
				<TextBlock x:Name="LastSelected"
				    Text="** none **" />
			</StackPanel>
			<StackPanel Orientation="Horizontal">
				<TextBlock Text="Last swipe item invoked: " />
				<TextBlock x:Name="LastSwipeInvoked"
				    Text="** none **" />
			</StackPanel>
		</StackPanel>

	</Grid>
</Page>
