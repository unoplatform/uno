<Page x:Class="MUXControlsTestApp.SwipeControlPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    AutomationProperties.Name="SwipePage"
    mc:Ignorable="d">

	<Page.Resources>
		<muxc:SymbolIconSource x:Key="SymbolIcon"
		    Symbol="Camera" />
		<muxc:FontIconSource x:Key="FontIcon"
		    FontWeight="Normal"
		    Glyph="&#xE115;" />
		<muxc:BitmapIconSource x:Key="BitmapIcon"
		    ShowAsMonochrome="False"
		    UriSource="ms-appx:///Assets/ingredient3.png" />
		<muxc:PathIconSource x:Key="PathIcon"
		    Data="F1 M 16,12 20,2L 20,16 1,16" />

		<Flyout x:Name="MyContextFlyout">
			<TextBlock Text="I'm a Context Flyout!" />
		</Flyout>

		<muxc:SwipeItems x:Key="ExecuteItemsHorizontal"
		    Mode="Execute">
			<muxc:SwipeItem BehaviorOnInvoked="Auto"
			    IconSource="{StaticResource SymbolIcon}"
			    Invoked="SwipeItemInvoked"
			    Text="ExecuteItem" />
		</muxc:SwipeItems>

		<muxc:SwipeItems x:Key="OneRevealItem"
		    Mode="Reveal">
			<muxc:SwipeItem BehaviorOnInvoked="RemainOpen"
			    IconSource="{StaticResource FontIcon}"
			    Invoked="SwipeItemInvoked"
			    Text="RevealItem1" />
		</muxc:SwipeItems>

		<muxc:SwipeItems x:Key="ExecuteItemsVertical"
		    Mode="Execute">
			<muxc:SwipeItem BehaviorOnInvoked="Auto"
			    IconSource="{StaticResource SymbolIcon}"
			    Invoked="SwipeItemInvoked"
			    Text="ExecuteItem" />
		</muxc:SwipeItems>

		<muxc:SwipeItems x:Key="ExecuteItemsProgramaticCloseVertical"
		    Mode="Execute">
			<muxc:SwipeItem BehaviorOnInvoked="RemainOpen"
			    IconSource="{StaticResource SymbolIcon}"
			    Invoked="ProgramaticallyCloseSwipeControl9"
			    Text="ExecuteItem" />
		</muxc:SwipeItems>

		<muxc:SwipeItems x:Key="TwoRevealItems"
		    Mode="Reveal">
			<muxc:SwipeItem BehaviorOnInvoked="RemainOpen"
			    IconSource="{StaticResource FontIcon}"
			    Invoked="SwipeItemInvoked"
			    Text="RevealItem1" />
			<muxc:SwipeItem BehaviorOnInvoked="Close"
			    IconSource="{StaticResource BitmapIcon}"
			    Invoked="SwipeItemInvoked"
			    Text="RevealItem2" />
		</muxc:SwipeItems>

		<muxc:SwipeItems x:Key="SixRevealItems"
		    Mode="Reveal">
			<muxc:SwipeItem Background="Red"
			    BehaviorOnInvoked="RemainOpen"
			    Foreground="Orange"
			    IconSource="{StaticResource FontIcon}"
			    Invoked="SwipeItemInvoked"
			    Text="RevealItem1" />
			<muxc:SwipeItem Background="Green"
			    BehaviorOnInvoked="Close"
			    IconSource="{StaticResource BitmapIcon}"
			    Invoked="SwipeItemInvoked"
			    Text="RevealItem2" />
			<muxc:SwipeItem Background="Red"
			    BehaviorOnInvoked="RemainOpen"
			    Foreground="Orange"
			    IconSource="{StaticResource FontIcon}"
			    Invoked="SwipeItemInvoked"
			    Text="RevealItem3" />
			<muxc:SwipeItem Background="Blue"
			    BehaviorOnInvoked="RemainOpen"
			    IconSource="{StaticResource BitmapIcon}"
			    Invoked="ProgramaticallyCloseSwipeControl3"
			    Text="RevealItem4" />
			<muxc:SwipeItem Background="Blue"
			    BehaviorOnInvoked="RemainOpen"
			    Foreground="Orange"
			    IconSource="{StaticResource FontIcon}"
			    Invoked="ProgramaticallyCloseSwipeControl11"
			    Text="RevealItem5" />
			<muxc:SwipeItem Background="Green"
			    BehaviorOnInvoked="Close"
			    IconSource="{StaticResource BitmapIcon}"
			    Invoked="SwipeItemInvoked"
			    Text="RevealItem6" />
			<muxc:SwipeItem Background="Green"
			    BehaviorOnInvoked="Close"
			    IconSource="{StaticResource BitmapIcon}"
			    Invoked="SwipeItemInvoked"
			    Text="RevealItem7" />

		</muxc:SwipeItems>

		<muxc:SwipeItems x:Key="FourRevealItems"
		    Mode="Reveal">
			<muxc:SwipeItem Background="Green"
			    BehaviorOnInvoked="RemainOpen"
			    IconSource="{StaticResource FontIcon}"
			    Invoked="SwipeItemInvokedAndResizeGrid"
			    Text="Scale Down" />
			<muxc:SwipeItem Background="Red"
			    BehaviorOnInvoked="RemainOpen"
			    IconSource="{StaticResource BitmapIcon}"
			    Invoked="SwipeItemInvoked"
			    Text="RevealItem1" />
			<muxc:SwipeItem Background="Green"
			    BehaviorOnInvoked="RemainOpen"
			    IconSource="{StaticResource BitmapIcon}"
			    Invoked="SwipeItemInvokedAndResizeGrid"
			    Text="Scale Up" />
			<muxc:SwipeItem Background="Green"
			    BehaviorOnInvoked="Close"
			    IconSource="{StaticResource BitmapIcon}"
			    Invoked="SwipeItemInvoked"
			    Text="RevealItem2" />
		</muxc:SwipeItems>

		<muxc:SwipeItems x:Key="CommandTestItemsToBeInvoked"
		    Mode="Execute">
			<muxc:SwipeItem Background="Red"
			    BehaviorOnInvoked="Close"
			    Command="{StaticResource command}"
			    CommandParameter="command's text"
			    IconSource="{StaticResource SymbolIcon}"
			    Text="ExecuteItem" />
		</muxc:SwipeItems>

		<muxc:SwipeItems x:Key="ScalingUpExecuteMode"
		    Mode="Execute">
			<muxc:SwipeItem Background="BlueViolet"
			    BehaviorOnInvoked="Close"
			    IconSource="{StaticResource SymbolIcon}"
			    Invoked="SwipeItemInvokedAndResizeGrid"
			    Text="Scale Up" />
		</muxc:SwipeItems>

		<muxc:SwipeItems x:Key="RevealCommandTestItemsToBeInvoked"
		    Mode="Reveal">
			<muxc:SwipeItem x:Name="RevealCommandTestItemToBeInvoked"
			    Background="Red"
			    BehaviorOnInvoked="Close" />
		</muxc:SwipeItems>
	</Page.Resources>

	<Grid x:Name="Container"
	    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<!--  Vertical Swipes  -->
		<StackPanel Grid.Column="0"
		    Margin="0,0,16,0">
			<TextBlock Style="{ThemeResource StandardGroupHeader}"
			    Text="Vertical SwipeView tests" />
			<StackPanel Height="500"
			    Orientation="Horizontal">
				<ListViewItem x:Name="SwipeControl8"
				    AutomationProperties.Name="SwipeControl8"
				    Background="LightBlue">
					<muxc:SwipeControl x:Name="sc8"
					    BottomItems="{StaticResource ExecuteItemsVertical}"
					    TopItems="{StaticResource FourRevealItems}">
						<TextBlock Text="SwipeControl 8" />
					</muxc:SwipeControl>
				</ListViewItem>
				<ListViewItem AutomationProperties.Name="SwipeControl9"
				    Background="LightGreen">
					<muxc:SwipeControl x:Name="sc9"
					    BottomItems="{StaticResource TwoRevealItems}"
					    TopItems="{StaticResource ExecuteItemsProgramaticCloseVertical}">
						<TextBlock Text="SwipeControl 9" />
					</muxc:SwipeControl>
				</ListViewItem>
			</StackPanel>
			<StackPanel Orientation="Horizontal">
				<StackPanel Width="118"
				    Orientation="Vertical">
					<TextBlock VerticalAlignment="Center">O:</TextBlock>
					<CheckBox x:Name="SwipeItem8OpenCheckBox"
					    Width="40"
					    AutomationProperties.Name="SwipeItem8OpenCheckBox"
					    IsChecked="false"
					    IsEnabled="false" />
					<TextBlock VerticalAlignment="Center">I:</TextBlock>
					<CheckBox x:Name="SwipeItem8IdleCheckBox"
					    AutomationProperties.Name="SwipeItem8IdleCheckBox"
					    IsChecked="true"
					    IsEnabled="false" />
				</StackPanel>
				<StackPanel Width="118"
				    Orientation="Vertical">
					<TextBlock VerticalAlignment="Center">O:</TextBlock>
					<CheckBox x:Name="SwipeItem9OpenCheckBox"
					    AutomationProperties.Name="SwipeItem9OpenCheckBox"
					    IsChecked="false"
					    IsEnabled="false" />
					<TextBlock VerticalAlignment="Center">I:</TextBlock>
					<CheckBox x:Name="SwipeItem9IdleCheckBox"
					    AutomationProperties.Name="SwipeItem9IdleCheckBox"
					    IsChecked="true"
					    IsEnabled="false" />
				</StackPanel>
			</StackPanel>
		</StackPanel>

		<!--  Horizontal Swipes  -->
		<StackPanel Grid.Column="1"
		    Margin="2">
			<TextBlock Style="{ThemeResource StandardGroupHeader}"
			    Text="Horizontal SwipeView test controls" />
			<StackPanel Orientation="Horizontal">
				<StackPanel x:Name="SwipePanel"
				    Width="400"
				    Background="{ThemeResource SystemChromeMediumColor}">
					<ListView TabNavigation="local">
						<!--  Testing commanding, swipe to reveal, and executing  -->
						<!--  Items should be cropped as the height is less than the recommended 40px  -->
						<ListViewItem Height="30"
						    AutomationProperties.Name="SwipeControl1">
							<muxc:SwipeControl x:Name="sc1"
							    LeftItems="{StaticResource ScalingUpExecuteMode}"
							    RightItems="{StaticResource CommandTestItemsToBeInvoked}">
								<TextBlock VerticalAlignment="Center"
								    Text="SwipeControl 1" />
							</muxc:SwipeControl>
						</ListViewItem>

						<!--  Testing executing, swipe to revealin one item (less than the threshold of 100px), and executing  -->
						<ListViewItem Height="40"
						    AutomationProperties.Name="SwipeControl2">
							<muxc:SwipeControl x:Name="sc2"
							    LeftItems="{StaticResource OneRevealItem}"
							    RightItems="{StaticResource ExecuteItemsHorizontal}">
								<TextBlock VerticalAlignment="Center"
								    Text="SwipeControl 2" />
							</muxc:SwipeControl>
						</ListViewItem>

						<ListViewItem Height="44"
						    AutomationProperties.Name="SwipeControl3">
							<muxc:SwipeControl x:Name="sc3"
							    LeftItems="{StaticResource SixRevealItems}"
							    RightItems="{StaticResource FourRevealItems}">
								<TextBlock VerticalAlignment="Center"
								    Text="SwipeControl 3" />
							</muxc:SwipeControl>
						</ListViewItem>

						<!--  Testing the same items can be reused in both sides just fine.  -->
						<ListViewItem x:Name="SwipeControl4"
						    Height="40"
						    AutomationProperties.Name="SwipeControl4"
						    ContextFlyout="{StaticResource MyContextFlyout}"
						    Loaded="TestSwipeControl_Loaded">
							<muxc:SwipeControl x:Name="sc4"
							    LeftItems="{StaticResource TwoRevealItems}"
							    RightItems="{StaticResource TwoRevealItems}">
								<TextBlock VerticalAlignment="Center"
								    Text="Swipe Control 4" />
							</muxc:SwipeControl>
						</ListViewItem>

						<ListViewItem x:Name="SwipeControl5"
						    AutomationProperties.Name="SwipeControl5">
							<muxc:SwipeControl x:Name="sc5"
							    RightItems="{StaticResource RevealCommandTestItemsToBeInvoked}">
								<TextBlock VerticalAlignment="Center"
								    Text="Swipe Control 5" />
							</muxc:SwipeControl>
						</ListViewItem>

						<ListViewItem x:Name="SwipeControl10"
						    AutomationProperties.Name="SwipeControl10">
							<muxc:SwipeControl x:Name="sc10">
								<muxc:SwipeControl.LeftItems>
									<muxc:SwipeItems>
										<muxc:SwipeItem x:Name="SwipeItemForUICommand"
										    BehaviorOnInvoked="RemainOpen"
										    Invoked="SwipeItemInvoked" />
									</muxc:SwipeItems>
								</muxc:SwipeControl.LeftItems>
								<TextBlock VerticalAlignment="Center"
								    Text="Swipe Control 10" />
							</muxc:SwipeControl>
						</ListViewItem>

						<ListViewItem x:Name="SwipeControl11"
						    AutomationProperties.Name="SwipeControl11">
							<muxc:SwipeControl x:Name="sc11">
								<muxc:SwipeControl.LeftItems>
									<muxc:SwipeItems Mode="Execute">
										<muxc:SwipeItem BehaviorOnInvoked="RemainOpen"
										    Invoked="ExecuteRemainOpenInvoked"
										    Text="ExecuteRemainOpen" />
									</muxc:SwipeItems>
								</muxc:SwipeControl.LeftItems>
								<TextBlock VerticalAlignment="Center"
								    Text="Swipe Control 11" />
							</muxc:SwipeControl>
						</ListViewItem>

					</ListView>
					<!--  Testing for only one item at any side doesn't crash swipe  -->
					<muxc:SwipeControl x:Name="sc6"
					    AutomationProperties.Name="SwipeControl6"
					    RightItems="{StaticResource TwoRevealItems}">
						<Grid Width="500"
						    Height="60"
						    Background="Gray" />
					</muxc:SwipeControl>

					<!--  Testing for only one item at any side doesn't crash swipe  -->
					<muxc:SwipeControl x:Name="sc7"
					    AutomationProperties.Name="SwipeControl7"
					    LeftItems="{StaticResource TwoRevealItems}">
						<Grid Width="500"
						    Height="60"
						    Background="Gray" />
					</muxc:SwipeControl>
				</StackPanel>
				<StackPanel>
					<StackPanel Height="40"
					    Orientation="Horizontal">
						<TextBlock VerticalAlignment="Center">O:</TextBlock>
						<CheckBox x:Name="SwipeItem1OpenCheckBox"
						    AutomationProperties.Name="SwipeItem1OpenCheckBox"
						    IsChecked="false"
						    IsEnabled="false" />
						<TextBlock VerticalAlignment="Center">I:</TextBlock>
						<CheckBox x:Name="SwipeItem1IdleCheckBox"
						    AutomationProperties.Name="SwipeItem1IdleCheckBox"
						    IsChecked="true"
						    IsEnabled="false" />
					</StackPanel>
					<StackPanel Height="40"
					    Orientation="Horizontal">
						<TextBlock VerticalAlignment="Center">O:</TextBlock>
						<CheckBox x:Name="SwipeItem2OpenCheckBox"
						    AutomationProperties.Name="SwipeItem2OpenCheckBox"
						    IsChecked="false"
						    IsEnabled="false" />
						<TextBlock VerticalAlignment="Center">I:</TextBlock>
						<CheckBox x:Name="SwipeItem2IdleCheckBox"
						    AutomationProperties.Name="SwipeItem2IdleCheckBox"
						    IsChecked="true"
						    IsEnabled="false" />
					</StackPanel>
					<StackPanel Height="44"
					    Orientation="Horizontal">
						<TextBlock VerticalAlignment="Center">O:</TextBlock>
						<CheckBox x:Name="SwipeItem3OpenCheckBox"
						    AutomationProperties.Name="SwipeItem3OpenCheckBox"
						    IsChecked="false"
						    IsEnabled="false" />
						<TextBlock VerticalAlignment="Center">I:</TextBlock>
						<CheckBox x:Name="SwipeItem3IdleCheckBox"
						    AutomationProperties.Name="SwipeItem3IdleCheckBox"
						    IsChecked="true"
						    IsEnabled="false" />
					</StackPanel>
					<StackPanel Height="40"
					    Orientation="Horizontal">
						<TextBlock VerticalAlignment="Center">O:</TextBlock>
						<CheckBox x:Name="SwipeItem4OpenCheckBox"
						    AutomationProperties.Name="SwipeItem4OpenCheckBox"
						    IsChecked="false"
						    IsEnabled="false" />
						<TextBlock VerticalAlignment="Center">I:</TextBlock>
						<CheckBox x:Name="SwipeItem4IdleCheckBox"
						    AutomationProperties.Name="SwipeItem4IdleCheckBox"
						    IsChecked="true"
						    IsEnabled="false" />
					</StackPanel>
					<StackPanel Height="40"
					    Orientation="Horizontal">
						<TextBlock VerticalAlignment="Center">O:</TextBlock>
						<CheckBox x:Name="SwipeItem5OpenCheckBox"
						    AutomationProperties.Name="SwipeItem5OpenCheckBox"
						    IsChecked="false"
						    IsEnabled="false" />
						<TextBlock VerticalAlignment="Center">I:</TextBlock>
						<CheckBox x:Name="SwipeItem5IdleCheckBox"
						    AutomationProperties.Name="SwipeItem5IdleCheckBox"
						    IsChecked="true"
						    IsEnabled="false" />
					</StackPanel>
					<StackPanel Height="40"
					    Orientation="Horizontal">
						<TextBlock VerticalAlignment="Center">O:</TextBlock>
						<CheckBox x:Name="SwipeItem10OpenCheckBox"
						    AutomationProperties.Name="SwipeItem10OpenCheckBox"
						    IsChecked="false"
						    IsEnabled="false" />
						<TextBlock VerticalAlignment="Center">I:</TextBlock>
						<CheckBox x:Name="SwipeItem10IdleCheckBox"
						    AutomationProperties.Name="SwipeItem10IdleCheckBox"
						    IsChecked="true"
						    IsEnabled="false" />
					</StackPanel>
					<StackPanel Height="40"
					    Orientation="Horizontal">
						<TextBlock VerticalAlignment="Center">O:</TextBlock>
						<CheckBox x:Name="SwipeItem11OpenCheckBox"
						    AutomationProperties.Name="SwipeItem11OpenCheckBox"
						    IsChecked="false"
						    IsEnabled="false" />
						<TextBlock VerticalAlignment="Center">I:</TextBlock>
						<CheckBox x:Name="SwipeItem11IdleCheckBox"
						    AutomationProperties.Name="SwipeItem11IdleCheckBox"
						    IsChecked="true"
						    IsEnabled="false" />
					</StackPanel>
					<StackPanel Height="60"
					    Orientation="Horizontal">
						<TextBlock VerticalAlignment="Center">O:</TextBlock>
						<CheckBox x:Name="SwipeItem6OpenCheckBox"
						    AutomationProperties.Name="SwipeItem6OpenCheckBox"
						    IsChecked="false"
						    IsEnabled="false" />
						<TextBlock VerticalAlignment="Center">I:</TextBlock>
						<CheckBox x:Name="SwipeItem6IdleCheckBox"
						    AutomationProperties.Name="SwipeItem6IdleCheckBox"
						    IsChecked="true"
						    IsEnabled="false" />
					</StackPanel>
					<StackPanel Height="60"
					    Orientation="Horizontal">
						<TextBlock VerticalAlignment="Center">O:</TextBlock>
						<CheckBox x:Name="SwipeItem7OpenCheckBox"
						    AutomationProperties.Name="SwipeItem7OpenCheckBox"
						    IsChecked="false"
						    IsEnabled="false" />
						<TextBlock VerticalAlignment="Center">I:</TextBlock>
						<CheckBox x:Name="SwipeItem7IdleCheckBox"
						    AutomationProperties.Name="SwipeItem7IdleCheckBox"
						    IsChecked="true"
						    IsEnabled="false" />
					</StackPanel>
				</StackPanel>
			</StackPanel>

			<StackPanel Margin="0,8,0,0"
			    Style="{ThemeResource StandardGroupingStackPanel}">
				<TextBlock Style="{ThemeResource StandardGroupHeader}"
				    Text="State and options" />
				<Button AutomationProperties.Name="ResetButton"
				    Click="OnResetClick"
				    Content="Reset" />
				<TextBlock x:Name="textBlock"
				    AutomationProperties.Name="TextBlock"
				    Text="TextBlock" />
				<TextBlock x:Name="PositionX"
				    AutomationProperties.Name="PositionX"
				    Text="TextBlock" />
				<TextBlock x:Name="PositionY"
				    AutomationProperties.Name="PositionY"
				    Text="TextBlock" />
				<TextBlock x:Name="SwipeState"
				    AutomationProperties.Name="SwipeState"
				    Text="TextBlock" />
				<StackPanel Orientation="Horizontal">
					<TextBlock Margin="1"
					    VerticalAlignment="Center"
					    Text="Widths:" />
					<TextBox x:Name="TextBox"
					    Margin="1"
					    AutomationProperties.Name="TextBox" />
				</StackPanel>
				<StackPanel Orientation="Horizontal">
					<TextBlock Margin="1"
					    Text="Swipe3BackgroundColor:" />
					<TextBlock x:Name="Swipe3BackgroundColorTextBlock"
					    Margin="1"
					    AutomationProperties.Name="Swipe3BackgroundColorTextBlock" />
				</StackPanel>
			</StackPanel>

		</StackPanel>


		<Grid Grid.Column="2"
		    Margin="2">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<TextBlock Foreground="Red"
			    Text="SwipeControl Messages &amp; Events" />

			<StackPanel Grid.Row="1"
			    Orientation="Horizontal">
				<Button x:Name="btnClearSwipeControlEvents"
				    Margin="1"
				    Click="BtnClearSwipeControlEvents_Click"
				    Content="Clear" />
				<CheckBox x:Name="chkLogSwipeControlMessages"
				    Margin="1"
				    Checked="ChkLogSwipeControlMessages_Checked"
				    Content="Log SwipeControl Messages?"
				    Unchecked="ChkLogSwipeControlMessages_Unchecked" />
				<CheckBox x:Name="chkLogSwipeControlEvents"
				    Margin="1"
				    Content="Log SwipeControl Events?"
				    IsChecked="true" />
				<CheckBox x:Name="chkDisplayLogs"
				    Margin="1"
				    Content="Display Logs?" />
			</StackPanel>
			<ListBox x:Name="lstSwipeControlEvents"
			    Grid.Row="2"
			    Margin="1"
			    ScrollViewer.HorizontalScrollBarVisibility="Auto"
			    ScrollViewer.HorizontalScrollMode="Auto" />

			<Grid Grid.Row="3">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<Button x:Name="btnGetFullLog"
				    Margin="1"
				    VerticalAlignment="Center"
				    AutomationProperties.AutomationId="btnGetFullLog"
				    Click="BtnGetFullLog_Click"
				    Content="Get log" />
				<Button x:Name="btnClearFullLog"
				    Grid.Column="1"
				    Margin="1"
				    VerticalAlignment="Center"
				    AutomationProperties.AutomationId="btnClearFullLog"
				    Click="BtnClearFullLog_Click"
				    Content="Clear log" />
				<ComboBox x:Name="cmbFullLog"
				    Grid.Column="2"
				    Width="175"
				    Margin="1"
				    VerticalAlignment="Center"
				    AutomationProperties.Name="cmbFullLog" />
			</Grid>
		</Grid>
	</Grid>
</Page>
