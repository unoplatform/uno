<Page x:Class="UITests.Windows_UI_Xaml_Controls.BitmapIconTests.BitmapIcon_Sizing"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.BitmapIconTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
			<RowDefinition Height="*" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>
		<Grid>
			<BitmapIcon ShowAsMonochrome="False"
			    UriSource="ms-appx:///Assets/Icon.png" />
			<TextBlock Text="Should stretch but remain square, center aligned" />
		</Grid>

		<StackPanel Grid.Column="1">
			<BitmapIcon ShowAsMonochrome="False"
			    UriSource="ms-appx:///Assets/Icon.png" />
		</StackPanel>
		<TextBlock Grid.Column="1"
		    Text="Should stretch, not remain square" />

		<Grid Grid.Row="1">
			<BitmapIcon HorizontalAlignment="Left"
			    VerticalAlignment="Top"
			    ShowAsMonochrome="False"
			    UriSource="ms-appx:///Assets/Icon.png" />
			<TextBlock Text="Should stretch but remain square, left aligned" />
		</Grid>

		<Grid Grid.Row="1"
		    Grid.Column="1">
			<BitmapIcon Width="100"
			    Height="100"
			    ShowAsMonochrome="False"
			    UriSource="ms-appx:///Assets/Icon.png" />
		</Grid>
		<TextBlock Grid.Row="1"
		    Grid.Column="1"
		    Text="Should be 100x100" />

		<Grid Grid.Row="2"
		    Grid.Column="0"
		    Height="30">
			<BitmapIcon x:Name="Icon3"
			    ShowAsMonochrome="False"
			    UriSource="ms-appx:///Assets/Icon.png" />
		</Grid>
		<TextBlock Grid.Row="2"
		    Grid.Column="0"
		    Text="Should be 30x30" />

		<Grid Grid.Row="2"
		    Grid.Column="1"
		    Width="60">
			<BitmapIcon x:Name="Icon60"
			    ShowAsMonochrome="False"
			    UriSource="ms-appx:///Assets/Icon.png" />
		</Grid>
		<TextBlock Grid.Row="2"
		    Grid.Column="1"
		    Text="Should be 60x60" />
	</Grid>
</Page>
