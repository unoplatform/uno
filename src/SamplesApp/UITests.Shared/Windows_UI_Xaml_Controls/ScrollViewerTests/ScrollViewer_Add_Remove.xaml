<UserControl
    x:Class="UITests.Windows_UI_Xaml_Controls.ScrollViewerTests.ScrollViewer_Add_Remove"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.ScrollViewerTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <StackPanel>
        <Button
            x:Name="YoinkButton"
            Click="YoinkButton_Click"
            Content="Toggle Border Child attached" />
        <Button
            x:Name="ScrollToBottomButton"
            Click="ScrollToBottomButton_Click"
            Content="Scroll to bottom" />
        <Grid
            Width="300"
            Height="200"
            Background="Beige">
            <Border Name="YoinkBorder" Height="200">
                <ScrollViewer x:Name="YoinkableScrollViewer">
                    <StackPanel>
                        <Border
                            Width="300"
                            Height="190"
                            Background="Red" />
                        <Border
                            Width="300"
                            Height="190"
                            Background="Orange" />
                        <Border
                            Width="300"
                            Height="190"
                            Background="Yellow" />
                        <Border
                            Width="300"
                            Height="190"
                            Background="Green" />
                        <Border
                            Width="300"
                            Height="190"
                            Background="Blue" />
                        <Border
                            Width="300"
                            Height="190"
                            Background="Indigo" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
            <Rectangle
                x:Name="ViewfinderRectangle"
                Height="100"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Bottom"
                Fill="Transparent"
                IsHitTestVisible="False" />
        </Grid>
        <TextBlock x:Name="ChildStatusTextBlock" Text="Present" />
    </StackPanel>
</UserControl>
