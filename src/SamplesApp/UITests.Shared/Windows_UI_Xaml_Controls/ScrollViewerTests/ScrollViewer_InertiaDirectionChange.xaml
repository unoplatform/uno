<Page x:Class="UITests.Shared.Windows_UI_Xaml_Controls.ScrollViewerTests.ScrollViewer_InertiaDirectionChange"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="0"
		    Margin="8"
		    Text="Repro: Flick down fast, then immediately touch and scroll up. The scroll should respond to the new (up) direction immediately, not fight the original (down) inertia."
		    TextWrapping="Wrap" />

		<ScrollViewer x:Name="SV"
		    Grid.Row="1">
			<StackPanel>
				<StackPanel.Resources>
					<Style TargetType="Border">
						<Setter Property="Height" Value="60" />
						<Setter Property="Margin" Value="4" />
						<Setter Property="CornerRadius" Value="4" />
					</Style>
				</StackPanel.Resources>
			</StackPanel>
		</ScrollViewer>
	</Grid>
</Page>
