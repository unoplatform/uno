<Page x:Class="UITests.Windows_UI_Xaml_Controls.CalendarView.CalendarDatePicker_Features"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<StackPanel Spacing="12">
		<StackPanel Padding="3"
		    Background="LightBlue"
		    Orientation="Horizontal"
		    Spacing="10">
			<ComboBox x:Name="dow"
			    Header="FirstDayOfWeek">
				<ComboBoxItem IsSelected="True">Sunday</ComboBoxItem>
				<ComboBoxItem>Monday</ComboBoxItem>
				<ComboBoxItem>Tuesday</ComboBoxItem>
				<ComboBoxItem>Wednesday</ComboBoxItem>
				<ComboBoxItem>Thursday</ComboBoxItem>
				<ComboBoxItem>Friday</ComboBoxItem>
				<ComboBoxItem>Saturday</ComboBoxItem>
			</ComboBox>
			<ComboBox x:Name="dowf"
			    Header="DOW Format">
				<!--  https://docs.microsoft.com/en-us/uwp/api/windows.globalization.datetimeformatting.datetimeformatter  -->
				<ComboBoxItem Content="{}{dayofweek.full}" />
				<ComboBoxItem Content="{}{dayofweek.abbreviated}"
				    IsSelected="True" />
				<ComboBoxItem Content="{}{dayofweek.abbreviated(2)}" />
				<ComboBoxItem Content="{}{dayofweek.abbreviated(3)}" />
				<ComboBoxItem Content="{}{dayofweek.solo.full}" />
				<ComboBoxItem Content="{}{dayofweek.solo.abbreviated}" />
				<ComboBoxItem Content="{}{dayofweek.solo.abbreviated(2)}" />
				<ComboBoxItem Content="{}{dayofweek.solo.abbreviated(3)}" />
			</ComboBox>
			<ComboBox x:Name="dateformat"
			    Header="DateFormat">
				<ComboBoxItem Content="{}{day.integer}/{month.integer}/{year.full}" />
				<ComboBoxItem Content="{}{month.full} {year.full}" />
				<ComboBoxItem Content="{}{month.full} {day.integer}" />
				<ComboBoxItem Content="{}{dayofweek.full}, {day.integer} {month.full} {year.full}" />
				<ComboBoxItem Content="{}{dayofweek.abbreviated}, {day.integer} {month.abbreviated} {year.full}" />
				<ComboBoxItem Content="{}{year.full}-{month.integer}-{day.integer}" />
				<ComboBoxItem Content="{}{day.integer}/{month.integer}/{year.abbreviated}" />
				<ComboBoxItem Content="{}{day.integer} {month.abbreviated} {year.full}" />
				<ComboBoxItem Content="{}{month.full} {day.integer}, {year.full}" />
				<ComboBoxItem Content="{}{month.abbreviated} {day.integer}, {year.full}" />
				<ComboBoxItem Content="{}{dayofweek.full}, {day.integer} {month.full} {year.full}" />
				<ComboBoxItem Content="{}{dayofweek.abbreviated}, {day.integer} {month.abbreviated} {year.abbreviated}" />
			</ComboBox>
			<ComboBox x:Name="cid"
			    Header="Calendar">
				<ComboBoxItem>ChineseLunarCalendar</ComboBoxItem>
				<ComboBoxItem IsSelected="True">GregorianCalendar</ComboBoxItem>
				<ComboBoxItem>HebrewCalendar</ComboBoxItem>
				<ComboBoxItem>HijriCalendar</ComboBoxItem>
				<ComboBoxItem>JapaneseCalendar</ComboBoxItem>
				<ComboBoxItem>JapaneseLunarCalendar</ComboBoxItem>
				<ComboBoxItem>JulianCalendar</ComboBoxItem>
				<ComboBoxItem>KoreanCalendar</ComboBoxItem>
				<ComboBoxItem>KoreanLunarCalendar</ComboBoxItem>
				<ComboBoxItem>PersianCalendar</ComboBoxItem>
				<ComboBoxItem>TaiwanCalendar</ComboBoxItem>
				<ComboBoxItem>TaiwanLunarCalendar</ComboBoxItem>
				<ComboBoxItem>ThaiCalendar</ComboBoxItem>
				<ComboBoxItem>UmAlQuraCalendar</ComboBoxItem>
				<ComboBoxItem>VietnameseLunarCalendar</ComboBoxItem>
			</ComboBox>
			<ToggleButton x:Name="today"
			    IsChecked="True">
				IsTodayHighlighted
			</ToggleButton>
		</StackPanel>
		<StackPanel Padding="3"
		    Background="Bisque"
		    Orientation="Horizontal"
		    Spacing="10">
			<CalendarDatePicker x:Name="cdp1"
			    CalendarIdentifier="{Binding SelectedItem.Content, ElementName=cid, FallbackValue=GregorianCalendar}"
			    DateFormat="{Binding SelectedItem.Content, ElementName=dateformat}"
			    DayOfWeekFormat="{Binding SelectedItem.Content, ElementName=dowf}"
			    FirstDayOfWeek="{Binding SelectedItem.Content, ElementName=dow, FallbackValue=Sunday}"
			    Header="Stock CalendarDatePicker"
			    IsTodayHighlighted="{Binding IsChecked, ElementName=today}" />
			<ToggleButton IsChecked="{Binding IsEnabled, ElementName=cdp1, Mode=TwoWay}">
				IsEnabled
			</ToggleButton>
			<ToggleButton IsChecked="{Binding IsCalendarOpen, ElementName=cdp1, Mode=TwoWay}">
				IsCalendarOpen
			</ToggleButton>
			<TextBox Header="Header"
			    Text="{Binding Header, ElementName=cdp1, Mode=TwoWay}" />
			<TextBlock>
				Date:<Run Text="{Binding Date, ElementName=cdp1}" /></TextBlock>
		</StackPanel>
		<StackPanel Padding="3"
		    Background="Bisque"
		    Orientation="Horizontal"
		    Spacing="10">
			<CalendarDatePicker x:Name="cdp2"
			    CalendarIdentifier="{Binding SelectedItem.Content, ElementName=cid, FallbackValue=GregorianCalendar}"
			    DayOfWeekFormat="{Binding SelectedItem.Content, ElementName=dowf}"
			    FirstDayOfWeek="{Binding SelectedItem.Content, ElementName=dow}"
			    Header="IsCalendarOpen=True"
			    IsCalendarOpen="True"
			    IsEnabled="False"
			    IsTodayHighlighted="{Binding IsChecked, ElementName=today}" />
			<ToggleButton IsChecked="{Binding IsEnabled, ElementName=cdp2, Mode=TwoWay}">
				IsEnabled
			</ToggleButton>
			<ToggleButton IsChecked="{Binding IsCalendarOpen, ElementName=cdp2, Mode=TwoWay}">
				IsCalendarOpen
			</ToggleButton>
			<TextBox Header="Header"
			    Text="{Binding Header, ElementName=cdp2, Mode=TwoWay}" />

			<TextBlock>
				Date:<Run Text="{Binding Date, ElementName=cdp2}" /></TextBlock>
		</StackPanel>
		<StackPanel Padding="3"
		    Background="Bisque"
		    Orientation="Horizontal"
		    Spacing="10">
			<CalendarDatePicker x:Name="cdp3"
			    CalendarIdentifier="{Binding SelectedItem.Content, ElementName=cid, FallbackValue=GregorianCalendar}"
			    DayOfWeekFormat="{Binding SelectedItem.Content, ElementName=dowf}"
			    FirstDayOfWeek="{Binding SelectedItem.Content, ElementName=dow}"
			    Header="IsGroupLabelVisible=False"
			    IsGroupLabelVisible="False"
			    IsTodayHighlighted="{Binding IsChecked, ElementName=today}"
			    PlaceholderText="--PLACEHOLDER--" />
			<ToggleButton IsChecked="{Binding IsEnabled, ElementName=cdp3, Mode=TwoWay}">
				IsEnabled
			</ToggleButton>
			<ToggleButton IsChecked="{Binding IsCalendarOpen, ElementName=cdp3, Mode=TwoWay}">
				IsCalendarOpen
			</ToggleButton>

			<TextBlock>
				Date:<Run Text="{Binding Date, ElementName=cdp3}" /></TextBlock>
		</StackPanel>
	</StackPanel>
</Page>
