<UserControl
    x:Class="UITests.Shared.Windows_UI_Xaml_Controls.MenuFlyoutTests.MenuFlyoutItem_Hierarchy"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_Xaml_Controls.MenuFlyoutItemTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <TextBlock x:Name="results" Text="Starting..." />
        <Button AutomationProperties.AutomationId="Help" Content="Help">
            <Button.Flyout>
                <MenuFlyout>

                    <MenuFlyoutItem
                        AutomationProperties.AutomationId="MenuViewHelp"
                        Click="{x:Bind OnItemClicked}"
                        Text="View Help" />

                    <MenuFlyoutSubItem
                        AutomationProperties.AutomationId="MenuDisabled"
                        IsEnabled="False"
                        Text="Disabled">
                        <MenuFlyoutItem
                            AutomationProperties.AutomationId="MenuCollapsed"
                            Click="{x:Bind OnItemClicked}"
                            Text="Can't be seen" />
                    </MenuFlyoutSubItem>

                    <MenuFlyoutSubItem AutomationProperties.AutomationId="MenuFeedback" Text="Send Feedback">

                        <MenuFlyoutItem
                            AutomationProperties.AutomationId="MenuReportProblem"
                            Click="{x:Bind OnItemClicked}"
                            Text="Report Problem" />

                        <MenuFlyoutItem
                            AutomationProperties.AutomationId="MenuSuggestFeature"
                            Click="{x:Bind OnItemClicked}"
                            Text="Suggest Feature" />

                        <MenuFlyoutSubItem AutomationProperties.AutomationId="MenuSettings" Text="Settings">

                            <MenuFlyoutItem
                                AutomationProperties.AutomationId="MenuAutoSave"
                                Click="{x:Bind OnItemClicked}"
                                Text="Auto Save" />

                            <MenuFlyoutItem
                                AutomationProperties.AutomationId="MenuStartup"
                                Click="{x:Bind OnItemClicked}"
                                Text="Start Up" />

                            <MenuFlyoutItem
                                AutomationProperties.AutomationId="MenuFontsAndColors"
                                Click="{x:Bind OnItemClicked}"
                                Text="Font and Colors" />
                        </MenuFlyoutSubItem>
                    </MenuFlyoutSubItem>
                </MenuFlyout>
            </Button.Flyout>
        </Button>

    </Grid>
</UserControl>
