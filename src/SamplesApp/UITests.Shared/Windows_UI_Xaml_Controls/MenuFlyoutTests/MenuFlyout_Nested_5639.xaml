<UserControl
    x:Class="UITests.Windows_UI_Xaml_Controls.MenuFlyoutTests.MenuFlyout_Nested_5639"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.MenuFlyoutTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid x:Name="HostGrid">
        <Button
            x:Name="DummyTopButton"
            VerticalAlignment="Top"
            Content="Dummy" />
        <Button
            x:Name="ButtonWithMenuFlyout"
            VerticalAlignment="Bottom"
            Content="Show menu">
            <Button.Flyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="Item 1" />
                    <MenuFlyoutItem Text="Item 2" />
                    <MenuFlyoutItem Text="Item 3" />
                    <MenuFlyoutSubItem x:Name="NestedMenuItem" Text="Nested menu">
                        <MenuFlyoutItem Text="Subitem 1" />
                        <MenuFlyoutItem Text="Subitem 2" />
                        <MenuFlyoutItem Text="Subitem 3" />
                        <MenuFlyoutItem Text="Subitem 4" />
                        <MenuFlyoutItem Text="Subitem 5" />
                        <MenuFlyoutItem Text="Subitem 6" />
                        <MenuFlyoutItem Text="Subitem 7" />
                        <MenuFlyoutItem x:Name="LastSubitem" Text="Last subitem" />
                    </MenuFlyoutSubItem>
                </MenuFlyout>
            </Button.Flyout>
        </Button>
    </Grid>
</UserControl>
