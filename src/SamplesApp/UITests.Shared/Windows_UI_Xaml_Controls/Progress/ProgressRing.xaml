<Page
    x:Class="SamplesApp.Samples.Progress.ProgressRing"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="">

    <StackPanel Spacing="10">
        <ToggleButton x:Name="btn" IsChecked="True">
            IS ACTIVE
        </ToggleButton>
        <StackPanel Orientation="Horizontal" Spacing="16">
            <ProgressRing Foreground="Red" IsActive="{Binding IsChecked, ElementName=btn}" />
            <ProgressRing
                Width="33"
                Height="33"
                Foreground="Blue"
                IsActive="{Binding IsChecked, ElementName=btn}" />
            <ProgressRing
                Width="66"
                Height="66"
                Foreground="Green"
                IsActive="{Binding IsChecked, ElementName=btn}" />
            <ProgressRing
                Width="99"
                Height="99"
                Foreground="Orange"
                IsActive="{Binding IsChecked, ElementName=btn}" />
        </StackPanel>
    </StackPanel>
</Page>
