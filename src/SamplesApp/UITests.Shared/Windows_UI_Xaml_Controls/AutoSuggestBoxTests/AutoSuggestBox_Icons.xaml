<Page x:Class="UITests.Windows_UI_Xaml_Controls.AutoSuggestBoxTests.AutoSuggestBox_Icons"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.AutoSuggestBoxTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<StackPanel Padding="12"
	    Spacing="8">
		<AutoSuggestBox x:Name="NoIconBox"
		    Header="No icon" />
		<AutoSuggestBox x:Name="SymbolIconBox"
		    Header="Symbol icon"
		    QueryIcon="Home" />
		<AutoSuggestBox x:Name="FontIconBox"
		    Header="Font icon">
			<AutoSuggestBox.QueryIcon>
				<FontIcon Glyph="&#xE128;" />
			</AutoSuggestBox.QueryIcon>
		</AutoSuggestBox>
		<AutoSuggestBox x:Name="BitmapIconBox"
		    Header="Switch icon">
			<AutoSuggestBox.QueryIcon>
				<BitmapIcon x:Name="BitmapIcon"
				    ShowAsMonochrome="False"
				    UriSource="ms-appx:///Assets/BlueSquare.png" />
			</AutoSuggestBox.QueryIcon>
		</AutoSuggestBox>
		<Button x:Name="SwitchIconButton"
		    Click="SwitchIconClick">
			Change icon
		</Button>
	</StackPanel>
</Page>
