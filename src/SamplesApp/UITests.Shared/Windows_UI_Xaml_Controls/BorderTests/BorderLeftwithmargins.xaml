<UserControl
    x:Class="Uno.UI.Samples.UITests.BorderTestsControl.BorderLeftwithmargins"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="using:Uno.UI.Samples.UITests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <controls:SampleControl SampleDescription="BorderLeftwithmargins">
        <controls:SampleControl.SampleContent>
            <DataTemplate>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Grid.Column="0"
                        Width="50"
                        Height="50"
                        Margin="0,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="Blue" />
                    <Border
                        Grid.Column="1"
                        Width="50"
                        Height="50"
                        Margin="0,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="Blue" />
                    <Border
                        Grid.Column="2"
                        Width="50"
                        Height="50"
                        Margin="0,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="Blue" />
                    <Border
                        Grid.Column="3"
                        Width="50"
                        Height="50"
                        Margin="0,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="Blue" />
                    <Border
                        Grid.Column="0"
                        Width="50"
                        Height="50"
                        Margin="50,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="Red" />
                    <Border
                        Grid.Column="1"
                        Width="50"
                        Height="50"
                        Margin="0,50,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="Red" />
                    <Border
                        Grid.Column="2"
                        Width="50"
                        Height="50"
                        Margin="0,0,50,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="Red" />
                    <Border
                        Grid.Column="3"
                        Width="50"
                        Height="50"
                        Margin="0,0,0,50"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="Red" />
                </Grid>
            </DataTemplate>
        </controls:SampleControl.SampleContent>
    </controls:SampleControl>
</UserControl>