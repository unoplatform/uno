<Page x:Class="Uno.UI.Samples.UITests.BorderTestsControl.Border_CornerRadius"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="using:Uno.UI.Samples.UITests.BorderTestsControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    mc:Ignorable="d ios android">

	<ScrollViewer>
		<StackPanel>
			<Border x:Name="Sample1"
			    Width="100"
			    Height="100"
			    Background="Red"
			    CornerRadius="50" />

			<!--  Sample for https://github.com/unoplatform/uno/issues/5440  -->
			<Border Height="30" />
			<Border x:Name="Sample2"
			    Width="128"
			    Height="64"
			    Background="Red"
			    CornerRadius="128" />

			<Border Height="30" />
			<Border Width="100"
			    Height="50"
			    BorderBrush="Black"
			    BorderThickness="1"
			    CornerRadius="4" />

			<Border Height="30" />
			<Border Width="100"
			    Height="100"
			    Background="Red"
			    CornerRadius="24,50,50,12" />


			<Border Height="30" />
			<Border Width="100"
			    Height="50"
			    Background="Red"
			    CornerRadius="24,50,50,12" />

			<Border Height="30" />
			<Border Background="Black">
				<Border Width="150"
				    Height="50"
				    Background="Red"
				    BorderBrush="Aqua"
				    BorderThickness="5"
				    CornerRadius="75" />
			</Border>

			<Border Height="30" />
			<Border Width="100"
			    Height="50"
			    Background="Red"
			    BorderBrush="#66121212"
			    BorderThickness="1"
			    CornerRadius="12" />

			<Border Height="30" />
			<Border Width="100"
			    Height="50"
			    Background="Red"
			    BorderBrush="#66121212"
			    BorderThickness="5"
			    CornerRadius="12" />

			<Border Height="30" />
			<Border Width="100"
			    Height="50"
			    Background="Red"
			    CornerRadius="15" />
		</StackPanel>
	</ScrollViewer>
</Page>
