<UserControl x:Class="Uno.UI.Samples.UITests.BorderTestsControl.NonUniformThicknessandRadius"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="using:Uno.UI.Samples.UITests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<controls:SampleControl SampleDescription="NonUniformThicknessandRadius">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<Grid>
					<!--
						This is not support in Umbrella UI, mainly because iOS CGContext
						doesn't out of the box, only 4 will be used for the border thickness
					-->
					<Border Background="Blue" />
					<Border Background="Red"
					    BorderBrush="Yellow"
					    BorderThickness="2,4,6,8"
					    CornerRadius="40" />
				</Grid>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>