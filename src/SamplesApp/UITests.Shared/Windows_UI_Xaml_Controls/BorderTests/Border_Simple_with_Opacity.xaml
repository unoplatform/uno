<UserControl x:Class="Uno.UI.Samples.UITests.BorderTestsControl.Border_Simple_with_Opacity"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="using:Uno.UI.Samples.UITests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<controls:SampleControl SampleDescription="A simple senmi-transpatent red border.">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<StackPanel>
					<TextBlock Text="Opacity on color" />
					<Border Height="200"
					    Background="#80FF0000" />

					<TextBlock Margin="0,20,0,0"
					    Text="Opacity on Brush" />
					<Border Height="200">
						<Border.Background>
							<SolidColorBrush Color="#FFFF0000"
							    Opacity="0.5" />
						</Border.Background>
					</Border>
				</StackPanel>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>