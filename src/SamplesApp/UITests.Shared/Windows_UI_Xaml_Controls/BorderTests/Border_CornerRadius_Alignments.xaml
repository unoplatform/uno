<Page x:Class="Uno.UI.Samples.UITests.BorderTestsControl.Border_CornerRadius_Alignments"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="using:Uno.UI.Samples.UITests.BorderTestsControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    mc:Ignorable="d ios android">

	<controls:SampleControl SampleDescription="CornerRadius Alignments">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<Grid Background="Red">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>
					<Grid.RowDefinitions>
						<RowDefinition Height="*" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>

					<Rectangle Grid.RowSpan="2"
					    Grid.ColumnSpan="2"
					    Margin="10"
					    Fill="White" />

					<Rectangle Grid.RowSpan="2"
					    Grid.ColumnSpan="2"
					    Width="150"
					    Height="150"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Center"
					    Fill="Red" />

					<Rectangle Grid.RowSpan="2"
					    Grid.ColumnSpan="2"
					    Width="148"
					    Height="148"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Center"
					    Fill="#40FFFFFF" />

					<!--  This rectangle should not be visible  -->
					<Border Grid.RowSpan="2"
					    Grid.ColumnSpan="2"
					    Width="150"
					    Height="150"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Center"
					    Background="Black"
					    BorderThickness="0"
					    CornerRadius="75" />

					<Border Grid.RowSpan="2"
					    Grid.ColumnSpan="2"
					    Width="150"
					    Height="150"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Center"
					    Background="Green"
					    BorderBrush="Yellow"
					    BorderThickness="10"
					    CornerRadius="75" />

					<Border Width="100"
					    Height="50"
					    Margin="10"
					    HorizontalAlignment="Left"
					    VerticalAlignment="Top"
					    Background="Green"
					    BorderBrush="Blue"
					    BorderThickness="5"
					    CornerRadius="25" />

					<Border Grid.Column="1"
					    Width="50"
					    Height="100"
					    Margin="10"
					    HorizontalAlignment="Right"
					    VerticalAlignment="Top"
					    Background="Green"
					    BorderBrush="Blue"
					    BorderThickness="5"
					    CornerRadius="25" />

					<Border Grid.Row="1"
					    Width="50"
					    Height="100"
					    Margin="10"
					    HorizontalAlignment="Left"
					    VerticalAlignment="Bottom"
					    Background="Green"
					    BorderBrush="Blue"
					    BorderThickness="5"
					    CornerRadius="25" />

					<Border Grid.Row="1"
					    Grid.Column="1"
					    Width="100"
					    Height="50"
					    Margin="10"
					    HorizontalAlignment="Right"
					    VerticalAlignment="Bottom"
					    Background="Green"
					    BorderBrush="Blue"
					    BorderThickness="5"
					    CornerRadius="25" />
				</Grid>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</Page>
