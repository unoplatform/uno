<UserControl x:Class="UITests.Windows_UI_Xaml_Controls.BorderTests.Border_CornerRadius_Gradient"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.BorderTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<UserControl.Resources>
		<LinearGradientBrush x:Key="MyColor" EndPoint="0,1" MappingMode="RelativeToBoundingBox" StartPoint="0,0">
			<LinearGradientBrush.GradientStops>
				<GradientStop Color="Purple" Offset="0.70" />
				<GradientStop Color="Blue" Offset="0.50" />
			</LinearGradientBrush.GradientStops>
		</LinearGradientBrush>
	</UserControl.Resources>

	<Grid>
		<Border x:Name="RedBorder"
		    Width="500"
		    Height="500"
		    HorizontalAlignment="Center"
		    VerticalAlignment="Center"
		    Background="Red">
			<Border x:Name="GreenBorder"
			    Width="300"
			    Height="300"
			    HorizontalAlignment="Center"
			    VerticalAlignment="Center"
			    Background="#00FF00"
			    BorderBrush="{StaticResource MyColor}"
			    BorderThickness="2"
			    CornerRadius="10" />
		</Border>
	</Grid>
</UserControl>
