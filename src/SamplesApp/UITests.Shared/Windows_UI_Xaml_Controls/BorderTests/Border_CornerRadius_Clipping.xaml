<UserControl
    x:Class="UITests.Windows_UI_Xaml_Controls.BorderTests.Border_CornerRadius_Clipping"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.BorderTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid Margin="50">
        <Border
            x:Name="MainBorder"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            BorderBrush="Red"
            BorderThickness="4"
            CornerRadius="10">
            <Grid>
                <Rectangle
                    Width="16"
                    Height="16"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Fill="Green" />
                <Rectangle
                    Width="16"
                    Height="16"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Fill="Green" />
                <Rectangle
                    Width="16"
                    Height="16"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Fill="Green" />
                <Rectangle
                    Width="16"
                    Height="16"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Fill="Green" />
            </Grid>
        </Border>
        <Border
            x:Name="TopLeftTarget"
            Width="10"
            Height="10"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            BorderBrush="Blue"
            BorderThickness="1" />
        <Border
            x:Name="TopRightTarget"
            Width="10"
            Height="10"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            BorderBrush="Blue"
            BorderThickness="1" />
        <Border
            x:Name="BottomLeftTarget"
            Width="10"
            Height="10"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            BorderBrush="Blue"
            BorderThickness="1" />
        <Border
            x:Name="BottomRightTarget"
            Width="10"
            Height="10"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            BorderBrush="Blue"
            BorderThickness="1" />
    </Grid>
</UserControl>
