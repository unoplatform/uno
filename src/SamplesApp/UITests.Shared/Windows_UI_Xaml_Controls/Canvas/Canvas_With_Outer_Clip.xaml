<UserControl x:Class="UITests.Shared.Windows_UI_Xaml_Controls.Canvas.Canvas_With_Outer_Clip"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_Xaml_Controls.Canvas"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">


	<StackPanel x:Name="OuterGrid"
	    Padding="20,100,20,20"
	    VerticalAlignment="Stretch"
	    Background="Red">
		<Border HorizontalAlignment="Center"
		    VerticalAlignment="Top">
			<Border.Clip>
				<RectangleGeometry Rect="0, 0, 200, 50" />
			</Border.Clip>
			<Grid Width="200"
			    Height="50"
			    Background="LightPink">
				<Canvas HorizontalAlignment="Stretch"
				    VerticalAlignment="Stretch">
					<Rectangle Canvas.Left="25"
					    Canvas.Top="15"
					    Width="150"
					    Height="80"
					    Fill="Blue" />
				</Canvas>
			</Grid>
		</Border>
		<Border x:Name="LocatorBorder1"
		    Width="200"
		    Height="30"
		    HorizontalAlignment="Center"
		    VerticalAlignment="Top"
		    Background="Transparent" />
		<Border HorizontalAlignment="Center"
		    VerticalAlignment="Top">
			<Grid Width="200"
			    Height="50"
			    Background="LightPink">
				<Canvas HorizontalAlignment="Stretch"
				    VerticalAlignment="Stretch">
					<Rectangle Canvas.Left="25"
					    Canvas.Top="15"
					    Width="150"
					    Height="80"
					    Fill="Blue" />
				</Canvas>
			</Grid>
		</Border>
		<Border x:Name="LocatorBorder2"
		    Width="200"
		    Height="30"
		    HorizontalAlignment="Center"
		    VerticalAlignment="Top"
		    Background="Transparent" />
	</StackPanel>
</UserControl>
