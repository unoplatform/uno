<UserControl x:Class="SamplesApp.Windows_UI_Xaml_Controls.Canvas.Measure_Children_In_Canvas"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<Grid>
		<Canvas>
			<Border x:Name="BBorderInCanvas"
			    Width="50"
			    Height="50"
			    HorizontalAlignment="Left"
			    Background="Red" />
		</Canvas>
		<Border x:Name="BBorderOutCanvas"
		    Width="50"
		    Height="50"
		    HorizontalAlignment="Center"
		    Background="Green" />
	</Grid>
</UserControl>
