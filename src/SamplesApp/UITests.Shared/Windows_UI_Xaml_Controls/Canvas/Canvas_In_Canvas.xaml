<UserControl x:Class="UITests.Shared.Windows_UI_Xaml_Controls.Canvas.Canvas_In_Canvas"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_Xaml_Controls.Canvas"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<StackPanel>
		<TextBlock FontSize="25">There should be a blue rectangle appearing</TextBlock>

		<StackPanel Orientation="Horizontal">
			<Canvas>
				<Canvas>
					<Border x:Name="CanvasBorderBlue1"
					    Width="80"
					    Height="40">
						<Rectangle Fill="Blue" />
					</Border>
				</Canvas>
			</Canvas>
		</StackPanel>
	</StackPanel>
</UserControl>
