<UserControl x:Class="Uno.UI.Samples.Content.UITests.GridTestsControl.Grid_with_UserControl_VerticalAlignment_Variable_Height"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="3000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<Grid Background="Red">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>
		<UserControl x:Name="MyUserControl_VerticalAlignedCenter"
		    Grid.Row="0"
		    Grid.Column="0"
		    VerticalAlignment="Center"
		    Background="Green">
			<TextBlock Text="Center" />
		</UserControl>
		<UserControl x:Name="MyUserControl_VerticalAlignedTop"
		    Grid.Row="0"
		    Grid.Column="1"
		    VerticalAlignment="Top"
		    Background="Yellow">
			<TextBlock Text="Top" />
		</UserControl>
		<UserControl x:Name="MyUserControl_VerticalAlignedBottom"
		    Grid.Row="0"
		    Grid.Column="2"
		    VerticalAlignment="Bottom"
		    Background="Purple">
			<TextBlock Text="Bottom" />
		</UserControl>
	</Grid>

</UserControl>
