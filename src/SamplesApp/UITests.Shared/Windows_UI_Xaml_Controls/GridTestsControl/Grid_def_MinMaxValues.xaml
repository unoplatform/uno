<Page
    x:Class="UITests.Windows_UI_Xaml_Controls.GridTestsControl.Grid_def_MinMaxValues"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel Margin="20" Spacing="8">
        <TextBlock FontSize="17">Following rectangles should all be identical:</TextBlock>
        <StackPanel Orientation="Horizontal" Spacing="8">

            <!--  Reference  -->
            <Rectangle
                Width="60"
                Height="20"
                Fill="Red"
                Stroke="Black"
                StrokeThickness="4" />

            <Grid
                Width="60"
                VerticalAlignment="Center"
                Background="Red"
                BorderBrush="Black"
                BorderThickness="4">
                <Grid.RowDefinitions>
                    <RowDefinition MinHeight="12" />
                </Grid.RowDefinitions>
            </Grid>

            <Grid
                Width="60"
                VerticalAlignment="Center"
                Background="Red"
                BorderBrush="Black"
                BorderThickness="4">
                <Grid.RowDefinitions>
                    <RowDefinition MinHeight="12" />
                </Grid.RowDefinitions>
            </Grid>

            <Grid
                Height="20"
                VerticalAlignment="Center"
                Background="Red"
                BorderBrush="Black"
                BorderThickness="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition MinWidth="52" />
                </Grid.ColumnDefinitions>
            </Grid>

            <Grid
                VerticalAlignment="Center"
                Background="Red"
                BorderBrush="Black"
                BorderThickness="4">
                <Grid.RowDefinitions>
                    <RowDefinition MinHeight="12" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition MinWidth="52" />
                </Grid.ColumnDefinitions>
            </Grid>

            <Canvas Width="60" Height="20">
                <Grid
                    Width="60"
                    VerticalAlignment="Center"
                    Background="Red"
                    BorderBrush="Black"
                    BorderThickness="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition MinHeight="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                </Grid>
            </Canvas>

            <Grid
                Width="60"
                VerticalAlignment="Center"
                Background="Red"
                BorderBrush="Black"
                BorderThickness="4">
                <Grid.RowDefinitions>
                    <RowDefinition MaxHeight="12" />
                </Grid.RowDefinitions>
                <Rectangle Height="30" />
            </Grid>
        </StackPanel>

        <StackPanel>
            <TextBlock>If the last one is bigger, that's because of a windows bug:</TextBlock>
            <HyperlinkButton NavigateUri="https://github.com/microsoft/microsoft-ui-xaml/issues/4887">https://github.com/microsoft/microsoft-ui-xaml/issues/4887</HyperlinkButton>
        </StackPanel>
    </StackPanel>
</Page>
