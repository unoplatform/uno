<UserControl x:Class="Uno.UI.Samples.Content.UITests.GridTestsControl.Grid_Style_Local_Override"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="3000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<Grid Background="Cyan">
		<Grid.Resources>
			<Style x:Key="panelStyle"
			    TargetType="Grid">
				<Setter Property="Background" Value="Red" />
			</Style>
		</Grid.Resources>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>
		<Grid Grid.Row="0"
		    Grid.Column="0"
		    Background="Blue"
		    Style="{StaticResource panelStyle}">
			<TextBlock Text="Should be blue"
			    TextWrapping="Wrap" />
		</Grid>
		<Grid Grid.Row="0"
		    Grid.Column="1"
		    Background="Blue"
		    Style="{StaticResource panelStyle}">
			<TextBlock Text="Should be blue too"
			    TextWrapping="Wrap" />
		</Grid>
		<Grid Grid.Row="0"
		    Grid.Column="2"
		    Style="{StaticResource panelStyle}">
			<TextBlock Text="Should be Red"
			    TextWrapping="Wrap" />
		</Grid>
	</Grid>

</UserControl>
