<UserControl x:Class="Uno.UI.Samples.UITests.LargeImageList"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="using:Uno.UI.Samples.UITests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.UITests"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<controls:SampleControl DataContext="{x:Bind SampleItems}"
	    SampleDescription="LargeImageList">
		<controls:SampleControl.SampleContent>
			<DataTemplate x:DataType="local:LargeImageList">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>
					<StackPanel>
						<TextBlock Height="40"
						    Foreground="Black">
							<Run Text="SampleItems: " /><Run Text="{Binding}" />
						</TextBlock>
					</StackPanel>
					<ListView Grid.Row="1"
					    Width="300"
					    Height="600"
					    ItemsSource="{Binding}">
						<ListView.ItemTemplate>
							<DataTemplate>
								<StackPanel>
									<TextBlock Height="40"
									    Foreground="Black">
										<Run Text="Image uri: " /><Run Text="{Binding Uri}" />
									</TextBlock>
									<Image Width="300"
									    Height="300"
									    Source="{Binding Uri}" />
								</StackPanel>
							</DataTemplate>
						</ListView.ItemTemplate>
					</ListView>
				</Grid>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>
