<UserControl
    x:Class="Uno.UI.Samples.UITests.Image.ImageOpened"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Uno.UI.Samples.UITests.Image"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <StackPanel>

        <Image
            x:Name="MyImage"
            Width="100"
            Height="100" />

        <Border Width="100" Height="100">
            <Border.Background>
                <ImageBrush x:Name="MyImageBrush" />
            </Border.Background>
        </Border>

        <TextBlock Text="Click any of the following URIs to update the above Image and ImageBrush:" />

        <Button Click="UpdateSource" Content="null" />

        <Button Click="UpdateSource" Content="ms-appx:///Assets/square100.png" />

        <Button Click="UpdateSource" Content="https://images.google.com/images/branding/googleg/1x/googleg_standard_color_128dp.png" />

        <Button Click="UpdateSource" Content="http://www.example.com/imagethatdoesnotexist.png" />

    </StackPanel>

</UserControl>
