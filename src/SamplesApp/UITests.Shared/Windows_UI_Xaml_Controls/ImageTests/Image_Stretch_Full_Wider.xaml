<Page
    x:Class="Uno.UI.Samples.UITests.Image.Image_Stretch_Full_Wider"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_Xaml_Controls.ImageTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel>
            <!--  UniformToFill  -->
            <TextBlock
                Margin="0,20,0,0"
                HorizontalAlignment="Center"
                Text="Stretch=UniformToFill and Image.Width=250 + Image.Height=500"
                TextAlignment="Center"
                TextWrapping="Wrap" />
            <Border
                Margin="20"
                Background="Cyan"
                BorderBrush="DarkBlue"
                BorderThickness="1">
                <Image
                    Width="250"
                    Height="500"
                    Source="ms-appx:///Assets/test_image_1252_836.png"
                    Stretch="UniformToFill" />
            </Border>

            <!--  Uniform  -->
            <TextBlock
                Margin="0,20,0,0"
                HorizontalAlignment="Center"
                Text="Stretch=Uniform and Image.Width=250 + Image.Height=500"
                TextAlignment="Center"
                TextWrapping="Wrap" />
            <Border
                Margin="20"
                Background="Cyan"
                BorderBrush="DarkBlue"
                BorderThickness="1">
                <Image
                    Width="250"
                    Height="500"
                    Source="ms-appx:///Assets/test_image_1252_836.png"
                    Stretch="Uniform" />
            </Border>

            <!--  Fill  -->
            <TextBlock
                Margin="0,20,0,0"
                HorizontalAlignment="Center"
                Text="Stretch=Fill and Image.Width=250 + Image.Height=500"
                TextAlignment="Center"
                TextWrapping="Wrap" />
            <Border
                Margin="20"
                Background="Cyan"
                BorderBrush="DarkBlue"
                BorderThickness="1">
                <Image
                    Width="250"
                    Height="500"
                    Source="ms-appx:///Assets/test_image_1252_836.png"
                    Stretch="Fill" />
            </Border>

            <!--  None  -->
            <TextBlock
                Margin="0,20,0,0"
                HorizontalAlignment="Center"
                Text="Stretch=None and Image.Width=250 + Image.Height=500"
                TextAlignment="Center"
                TextWrapping="Wrap" />
            <Border
                Margin="20"
                Background="Cyan"
                BorderBrush="DarkBlue"
                BorderThickness="1">
                <Image
                    Width="250"
                    Height="500"
                    Source="ms-appx:///Assets/test_image_1252_836.png"
                    Stretch="None" />
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
