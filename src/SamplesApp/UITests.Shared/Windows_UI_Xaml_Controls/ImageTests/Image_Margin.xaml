<Page x:Class="Uno.UI.Samples.UITests.Image.Image_Margin"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_Xaml_Controls.ImageTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
			<RowDefinition Height="*" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<Grid Grid.Row="0"
		    Grid.Column="0"
		    Width="100"
		    Height="100"
		    Background="Orange">
			<StackPanel HorizontalAlignment="Stretch"
			    VerticalAlignment="Center">
				<Image Margin="0,0"
				    Source="ms-appx:///Assets/ingredient3.png"
				    Stretch="Uniform" />
			</StackPanel>
		</Grid>

		<Grid Grid.Row="0"
		    Grid.Column="1"
		    Width="100"
		    Height="100"
		    Background="Orange">
			<StackPanel HorizontalAlignment="Stretch"
			    VerticalAlignment="Center">
				<Image Margin="20,0"
				    Source="ms-appx:///Assets/ingredient3.png"
				    Stretch="Uniform" />
			</StackPanel>
		</Grid>

		<Grid Grid.Row="0"
		    Grid.Column="2"
		    Width="100"
		    Height="100"
		    Background="Orange">
			<StackPanel HorizontalAlignment="Stretch"
			    VerticalAlignment="Center">
				<Image Margin="0,20"
				    Source="ms-appx:///Assets/ingredient3.png"
				    Stretch="Uniform" />
			</StackPanel>
		</Grid>

		<Grid Grid.Row="1"
		    Grid.Column="0"
		    Width="100"
		    Height="100"
		    Background="Orange">
			<StackPanel HorizontalAlignment="Stretch"
			    VerticalAlignment="Center">
				<Image Margin="20,0,0,0"
				    Source="ms-appx:///Assets/ingredient3.png"
				    Stretch="Uniform" />
			</StackPanel>
		</Grid>

		<Grid Grid.Row="1"
		    Grid.Column="1"
		    Width="100"
		    Height="100"
		    Background="Orange">
			<StackPanel HorizontalAlignment="Stretch"
			    VerticalAlignment="Center">
				<Image Margin="0,20,0,0"
				    Source="ms-appx:///Assets/ingredient3.png"
				    Stretch="Uniform" />
			</StackPanel>
		</Grid>

		<Grid Grid.Row="1"
		    Grid.Column="2"
		    Width="100"
		    Height="100"
		    Background="Orange">
			<StackPanel HorizontalAlignment="Stretch"
			    VerticalAlignment="Center">
				<Image Margin="0,0,20,0"
				    Source="ms-appx:///Assets/ingredient3.png"
				    Stretch="Uniform" />
			</StackPanel>
		</Grid>

		<Grid Grid.Row="2"
		    Grid.Column="0"
		    Width="100"
		    Height="100"
		    Background="Orange">
			<StackPanel HorizontalAlignment="Stretch"
			    VerticalAlignment="Center">
				<Image Margin="0,0,0,20"
				    Source="ms-appx:///Assets/ingredient3.png"
				    Stretch="Uniform" />
			</StackPanel>
		</Grid>

		<StackPanel Grid.Row="2"
		    Grid.Column="1"
		    Margin="16,0,0,0"
		    Orientation="Horizontal">

			<Border Width="32"
			    Height="32"
			    Margin="16,0,0,0"
			    Background="Red" />

			<Border>
				<Image Width="32"
				    Margin="16,0,0,0"
				    Source="Assets/ingredient3.png" />
			</Border>
		</StackPanel>
	</Grid>
</Page>
