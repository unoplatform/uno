<Page x:Class="Uno.UI.Samples.UITests.Image.Image_Stretch_Alignment_Wider"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Uno.UI.Samples.UITests.Image"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d not_win">

	<Grid HorizontalAlignment="Center">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<local:Image_Stretch_Modes_Picker x:Name="modesPicker" />
		<ScrollViewer Grid.Row="1">
			<ItemsControl ItemsSource="{Binding Items, ElementName=modesPicker}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<win:VariableSizedWrapGrid Orientation="Horizontal" />
						<not_win:WrapPanel Orientation="Horizontal" />
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<StackPanel Width="150"
						    Margin="5"
						    Padding="5"
						    Background="Chocolate">
							<TextBlock FontSize="12">
								<Run Text="{Binding Index}" />
								) s=<Run FontWeight="Bold"
								    Text="{Binding Stretch}" />
								<LineBreak />
								h=<Run FontWeight="Bold"
								    Text="{Binding HorizontalAlignment}" />
								<LineBreak />
								v=<Run FontWeight="Bold"
								    Text="{Binding VerticalAlignment}" />
							</TextBlock>
							<Border Width="125"
							    Height="125"
							    Background="DeepPink"
							    BorderBrush="Black"
							    BorderThickness="1">
								<Image HorizontalAlignment="{Binding HorizontalAlignment}"
								    VerticalAlignment="{Binding VerticalAlignment}"
								    Source="ms-appx:///Assets/test_image_150_100.png"
								    Stretch="{Binding Stretch}" />
							</Border>
						</StackPanel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</Grid>
</Page>
