<UserControl x:Class="Uno.UI.Samples.UITests.ImageTestsControl.Image_Stretch_None_Containers"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Uno.UI.Samples.UITests.ImageTestsControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<ScrollViewer>

		<StackPanel Background="LightGray">

			<TextBlock Text="ScrollViewer 0D" />
			<ScrollViewer Width="150"
			    Height="150"
			    Margin="10"
			    Background="White"
			    HorizontalScrollBarVisibility="Disabled"
			    HorizontalScrollMode="Disabled"
			    VerticalScrollBarVisibility="Disabled"
			    VerticalScrollMode="Disabled">
				<Image Width="300"
				    Height="300"
				    HorizontalAlignment="Right"
				    VerticalAlignment="Bottom"
				    Source="https://blog.xenproject.org/wp-content/uploads/2014/10/Testing.jpg"
				    Stretch="None" />
			</ScrollViewer>

			<TextBlock Text="ScrollViewer 1D" />
			<ScrollViewer Width="150"
			    Height="150"
			    Margin="10"
			    Background="White">
				<Image Width="300"
				    Height="300"
				    HorizontalAlignment="Right"
				    VerticalAlignment="Bottom"
				    Source="https://blog.xenproject.org/wp-content/uploads/2014/10/Testing.jpg"
				    Stretch="None" />
			</ScrollViewer>

			<TextBlock Text="ScrollViewer 2D" />
			<ScrollViewer Width="150"
			    Height="150"
			    Background="White"
			    HorizontalScrollBarVisibility="Visible"
			    HorizontalScrollMode="Enabled"
			    VerticalScrollBarVisibility="Visible"
			    VerticalScrollMode="Enabled">
				<Image Width="300"
				    Height="300"
				    HorizontalAlignment="Right"
				    VerticalAlignment="Bottom"
				    Source="https://blog.xenproject.org/wp-content/uploads/2014/10/Testing.jpg"
				    Stretch="None" />
			</ScrollViewer>

			<TextBlock Text="Border" />
			<Border Width="150"
			    Height="150"
			    Background="White">
				<Image Width="300"
				    Height="300"
				    HorizontalAlignment="Right"
				    VerticalAlignment="Bottom"
				    Source="https://blog.xenproject.org/wp-content/uploads/2014/10/Testing.jpg"
				    Stretch="None" />
			</Border>

			<TextBlock Text="StackPanel" />
			<StackPanel Width="150"
			    Height="150"
			    Background="White">
				<Image Width="300"
				    Height="300"
				    HorizontalAlignment="Right"
				    VerticalAlignment="Bottom"
				    Source="https://blog.xenproject.org/wp-content/uploads/2014/10/Testing.jpg"
				    Stretch="None" />
			</StackPanel>

		</StackPanel>
	</ScrollViewer>

</UserControl>
