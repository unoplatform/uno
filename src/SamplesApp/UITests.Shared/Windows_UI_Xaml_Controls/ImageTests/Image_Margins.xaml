<Page
    x:Class="UITests.Windows_UI_Xaml_Controls.ImageTests.Image_Margins"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="10">
        <TextBlock>Those 5 should all look-like identical:</TextBlock>
        <StackPanel Background="LightBlue" Orientation="Horizontal">
            <StackPanel>
                <Image
                    x:Name="img0"
                    Height="45"
                    Margin="12"
                    Source="ms-appx:///Assets/test_image_100_100.png" />
                <Rectangle
                    x:Name="rect0"
                    Width="45"
                    Height="45"
                    Fill="Red" />
            </StackPanel>
            <StackPanel>
                <Border>
                    <Image
                        x:Name="img1"
                        Height="45"
                        Margin="12"
                        Source="ms-appx:///Assets/test_image_100_100.png" />
                </Border>
                <Rectangle
                    x:Name="rect1"
                    Width="45"
                    Height="45"
                    Fill="Red" />
            </StackPanel>
            <StackPanel>
                <Border Height="45" Margin="12">
                    <Image x:Name="img2" Source="ms-appx:///Assets/test_image_100_100.png" />
                </Border>
                <Rectangle
                    x:Name="rect2"
                    Width="45"
                    Height="45"
                    Fill="Red" />
            </StackPanel>
            <StackPanel>
                <Image
                    x:Name="img3"
                    Height="45"
                    Margin="12"
                    Source="ms-appx:///Assets/test_image_100_100.png" />
                <Rectangle
                    x:Name="rect3"
                    Width="45"
                    Height="45"
                    Fill="Red" />
            </StackPanel>
            <StackPanel>
                <Border Padding="12">
                    <Image
                        x:Name="img4"
                        Height="45"
                        Source="ms-appx:///Assets/test_image_100_100.png" />
                </Border>
                <Rectangle
                    x:Name="rect4"
                    Width="45"
                    Height="45"
                    Fill="Red" />
            </StackPanel>
        </StackPanel>
        <TextBlock
            x:Name="tree"
            FontSize="14"
            TextWrapping="WrapWholeWords" />
    </StackPanel>
</Page>
