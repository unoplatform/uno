<Page x:Class="UITests.Windows_UI_Xaml_Controls.ImageTests.Image_AnimatedWebP"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<StackPanel Padding="16"
	    Spacing="16">
		<TextBlock Style="{StaticResource SubtitleTextBlockStyle}">Animated WebP</TextBlock>
		<Image Width="100"
		    Height="100"
		    Source="ms-appx:///Assets/Formats/animated.webp" />

		<TextBlock Style="{StaticResource SubtitleTextBlockStyle}">Animated GIF (reference)</TextBlock>
		<Image Width="100"
		    Height="100"
		    Source="ms-appx:///Assets/Formats/animated.gif" />

		<TextBlock Style="{StaticResource SubtitleTextBlockStyle}">Static WebP</TextBlock>
		<Image Width="100"
		    Height="100"
		    Source="ms-appx:///Assets/Formats/uno-overalls.webp" />
	</StackPanel>
</Page>
