<UserControl
    x:Class="Uno.UI.Samples.UITests.ImageTestsControl.UniformToFill100x100"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Uno.UI.Samples.UITests.ImageTestsControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <StackPanel>
        <Border
            Width="500"
            Height="200"
            Margin="0,20">
            <Image
                VerticalAlignment="Top"
                Source="https://upload.wikimedia.org/wikipedia/commons/thumb/9/95/Big_Pine_landscape.jpg/1920px-Big_Pine_landscape.jpg"
                Stretch="UniformToFill" />
        </Border>
        <Border
            Width="500"
            Height="200"
            Margin="0,20">
            <Image
                VerticalAlignment="Center"
                Source="https://upload.wikimedia.org/wikipedia/commons/thumb/9/95/Big_Pine_landscape.jpg/1920px-Big_Pine_landscape.jpg"
                Stretch="UniformToFill" />
        </Border>
        <Border
            Width="500"
            Height="200"
            Margin="0,20">
            <Image
                VerticalAlignment="Bottom"
                Source="https://upload.wikimedia.org/wikipedia/commons/thumb/9/95/Big_Pine_landscape.jpg/1920px-Big_Pine_landscape.jpg"
                Stretch="UniformToFill" />
        </Border>

    </StackPanel>
</UserControl>
