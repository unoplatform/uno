<UserControl
    x:Class="UITests.Shared.Windows_UI_Xaml_Controls.MediaPlayerElement.MediaPlayerElement_Multiple"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.MediaPlayerElement"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="200" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />

                <RowDefinition Height="200" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Row="0"
                Grid.ColumnSpan="2"
                Margin="12"
                Text="Test Two MediaPlayers on UI."
                TextWrapping="Wrap" />


            <MediaPlayerElement
                x:Name="Mpe"
                Grid.Row="1"
                Grid.ColumnSpan="2"
                AreTransportControlsEnabled="True"
                AutoPlay="True" />

            <TextBlock
                Grid.Row="2"
                Grid.ColumnSpan="2"
                Margin="12"
                Text="Change the source of the video player dynamically by entering a different url. An empty url should clear the video."
                TextWrapping="Wrap" />

            <TextBox
                x:Name="SourceTextBox"
                Grid.Row="3"
                Margin="12"
                HorizontalAlignment="Stretch"
                Text="https://uno-assets.platform.uno/tests/videos/Mobile_Development_in_VS_Code_with_Uno_Platform_orDotNetMAUI.mp4" />

            <Button
                x:Name="UpdateButton"
                Grid.Row="3"
                Grid.Column="1"
                Width="125"
                Margin="12"
                Click="UpdateButton_Click"
                Content="Update source" />

            <MediaPlayerElement
                x:Name="MpeTwo"
                Grid.Row="4"
                Grid.ColumnSpan="2"
                AreTransportControlsEnabled="True"
                AutoPlay="True" />

            <TextBlock
                Grid.Row="5"
                Grid.ColumnSpan="2"
                Margin="12"
                Text="Change the source of the video player dynamically by entering a different url. An empty url should clear the video."
                TextWrapping="Wrap" />

            <TextBox
                x:Name="SourceTwoTextBox"
                Grid.Row="6"
                Margin="12"
                HorizontalAlignment="Stretch"
                Text="https://uno-assets.platform.uno/tests/videos/Getting_Started_with_Uno_Platform_and_Visual_Studio_Code.mp4" />

            <Button
                x:Name="UpdateButtonTwo"
                Grid.Row="6"
                Grid.Column="1"
                Width="125"
                Margin="12"
                Click="UpdateButtonTwo_Click"
                Content="Update source" />
        </Grid>
    </ScrollViewer>
</UserControl>
