<UserControl x:Class="Uno.UI.Samples.Content.UITests.TextBoxControl.TextBoxPadding"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<controls:SampleControl SampleDescription="TextBox with Padding set">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<StackPanel VerticalAlignment="Center"
				    Background="Beige"
				    Orientation="Horizontal">
					<TextBlock Padding="0,40"
					    VerticalAlignment="Bottom"
					    FontSize="11"
					    Foreground="Red"
					    Text=" TextBlockText" />
					<TextBox Padding="0,40"
					    FontSize="11"
					    Header="TextBoxHeader"
					    Text="TextBoxText" />
				</StackPanel>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>
