<Page x:Class="UITests.Shared.Windows_UI_Xaml_Controls.TextBoxes.TextBox_NaturalSize"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<StackPanel HorizontalAlignment="Left">
		<TextBlock FontSize="22">
			An empty TextBox render width should be 64px.<LineBreak />
			So it should be the same width as the red rectangle.<LineBreak />
			The yellow panel shouldn't be visible at all.</TextBlock>
		<Rectangle x:Name="recth"
		    Width="64"
		    Height="9"
		    Margin="0"
		    HorizontalAlignment="Left"
		    Fill="Red" />
		<StackPanel x:Name="yellowpanel"
		    HorizontalAlignment="Left"
		    Background="Yellow"
		    Orientation="Horizontal">
			<TextBox x:Name="textbox_sut"
			    Background="White" />
		</StackPanel>
	</StackPanel>
</Page>
