<UserControl
    x:Class="Uno.UI.Samples.UITests.TextBoxControl.TextBox_IsReadOnly"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel>
        <TextBox
            x:Name="txt"
            IsEnabled="True"
            IsReadOnly="True"
            Text="This text should initially be READONLY and ENABLED..." />
        <ToggleButton x:Name="tglReadonly" IsChecked="{Binding IsReadOnly, ElementName=txt, Mode=TwoWay}">
            IsReadOnly
        </ToggleButton>
        <ToggleButton x:Name="tglEnabled" IsChecked="{Binding IsEnabled, ElementName=txt, Mode=TwoWay}">
            IsEnabled
        </ToggleButton>
    </StackPanel>
</UserControl>
