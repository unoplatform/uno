<UserControl
    x:Class="UITests.Shared.Windows_UI_Xaml_Controls.TextBoxTests.Width_Affects_Delete_Button"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.TextBox"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBox
                x:Name="initiallySmall"
                Width="70"
                FontSize="14"
                Text="A" />
            <Button
                x:Name="makeBiggerBtn"
                Click="MakeBiggerClick"
                Content="Make bigger" />
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBox
                x:Name="initiallyLarge"
                Width="71"
                FontSize="14"
                Text="A" />
            <Button
                x:Name="makeSmallerBtn"
                Click="MakeSmallerClick"
                Content="Make smaller" />
        </StackPanel>

    </StackPanel>
</UserControl>
