<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.TextBoxControl.TextBox_HorizontalAlignment"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <StackPanel>

        <TextBlock Text="Typing in Source should expand other TextBoxes" />

        <TextBox
            x:Name="Source"
            Margin="0,0,0,50"
            Header="Source"
            Text="Text" />

        <TextBox
            HorizontalAlignment="Stretch"
            Header="Stretch"
            Text="{Binding Text, ElementName=Source}" />

        <TextBox
            HorizontalAlignment="Left"
            Header="Left"
            Text="{Binding Text, ElementName=Source}" />

        <TextBox
            HorizontalAlignment="Center"
            Header="Center"
            Text="{Binding Text, ElementName=Source}" />

        <TextBox
            HorizontalAlignment="Right"
            Header="Right"
            Text="{Binding Text, ElementName=Source}" />

        <TextBox
            HorizontalAlignment="Center"
            AcceptsReturn="True"
            Header="Center Multiline"
            Text="{Binding Text, ElementName=Source}" />

    </StackPanel>

</UserControl>
