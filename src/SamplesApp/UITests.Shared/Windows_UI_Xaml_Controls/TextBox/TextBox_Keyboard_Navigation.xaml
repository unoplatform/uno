<UserControl
    x:Class="UITests.Shared.Windows_UI_Xaml_Controls.TextBoxTests.TextBox_Keyboard_Navigation"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid KeyDown="Grid_KeyDown" XYFocusKeyboardNavigation="Enabled">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" />
            <ColumnDefinition Width="350" />
            <ColumnDefinition Width="350" />
        </Grid.ColumnDefinitions>
        <PasswordBox
            Grid.Row="0"
            Grid.Column="0"
            Password="Lorem" />
        <TextBox
            Grid.Row="0"
            Grid.Column="1"
            Text="ipsum" />
        <TextBox
            Grid.Row="0"
            Grid.Column="2"
            Text="dolor" />
        <TextBox
            Grid.Row="1"
            Grid.Column="0"
            Text="sit" />
        <PasswordBox
            Grid.Row="1"
            Grid.Column="1"
            Password="amet" />
        <TextBox
            Grid.Row="1"
            Grid.Column="2"
            Text="consectetur" />
        <Button
            Grid.Row="2"
            Grid.Column="0"
            Width="80"
            Height="30"
            Click="Button_OnClick"
            Content="Clear" />
        <Button
            Grid.Row="2"
            Grid.Column="1"
            Width="80"
            Height="30"
            Click="Button_OnClick"
            Content="Clear" />
        <Button
            Grid.Row="2"
            Grid.Column="2"
            Width="80"
            Height="30"
            Click="Button_OnClick"
            Content="Clear" />
        <ScrollViewer Grid.Row="3" Grid.Column="0">
            <TextBlock x:Name="myContent" Text="Event info:&#x0a;" />
        </ScrollViewer>
    </Grid>
</UserControl>
