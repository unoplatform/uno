<UserControl x:Class="UITests.Shared.Windows_UI_Xaml_Controls.TextBoxTests.TextBox_CharacterCasing"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.TextBox"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<StackPanel Padding="20"
	    Spacing="20">

		<TextBox x:Name="DefaultCasingTextBox"
		    Header="Default"
		    PlaceholderText="Default (any casing)" />

		<TextBox x:Name="LowerCasingTextBox"
		    CharacterCasing="Lower"
		    Header="Lower"
		    PlaceholderText="Only Lower Text" />

		<TextBox x:Name="UpperCasingTextBox"
		    CharacterCasing="Upper"
		    Header="Upper"
		    PlaceholderText="Only Upper Text" />

		<TextBox x:Name="NormalCasingTextBox"
		    CharacterCasing="Normal"
		    Header="Normal"
		    PlaceholderText="Normal (any casing)" />
	</StackPanel>
</UserControl>
