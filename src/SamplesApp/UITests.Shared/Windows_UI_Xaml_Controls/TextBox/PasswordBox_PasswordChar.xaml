<UserControl x:Class="Uno.UI.Samples.Content.UITests.TextBoxControl.PasswordBox_PasswordChar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
		<ScrollViewer>
			<StackPanel Margin="20">
				<TextBlock Margin="0,0,0,20"
				    Style="{ThemeResource HeaderTextBlockStyle}"
				    Text="PasswordBox PasswordChar Testing" />

				<TextBlock Margin="0,0,0,5"
				    Text="Default PasswordChar:" />
				<PasswordBox x:Name="DefaultPasswordBox"
				    Margin="0,0,0,20"
				    Password="TestPassword" />

				<TextBlock Margin="0,0,0,5"
				    Text="Custom PasswordChar (*):" />
				<PasswordBox x:Name="CustomPasswordBox"
				    Margin="0,0,0,20"
				    Password="TestPassword"
				    PasswordChar="*" />

				<TextBlock Margin="0,0,0,5"
				    Text="Custom PasswordChar (?):" />
				<PasswordBox x:Name="QuestionPasswordBox"
				    Margin="0,0,0,20"
				    Password="TestPassword"
				    PasswordChar="?" />

				<TextBlock Margin="0,0,0,5"
				    Text="Dollar Character ($):" />
				<PasswordBox x:Name="DollarPasswordBox"
				    Margin="0,0,0,20"
				    Password="TestPassword"
				    PasswordChar="$" />

				<TextBlock Margin="0,0,0,5"
				    Text="Change PasswordChar dynamically:" />
				<PasswordBox x:Name="DynamicPasswordBox"
				    Margin="0,0,0,10"
				    Password="TestPassword" />
				<StackPanel Margin="0,0,0,20"
				    Orientation="Horizontal"
				    Spacing="10">
					<Button Click="SetDefaultChar_Click"
					    Content="Set to default" />
					<Button Click="SetAsterisk_Click"
					    Content="Set to *" />
					<Button Click="SetQuestion_Click"
					    Content="Set to ?" />
					<Button Click="SetDollar_Click"
					    Content="Set to $" />
				</StackPanel>

				<TextBlock Margin="0,20,0,10"
				    Style="{ThemeResource SubheaderTextBlockStyle}"
				    Text="Current PasswordChar values:" />
				<StackPanel x:Name="ValuesPanel">
					<TextBlock x:Name="DefaultValueText"
					    Margin="0,0,0,5" />
					<TextBlock x:Name="CustomValueText"
					    Margin="0,0,0,5" />
					<TextBlock x:Name="QuestionValueText"
					    Margin="0,0,0,5" />
					<TextBlock x:Name="DollarValueText"
					    Margin="0,0,0,5" />
					<TextBlock x:Name="DynamicValueText"
					    Margin="0,0,0,5" />
				</StackPanel>
			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>
