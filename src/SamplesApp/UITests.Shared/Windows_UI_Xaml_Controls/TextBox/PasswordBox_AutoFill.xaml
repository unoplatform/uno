<UserControl x:Class="Uno.UI.Samples.Content.UITests.TextBoxControl.PasswordBox_AutoFill"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<UserControl.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="PasswordBox_Style.xaml" />
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</UserControl.Resources>

	<StackPanel HorizontalAlignment="Left"
	    VerticalAlignment="Top">
		<TextBlock Text="Make sure Settings-&gt;Passwords-&gt;Autofill is on. Password boxes should still work as normal with the iOS soft keyboard with no auto-fill interference."
		    TextWrapping="Wrap" />

		<!--  A texbox is needed on the same page to trigger auto-fill for the password boxes  -->
		<TextBlock Text="EMAIL" />
		<TextBox Name="EmailBox"
		    InputScope="EmailSmtpAddress"
		    IsSpellCheckEnabled="false" />

		<TextBlock Text="PASSWORD" />
		<PasswordBox x:Name="PasswordBox" />

		<TextBlock Text="CONFIRM PASSWORD" />
		<PasswordBox x:Name="ConfirmPasswordBox" />
	</StackPanel>
</UserControl>
