<Page x:Class="UITests.Windows_UI_Xaml_Controls.TextBox.TextBox_Visibility"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.TextBox"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<StackPanel>
		<TextBox x:Name="MyTextBox"
		    Foreground="Red"
		    Text="My TextBox" />
		<Button x:Name="ShowHideButton"
		    Click="ShowHideButton_Click"
		    Content="Show/Hide TextBox" />
	</StackPanel>
</Page>
