<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.TextBoxControl.TextBox_ScrollView_Inset_ChangeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="800"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <!--
        Reproduces: multiline TextBox with disabled internal scrolling inside an outer ScrollViewer.
        Tests that the outer ScrollViewer scrolls to the caret position on focus and text changes.
    -->
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header bar simulating a modal navigation bar  -->
        <Grid
            Grid.Row="0"
            Padding="16,8"
            Background="#6A1B9A"
            CornerRadius="12,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                Content="Cancel"
                Foreground="White" />

            <TextBlock
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="White"
                Text="Session Narrative" />

            <Button
                Grid.Column="2"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                Content="OK"
                Foreground="White" />
        </Grid>

        <!--
            The outer ScrollViewer handles all scrolling; the TextBox's internal
            scrolling is disabled so it grows naturally with content.
        -->
        <ScrollViewer
            x:Name="ContentScrollViewer"
            Grid.Row="1"
            Padding="28,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Margin="0,12,0,0"
                    FontSize="14"
                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                    Text="Please review, edit, and add relevant detail so that this accurately summarizes your session."
                    TextWrapping="Wrap" />

                <Grid Grid.Row="1">
                    <TextBox
                        x:Name="NarrativeTextBox"
                        MinHeight="48"
                        Margin="0,16"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        AcceptsReturn="True"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="1"
                        PlaceholderText="Session Narrative"
                        ScrollViewer.IsDeferredScrollingEnabled="False"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollMode="Disabled"
                        TextWrapping="Wrap" />
                </Grid>
            </Grid>
        </ScrollViewer>

        <!--  Save button at bottom  -->
        <Button
            Grid.Row="2"
            Margin="16,30"
            Padding="12"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            Background="#6A1B9A"
            Content="Save Session Note"
            Foreground="White" />
    </Grid>
</UserControl>
