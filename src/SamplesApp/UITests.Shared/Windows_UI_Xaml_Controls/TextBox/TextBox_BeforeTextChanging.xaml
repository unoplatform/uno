<UserControl x:Class="UITests.Shared.Windows_UI_Xaml_Controls.TextBoxTests.TextBox_BeforeTextChanging"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<StackPanel>
		<TextBox x:Name="BeforeTextBox"
		    Margin="5"
		    BeforeTextChanging="BeforeTextBox_BeforeTextChanging"
		    IsSpellCheckEnabled="False"
		    MaxLength="20"
		    PlaceholderText="only permits the letter e..." />
		<TextBlock x:Name="BeforeTextBlock"
		    Text="{Binding ElementName=BeforeTextBox, Path=Text}" />
	</StackPanel>
</UserControl>
