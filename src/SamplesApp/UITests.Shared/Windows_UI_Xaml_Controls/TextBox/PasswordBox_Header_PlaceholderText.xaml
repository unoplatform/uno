<UserControl x:Class="Uno.UI.Samples.Content.UITests.TextBoxControl.PasswordBox_Header_PlaceholderText"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<controls:SampleControl SampleDescription="PasswordBox with Header and PlaceholderText">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<PasswordBox Width="200"
				    VerticalAlignment="Top"
				    Header="Cool password"
				    PlaceholderText="Enter password here" />
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>
