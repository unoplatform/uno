<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.TextBoxControl.TextBox_TextAlignment"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <controls:SampleControl SampleDescription="TextBox with different TextAlignment values">
        <controls:SampleControl.SampleContent>
            <DataTemplate>
                <StackPanel>
                    <TextBox
                        x:Name="LeftAlignedTextBox"
                        Text="Left"
                        TextAlignment="Left" />

                    <TextBox
                        x:Name="CenterAlignedTextBox"
                        Text="Center"
                        TextAlignment="Center" />

                    <TextBox
                        x:Name="RightAlignedTextBox"
                        Text="Right"
                        TextAlignment="Right" />

                    <TextBox
                        x:Name="JustifyAlignedTextBox"
                        Text="Justify"
                        TextAlignment="Justify" />

                    <TextBox
                        x:Name="DetectFromContentAlignedTextBox"
                        Text="Detected from content"
                        TextAlignment="DetectFromContent" />
                </StackPanel>
            </DataTemplate>
        </controls:SampleControl.SampleContent>
    </controls:SampleControl>
</UserControl>
