<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.TextBoxControl.TextBox_ControlCharacter"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <StackPanel Padding="20" Spacing="12">
        <TextBlock
            FontSize="20"
            FontWeight="Bold"
            Text="Control Character Filtering Test" />

        <TextBlock TextWrapping="Wrap">
            This test validates that pressing Ctrl + letter keys does not insert control characters into the TextBox.
            Control characters (ASCII 0x00-0x1F) should be filtered out and not appear as text.
        </TextBlock>

        <TextBlock
            Margin="0,12,0,0"
            FontWeight="SemiBold"
            Text="Test Instructions:" />

        <TextBlock TextWrapping="Wrap">
            1. Click on the TextBox below to focus it
        </TextBlock>
        <TextBlock TextWrapping="Wrap">
            2. Press Ctrl+F, Ctrl+G, Ctrl+H, Ctrl+B, or any other Ctrl+letter combination
        </TextBlock>
        <TextBlock TextWrapping="Wrap">
            3. Verify that NO characters appear in the TextBox (no squares/rectangles)
        </TextBlock>

        <TextBlock
            Margin="0,12,0,0"
            FontWeight="SemiBold"
            Text="Expected Exceptions (these SHOULD insert text):" />

        <TextBlock TextWrapping="Wrap">
            • Ctrl+V - Should paste clipboard content
        </TextBlock>

        <TextBlock
            Margin="0,16,0,4"
            FontWeight="SemiBold"
            Text="Single-line TextBox:" />
        <TextBox x:Name="SingleLineTextBox" PlaceholderText="Type here or press Ctrl+letter..." />

        <TextBlock
            Margin="0,16,0,4"
            FontWeight="SemiBold"
            Text="Multi-line TextBox (AcceptsReturn=True):" />
        <TextBox
            x:Name="MultiLineTextBox"
            Height="100"
            AcceptsReturn="True"
            PlaceholderText="Type here - Enter should insert newline..."
            TextWrapping="Wrap" />

        <TextBlock
            Margin="0,16,0,0"
            FontWeight="SemiBold"
            Text="Pass Criteria:" />
        <TextBlock TextWrapping="Wrap">
            ✓ Ctrl+F, Ctrl+G, Ctrl+B, etc. do NOT insert any characters (no squares/rectangles)
        </TextBlock>
        <TextBlock TextWrapping="Wrap">
            ✓ Ctrl+V pastes normally
        </TextBlock>

        <TextBlock
            Margin="0,12,0,0"
            FontWeight="SemiBold"
            Text="Fail Criteria:" />
        <TextBlock TextWrapping="Wrap">
            ✗ Pressing Ctrl+letter inserts visible squares/rectangles (invalid characters)
        </TextBlock>
    </StackPanel>
</UserControl>
