<Page
    x:Class="UITests.Shared.Windows_UI_Xaml_Controls.Popup.Popup_LightDismiss"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel>
        <TextBlock>Open 4 dismissable popups. They should be dismissable one after the other, starting by the last (forth) one.</TextBlock>
        <Button x:Name="btn4">Open 4 dismissable popups</Button>
        <TextBlock><LineBreak />
            Open 4 dismissable popups. They should be dismissable one after the other, starting by the first one (last opened).</TextBlock>
        <Button x:Name="btn4R">Open 4 dismissable popups in reverse order</Button>
        <TextBlock><LineBreak />
            Open 4 dismissable popups + 1 non-dismissable one. You should be able to dismiss all 4 popups even when the 5th is still opened.</TextBlock>
        <Button x:Name="btn5">Open 4 dismissable popups + 1 non-dismissable popup</Button>
        <TextBlock><LineBreak /><LineBreak />
            Important: clicking/tapping in the last opened dismissable popup shouldn't dismiss it.</TextBlock>

        <Popup
            x:Name="popup1"
            HorizontalOffset="100"
            IsLightDismissEnabled="True">
            <Border
                Width="75"
                Height="50"
                Background="Red">
                <TextBlock x:Name="FirstPopupTextBlock">First Popup</TextBlock>
            </Border>
        </Popup>
        <Popup
            x:Name="popup2"
            HorizontalOffset="200"
            IsLightDismissEnabled="True">
            <Border
                Width="75"
                Height="50"
                Background="Yellow">
                <TextBlock x:Name="SecondPopupTextBlock">Second Popup</TextBlock>
            </Border>
        </Popup>
        <Popup
            x:Name="popup3"
            HorizontalOffset="100"
            IsLightDismissEnabled="True"
            VerticalOffset="100">
            <Border
                Width="75"
                Height="50"
                Background="Blue">
                <TextBlock x:Name="ThirdPopupTextBlock">Third Popup</TextBlock>
            </Border>
        </Popup>
        <Popup
            x:Name="popup4"
            HorizontalOffset="200"
            IsLightDismissEnabled="True"
            VerticalOffset="100">
            <Border
                Width="75"
                Height="50"
                Background="Green">
                <TextBlock x:Name="FourthPopupTextBlock">Fourth Popup</TextBlock>
            </Border>
        </Popup>

        <Popup
            x:Name="popup5"
            HorizontalOffset="100"
            IsLightDismissEnabled="False"
            VerticalOffset="200">
            <Border
                Width="175"
                Height="50"
                Padding="8"
                Background="Cyan">
                <Button x:Name="close5">Close this</Button>
            </Border>
        </Popup>
    </StackPanel>
</Page>
