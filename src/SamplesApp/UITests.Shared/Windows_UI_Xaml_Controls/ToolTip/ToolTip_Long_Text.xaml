<UserControl
    x:Class="UITests.Windows_UI_Xaml_Controls.ToolTip.ToolTip_Long_Text"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.ToolTip"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <StackPanel Margin="0,100,0,0" HorizontalAlignment="Center">
        <Rectangle
            x:Name="UpperLocator"
            Height="100"
            HorizontalAlignment="Stretch"
            Fill="Transparent" />
        <Button
            x:Name="ButtonWithTooltip"
            Width="250"
            Height="200"
            Content="Button with tooltip">
            <ToolTipService.ToolTip>
                <Border
                    x:Name="BorderInsideToolTip"
                    Height="80"
                    Background="Pink"
                    CornerRadius="15">
                    <TextBlock Text="Tooltip content" />
                </Border>
            </ToolTipService.ToolTip>
        </Button>
        <Rectangle
            x:Name="LowerLocator"
            Height="100"
            HorizontalAlignment="Stretch"
            Fill="Transparent" />
        <Button x:Name="DummyButton" Content="Dummy" />
    </StackPanel>
</UserControl>
