<Page
    x:Class="UITests.Shared.Windows_UI_Xaml_Controls.ViewBoxTests.ViewBox_Alignment"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_Xaml_Controls.ViewBoxTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Viewbox Grid.ColumnSpan="2" Stretch="None">
            <Border
                Width="100"
                Height="100"
                Background="DeepSkyBlue">
                <TextBlock Text="Default" />
            </Border>
        </Viewbox>

        <Viewbox
            Grid.Row="1"
            Grid.Column="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Stretch="None">
            <Border
                Width="100"
                Height="100"
                Background="#FF69B4">
                <TextBlock Text="ViewBox top-left" TextWrapping="Wrap" />
            </Border>
        </Viewbox>
        <Viewbox
            Grid.Row="1"
            Grid.Column="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Stretch="None">
            <Border
                Width="100"
                Height="100"
                Margin="0,0,1,1"
                Background="#FF0000">
                <TextBlock Text="ViewBox top-right" TextWrapping="Wrap" />
            </Border>
        </Viewbox>
        <Viewbox
            Grid.Row="2"
            Grid.Column="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Stretch="None">
            <Border
                Width="100"
                Height="100"
                Margin="0,0,1,1"
                Background="#FF8E00">
                <TextBlock Text="ViewBox bottom-left" TextWrapping="Wrap" />
            </Border>
        </Viewbox>
        <Viewbox
            Grid.Row="2"
            Grid.Column="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Stretch="None">
            <Border
                Width="100"
                Height="100"
                Margin="0,0,1,1"
                Background="#FFFF00">
                <TextBlock Text="ViewBox bottom-right" TextWrapping="Wrap" />
            </Border>
        </Viewbox>

        <Viewbox
            Grid.Row="3"
            Grid.Column="0"
            Stretch="None">
            <Border
                Width="100"
                Height="100"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="#008E00">
                <TextBlock Text="Child top-left" TextWrapping="Wrap" />
            </Border>
        </Viewbox>
        <Viewbox
            Grid.Row="3"
            Grid.Column="1"
            Stretch="None">
            <Border
                Width="100"
                Height="100"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="#00C0C0">
                <TextBlock Text="Child top-right" TextWrapping="Wrap" />
            </Border>
        </Viewbox>
        <Viewbox
            Grid.Row="4"
            Grid.Column="0"
            Stretch="None">
            <Border
                Width="100"
                Height="100"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Background="#400098">
                <TextBlock Text="Child bottom-left" TextWrapping="Wrap" />
            </Border>
        </Viewbox>
        <Viewbox
            Grid.Row="4"
            Grid.Column="1"
            Stretch="None">
            <Border
                Width="100"
                Height="100"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="#8E008E">
                <TextBlock Text="Child bottom-right" TextWrapping="Wrap" />
            </Border>
        </Viewbox>
    </Grid>
</Page>
