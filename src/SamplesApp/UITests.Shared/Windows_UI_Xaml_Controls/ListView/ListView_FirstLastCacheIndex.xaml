<UserControl x:Class="SamplesApp.Windows_UI_Xaml_Controls.ListView.ListView_FirstLastCacheIndex"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<StackPanel>
		<ListView x:Name="MyListView"
		    Width="230"
		    Height="300"
		    Background="Gray"
		    ItemsSource="{Binding LotsOfNumbers}">
			<ListView.ItemTemplate>
				<DataTemplate>
					<Border Width="50"
					    Height="25"
					    BorderBrush="Blue"
					    BorderThickness="1">
						<TextBlock VerticalAlignment="Center"
						    FontSize="10"
						    Text="{Binding}" />
					</Border>
				</DataTemplate>
			</ListView.ItemTemplate>
			<ListView.ItemsPanel>
				<ItemsPanelTemplate>
					<ItemsStackPanel CacheLength="4" />
				</ItemsPanelTemplate>
			</ListView.ItemsPanel>
		</ListView>
		<TextBlock x:Name="FirstCacheIndexTextBlock"
		    Text="FirstCacheIndex:" />
		<TextBlock x:Name="LastCacheIndexTextBlock"
		    Text="LastCacheIndex:" />
	</StackPanel>
</UserControl>
