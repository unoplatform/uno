<UserControl x:Class="SamplesApp.Windows_UI_Xaml_Controls.ListView.ListViewMarginTest"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">
	<UserControl.Resources>
		<Style x:Key="ListViewItemMarginStyle"
		    TargetType="ListViewItem">
			<Setter Property="HorizontalContentAlignment" Value="Stretch" />
			<Setter Property="VerticalContentAlignment" Value="Stretch" />
			<Setter Property="Width" Value="25" />
			<Setter Property="Height" Value="120" />
			<Setter Property="Margin" Value="40,20,10,10" />
			<Setter Property="Padding" Value="0" />
		</Style>
	</UserControl.Resources>

	<controls:SampleControl SampleDescription="ListView with Margin set on ListViewItem. Coloured rectangles outside and inside the ListView should be the same size.">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>
					<StackPanel Grid.Row="0"
					    Grid.Column="1"
					    BorderBrush="Brown"
					    BorderThickness="1"
					    Orientation="Horizontal">
						<ListViewItem Width="25"
						    Height="120"
						    Style="{StaticResource ListViewItemMarginStyle}">
							<Border Width="1000"
							    Height="1000">
								<Border.Background>
									<SolidColorBrush Color="Brown" />
								</Border.Background>
							</Border>
						</ListViewItem>
					</StackPanel>
					<StackPanel Grid.Row="1"
					    Grid.Column="0"
					    BorderBrush="Brown"
					    BorderThickness="1"
					    Orientation="Vertical">
						<ListViewItem Width="25"
						    Height="120"
						    Style="{StaticResource ListViewItemMarginStyle}">
							<Border Width="1000"
							    Height="1000">
								<Border.Background>
									<SolidColorBrush Color="Brown" />
								</Border.Background>
							</Border>
						</ListViewItem>
						<ListViewItem Width="25"
						    Height="120"
						    Style="{StaticResource ListViewItemMarginStyle}">
							<Border Width="1000"
							    Height="1000">
								<Border.Background>
									<SolidColorBrush Color="Brown" />
								</Border.Background>
							</Border>
						</ListViewItem>
					</StackPanel>
					<Border Grid.Row="1"
					    Grid.Column="1"
					    Margin="0"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Center"
					    BorderBrush="Black"
					    BorderThickness="1">
						<ListView Height="300"
						    ItemContainerStyle="{StaticResource ListViewItemMarginStyle}"
						    ItemsSource="{Binding SampleColors}">
							<ListView.ItemTemplate>
								<DataTemplate>
									<Border Width="1000"
									    Height="1000">
										<Border.Background>
											<SolidColorBrush Color="{Binding}" />
										</Border.Background>
										<!--<Border.Child>
									<TextBlock Text="{Binding}" Foreground="White" TextWrapping="Wrap"/>
								</Border.Child>-->
									</Border>
								</DataTemplate>
							</ListView.ItemTemplate>
						</ListView>
					</Border>
				</Grid>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>
