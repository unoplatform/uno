<UserControl x:Class="SamplesApp.Windows_UI_Xaml_Controls.ListView.ListView_WithScrollViewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<Grid>

		<ListView Header="{Binding}"
		    ItemsSource="{Binding SingleItemList}">
			<ListView.HeaderTemplate>
				<DataTemplate>
					<StackPanel>
						<TextBlock Text="{Binding HorizontalScrollDescription}"
						    TextWrapping="Wrap" />

						<Image Height="50"
						    HorizontalAlignment="Left"
						    Source="ms-appx:/Assets/ScrollGesture.png"
						    Stretch="Uniform" />
					</StackPanel>
				</DataTemplate>
			</ListView.HeaderTemplate>
			<ListView.ItemTemplate>
				<DataTemplate>
					<Border Height="500"
					    Margin="5"
					    Background="Green"
					    BorderBrush="Black"
					    BorderThickness="2">
						<ScrollViewer HorizontalScrollBarVisibility="Visible"
						    HorizontalScrollMode="Enabled"
						    VerticalScrollBarVisibility="Disabled"
						    VerticalScrollMode="Disabled">
							<StackPanel Orientation="Horizontal">

								<TextBlock Width="313"
								    Height="100"
								    Margin="5"
								    Text="Item #1" />

								<TextBlock Width="313"
								    Height="100"
								    Margin="5"
								    Text="Item #2" />

								<TextBlock Width="313"
								    Height="100"
								    Margin="5"
								    Text="Item #3" />

								<TextBlock Width="313"
								    Height="100"
								    Margin="5"
								    Text="Item #4" />

								<TextBlock Width="313"
								    Height="100"
								    Margin="5"
								    Text="Item #5" />

								<TextBlock Width="313"
								    Height="100"
								    Margin="5"
								    Text="Item #6" />

								<TextBlock Width="313"
								    Height="100"
								    Margin="5"
								    Text="Item #7" />

								<TextBlock Width="313"
								    Height="100"
								    Margin="5"
								    Text="Item #8" />

								<TextBlock Width="313"
								    Height="100"
								    Margin="5"
								    Text="Item #9" />

								<TextBlock Width="313"
								    Height="100"
								    Margin="5"
								    Text="Item #10" />

								<TextBlock Width="313"
								    Height="100"
								    Margin="5"
								    Text="Item #11" />

								<TextBlock Width="313"
								    Height="100"
								    Margin="5"
								    Text="Item #12" />

								<TextBlock Width="313"
								    Height="100"
								    Margin="5"
								    Text="Item #13" />

								<TextBlock Width="313"
								    Height="100"
								    Margin="5"
								    Text="Item #14" />

								<TextBlock Width="313"
								    Height="100"
								    Margin="5"
								    Text="Item #15" />

								<TextBlock Width="313"
								    Height="100"
								    Margin="5"
								    Text="Item #16" />
							</StackPanel>
						</ScrollViewer>
					</Border>
				</DataTemplate>
			</ListView.ItemTemplate>
		</ListView>
	</Grid>
</UserControl>
