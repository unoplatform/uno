<UserControl
    x:Class="SamplesApp.Windows_UI_Xaml_Controls.ListView.SubButtonsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Rectangle
            x:Name="LeftRectangle"
            Grid.Row="0"
            Grid.Column="0"
            Width="50"
            Height="50"
            Margin="10"
            Fill="Blue" />
        <Rectangle
            x:Name="RightRectangle"
            Grid.Row="0"
            Grid.Column="1"
            Width="50"
            Height="50"
            Margin="10"
            Fill="Blue" />
        <Button
            x:Name="LeftButton"
            Grid.Row="1"
            Grid.Column="0"
            Margin="10"
            Click="ChangeRectangleColor"
            Content="Left button">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border
                        Background="Yellow"
                        BorderBrush="Blue"
                        BorderThickness="2">
                        <TextBlock
                            Margin="4"
                            Foreground="Blue"
                            Text="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <Button
            x:Name="RightButton"
            Grid.Row="1"
            Grid.Column="1"
            Margin="10"
            Click="ChangeRectangleColor"
            Content="Right button">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border BorderBrush="Blue" BorderThickness="2">
                        <TextBlock
                            Margin="4"
                            Foreground="Blue"
                            Text="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>
