<UserControl x:Class="SamplesApp.Windows_UI_Xaml_Controls.ListView.ListViewResizable"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">
	<UserControl.Resources>
		<Style x:Key="StretchListViewItemStyle"
		    TargetType="ListViewItem">
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="HorizontalContentAlignment" Value="Stretch" />
		</Style>
	</UserControl.Resources>

	<controls:SampleControl SampleDescription="ListView whose width can be changed.">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<StackPanel Height="800">
					<GridView Width="500"
					    ItemsSource="{Binding WidthChoices}"
					    SelectedItem="{Binding [VariableWidth], Mode=TwoWay}" />
					<Rectangle Width="{Binding [VariableWidth]}"
					    Height="30"
					    Margin="0,10"
					    Fill="Brown" />
					<Border Width="{Binding [VariableWidth]}"
					    Height="300"
					    Background="Yellow">
						<ListView Header="A list of items"
						    ItemContainerStyle="{StaticResource StretchListViewItemStyle}"
						    ItemsSource="{Binding VariableLengthItemsLong}">
							<ListView.ItemTemplate>
								<DataTemplate>
									<Border Background="Green"
									    BorderBrush="GreenYellow"
									    BorderThickness="2">
										<TextBlock Foreground="Yellow"
										    Text="{Binding}"
										    TextWrapping="Wrap" />
									</Border>
								</DataTemplate>
							</ListView.ItemTemplate>
						</ListView>
					</Border>
				</StackPanel>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>
