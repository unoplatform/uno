<UserControl
    x:Class="SamplesApp.Windows_UI_Xaml_Controls.ListView.ListViewLarge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <controls:SampleControl SampleDescription="ListView with large number of items">
        <controls:SampleControl.SampleContent>
            <DataTemplate>
                <ListView
                    Width="125"
                    Height="400"
                    ItemsSource="{Binding SampleItemsLong}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Height="25"
                                Background="Green"
                                BorderBrush="GreenYellow"
                                BorderThickness="2">
                                <TextBlock Foreground="Yellow" Text="{Binding}" />
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DataTemplate>
        </controls:SampleControl.SampleContent>
    </controls:SampleControl>
</UserControl>
