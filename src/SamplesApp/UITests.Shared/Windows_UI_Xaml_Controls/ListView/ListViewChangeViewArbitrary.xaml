<UserControl
    x:Class="SamplesApp.Windows_UI_Xaml_Controls.ListView.ListViewChangeViewArbitrary"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">
    <StackPanel>
        <TextBox
            x:Name="OffsetTextBox"
            Header="Target offset"
            InputScope="Number" />
        <Button Click="ApplyOffsetDefault" Content="ChangeView(horizontalOffset, verticalOffset, zoomFactor)" />
        <Button Click="ApplyOffsetChooseAnimate" Content="ChangeView(horizontalOffset, verticalOffset, zoomFactor, disableAnimation)" />
        <CheckBox x:Name="DisableAnimationCheckBox" Content="disableAnimation" />
        <ListView
            x:Name="TargetListView"
            Width="150"
            Height="300"
            ItemsSource="{Binding VariableLengthItems}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Green" BorderThickness="1">
                        <TextBlock
                            Margin="20"
                            Text="{Binding}"
                            TextWrapping="Wrap" />
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <TextBlock Text="(VerticalOffset,IsIntermediate)" />
        <Button Click="ClearScrollArgsText" Content="Clear" />
        <TextBlock
            x:Name="ScrollArgsTextBlock"
            Text="(,)"
            TextWrapping="Wrap" />
    </StackPanel>
</UserControl>
