<UserControl x:Class="SamplesApp.Wasm.Windows_UI_Xaml_Controls.ListView.ListView_IsSelected"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Uno.UI.Samples.Content.UITests.ListView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="1*" />
			<RowDefinition Height="1*" />
			<RowDefinition Height="1*" />
			<RowDefinition Height="1*" />
		</Grid.RowDefinitions>
		<ListView x:Name="NoSelected"
		    Grid.Row="0"
		    Width="120"
		    Margin="0,12,0,0">
			<ListViewItem x:Name="RGBNoSelected"
			    Content="RGB" />
			<ListViewItem x:Name="HSVNoSelected"
			    Content="HSV" />
		</ListView>
		<ListView x:Name="SingleSelected"
		    Grid.Row="1"
		    Width="120"
		    Margin="0,12,0,0">
			<ListViewItem x:Name="RGBSingleSelected"
			    Content="RGB"
			    IsSelected="True" />
			<ListViewItem x:Name="HSVSingleSelected"
			    Content="HSV" />
		</ListView>
		<ListView x:Name="DuplicateSelected"
		    Grid.Row="2"
		    Width="120"
		    Margin="0,12,0,0">
			<ListViewItem x:Name="RGBDuplicateSelected"
			    Content="RGB" />
			<ListViewItem x:Name="RGB2DuplicateSelected"
			    Content="RGB"
			    IsSelected="True" />
			<ListViewItem x:Name="HSVDuplicateSelected"
			    Content="HSV" />
		</ListView>
		<ListView x:Name="MultiSelectedInSingle"
		    Grid.Row="3"
		    Width="120"
		    Margin="0,12,0,0">
			<ListViewItem x:Name="RGBMultiSelectedInSingle"
			    Content="RGB" />
			<ListViewItem x:Name="RGB2MultiSelectedInSingle"
			    Content="RGB"
			    IsSelected="True" />
			<ListViewItem x:Name="HSVMultiSelectedInSingle"
			    Content="HSV"
			    IsSelected="True" />
		</ListView>
		<ListView x:Name="MultiSelected"
		    Grid.Row="3"
		    Width="120"
		    Margin="0,12,0,0"
		    SelectionMode="Multiple">
			<ListViewItem x:Name="RGBMultiSelected"
			    Content="RGB" />
			<ListViewItem x:Name="RGB2MultiSelected"
			    Content="RGB"
			    IsSelected="True" />
			<ListViewItem x:Name="HSVMultiSelected"
			    Content="HSV"
			    IsSelected="True" />
		</ListView>
	</Grid>
</UserControl>
