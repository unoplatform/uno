<UserControl x:Class="SamplesApp.Windows_UI_Xaml_Controls.ListView.ListViewGroupedEmpty"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<controls:SampleControl SampleDescription="ListView with empty source that is recognised as grouped">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<Border BorderBrush="Red"
				    BorderThickness="3">
					<ListView Width="200"
					    Height="450"
					    ItemsSource="{Binding [EmptyAsSource]}">
						<ListView.GroupStyle>
							<GroupStyle HidesIfEmpty="False">
								<GroupStyle.HeaderTemplate>
									<DataTemplate>
										<Border BorderBrush="Gray"
										    BorderThickness="2">
											<TextBlock FontSize="32"
											    Foreground="Blue"
											    Text="{Binding Key}" />
										</Border>
									</DataTemplate>
								</GroupStyle.HeaderTemplate>
							</GroupStyle>
						</ListView.GroupStyle>
					</ListView>
				</Border>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>
