<UserControl
    x:Class="UITests.Windows_UI_Xaml_Controls.ListView.ListView_ObservableCollection_CreationCount"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:UITests.ValueConverters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.ListView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d not_win">
    <UserControl.Resources>
        <converters:StringConverter x:Key="StringConverter" />
        <Style
            x:Key="CounterListViewItemStyle"
            BasedOn="{StaticResource ListViewItemExpanded}"
            TargetType="ListViewItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid>
                            <local:CounterGrid2 />
                            <ContentPresenter not_win:ContentTemplate="{TemplateBinding ContentTemplate}" Content="{TemplateBinding Content}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ListView
            x:Name="SubjectList"
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Height="150"
            MaxWidth="250"
            HorizontalAlignment="Left"
            Background="Beige"
            ItemContainerStyle="{StaticResource CounterListViewItemStyle}">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel CacheLength="0" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <local:CounterGrid
                        Height="{Binding ItemHeight}"
                        BorderBrush="Black"
                        BorderThickness="1">
                        <TextBlock Text="{Binding Display}" />
                    </local:CounterGrid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <ComboBox x:Name="ModificationSelector" Grid.Row="1">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Converter={StaticResource StringConverter}}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <Button
            x:Name="ModifyItemsButton"
            Grid.Row="2"
            Click="ApplyModifications"
            Content="Apply modification" />
        <GridView
            x:Name="ModificationSelectionList"
            Grid.Row="3"
            Grid.ColumnSpan="2"
            SelectionMode="Multiple" />
        <TextBlock
            Grid.Row="4"
            Grid.Column="0"
            Text="DataTemplate creation count: " />
        <TextBlock
            x:Name="CreationCountText"
            Grid.Row="4"
            Grid.Column="1"
            Text="0" />
        <TextBlock
            Grid.Row="5"
            Grid.Column="0"
            Text="DataTemplate binding count: " />
        <TextBlock
            x:Name="BindCountText"
            Grid.Row="5"
            Grid.Column="1"
            Text="0" />
        <TextBlock
            Grid.Row="6"
            Grid.Column="0"
            Text="ListViewItem creation count: " />
        <TextBlock
            x:Name="CreationCount2Text"
            Grid.Row="6"
            Grid.Column="1"
            Text="0" />
        <Button
            x:Name="AutomateButton"
            Grid.Row="7"
            Click="Automate_Click"
            Content="Automated" />
        <TextBlock
            x:Name="AutomationStepTextBlock"
            Grid.Row="8"
            FontSize="10"
            Text="Not started" />
    </Grid>
</UserControl>
