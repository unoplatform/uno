<UserControl
    x:Class="UITests.Shared.Windows_UI_Xaml_Controls.ListView.ListView_Infinite_Breadth"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_Xaml_Controls.ListView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid>
        <StackPanel
            Height="300"
            Background="LightPink"
            Orientation="Horizontal">
            <Grid Width="{Binding ElementName=ListWidthSlider, Path=Value}" Background="Beige">
                <ListView
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    ItemsSource="{Binding VariableLengthItemsLong}">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel CacheLength="0" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel
                                BorderBrush="Red"
                                BorderThickness="1"
                                CornerRadius="5">
                                <TextBlock Text="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
            <TextBlock
                MaxWidth="100"
                Text="Horizontal StackPanel"
                TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</UserControl>
