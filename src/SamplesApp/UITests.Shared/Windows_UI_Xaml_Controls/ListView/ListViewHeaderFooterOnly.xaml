<UserControl x:Class="SamplesApp.Windows_UI_Xaml_Controls.ListView.ListViewHeaderFooterOnly"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<controls:SampleControl SampleDescription="ListView with large header and footer and no items. Should be scrollable.">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<ListView Width="250"
				    Height="300"
				    Footer="{Binding LargeText2}"
				    Header="{Binding LargeText1}">
					<ListView.HeaderTemplate>
						<DataTemplate>
							<Border BorderBrush="Black"
							    BorderThickness="2">
								<Border.Background>
									<LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
										<LinearGradientBrush.GradientStops>
											<GradientStopCollection>
												<GradientStop Color="LightBlue" Offset="0.0" />
												<GradientStop Color="Blue" Offset="1.0" />
											</GradientStopCollection>
										</LinearGradientBrush.GradientStops>
									</LinearGradientBrush>
								</Border.Background>
								<TextBlock Margin="8"
								    Text="{Binding}"
								    TextWrapping="Wrap" />
							</Border>
						</DataTemplate>
					</ListView.HeaderTemplate>
					<ListView.FooterTemplate>
						<DataTemplate>
							<Border BorderBrush="Black"
							    BorderThickness="2">
								<Border.Background>
									<LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
										<LinearGradientBrush.GradientStops>
											<GradientStopCollection>
												<GradientStop Color="LightGreen" Offset="0.0" />
												<GradientStop Color="Green" Offset="1.0" />
											</GradientStopCollection>
										</LinearGradientBrush.GradientStops>
									</LinearGradientBrush>
								</Border.Background>
								<TextBlock Margin="8"
								    Text="{Binding}"
								    TextWrapping="Wrap" />
							</Border>
						</DataTemplate>
					</ListView.FooterTemplate>
				</ListView>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>
