<UserControl x:Class="SamplesApp.Windows_UI_Xaml_Controls.ListView.ListViewGrouped"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    mc:Ignorable="d android not_win">

	<UserControl.Resources>

		<Style x:Key="GroupHeaderContainerStyle"
		    TargetType="ListViewHeaderItem">
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate>
						<Border BorderBrush="Orange"
						    BorderThickness="10">
							<ContentPresenter not_win:Content="{TemplateBinding Content}"
							    not_win:ContentTemplate="{TemplateBinding ContentTemplate}"
							    not_win:ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}" />
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

	</UserControl.Resources>

	<controls:SampleControl SampleDescription="ListViewGrouped">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<StackPanel>
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="SelectedIndex: " />
						<TextBlock Text="{Binding ElementName=TargetListView, Path=SelectedIndex}" />
					</StackPanel>
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="SelectedItem: " />
						<TextBlock Text="{Binding ElementName=TargetListView, Path=SelectedItem}" />
					</StackPanel>
					<Border Background="Red">
						<ListView x:Name="TargetListView"
						    Height="600"
						    Footer="Footer"
						    Header="Header"
						    ItemsSource="{Binding [GroupedSampleItemsAsSource]}">
							<ListView.HeaderTemplate>
								<DataTemplate>
									<Border HorizontalAlignment="Stretch"
									    Background="Green">
										<TextBlock Margin="20"
										    Text="{Binding}" />
									</Border>
								</DataTemplate>
							</ListView.HeaderTemplate>
							<ListView.FooterTemplate>
								<DataTemplate>
									<Border Background="Purple">
										<TextBlock Margin="20"
										    Text="{Binding}" />
									</Border>
								</DataTemplate>
							</ListView.FooterTemplate>
							<ListView.GroupStyle>
								<GroupStyle HeaderContainerStyle="{StaticResource GroupHeaderContainerStyle}"
								    HidesIfEmpty="True">
									<GroupStyle.HeaderTemplate>
										<DataTemplate>
											<Border Background="Blue">
												<TextBlock Height="40"
												    FontSize="32"
												    Foreground="Red"
												    Text="{Binding Key}" />
											</Border>
										</DataTemplate>
									</GroupStyle.HeaderTemplate>
								</GroupStyle>
							</ListView.GroupStyle>
							<ListView.ItemTemplate>
								<DataTemplate>
									<Border Background="White">
										<TextBlock Height="16"
										    Foreground="Blue"
										    Text="{Binding}" />
									</Border>
								</DataTemplate>
							</ListView.ItemTemplate>
						</ListView>
					</Border>
				</StackPanel>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>
