<UserControl x:Class="SamplesApp.Windows_UI_Xaml_Controls.ListView.ListViewVariableItemHeight"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<controls:SampleControl SampleDescription="ListView whose items vary in size depending on their content.">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<Border Background="Indigo">
					<ListView Width="150"
					    Height="400"
					    ItemsSource="{Binding VariableLengthItems}">
						<ListView.HeaderTemplate>
							<DataTemplate>
								<Border Background="Aqua"
								    BorderBrush="Red"
								    BorderThickness="1">
									<TextBlock Text="This header text is long and it will wrap. The list should measure it correctly."
									    TextWrapping="Wrap" />
								</Border>
							</DataTemplate>
						</ListView.HeaderTemplate>
						<ListView.ItemTemplate>
							<DataTemplate>
								<Border Background="PeachPuff"
								    BorderBrush="Green"
								    BorderThickness="1">
									<TextBlock Text="{Binding}"
									    TextWrapping="Wrap" />
								</Border>
							</DataTemplate>
						</ListView.ItemTemplate>
					</ListView>
				</Border>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>
