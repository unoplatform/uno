<UserControl x:Class="SamplesApp.Windows_UI_Xaml_Controls.ListView.ListViewChangeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="using:SamplesApp.Windows_UI_Xaml_Controls.ListView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">
	<UserControl.Resources>
		<ResourceDictionary Source="./ParallaxListView/ParallaxListView.xaml" />
	</UserControl.Resources>

	<controls:SampleControl SampleDescription="Illustrates a parallax effect using ChangeView and ViewChanged members on the ScrollViewer inside ListView">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<local:ParallaxListView Title="Heroic videos"
				    Width="200"
				    Height="500"
				    HeaderBackgroundImage="http://www.tallshipsfalmouth.co.uk/wp-content/uploads/2012/11/Mercedes-tall-ship2-e1354287088569.jpg" />
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>
