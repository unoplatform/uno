<UserControl x:Class="SamplesApp.Windows_UI_Xaml_Controls.ListView.ListView_Padding_All_Sides"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<controls:SampleControl SampleDescription="ListView with Padding applied on all sides">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<Grid Width="250"
				    Height="300">
					<ListView Height="200"
					    Padding="50"
					    VerticalAlignment="Top"
					    Background="LightGreen"
					    ItemsSource="{Binding VariableLengthItems}">
						<ListView.ItemTemplate>
							<DataTemplate>
								<Border Background="LightBlue"
								    BorderBrush="Blue"
								    BorderThickness="2">
									<TextBlock HorizontalAlignment="Stretch"
									    Text="{Binding}"
									    TextWrapping="Wrap" />
								</Border>
							</DataTemplate>
						</ListView.ItemTemplate>
					</ListView>
					<Rectangle Width="50"
					    Height="50"
					    HorizontalAlignment="Left"
					    VerticalAlignment="Top"
					    Fill="Aqua" />
					<Rectangle Width="50"
					    Height="50"
					    HorizontalAlignment="Right"
					    VerticalAlignment="Top"
					    Fill="Aqua" />
				</Grid>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>
