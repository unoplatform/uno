<UserControl
    x:Class="SamplesApp.Windows_UI_Xaml_Controls.ListView.ListView_Last_Item_Large"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <StackPanel>

        <TextBlock Text="Expected behavior:" TextWrapping="Wrap" />
        <TextBlock Text="1. Notice that the ListView (yellow) is narrow and roughly matches the width of the numbers." TextWrapping="Wrap" />
        <TextBlock Text="2. Scroll all the way to the bottom of the list." TextWrapping="Wrap" />
        <TextBlock Text="3. Notice that the ListView (yellow) is larger and matches the size of the last number." TextWrapping="Wrap" />

        <ListView
            x:Name="MyListView"
            Height="200"
            HorizontalAlignment="Left"
            Background="Yellow" />

    </StackPanel>

</UserControl>
