<UserControl x:Class="SamplesApp.Windows_UI_Xaml_Controls.ListView.ListViewContainerFromItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<Grid Width="200"
	    Height="200">
		<ListView x:Name="TargetListView"
		    Width="150"
		    HorizontalAlignment="Left"
		    Background="Beige"
		    ItemsSource="123456789ABCDEFGHIJKL"
		    SelectionChanged="TargetListView_SelectionChanged" />
		<Canvas>
			<Ellipse x:Name="TrackerView"
			    Canvas.Left="150"
			    Width="46"
			    Height="20"
			    Margin="2"
			    Fill="Khaki" />
		</Canvas>
	</Grid>
</UserControl>
