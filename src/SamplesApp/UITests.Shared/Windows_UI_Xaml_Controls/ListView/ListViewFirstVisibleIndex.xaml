<UserControl x:Class="SamplesApp.Windows_UI_Xaml_Controls.ListView.ListViewFirstVisibleIndex"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<StackPanel>
		<TextBlock Text="FirstVisibleIndex:" />
		<TextBlock x:Name="FirstVisibleIndexTextBlock" />
		<TextBlock Text="LastVisibleIndex:" />
		<TextBlock x:Name="LastVisibleIndexTextBlock" />
		<ListView Width="150"
		    Height="250"
		    ItemsSource="0123456789ABCDEFGHIJKLMNOP"
		    Loaded="ListView_Loaded">
			<ListView.ItemTemplate>
				<DataTemplate>
					<Border Width="80"
					    BorderBrush="Red"
					    BorderThickness="2">
						<StackPanel>
							<TextBlock Height="14"
							    FontSize="10"
							    Foreground="Red"
							    Text="{Binding}" />
							<TextBlock Height="14"
							    FontSize="10"
							    Foreground="Red"
							    Text="{Binding}" />
							<TextBlock Height="14"
							    FontSize="10"
							    Foreground="Red"
							    Text="{Binding}" />
							<TextBlock Height="14"
							    FontSize="10"
							    Foreground="Red"
							    Text="{Binding}" />
							<TextBlock Height="14"
							    FontSize="10"
							    Foreground="Red"
							    Text="{Binding}" />
						</StackPanel>
					</Border>
				</DataTemplate>
			</ListView.ItemTemplate>
		</ListView>
	</StackPanel>
</UserControl>
