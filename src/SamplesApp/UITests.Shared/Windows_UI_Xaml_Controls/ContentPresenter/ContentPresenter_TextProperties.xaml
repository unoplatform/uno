<UserControl x:Class="Uno.UI.Samples.Content.UITests.ContentPresenter.ContentPresenter_TextProperties"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://nventive.com/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://nventive.com/ios"
    xmlns:local="Uno.UI.Samples.Content.UITests.ContentPresenter"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<controls:SampleControl SampleDescription="This sample demonstrates the behavior of the Text properties of the ContentPresenter">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<StackPanel>
					<Border BorderBrush="Red"
					    BorderThickness="1">
						<ContentPresenter Width="50"
						    TextWrapping="Wrap">
							<TextBlock Text="Should not wrap even if it is very long"
							    TextWrapping="NoWrap" />
						</ContentPresenter>
					</Border>
					<Border BorderBrush="Blue"
					    BorderThickness="1">
						<ContentPresenter Width="50"
						    Content="Should wrap becayse if it is very long"
						    TextWrapping="Wrap" />
					</Border>
				</StackPanel>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>