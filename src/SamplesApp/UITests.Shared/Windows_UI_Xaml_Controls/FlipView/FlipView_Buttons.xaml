<UserControl x:Class="UITests.Windows_UI_Xaml_Controls.FlipView.FlipView_Buttons"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.FlipView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<StackPanel Orientation="Horizontal">
		<Border x:Name="LeftBorder"
		    Width="10"
		    Height="100"
		    Background="Green" />
		<FlipView x:Name="SUT"
		    Width="200"
		    Height="100">
			<Button x:Name="Button1"
			    Width="200"
			    AutomationProperties.Name="Button1"
			    Background="Green"
			    Content="Button 1" />
			<Button x:Name="Button2"
			    Width="200"
			    AutomationProperties.Name="Button2"
			    Background="Blue"
			    Content="Button 2" />
			<Button x:Name="Button3"
			    Width="200"
			    AutomationProperties.Name="Button3"
			    Background="Red"
			    Content="Button 3" />
			<Button x:Name="Button4"
			    Width="200"
			    AutomationProperties.Name="Button4"
			    Background="Fuchsia"
			    Content="Button 4" />
			<Button x:Name="Button5"
			    Width="200"
			    AutomationProperties.Name="Button5"
			    Background="Orange"
			    Content="Button 5" />
		</FlipView>
		<Border x:Name="RightBorder"
		    Width="10"
		    Height="100"
		    Background="Yellow" />
	</StackPanel>
</UserControl>
