<UserControl x:Class="Uno.UI.Samples.Content.UITests.GridView.GridView_Vertical_MaxItemWidth"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="Uno.UI.Samples.Content.UITests.GridView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:nVentive.Umbrella.Views.Controls"
    xmlns:uBehaviors="using:nVentive.Umbrella.Views.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<controls:SampleControl SampleDescription="Demonstrates the use of the ItemMaxWidth property on supported platforms, where the items should use up all the space.">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<StackPanel>
					<Border Width="300"
					    Height="150"
					    BorderBrush="Green"
					    BorderThickness="1">
						<GridView win:ScrollViewer.HorizontalScrollBarVisibility="Auto"
						    win:ScrollViewer.HorizontalScrollMode="Auto"
						    ItemsSource="{Binding [SampleItems]}">
							<GridView.ItemTemplate>
								<DataTemplate>
									<Border Background="White">
										<TextBlock Height="50"
										    Foreground="Blue"
										    Text="{Binding}" />
									</Border>
								</DataTemplate>
							</GridView.ItemTemplate>
						</GridView>
					</Border>
					<Border Width="400"
					    Height="150"
					    BorderBrush="Purple"
					    BorderThickness="1">
						<GridView win:ScrollViewer.HorizontalScrollBarVisibility="Auto"
						    win:ScrollViewer.HorizontalScrollMode="Auto"
						    ItemsSource="{Binding [SampleItems]}">
							<GridView.ItemTemplate>
								<DataTemplate>
									<Border Background="White">
										<TextBlock Height="50"
										    Foreground="Blue"
										    Text="{Binding}" />
									</Border>
								</DataTemplate>
							</GridView.ItemTemplate>
						</GridView>
					</Border>
					<Border Width="500"
					    Height="150"
					    BorderBrush="Purple"
					    BorderThickness="1">
						<GridView win:ScrollViewer.HorizontalScrollBarVisibility="Auto"
						    win:ScrollViewer.HorizontalScrollMode="Auto"
						    ItemsSource="{Binding [SampleItems]}">
							<GridView.ItemTemplate>
								<DataTemplate>
									<Border Background="White">
										<TextBlock Height="50"
										    Foreground="Blue"
										    Text="{Binding}" />
									</Border>
								</DataTemplate>
							</GridView.ItemTemplate>
						</GridView>
					</Border>
				</StackPanel>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>