<UserControl x:Class="Uno.UI.Samples.Content.UITests.GridView.GridView_Inside_ScrollViewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="using:Uno.UI.Samples.Content.UITests.GridView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:nVentive.Umbrella.Views.Controls"
    xmlns:uBehaviors="using:nVentive.Umbrella.Views.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<controls:SampleControl SampleDescription="Description for sample of GridView_Inside_ScrollViewer">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<ScrollViewer Width="400"
				    Height="400">
					<StackPanel>
						<Border Width="200"
						    Height="200"
						    Background="Green" />
						<GridView ItemsSource="{Binding [UngroupedSampleItems]}" />
					</StackPanel>
				</ScrollViewer>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>