<UserControl x:Class="Uno.UI.Samples.Content.UITests.GridView.GridViewItemWidthItemHeight"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="Uno.UI.Samples.Content.UITests.GridView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:nVentive.Umbrella.Views.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">
	<UserControl.Resources>
		<Style x:Key="GridViewItemStretchStyle"
		    TargetType="GridViewItem">
			<Setter Property="HorizontalContentAlignment" Value="Stretch" />
			<Setter Property="VerticalContentAlignment" Value="Stretch" />
		</Style>
	</UserControl.Resources>

	<controls:SampleControl SampleDescription="GridView with ItemWidth and ItemHeight set">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<GridView Width="300"
				    Height="400"
				    ItemContainerStyle="{StaticResource GridViewItemStretchStyle}"
				    ItemsSource="{Binding SampleColors}">
					<GridView.ItemsPanel>
						<ItemsPanelTemplate>
							<ItemsWrapGrid ItemHeight="150"
							    ItemWidth="75"
							    Orientation="Horizontal" />
						</ItemsPanelTemplate>
					</GridView.ItemsPanel>
					<GridView.ItemTemplate>
						<DataTemplate>
							<Border Width="1000"
							    Height="1000">
								<Border.Background>
									<SolidColorBrush Color="{Binding}" />
								</Border.Background>
								<!--<Border.Child>
									<TextBlock Text="{Binding}" Foreground="White" TextWrapping="Wrap"/>
								</Border.Child>-->
							</Border>
						</DataTemplate>
					</GridView.ItemTemplate>
				</GridView>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>