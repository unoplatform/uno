<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.GridView.GridViewMarginTest"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="Uno.UI.Samples.Content.UITests.GridView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:nVentive.Umbrella.Views.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">
    <UserControl.Resources>
        <Style x:Key="GridViewItemStretchStyle" TargetType="GridViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="40,20,10,10" />
        </Style>
    </UserControl.Resources>

    <controls:SampleControl SampleDescription="GridView with Margin set on GridViewItem. Coloured borders outside and inside the GridView should be the same size.">
        <controls:SampleControl.SampleContent>
            <DataTemplate>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="1"
                        BorderBrush="Brown"
                        BorderThickness="1"
                        Orientation="Horizontal">
                        <GridViewItem
                            Width="25"
                            Height="120"
                            Style="{StaticResource GridViewItemStretchStyle}">
                            <Border Width="1000" Height="1000">
                                <Border.Background>
                                    <SolidColorBrush Color="Brown" />
                                </Border.Background>
                            </Border>
                        </GridViewItem>
                        <GridViewItem
                            Width="25"
                            Height="120"
                            Style="{StaticResource GridViewItemStretchStyle}">
                            <Border Width="1000" Height="1000">
                                <Border.Background>
                                    <SolidColorBrush Color="Brown" />
                                </Border.Background>
                            </Border>
                        </GridViewItem>
                    </StackPanel>
                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="0"
                        BorderBrush="Brown"
                        BorderThickness="1"
                        Orientation="Vertical">
                        <GridViewItem
                            Width="25"
                            Height="120"
                            Style="{StaticResource GridViewItemStretchStyle}">
                            <Border Width="1000" Height="1000">
                                <Border.Background>
                                    <SolidColorBrush Color="Brown" />
                                </Border.Background>
                            </Border>
                        </GridViewItem>
                        <GridViewItem
                            Width="25"
                            Height="120"
                            Style="{StaticResource GridViewItemStretchStyle}">
                            <Border Width="1000" Height="1000">
                                <Border.Background>
                                    <SolidColorBrush Color="Brown" />
                                </Border.Background>
                            </Border>
                        </GridViewItem>
                    </StackPanel>
                    <Border
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        BorderBrush="Black"
                        BorderThickness="1">
                        <GridView
                            Width="200"
                            Height="300"
                            ItemContainerStyle="{StaticResource GridViewItemStretchStyle}"
                            ItemsSource="{Binding SampleColors}">
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid
                                        ItemHeight="150"
                                        ItemWidth="75"
                                        Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="1000" Height="1000">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding}" />
                                        </Border.Background>
                                        <!--<Border.Child>
									<TextBlock Text="{Binding}" Foreground="White" TextWrapping="Wrap"/>
								</Border.Child>-->
                                    </Border>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </Border>
                </Grid>
            </DataTemplate>
        </controls:SampleControl.SampleContent>
    </controls:SampleControl>
</UserControl>