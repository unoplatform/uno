<UserControl x:Class="Uno.UI.Samples.Content.UITests.GridView.GridViewGroupedResizable"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="Uno.UI.Samples.Content.UITests.GridView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:nVentive.Umbrella.Views.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<controls:SampleControl SampleDescription="GridView with grouped source whose width can be changed.">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<StackPanel Height="800">
					<GridView Width="500"
					    ItemsSource="{Binding WidthChoices}"
					    SelectedItem="{Binding [VariableWidth], Mode=TwoWay}" />
					<Rectangle Width="{Binding [VariableWidth]}"
					    Height="30"
					    Margin="0,10"
					    Fill="Brown" />
					<Border Width="{Binding [VariableWidth]}"
					    Height="300"
					    Background="Red">
						<GridView ItemsSource="{Binding [GroupedTownsAsSource]}">
							<GridView.GroupStyle>
								<GroupStyle HidesIfEmpty="False">
									<GroupStyle.HeaderTemplate>
										<DataTemplate>
											<Border Background="Blue"
											    BorderBrush="Gray"
											    BorderThickness="2">
												<TextBlock Width="50"
												    Height="40"
												    FontSize="32"
												    Foreground="Red"
												    Text="{Binding Key}" />
											</Border>
										</DataTemplate>
									</GroupStyle.HeaderTemplate>
								</GroupStyle>
							</GridView.GroupStyle>
							<GridView.ItemTemplate>
								<DataTemplate>
									<Border Background="White"
									    BorderBrush="Gray"
									    BorderThickness="2">
										<TextBlock Width="150"
										    Height="20"
										    Foreground="Blue"
										    Text="{Binding}" />
									</Border>
								</DataTemplate>
							</GridView.ItemTemplate>
						</GridView>
					</Border>
				</StackPanel>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>