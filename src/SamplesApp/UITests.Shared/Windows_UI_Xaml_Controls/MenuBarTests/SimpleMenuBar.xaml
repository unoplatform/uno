<UserControl
    x:Class="UITests.Shared.Windows_UI_Xaml_Controls.MenuBarTests.SimpleMenuBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_Xaml_Controls.MenuBarTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <muxc:MenuBar>
            <muxc:MenuBarItem x:Name="fileMenu" Title="File">
                <MenuFlyoutSubItem x:Name="newMenu" Text="New">
                    <MenuFlyoutItem
                        x:Name="plainTextMenu"
                        Command="{x:Bind MyCommand}"
                        CommandParameter="Plain Text"
                        Text="Plain Text Document" />
                    <MenuFlyoutItem Command="{x:Bind MyCommand}" Text="Plain Text Document (NoParam)" />
                    <MenuFlyoutItem
                        Click="MenuFlyoutItem_Click"
                        Text="Rich Text Document"
                        ToolTipService.ToolTip="Rich Text Description" />
                    <MenuFlyoutItem Click="MenuFlyoutItem_Click" Text="Other Formats..." />
                </MenuFlyoutSubItem>
                <MenuFlyoutItem
                    x:Name="openMenu"
                    Click="MenuFlyoutItem_Click"
                    Icon="MailForward"
                    Text="Open..." />
                <MenuFlyoutItem
                    x:Name="saveMenu"
                    AccessKey="S"
                    Click="MenuFlyoutItem_Click"
                    Icon="Save"
                    Text="Save">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Key="S" Modifiers="Control" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem
                    x:Name="xamlUIMenu"
                    Command="{x:Bind MyXamlUICommand}"
                    CommandParameter="xamlUIMenu" />
                <MenuFlyoutItem
                    x:Name="disabledItem"
                    IsEnabled="False"
                    Text="Disabled" />
                <MenuFlyoutItem
                    x:Name="exitMenu"
                    AccessKey="X"
                    Click="MenuFlyoutItem_Click"
                    Text="Exit" />
            </muxc:MenuBarItem>

            <muxc:MenuBarItem x:Name="editMenu" Title="Edit">
                <MenuFlyoutItem Click="MenuFlyoutItem_Click" Text="Undo" />
                <MenuFlyoutItem Click="MenuFlyoutItem_Click" Text="Cut" />
                <MenuFlyoutItem Click="MenuFlyoutItem_Click" Text="Copy" />
                <MenuFlyoutItem Click="MenuFlyoutItem_Click" Text="Paste" />
                <ToggleMenuFlyoutItem
                    x:Name="RepeatToggleMenuFlyoutItem"
                    Click="MenuFlyoutItem_Click"
                    IsChecked="True"
                    Text="Repeat" />
                <ToggleMenuFlyoutItem
                    x:Name="ShuffleToggleMenuFlyoutItem"
                    Click="MenuFlyoutItem_Click"
                    IsChecked="False"
                    Text="Shuffle" />
            </muxc:MenuBarItem>

            <muxc:MenuBarItem x:Name="helpMenu" Title="Help">
                <MenuFlyoutItem Click="MenuFlyoutItem_Click" Text="About" />
            </muxc:MenuBarItem>
        </muxc:MenuBar>
        <StackPanel Grid.Row="1">
            <TextBlock x:Name="result" />
        </StackPanel>
    </Grid>
</UserControl>
