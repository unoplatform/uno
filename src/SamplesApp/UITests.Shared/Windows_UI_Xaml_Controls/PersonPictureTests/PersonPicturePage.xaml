<UserControl x:Class="MUXControlsTestApp.PersonPicturePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

	<Grid x:Name="rootGrid"
	    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
		<Grid.ColumnDefinitions>
			<ColumnDefinition />
			<ColumnDefinition />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<Grid.Resources>
			<CollectionViewSource x:Name="cvs" />
			<Style TargetType="StackPanel">
				<Setter Property="Margin" Value="4" />
			</Style>
			<Style TargetType="TextBlock">
				<Setter Property="VerticalAlignment" Value="Center" />
				<Setter Property="Margin" Value="0,0,4,0" />
			</Style>
		</Grid.Resources>
		<StackPanel HorizontalAlignment="Left"
		    Style="{ThemeResource StandardGroupingStackPanel}">
			<TextBlock Style="{ThemeResource StandardGroupHeader}"
			    Text="Options" />
			<StackPanel Orientation="Horizontal">
				<TextBlock Text="GroupGlyph:" />
				<CheckBox x:Name="GroupCheckBox"
				    AutomationProperties.Name="GroupCheckBox"
				    Checked="GroupCheckBox_Checked"
				    Unchecked="GroupCheckBox_Unchecked" />
			</StackPanel>

			<StackPanel Orientation="Horizontal">
				<TextBlock Text="Initials:" />
				<TextBox x:Name="InitialTextBox"
				    AutomationProperties.Name="InitialTextBox"
				    MaxLength="2"
				    TextChanged="InitialTextBox_TextChanged" />
			</StackPanel>

			<StackPanel Orientation="Horizontal">
				<TextBlock Text="DisplayName:" />
				<TextBox x:Name="DisplayNameTextBox"
				    AutomationProperties.Name="DisplayNameTextBox"
				    TextChanged="DisplayNameTextBox_TextChanged" />
			</StackPanel>

			<StackPanel Orientation="Horizontal">
				<TextBlock Text="BadgeNumber:" />
				<TextBox x:Name="BadgeNumberTextBox"
				    AutomationProperties.Name="BadgeNumberTextBox"
				    TextChanged="BadgeNumberTextBox_TextChanged" />
			</StackPanel>

			<StackPanel>
				<TextBlock Text="BadgeGlyph:" />
				<TextBox x:Name="BadgeGlyphTextBox"
				    AutomationProperties.Name="BadgeGlyphTextBox"
				    TextChanged="BadgeGlyphTextBox_TextChanged" />
			</StackPanel>

			<TextBlock Text="Contact:" />
			<StackPanel Orientation="Horizontal">
				<Button x:Name="ContactBtn"
				    Margin="0,0,10,0"
				    AutomationProperties.Name="ContactBtn"
				    Click="ContactBtn_Click"
				    Content="Set Contact" />
				<Button x:Name="ContactImageBtn"
				    Margin="10,0,10,0"
				    AutomationProperties.Name="ContactImageBtn"
				    Click="ContactImageBtn_Click"
				    Content="Set Contact (w/ Image)" />
				<Button x:Name="ClearContactBtn"
				    Margin="10,0,10,0"
				    AutomationProperties.Name="ClearContactBtn"
				    Click="ClearContactBtn_Click"
				    Content="Clear Contact" />
			</StackPanel>

			<TextBlock Text="ImageSource:" />
			<StackPanel Orientation="Horizontal">
				<Button x:Name="ImageBtn"
				    Margin="0,0,10,0"
				    AutomationProperties.Name="ImageBtn"
				    Click="ImageBtn_Click"
				    Content="Set Image" />
				<Button x:Name="ClearImageBtn"
				    Margin="10,0,10,0"
				    AutomationProperties.Name="ClearImageBtn"
				    Click="ClearImageBtn_Click"
				    Content="Clear Image" />
			</StackPanel>

			<TextBlock Text="Size:" />
			<StackPanel Orientation="Horizontal">
				<Slider x:Name="HeightSlider"
				    Width="50"
				    Margin="10,0,10,0"
				    AutomationProperties.Name="HeightSlider"
				    Header="Height"
				    IsThumbToolTipEnabled="False"
				    Maximum="130"
				    Minimum="70"
				    Value="{Binding Height, ElementName=TestPersonPicture, Mode=TwoWay}" />
				<Slider x:Name="WidthSlider"
				    Width="50"
				    Margin="10,0,10,0"
				    AutomationProperties.Name="WidthSlider"
				    Header="Width"
				    IsThumbToolTipEnabled="False"
				    Maximum="130"
				    Minimum="70"
				    Value="{Binding Width, ElementName=TestPersonPicture, Mode=TwoWay}" />
				<CheckBox x:Name="DimensionsMatch"
				    Margin="10,0,10,0"
				    AutomationProperties.Name="DimensionsMatch"
				    Content="Height and width consistent"
				    IsChecked="True" />
			</StackPanel>
		</StackPanel>

		<StackPanel Grid.Column="1">
			<TextBlock Style="{ThemeResource StandardGroupHeader}"
			    Text="Sample controls" />

			<controls:PersonPicture x:Name="TestPersonPicture"
			    AutomationProperties.Name="TestPersonPicture"
			    SizeChanged="TestPersonPicture_SizeChanged" />

			<StackPanel Orientation="Horizontal">
				<ListView x:Name="PeopleLV"
				    Height="200"
				    Margin="10"
				    AutomationProperties.Name="PeopleLV">
					<ListViewItem>
						<controls:PersonPicture x:Name="PersonPicture0"
						    AutomationProperties.Name="PersonPicture0"
						    BadgeGlyph="\uE765"
						    BadgeNumber="1"
						    DisplayName="James Bond"
						    Initials="JB" />
					</ListViewItem>
					<ListViewItem>
						<controls:PersonPicture x:Name="PersonPicture1"
						    AutomationProperties.Name="PersonPicture1"
						    BadgeGlyph="\uE766"
						    BadgeNumber="2"
						    DisplayName="Austin Powers"
						    Initials="AP" />
					</ListViewItem>
					<ListViewItem>
						<controls:PersonPicture x:Name="PersonPicture2"
						    AutomationProperties.Name="PersonPicture2"
						    BadgeGlyph="\uE767"
						    BadgeNumber="3"
						    DisplayName="Steve Austin"
						    Initials="SA" />
					</ListViewItem>
					<ListViewItem>
						<controls:PersonPicture x:Name="PersonPicture3"
						    AutomationProperties.Name="PersonPicture3"
						    BadgeGlyph="\uE768"
						    BadgeNumber="4"
						    DisplayName="Super Jaimie"
						    Initials="SJ" />
					</ListViewItem>
					<ListViewItem>
						<controls:PersonPicture x:Name="PersonPicture4"
						    AutomationProperties.Name="PersonPicture4"
						    BadgeGlyph="\uE769"
						    BadgeNumber="5"
						    DisplayName="Bruce Banner"
						    Initials="BB" />
					</ListViewItem>
					<ListViewItem>
						<controls:PersonPicture x:Name="PersonPicture5"
						    AutomationProperties.Name="PersonPicture5"
						    BadgeGlyph="\uE770"
						    BadgeNumber="6"
						    DisplayName="Bruce Wayne"
						    Initials="BW" />
					</ListViewItem>
				</ListView>

				<ListView x:Name="PeopleGLV"
				    Height="250"
				    Margin="10"
				    AutomationProperties.Name="PeopleGLV"
				    ItemsSource="{Binding Source={StaticResource cvs}}">
					<ListView.ItemTemplate>
						<DataTemplate>
							<controls:PersonPicture BadgeNumber="{Binding BadgeNumber}"
							    DisplayName="{Binding DisplayName}"
							    Initials="{Binding Initials}" />
						</DataTemplate>
					</ListView.ItemTemplate>
					<ListView.GroupStyle>
						<GroupStyle>
							<GroupStyle.HeaderTemplate>
								<DataTemplate>
									<TextBlock Text="{Binding Name}" />
								</DataTemplate>
							</GroupStyle.HeaderTemplate>
						</GroupStyle>
					</ListView.GroupStyle>
				</ListView>
			</StackPanel>
			<TextBlock Style="{ThemeResource StandardGroupHeader}"
			    Text="Properties" />
			<CheckBox x:Name="BgEllipseFilled"
			    AutomationProperties.Name="BgEllipseFilled"
			    Content="Control is showing an image"
			    IsChecked="False"
			    IsEnabled="False" />
		</StackPanel>
	</Grid>
</UserControl>
