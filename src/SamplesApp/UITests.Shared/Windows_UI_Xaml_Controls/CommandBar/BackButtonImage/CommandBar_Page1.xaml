<Page x:Class="UITests.Windows_UI_Xaml_Controls.CommandBar.BackButtonImage.CommandBar_Page1"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.CommandBar.BackButtonImage"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d not_win">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<CommandBar x:Name="Page1ommandBar"
		    Content="Page1" />

		<StackPanel Grid.Row="1"
		    VerticalAlignment="Center"
		    Spacing="10">

			<TextBlock HorizontalAlignment="Center"
			    Text="Main Page" />

			<Button x:Name="NavigateToPage2Button"
			    Grid.Row="1"
			    HorizontalAlignment="Center"
			    Click="OnButtonClicked"
			    Content="Navigate to Page 2" />
		</StackPanel>
	</Grid>
</Page>
