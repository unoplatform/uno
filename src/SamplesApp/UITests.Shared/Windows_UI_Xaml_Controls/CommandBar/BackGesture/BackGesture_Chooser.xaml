<Page x:Class="Uno.UI.Samples.Content.UITests.CommandBar.BackGesture.BackGesture_Chooser"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Uno.UI.Samples.Content.UITests.CommandBar.BackGesture"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

	<Grid Padding="0,40,0,0"
	    Background="White">
		<StackPanel>
			<Button x:Name="GoBack"
			    Background="LightGray"
			    Click="Back_Click"
			    Content="Back" />

			<Button x:Name="Normal"
			    Background="LightGray"
			    Click="Normal_Click"
			    Content="Normal" />

			<Button x:Name="Collapsed"
			    Background="LightGray"
			    Click="Collapsed_Click"
			    Content="Collapsed" />

			<Button x:Name="NavigationCommand"
			    Background="LightGray"
			    Click="NavigationCommand_Click"
			    Content="NavigationCommand" />

			<Button x:Name="CollapsedNavigationCommand"
			    Background="LightGray"
			    Click="CollapsedNavigationCommand_Click"
			    Content="Collapsed NavigationCommand" />
		</StackPanel>
	</Grid>
</Page>
