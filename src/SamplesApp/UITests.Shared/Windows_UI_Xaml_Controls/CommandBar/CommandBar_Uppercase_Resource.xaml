<UserControl x:Class="Uno.UI.Samples.Content.UITests.CommandBar.CommandBar_Uppercase_Resource"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://nventive.com/android"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Uno.UI.Samples.Content.UITests.CommandBar"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d android">

	<Grid>
		<android:Grid>
			<CommandBar>
				<AppBarButton>
					<AppBarButton.Icon>
						<BitmapIcon UriSource="ms-appx:///Assets/Icons/UPPERCASE.png" />
					</AppBarButton.Icon>
				</AppBarButton>
			</CommandBar>
		</android:Grid>

	</Grid>
</UserControl>
