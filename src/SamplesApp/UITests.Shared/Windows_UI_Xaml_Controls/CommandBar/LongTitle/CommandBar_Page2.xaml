<Page x:Class="UITests.Windows_UI_Xaml_Controls.CommandBar.LongTitle.CommandBar_Page2"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.CommandBar.LongTitle"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<CommandBar x:Name="Page2CommandBar">
			<CommandBar.Content>
				<Border Height="44"
				    HorizontalAlignment="Center"
				    VerticalAlignment="Center">
					<TextBlock Foreground="Black"
					    Text="This is supposed to be a very long text used to overflow the CommandBar title and validate how it behaves on navigation and will try to make it very long in case this is run on an iPad"
					    TextTrimming="CharacterEllipsis"
					    TextWrapping="NoWrap" />
				</Border>
			</CommandBar.Content>
			<CommandBar.PrimaryCommands>
				<AppBarButton Content="Save" />
			</CommandBar.PrimaryCommands>
		</CommandBar>

		<StackPanel Grid.Row="1"
		    VerticalAlignment="Center"
		    Spacing="10">

			<TextBlock HorizontalAlignment="Center"
			    Text="Page 2" />

			<Button x:Name="GoBackButton"
			    HorizontalAlignment="Center"
			    Click="OnBackButtonClicked"
			    Content="Go Back" />

			<Button x:Name="NavigateToPage3Button"
			    HorizontalAlignment="Center"
			    Click="OnButtonClicked"
			    Content="Navigate to Page 3" />

			<Button x:Name="CalculateSize"
			    HorizontalAlignment="Center"
			    Click="OnCalculateSizeClicked"
			    Content="Calculate TitleView Size" />

			<TextBlock x:Name="Result"
			    HorizontalAlignment="Center" />
		</StackPanel>

	</Grid>
</Page>
