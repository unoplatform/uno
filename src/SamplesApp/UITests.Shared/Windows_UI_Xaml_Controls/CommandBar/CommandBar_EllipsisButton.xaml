<UserControl x:Class="Uno.UI.Samples.Content.UITests.CommandBar.CommandBar_EllipsisButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!-- Repro for https://github.com/unoplatform/uno/issues/4395
         Bug 1: CommandBar ellipsis button (⋯) is not vertically centered
         Bug 2: AppBarEllipsisButtonForeground resource not applied to ellipsis button

         How to verify:
           1. Observe that the ellipsis (⋯) button at the right edge should be vertically
              centered in the CommandBar — on Uno it may appear offset
           2. The ellipsis button should be Red (as set by AppBarEllipsisButtonForeground)
              — on Uno it may show the wrong default color -->

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Height="200">
        <Grid.Resources>
            <!-- Bug: This color should be applied to the ellipsis button foreground -->
            <SolidColorBrush x:Key="AppBarEllipsisButtonForeground" Color="Red" />
            <SolidColorBrush x:Key="AppBarEllipsisButtonForegroundPressed" Color="DarkRed" />
            <SolidColorBrush x:Key="AppBarEllipsisButtonForegroundPointerOver" Color="OrangeRed" />
        </Grid.Resources>

        <StackPanel>
            <TextBlock Text="Repro for #4395: CommandBar Ellipsis Button Issues" TextWrapping="Wrap" Margin="8" />
            <TextBlock Text="Bug 1: The ellipsis (⋯) should be vertically centered in the CommandBar" TextWrapping="Wrap" Margin="8" />
            <TextBlock Text="Bug 2: The ellipsis (⋯) should be Red (set via AppBarEllipsisButtonForeground)" TextWrapping="Wrap" Margin="8" />

            <CommandBar>
                <AppBarButton Label="Button1" Icon="Add" />
                <CommandBar.SecondaryCommands>
                    <AppBarButton Label="Secondary 1" />
                    <AppBarButton Label="Secondary 2" />
                </CommandBar.SecondaryCommands>
            </CommandBar>

            <TextBlock Text="Expected: ⋯ is centered and Red" Margin="8" FontWeight="Bold" />
        </StackPanel>
    </Grid>
</UserControl>
