<UserControl x:Class="Uno.UI.Samples.Content.UITests.CommandBar.CommandBar_Content"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://nventive.com/android"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://nventive.com/ios"
    xmlns:local="using:Uno.UI.Samples.Content.UITests.CommandBar"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:Uno.UI.Toolkit"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<UserControl.Resources>
		<Style x:Key="DefaultCommandBarTitle"
		    TargetType="local:CommandBarTitle">

			<Setter Property="HorizontalAlignment" Value="Center" />
			<android:Setter Property="HorizontalAlignment"
			    Value="Left" />
			<Setter Property="Margin" Value="0" />

			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="local:CommandBarTitle">

						<Grid HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
						    VerticalAlignment="Center">

							<Grid.RowDefinitions>
								<RowDefinition Height="Auto" />
								<RowDefinition Height="Auto" />
							</Grid.RowDefinitions>

							<!--  Main Title  -->
							<TextBlock Grid.Row="0"
							    MaxWidth="556"
							    Margin="{TemplateBinding Margin}"
							    ios:TextAlignment="Center"
							    Text="{TemplateBinding MainTitle}"
							    TextWrapping="NoWrap" />

							<!--  Sub Title  -->
							<StackPanel Grid.Row="1"
							    android:Margin="0,-6,0,0"
							    ios:HorizontalAlignment="Center"
							    Orientation="Horizontal">

								<TextBlock x:Name="SubTitle1"
								    Margin="0,0,2,0"
								    Text="{TemplateBinding SubTitle1}" />

								<TextBlock x:Name="SubTitle2"
								    Text="{TemplateBinding SubTitle2}" />

							</StackPanel>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</UserControl.Resources>

	<ScrollViewer>
		<StackPanel>

			<TextBlock Text="Empty" />
			<CommandBar Background="Orange">
				<toolkit:CommandBarExtensions.NavigationCommand>
					<AppBarButton Command="{Binding Command}"
					    Label="Label">
						<AppBarButton.Icon>
							<BitmapIcon UriSource="ms-appx:///Assets/Icons/menu.png" />
						</AppBarButton.Icon>
					</AppBarButton>
				</toolkit:CommandBarExtensions.NavigationCommand>
				<CommandBar.PrimaryCommands>
					<AppBarButton Content="Button" />
					<AppBarButton>
						<AppBarButton.Icon>
							<BitmapIcon UriSource="ms-appx:///Assets/Icons/search.png" />
						</AppBarButton.Icon>
					</AppBarButton>
				</CommandBar.PrimaryCommands>
			</CommandBar>

			<TextBlock Text="String" />
			<CommandBar Background="LightGreen"
			    Content="String"
			    Foreground="DarkGray">
				<toolkit:CommandBarExtensions.NavigationCommand>
					<AppBarButton Command="{Binding Command}"
					    Label="Label">
						<AppBarButton.Icon>
							<BitmapIcon UriSource="ms-appx:///Assets/Icons/menu.png" />
						</AppBarButton.Icon>
					</AppBarButton>
				</toolkit:CommandBarExtensions.NavigationCommand>
				<CommandBar.PrimaryCommands>
					<AppBarButton Content="Button" />
					<AppBarButton>
						<AppBarButton.Icon>
							<BitmapIcon UriSource="ms-appx:///Assets/Icons/search.png" />
						</AppBarButton.Icon>
					</AppBarButton>
				</CommandBar.PrimaryCommands>
			</CommandBar>

			<TextBlock Text="Border Stretch" />
			<CommandBar Foreground="Black">
				<CommandBar.Content>
					<Border Background="Red" />
				</CommandBar.Content>
				<toolkit:CommandBarExtensions.NavigationCommand>
					<AppBarButton Command="{Binding Command}"
					    Label="Label">
						<AppBarButton.Icon>
							<BitmapIcon UriSource="ms-appx:///Assets/Icons/menu.png" />
						</AppBarButton.Icon>
					</AppBarButton>
				</toolkit:CommandBarExtensions.NavigationCommand>
				<CommandBar.PrimaryCommands>
					<AppBarButton>
						<AppBarButton.Icon>
							<BitmapIcon UriSource="ms-appx:///Assets/Icons/search.png" />
						</AppBarButton.Icon>
					</AppBarButton>
				</CommandBar.PrimaryCommands>
				<CommandBar.SecondaryCommands>
					<AppBarButton Content="SecondaryCommand"
					    Foreground="Green" />
				</CommandBar.SecondaryCommands>
			</CommandBar>

			<TextBlock Text="Border Center" />
			<CommandBar Background="LightGray"
			    Foreground="Red">
				<CommandBar.Content>
					<Border Width="20"
					    Height="20"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Center"
					    Background="Red" />
				</CommandBar.Content>
				<toolkit:CommandBarExtensions.NavigationCommand>
					<AppBarButton Command="{Binding Command}"
					    Label="Label">
						<AppBarButton.Icon>
							<BitmapIcon UriSource="ms-appx:///Assets/Icons/menu.png" />
						</AppBarButton.Icon>
					</AppBarButton>
				</toolkit:CommandBarExtensions.NavigationCommand>
				<CommandBar.PrimaryCommands>
					<AppBarButton Content="Button" />
					<AppBarButton>
						<AppBarButton.Icon>
							<BitmapIcon UriSource="ms-appx:///Assets/Icons/search.png" />
						</AppBarButton.Icon>
					</AppBarButton>
				</CommandBar.PrimaryCommands>
			</CommandBar>

			<TextBlock Text="Title" />
			<CommandBar Foreground="DarkBlue">
				<CommandBar.Content>
					<TextBlock VerticalAlignment="Center"
					    android:FontSize="20"
					    android:HorizontalAlignment="Left"
					    ios:FontSize="17"
					    ios:FontWeight="Medium"
					    ios:HorizontalAlignment="Center"
					    Text="TextBlock" />
				</CommandBar.Content>
				<toolkit:CommandBarExtensions.NavigationCommand>
					<AppBarButton Command="{Binding Command}"
					    Label="Label">
						<AppBarButton.Icon>
							<BitmapIcon UriSource="ms-appx:///Assets/Icons/menu.png" />
						</AppBarButton.Icon>
					</AppBarButton>
				</toolkit:CommandBarExtensions.NavigationCommand>
				<CommandBar.SecondaryCommands>
					<AppBarButton Foreground="DarkBlue"
					    Label="SecondaryCommand1" />
					<AppBarButton Foreground="DarkBlue">
						<AppBarButton.Icon>
							<BitmapIcon UriSource="ms-appx:///Assets/Icons/search.png" />
						</AppBarButton.Icon>
					</AppBarButton>
				</CommandBar.SecondaryCommands>
			</CommandBar>

			<TextBlock Text="Subtitle" />
			<CommandBar Foreground="Brown">
				<CommandBar.Content>
					<StackPanel VerticalAlignment="Center"
					    android:HorizontalAlignment="Left"
					    ios:HorizontalAlignment="Center">
						<TextBlock android:FontSize="20"
						    android:HorizontalAlignment="Left"
						    ios:FontSize="15"
						    ios:HorizontalAlignment="Center"
						    Text="TextBlock" />
						<TextBlock android:FontSize="14"
						    android:HorizontalAlignment="Left"
						    ios:FontSize="11"
						    ios:HorizontalAlignment="Center"
						    Text="TextBlock" />
					</StackPanel>
				</CommandBar.Content>
				<toolkit:CommandBarExtensions.NavigationCommand>
					<AppBarButton Command="{Binding Command}"
					    Label="Label">
						<AppBarButton.Icon>
							<BitmapIcon UriSource="ms-appx:///Assets/Icons/menu.png" />
						</AppBarButton.Icon>
					</AppBarButton>
				</toolkit:CommandBarExtensions.NavigationCommand>
				<CommandBar.PrimaryCommands>
					<AppBarButton Content="Button" />
					<AppBarButton>
						<AppBarButton.Icon>
							<BitmapIcon UriSource="ms-appx:///Assets/Icons/search.png" />
						</AppBarButton.Icon>
					</AppBarButton>
				</CommandBar.PrimaryCommands>
			</CommandBar>

			<TextBlock Text="TextBox" />
			<CommandBar Background="Purple">
				<CommandBar.Content>
					<TextBox PlaceholderText="TextBox"
					    Style="{StaticResource XamlDefaultTextBox}" />
				</CommandBar.Content>
				<toolkit:CommandBarExtensions.NavigationCommand>
					<AppBarButton Command="{Binding Command}"
					    Label="Label">
						<AppBarButton.Icon>
							<BitmapIcon UriSource="ms-appx:///Assets/Icons/menu.png" />
						</AppBarButton.Icon>
					</AppBarButton>
				</toolkit:CommandBarExtensions.NavigationCommand>
				<CommandBar.PrimaryCommands>
					<AppBarButton>
						<AppBarButton.Icon>
							<BitmapIcon UriSource="ms-appx:///Assets/Icons/search.png" />
						</AppBarButton.Icon>
					</AppBarButton>
					<AppBarButton Content="Button" />
				</CommandBar.PrimaryCommands>
			</CommandBar>

			<TextBlock Text="Foreground" />
			<CommandBar Background="Yellow"
			    Foreground="Red">
				<CommandBar.Content>
					<TextBlock Text="TextBlock" />
				</CommandBar.Content>
				<toolkit:CommandBarExtensions.NavigationCommand>
					<AppBarButton Command="{Binding Command}"
					    Label="Label">
						<AppBarButton.Icon>
							<BitmapIcon UriSource="ms-appx:///Assets/Icons/menu.png" />
						</AppBarButton.Icon>
					</AppBarButton>
				</toolkit:CommandBarExtensions.NavigationCommand>
				<CommandBar.PrimaryCommands>
					<AppBarButton Content="Button" />
					<AppBarButton Label="Icon">
						<AppBarButton.Icon>
							<BitmapIcon UriSource="ms-appx:///Assets/Icons/search.png" />
						</AppBarButton.Icon>
					</AppBarButton>
				</CommandBar.PrimaryCommands>
			</CommandBar>

			<TextBlock Text="DataContext" />
			<CommandBar DataContext="DataContext"
			    Foreground="Black">
				<CommandBar.Content>
					<TextBlock Text="{Binding}" />
				</CommandBar.Content>
				<toolkit:CommandBarExtensions.NavigationCommand>
					<AppBarButton Command="{Binding Command}"
					    Label="Label">
						<AppBarButton.Icon>
							<BitmapIcon UriSource="ms-appx:///Assets/Icons/menu.png" />
						</AppBarButton.Icon>
					</AppBarButton>
				</toolkit:CommandBarExtensions.NavigationCommand>
				<CommandBar.PrimaryCommands>
					<AppBarButton Content="Button" />
					<AppBarButton>
						<AppBarButton.Icon>
							<BitmapIcon UriSource="ms-appx:///Assets/Icons/search.png" />
						</AppBarButton.Icon>
					</AppBarButton>
				</CommandBar.PrimaryCommands>
			</CommandBar>

			<TextBlock Text="Complex control whose content is dynamic and forces resizes" />
			<CommandBar Foreground="Blue">
				<CommandBar.Content>
					<local:CommandBarTitle MainTitle="{Binding [DynamicTitle]}"
					    Style="{StaticResource DefaultCommandBarTitle}"
					    SubTitle1="{Binding [DynamicSubTitle1]}"
					    SubTitle2="{Binding [DynamicSubTitle2]}" />
				</CommandBar.Content>
			</CommandBar>
		</StackPanel>
	</ScrollViewer>

</UserControl>
