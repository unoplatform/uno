<Page x:Class="UITests.Windows_UI_Xaml_Controls.CommandBar.BackButtonTitle.CommandBar_Page2"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.CommandBar.BackButtonTitle"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<CommandBar x:Name="Page2CommandBar"
		    Content="Page 2" />

		<StackPanel Grid.Row="1"
		    VerticalAlignment="Center">
			<Button x:Name="BackButtonTitleButton"
			    HorizontalAlignment="Center"
			    Click="OnButtonClicked"
			    Content="Get Back Text" />

			<TextBlock x:Name="InfoTextBlock"
			    HorizontalAlignment="Center" />
		</StackPanel>

	</Grid>
</Page>
