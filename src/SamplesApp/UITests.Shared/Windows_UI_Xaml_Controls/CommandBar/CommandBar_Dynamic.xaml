<Page x:Class="Uno.UI.Samples.Content.UITests.CommandBar.CommandBar_Dynamic"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:Uno.UI.Toolkit"
    xmlns:valueconverters="using:UITests.ValueConverters"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<UserControl.Resources>

		<DataTemplate x:Key="ColorDataTemplate">
			<Border Height="20">
				<Border.Background>
					<SolidColorBrush Color="{Binding}" />
				</Border.Background>
			</Border>
		</DataTemplate>

		<Style TargetType="Slider">
			<Setter Property="Maximum" Value="1" />
			<Setter Property="StepFrequency" Value="0.05" />
		</Style>

		<valueconverters:FromNullableBoolToCustomValueConverter x:Key="nativeTemplateConverter"
		    NullOrFalseValue="{StaticResource XamlDefaultCommandBar}"
		    TrueValue="{StaticResource NativeDefaultCommandBar}" />

	</UserControl.Resources>

	<Grid x:Name="RootPanel"
	    toolkit:VisibleBoundsPadding.PaddingMask="All">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<Border x:Name="TheBorder"
		    Grid.Row="1"
		    BorderBrush="Yellow"
		    BorderThickness="4" />
		<CommandBar x:Name="TheCommandBar"
		    Content="{Binding Text, ElementName=Content2}"
		    Opacity="{Binding Value, ElementName=sliderOpacity}"
		    Style="{Binding IsChecked, ElementName=native, Converter={StaticResource nativeTemplateConverter}}"
		    Visibility="{Binding Text, ElementName=cbVisibility}">
			<CommandBar.Foreground>
				<SolidColorBrush Color="{Binding SelectedItem, ElementName=ForegroundColor}"
				    Opacity="{Binding Value, ElementName=ForegroundOpacity}" />
			</CommandBar.Foreground>
			<CommandBar.Background>
				<SolidColorBrush Color="{Binding SelectedItem, ElementName=BackgroundColor}"
				    Opacity="{Binding Value, ElementName=BackgroundOpacity}" />
			</CommandBar.Background>
			<toolkit:CommandBarExtensions.NavigationCommand>
				<AppBarButton IsEnabled="{Binding SelectedItem, ElementName=CommandIsEnabled}"
				    Label="{Binding Text, ElementName=CommandLabel}"
				    Opacity="{Binding Value, ElementName=CommandOpacity}"
				    Visibility="{Binding SelectedItem, ElementName=CommandVisibility}">
					<AppBarButton.Foreground>
						<SolidColorBrush Color="{Binding SelectedItem, ElementName=ForegroundColor}"
						    Opacity="{Binding Value, ElementName=ForegroundOpacity}" />
					</AppBarButton.Foreground>
					<AppBarButton.Icon>
						<BitmapIcon UriSource="ms-appx:///Assets/Icons/menu.png" />
					</AppBarButton.Icon>
				</AppBarButton>
			</toolkit:CommandBarExtensions.NavigationCommand>
			<CommandBar.PrimaryCommands>
				<AppBarButton Content="{Binding Text, ElementName=Content2}"
				    IsEnabled="{Binding SelectedItem, ElementName=CommandIsEnabled}"
				    Label="{Binding Text, ElementName=CommandLabel}"
				    Opacity="{Binding Value, ElementName=CommandOpacity}"
				    Visibility="{Binding SelectedItem, ElementName=CommandVisibility}">
					<AppBarButton.Foreground>
						<SolidColorBrush Color="{Binding SelectedItem, ElementName=ForegroundColor}"
						    Opacity="{Binding Value, ElementName=ForegroundOpacity}" />
					</AppBarButton.Foreground>
				</AppBarButton>
				<AppBarButton Content="{Binding Text, ElementName=Content2}"
				    IsEnabled="{Binding SelectedItem, ElementName=CommandIsEnabled}"
				    Label="{Binding Text, ElementName=CommandLabel}"
				    Opacity="{Binding Value, ElementName=CommandOpacity}"
				    Visibility="{Binding SelectedItem, ElementName=CommandVisibility}">
					<AppBarButton.Foreground>
						<SolidColorBrush Color="{Binding SelectedItem, ElementName=ForegroundColor}"
						    Opacity="{Binding Value, ElementName=ForegroundOpacity}" />
					</AppBarButton.Foreground>
					<AppBarButton.Icon>
						<BitmapIcon UriSource="{Binding Text, ElementName=CommandIcon}" />
					</AppBarButton.Icon>
				</AppBarButton>
			</CommandBar.PrimaryCommands>
			<CommandBar.SecondaryCommands>
				<AppBarButton Content="{Binding Text, ElementName=Content2}"
				    IsEnabled="{Binding SelectedItem, ElementName=CommandIsEnabled}"
				    Label="{Binding Text, ElementName=CommandLabel}"
				    Opacity="{Binding Value, ElementName=sliderOpacity}"
				    Visibility="{Binding SelectedItem, ElementName=CommandVisibility}">
					<AppBarButton.Foreground>
						<SolidColorBrush Color="{Binding SelectedItem, ElementName=ForegroundColor}"
						    Opacity="{Binding Value, ElementName=ForegroundOpacity}" />
					</AppBarButton.Foreground>
					<AppBarButton.Icon>
						<BitmapIcon UriSource="{Binding Text, ElementName=CommandIcon}" />
					</AppBarButton.Icon>
				</AppBarButton>
			</CommandBar.SecondaryCommands>
		</CommandBar>
		<ScrollViewer Grid.Row="1">
			<StackPanel Margin="30,0"
			    Spacing="8">
				<CheckBox x:Name="native"
				    Content="NativeCommandBar"
				    IsChecked="True" />
				<ComboBox x:Name="cbVisibility"
				    HorizontalAlignment="Stretch"
				    Header="Visibility"
				    Style="{StaticResource XamlDefaultComboBox}" />
				<Slider x:Name="sliderOpacity"
				    Header="Opacity"
				    Value="1" />
				<TextBox x:Name="Content2"
				    HorizontalAlignment="Stretch"
				    Header="Content"
				    Style="{StaticResource XamlDefaultTextBox}"
				    Text="Content" />
				<ComboBox x:Name="BackgroundColor"
				    HorizontalAlignment="Stretch"
				    Header="BackgroundColor"
				    ItemTemplate="{StaticResource ColorDataTemplate}"
				    Style="{StaticResource XamlDefaultComboBox}" />
				<Slider x:Name="BackgroundOpacity"
				    Header="BackgroundOpacity"
				    Value="1" />
				<ComboBox x:Name="ForegroundColor"
				    HorizontalAlignment="Stretch"
				    Header="ForegroundColor"
				    ItemTemplate="{StaticResource ColorDataTemplate}"
				    Style="{StaticResource XamlDefaultComboBox}" />
				<Slider x:Name="ForegroundOpacity"
				    Header="ForegroundOpacity"
				    Value="1" />
				<ComboBox x:Name="CommandVisibility"
				    HorizontalAlignment="Stretch"
				    Header="CommandVisibility"
				    Style="{StaticResource XamlDefaultComboBox}" />
				<Slider x:Name="CommandOpacity"
				    Header="CommandOpacity"
				    Value="1" />
				<ComboBox x:Name="CommandIsEnabled"
				    HorizontalAlignment="Stretch"
				    Header="CommandIsEnabled"
				    Style="{StaticResource XamlDefaultComboBox}" />
				<TextBox x:Name="CommandIcon"
				    HorizontalAlignment="Stretch"
				    Header="CommandIcon"
				    Style="{StaticResource XamlDefaultTextBox}"
				    Text="ms-appx:///Assets/Icons/search.png" />
				<TextBox x:Name="CommandLabel"
				    HorizontalAlignment="Stretch"
				    Header="CommandLabel"
				    Style="{StaticResource XamlDefaultTextBox}"
				    Text="Label" />
			</StackPanel>
		</ScrollViewer>
		<StackPanel Grid.RowSpan="2"
		    Width="200"
		    IsHitTestVisible="False"
		    Orientation="Horizontal">
			<Border Height="24"
			    VerticalAlignment="Top"
			    Background="#90ff8000"
			    BorderBrush="Black"
			    BorderThickness="1">
				<TextBlock Margin="2"
				    FontSize="8"
				    FontWeight="Bold"
				    Text="24" />
			</Border>
			<Border Height="32"
			    VerticalAlignment="Top"
			    Background="#90ffff00"
			    BorderBrush="Black"
			    BorderThickness="1">
				<TextBlock Margin="2"
				    FontSize="8"
				    FontWeight="Bold"
				    Text="32" />
			</Border>
			<Border Height="40"
			    VerticalAlignment="Top"
			    Background="#90ff8000"
			    BorderBrush="Black"
			    BorderThickness="1">
				<TextBlock Margin="2"
				    FontSize="8"
				    FontWeight="Bold"
				    Text="40" />
			</Border>
			<Border Height="44"
			    VerticalAlignment="Top"
			    Background="#90ffff00"
			    BorderBrush="Black"
			    BorderThickness="1">
				<TextBlock Margin="2"
				    FontSize="8"
				    FontWeight="Bold"
				    Text="44" />
			</Border>
			<Border Height="50"
			    VerticalAlignment="Top"
			    Background="#90ff8000"
			    BorderBrush="Black"
			    BorderThickness="1">
				<TextBlock Margin="2"
				    FontSize="8"
				    FontWeight="Bold"
				    Text="50" />
			</Border>
		</StackPanel>
	</Grid>

</Page>
