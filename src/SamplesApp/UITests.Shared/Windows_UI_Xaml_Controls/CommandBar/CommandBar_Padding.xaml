<UserControl x:Class="Uno.UI.Samples.Content.UITests.CommandBar.CommandBar_Padding"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Uno.UI.Samples.Content.UITests.CommandBar"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<StackPanel>

		<CommandBar Margin="10"
		    Padding="0,0,0,0"
		    Background="Tomato"
		    Content="No padding (0,0,0,0)" />

		<CommandBar Margin="10"
		    Padding="0,25,0,0"
		    Background="Tomato"
		    Content="Top 'status bar' padding (0,25,0,0)" />

		<CommandBar Margin="10"
		    Padding="10,10,10,10"
		    Background="Tomato"
		    Content="All-around padding (10,10,10,10)" />

	</StackPanel>

</UserControl>
