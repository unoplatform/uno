<UserControl x:Class="Uno.UI.Samples.Content.UITests.CommandBar.CommandBar_Extensions"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://nventive.com/android"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://nventive.com/ios"
    xmlns:local="using:Uno.UI.Samples.Content.UITests.CommandBar"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    xmlns:toolkit="using:Uno.UI.Toolkit"
    xmlns:uno="using:Uno.UI.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d not_win ios android">

	<ScrollViewer>
		<StackPanel>

			<AppBarButton Command="{Binding Command}"
			    Foreground="White"
			    Label="Label">
				<AppBarButton.Icon>
					<BitmapIcon UriSource="ms-appx:///Assets/Icons/menu.png" />
				</AppBarButton.Icon>
			</AppBarButton>

			<android:Grid>
				<CommandBar toolkit:CommandBarExtensions.Subtitle="Subtitle"
				    Content="Title" />
			</android:Grid>

			<not_win:Grid>
				<CommandBar Content="Title">
					<toolkit:CommandBarExtensions.NavigationCommand>
						<AppBarButton Command="{Binding Command}"
						    Label="Label">
							<AppBarButton.Icon>
								<BitmapIcon UriSource="ms-appx:///Assets/Icons/menu.png" />
							</AppBarButton.Icon>
						</AppBarButton>
					</toolkit:CommandBarExtensions.NavigationCommand>
				</CommandBar>
			</not_win:Grid>

			<not_win:Grid>
				<CommandBar Background="Tomato"
				    Content="Title"
				    Foreground="White">
					<toolkit:CommandBarExtensions.NavigationCommand>
						<AppBarButton Command="{Binding Command}"
						    Foreground="White"
						    Label="Label">
							<AppBarButton.Icon>
								<BitmapIcon UriSource="ms-appx:///Assets/Icons/menu.png" />
							</AppBarButton.Icon>
						</AppBarButton>
					</toolkit:CommandBarExtensions.NavigationCommand>
				</CommandBar>
			</not_win:Grid>

			<ios:Grid>
				<CommandBar toolkit:CommandBarExtensions.BackButtonForeground="Red"
				    Content="Title">
					<toolkit:CommandBarExtensions.NavigationCommand>
						<AppBarButton Command="{Binding Command}"
						    Label="Label">
							<AppBarButton.Icon>
								<BitmapIcon UriSource="ms-appx:///Assets/Icons/menu.png" />
							</AppBarButton.Icon>
						</AppBarButton>
					</toolkit:CommandBarExtensions.NavigationCommand>
					<AppBarButton Content="Button" />
					<AppBarButton>
						<AppBarButton.Icon>
							<BitmapIcon UriSource="ms-appx:///Assets/Icons/search.png" />
						</AppBarButton.Icon>
					</AppBarButton>
				</CommandBar>
			</ios:Grid>


		</StackPanel>
	</ScrollViewer>

</UserControl>
