<UserControl x:Class="Uno.UI.Samples.Content.UITests.ContentControlTestsControl.ContentControl_ContentFlicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400"
             d:DesignWidth="400">

    <!-- Repro for https://github.com/unoplatform/uno/issues/2807
         Bug: Changing the Content of a ContentControl causes visual flicker on WASM.
         How to verify:
           1. Click the "Switch Content" button rapidly
           2. Observe whether the background flashes white/blank between content changes
           Expected: No flash — content should transition smoothly without a blank frame
           Bug: On WASM, a brief blank frame appears between old and new content -->

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="2" Margin="20">
            <ContentControl x:Name="TheContentControl"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch">
                <ContentControl.ContentTemplate>
                    <DataTemplate>
                        <Grid Background="LightBlue">
                            <TextBlock Text="{Binding}"
                                       FontSize="24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>
        </Border>

        <TextBlock Grid.Row="1"
                   Text="Click Switch Content rapidly — watch for blank flashes between transitions."
                   TextWrapping="Wrap"
                   Margin="20,0,20,8" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" Margin="0,0,0,16">
            <Button x:Name="SwitchButton" Click="OnSwitchClick" Content="Switch Content" />
            <TextBlock x:Name="CounterText" VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
