<UserControl x:Class="Uno.UI.Samples.Content.UITests.ContentControlTestsControl.ContentControl_SetNull"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="Uno.UI.Samples.Content.UITests.ContentControlTestsControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<controls:SampleControl SampleDescription="ContentControls with bound Content. After pressing the button, previous Content should not be seen.">
		<controls:SampleControl.SampleContent>
			<DataTemplate>
				<StackPanel>
					<Button Margin="10"
					    Command="{Binding [SetChangeablePropertyToNull]}"
					    Content="Set Contents to null" />
					<TextBlock Text="ContentControl with no ContentTemplate" />
					<ContentControl Content="{Binding [ChangeableProperty]}" />
					<TextBlock Text="ContentControl with custom ContentTemplate" />
					<ContentControl Content="{Binding [ChangeableProperty]}">
						<ContentControl.ContentTemplate>
							<DataTemplate>
								<Border Width="150"
								    Height="30"
								    Background="Thistle">
									<TextBlock Text="{Binding}" />
								</Border>
							</DataTemplate>
						</ContentControl.ContentTemplate>
					</ContentControl>
					<TextBlock Text="ContentControl with custom Template" />
					<ContentControl Content="{Binding [ChangeableProperty]}">
						<ContentControl.Template>
							<ControlTemplate TargetType="ContentControl">
								<Border Width="150"
								    Height="30"
								    Background="LimeGreen">
									<ContentPresenter Content="{TemplateBinding Content}" />
								</Border>
							</ControlTemplate>
						</ContentControl.Template>
					</ContentControl>
				</StackPanel>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>