<Page x:Class="UITests.Windows_UI_Xaml_Controls.ThumbTests.Thumb_DragEvents"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.ThumbTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Grid>
		<StackPanel HorizontalAlignment="Left"
		    VerticalAlignment="Top">
			<TextBlock Text="Start:" />
			<TextBlock x:Name="DragStartedOutput" />
			<TextBlock Text="Delta:" />
			<TextBlock x:Name="DragDeltaOutput" />
			<TextBlock Text="End:" />
			<TextBlock x:Name="DragCompletedOutput" />
		</StackPanel>

		<Grid Width="100"
		    Height="100"
		    HorizontalAlignment="Center"
		    VerticalAlignment="Center"
		    Background="Red">
			<Thumb x:Name="TheThumb"
			    Width="20"
			    Height="20"
			    HorizontalAlignment="Center"
			    VerticalAlignment="Center"
			    DragCompleted="OnThumbDragCompleted"
			    DragDelta="OnThumbDragDelta"
			    DragStarted="OnThumbDragStarted">
				<Thumb.Template>
					<ControlTemplate>
						<Border Background="Blue" />
					</ControlTemplate>
				</Thumb.Template>
			</Thumb>
		</Grid>
	</Grid>
</Page>
