<UserControl x:Class="Uno.UI.Samples.Content.UITests.WebView.WebView_Static"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Uno.UI.Samples.Content.UITests.WebView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    xmlns:u="using:Uno.UI.Samples.Controls"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d not_win">

	<not_win:Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<WebView local:WebViewObserverBehavior.IsAttached="True"
		    Source="{Binding [WebSource]}" />

		<Button Grid.Row="1"
		    Command="{Binding [GoToNextWebSource]}"
		    Content="Next URL" />
	</not_win:Grid>
</UserControl>
