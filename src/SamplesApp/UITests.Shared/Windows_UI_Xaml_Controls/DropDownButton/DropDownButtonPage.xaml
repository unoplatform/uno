<UserControl x:Class="MUXControlsTestApp.DropDownButtonPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="DropDownButtonTestPage"
    mc:Ignorable="d">

	<Grid Margin="12"
	    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<ScrollViewer Grid.Column="0"
		    Height="Auto">
			<StackPanel Width="Auto"
			    Height="Auto"
			    VerticalAlignment="Top"
			    Orientation="Vertical">
				<TextBlock Margin="0"
				    Style="{ThemeResource StandardGroupHeader}"
				    Text="Demo controls" />
				<StackPanel Margin="0,12,0,0"
				    Orientation="Horizontal">
					<controls:DropDownButton x:Name="TestDropDownButton"
					    AutomationProperties.Name="TestDropDownButton"
					    Click="TestDropDownButton_Click"
					    Content="Test Button"
					    CornerRadius="2">
						<controls:DropDownButton.Flyout>
							<Flyout x:Name="TestFlyout"
							    AutomationProperties.Name="TestFlyout"
							    Closed="TestDropDownButtonFlyout_Closed"
							    Opened="TestDropDownButtonFlyout_Opened"
							    Placement="Bottom">
								<TextBlock Text="Hello" />
							</Flyout>
						</controls:DropDownButton.Flyout>
					</controls:DropDownButton>

					<Button Margin="6,0,0,0"
					    Content="For Comparison">
						<Button.Flyout>
							<Flyout>
								<TextBlock Text="Button flyout" />
							</Flyout>
						</Button.Flyout>
					</Button>
				</StackPanel>


				<TextBlock Margin="0,16,0,8"
				    Style="{ThemeResource StandardGroupHeader}"
				    Text="Options" />
				<CheckBox x:Name="SetFlyoutCheckbox"
				    AutomationProperties.Name="SetFlyoutCheckbox"
				    Checked="SetFlyoutCheckbox_Checked"
				    Content="Flyout set"
				    IsChecked="True"
				    Unchecked="SetFlyoutCheckbox_Unchecked" />

				<TextBlock Margin="0,16,0,8"
				    Style="{ThemeResource StandardGroupHeader}"
				    Text="Status" />
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

					<Grid.RowDefinitions>
						<RowDefinition />
						<RowDefinition />
						<RowDefinition />
					</Grid.RowDefinitions>

					<TextBlock Grid.Row="0">Click count:</TextBlock>
					<TextBlock x:Name="ClickCountTextBlock"
					    Grid.Row="0"
					    Grid.Column="1"
					    Margin="4,0,0,0"
					    AutomationProperties.Name="ClickCountTextBlock"
					    Text="0" />
					<TextBlock Grid.Row="1">Flyout opened:</TextBlock>
					<TextBlock x:Name="FlyoutOpenedCountTextBlock"
					    Grid.Row="1"
					    Grid.Column="1"
					    Margin="4,0,0,0"
					    AutomationProperties.Name="FlyoutOpenedCountTextBlock"
					    Text="0" />
					<TextBlock Grid.Row="2">Flyout closed:</TextBlock>
					<TextBlock x:Name="FlyoutClosedCountTextBlock"
					    Grid.Row="2"
					    Grid.Column="1"
					    Margin="4,0,0,0"
					    AutomationProperties.Name="FlyoutClosedCountTextBlock"
					    Text="0" />
				</Grid>


			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>
