<UserControl x:Class="SamplesApp.Wasm.Windows_UI_Xaml_Controls.ComboBox.ComboBox_ScrollViewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Uno.UI.Samples.Content.UITests.ComboBox"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">
	<Grid>
		<ScrollViewer Width="300"
		    Height="300"
		    Background="LightGray"
		    HorizontalScrollBarVisibility="Visible"
		    VerticalScrollBarVisibility="Visible">
			<StackPanel Width="500"
			    Height="500">
				<ComboBox Margin="200,200,0,0"
				    ItemsSource="{Binding [SampleItems]}" />
			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>
