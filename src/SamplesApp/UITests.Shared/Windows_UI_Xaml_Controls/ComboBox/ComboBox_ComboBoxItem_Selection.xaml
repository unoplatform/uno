<UserControl
    x:Class="UITests.Shared.Windows_UI_Xaml_Controls.ComboBox.ComboBox_ComboBoxItem_Selection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <StackPanel>
        <ComboBox x:Name="_combo">
            <ComboBoxItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse
                        Width="20"
                        Height="30"
                        Fill="Aquamarine" />
                    <TextBlock>Item 1</TextBlock>
                </StackPanel>
            </ComboBoxItem>
            <ComboBoxItem>Item 2</ComboBoxItem>
            <ComboBoxItem>Item 3</ComboBoxItem>
            <ComboBoxItem>Item 4</ComboBoxItem>
        </ComboBox>
        <TextBlock>
            Previous Combo VisualTree (first item):<LineBreak />
            <Run x:Name="_combo1Txt" />
        </TextBlock>
        <ComboBox x:Name="_combo2">
            <TextBlock x:Name="_tb1">Item 1</TextBlock>
            <TextBlock x:Name="_tb2">Item 2</TextBlock>
            <TextBlock>Item 3</TextBlock>
            <TextBlock>Item 4</TextBlock>
            <TextBlock>Item 5</TextBlock>
        </ComboBox>
        <TextBlock>
            Previous Combo VisualTree (first item):<LineBreak />
            <Run x:Name="_combo2Txt" />
        </TextBlock>
        <Button
            x:Name="ChangeSelectionButton"
            Click="ChangeSelectionButton_Click"
            Content="Increment SelectedIndex" />
    </StackPanel>
</UserControl>
