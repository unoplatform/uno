<Page x:Class="UITests.Windows_UI_Xaml_Controls.DatePicker.DatePicker_Placement"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d not_win">

	<Grid Padding="10">
		<DatePicker x:Name="topLeft"
		    HorizontalAlignment="Left"
		    VerticalAlignment="Top"
		    not_win:UseNativeStyle="False" />
		<DatePicker x:Name="topRight"
		    HorizontalAlignment="Right"
		    VerticalAlignment="Top"
		    not_win:UseNativeStyle="False" />
		<DatePicker x:Name="bottomLeft"
		    HorizontalAlignment="Left"
		    VerticalAlignment="Bottom"
		    not_win:UseNativeStyle="False" />
		<DatePicker x:Name="bottomRight"
		    HorizontalAlignment="Right"
		    VerticalAlignment="Bottom"
		    not_win:UseNativeStyle="False" />
		<DatePicker x:Name="centerLeftOutside"
		    HorizontalAlignment="Left"
		    VerticalAlignment="Center"
		    not_win:UseNativeStyle="False">
			<DatePicker.RenderTransform>
				<TranslateTransform X="-100" />
			</DatePicker.RenderTransform>
		</DatePicker>
		<DatePicker x:Name="rightLeftOutside"
		    HorizontalAlignment="Right"
		    VerticalAlignment="Center"
		    not_win:UseNativeStyle="False">
			<DatePicker.RenderTransform>
				<TranslateTransform X="100" />
			</DatePicker.RenderTransform>
		</DatePicker>
		<DatePicker x:Name="topCenterRotated"
		    HorizontalAlignment="Center"
		    VerticalAlignment="Top"
		    not_win:UseNativeStyle="False"
		    RenderTransformOrigin="0.5, 0.5">
			<DatePicker.RenderTransform>
				<RotateTransform Angle="90" />
			</DatePicker.RenderTransform>
		</DatePicker>
		<StackPanel HorizontalAlignment="Center"
		    VerticalAlignment="Center">
			<DatePicker x:Name="center"
			    not_win:UseNativeStyle="False"
			    RenderTransformOrigin="0.5, 0.5">
				<DatePicker.RenderTransform>
					<RotateTransform Angle="180" />
				</DatePicker.RenderTransform>
			</DatePicker>
			<DatePicker x:Name="narrow"
			    Width="120"
			    not_win:UseNativeStyle="False" />
			<DatePicker x:Name="wide"
			    Width="420"
			    not_win:UseNativeStyle="False" />
			<DatePicker x:Name="scaled"
			    not_win:UseNativeStyle="False"
			    RenderTransformOrigin="0.5, 0.5">
				<DatePicker.RenderTransform>
					<ScaleTransform ScaleX="1.25" ScaleY="0.75" />
				</DatePicker.RenderTransform>
			</DatePicker>
			<Viewbox Height="50">
				<DatePicker x:Name="viewBox"
				    not_win:UseNativeStyle="False" />
			</Viewbox>
		</StackPanel>
	</Grid>
</Page>
