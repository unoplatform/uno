<UserControl x:Class="UITests.Windows_UI_Xaml_Controls.PageTests.Page_Update_Background"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.PageTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<StackPanel>
		<Page x:Name="TargetPage"
		    Width="200"
		    Height="350"
		    Background="Blue" />
		<Button x:Name="AdvanceTestButton"
		    Click="AdvanceTestButton_Click"
		    Content="Advance test" />
		<TextBlock x:Name="StatusTextBlock"
		    Text="Not started" />
	</StackPanel>
</UserControl>
