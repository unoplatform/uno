<UserControl x:Class="Uno.UI.Samples.Content.UITests.Flyout.Flyout_Events"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Uno.UI.Samples.Content.UITests.Flyout"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<StackPanel>

		<CheckBox x:Name="CancelClosing"
		    Content="Cancel Closing" />

		<Button Content="Open flyout">
			<Button.Flyout>
				<Flyout x:Name="MyFlyout">
					<Border Width="100"
					    Height="100"
					    Background="Red" />
				</Flyout>
			</Button.Flyout>
		</Button>

		<TextBlock x:Name="Events"
		    TextWrapping="Wrap" />

	</StackPanel>

</UserControl>
