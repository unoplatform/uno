<UserControl x:Class="Uno.UI.Samples.Content.UITests.Flyout.Flyout_Target"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Uno.UI.Samples.Content.UITests.Flyout"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<StackPanel VerticalAlignment="Center">
		<TextBlock x:Name="result" />
		<Button x:Name="target1"
		    Click="OnClick"
		    Content="Flyout Target #1" />
		<Button x:Name="target2"
		    Click="OnClick"
		    Content="Flyout Target #2" />
		<Button x:Name="flyoutFull"
		    Click="OnClickFull"
		    Content="Flyout Full Placement NoTarget" />
	</StackPanel>

</UserControl>
