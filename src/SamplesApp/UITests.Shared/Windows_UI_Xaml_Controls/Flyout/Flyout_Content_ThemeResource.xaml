<Page x:Class="UITests.Shared.Windows_UI_Xaml_Controls.Flyout.Flyout_Content_ThemeResource"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.Flyout"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Grid>
		<Button Background="{ThemeResource GlobalThemeResource_Test01}"
		    Content="Click me">
			<Button.Flyout>
				<local:Flyout_Local />
			</Button.Flyout>
		</Button>
	</Grid>

</Page>
