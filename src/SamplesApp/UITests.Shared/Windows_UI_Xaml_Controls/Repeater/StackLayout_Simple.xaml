<Page x:Class="UITests.Windows_UI_Xaml_Controls.Repeater.StackLayout_Simple"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mux="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<ScrollViewer x:Name="RepeaterScrollViewer"
		    Grid.Row="1"
		    AutomationProperties.Name="RepeaterScrollViewer"
		    Background="HotPink"
		    HorizontalScrollBarVisibility="Auto"
		    HorizontalScrollMode="Auto"
		    IsVerticalScrollChainingEnabled="False">
			<mux:ItemsRepeater x:Name="UniformGridRepeater"
			    Margin="10"
			    Background="Aquamarine"
			    ItemsSource="{x:Bind Items}">
				<mux:ItemsRepeater.Layout>
					<mux:StackLayout x:Name="layout"
					    Orientation="{Binding SelectedItem.Content, ElementName=orientation}"
					    Spacing="{Binding Value, ElementName=spacing}" />
				</mux:ItemsRepeater.Layout>
				<mux:ItemsRepeater.ItemTemplate>
					<DataTemplate>
						<Border Width="300"
						    Height="300"
						    HorizontalAlignment="Center"
						    VerticalAlignment="Center"
						    Background="Yellow">
							<Grid Padding="8">
								<Rectangle Fill="Cyan" />
								<TextBlock FontSize="80"
								    Text="{Binding}" />
							</Grid>
						</Border>
					</DataTemplate>
				</mux:ItemsRepeater.ItemTemplate>
			</mux:ItemsRepeater>
		</ScrollViewer>
		<StackPanel>
			<StackPanel Orientation="Horizontal">
				<Button Click="Scroll"
				    Tag="0">
					Scroll 0%
				</Button>
				<Button Click="Scroll"
				    Tag="0.25">
					Scroll 25%
				</Button>
				<Button Click="Scroll"
				    Tag="0.5">
					Scroll 50%
				</Button>
				<Button Click="Scroll"
				    Tag="0.75">
					Scroll 75%
				</Button>
				<Button Click="Scroll"
				    Tag="100">
					Scroll 100%
				</Button>
				<Button Click="Tree">Tree</Button>
				<ComboBox x:Name="orientation"
				    Header="Orientation">
					<ComboBoxItem Content="Vertical" />
					<ComboBoxItem Content="Horizontal" />
				</ComboBox>
			</StackPanel>
			<Slider x:Name="spacing"
			    Header="Spacing"
			    Maximum="30"
			    Minimum="0"
			    Value="5" />
		</StackPanel>
	</Grid>
</Page>
