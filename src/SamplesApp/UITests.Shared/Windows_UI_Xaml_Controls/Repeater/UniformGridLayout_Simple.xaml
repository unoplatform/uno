<Page
    x:Class="UITests.Windows_UI_Xaml_Controls.Repeater.UniformGridLayout_Simple"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mux="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <ScrollViewer
            x:Name="RepeaterScrollViewer"
            Grid.Row="1"
            Background="HotPink">
            <mux:ItemsRepeater
                x:Name="UniformGridRepeater"
                Margin="10"
                Background="Aquamarine"
                ItemsSource="{x:Bind Items}">
                <mux:ItemsRepeater.Layout>
                    <mux:UniformGridLayout
                        x:Name="layout"
                        ItemsJustification="{Binding SelectedItem.Content, ElementName=justification}"
                        ItemsStretch="{Binding SelectedItem.Content, ElementName=stretch}"
                        MaximumRowsOrColumns="{Binding Value, ElementName=maxColumns}"
                        MinColumnSpacing="8"
                        MinRowSpacing="8"
                        Orientation="{Binding SelectedItem.Content, ElementName=orientation}" />
                </mux:ItemsRepeater.Layout>
                <mux:ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Width="300"
                            Height="300"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="Yellow">
                            <Grid Padding="8">
                                <Rectangle Fill="Cyan" />
                                <TextBlock FontSize="80" Text="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </mux:ItemsRepeater.ItemTemplate>
            </mux:ItemsRepeater>
        </ScrollViewer>
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Button Click="Scroll" Tag="0">
                    Scroll 0%
                </Button>
                <Button Click="Scroll" Tag="0.25">
                    Scroll 25%
                </Button>
                <Button Click="Scroll" Tag="0.5">
                    Scroll 50%
                </Button>
                <Button Click="Scroll" Tag="0.75">
                    Scroll 75%
                </Button>
                <Button Click="Scroll" Tag="100">
                    Scroll 100%
                </Button>
                <Button Click="Tree">Tree</Button>
                <ComboBox x:Name="justification" Header="Justification">
                    <ComboBoxItem Content="Start" />
                    <ComboBoxItem Content="Center" IsSelected="True" />
                    <ComboBoxItem Content="End" />
                    <ComboBoxItem Content="SpaceAround" />
                    <ComboBoxItem Content="SpaceBetween" />
                    <ComboBoxItem Content="SpaceEvenly" />
                </ComboBox>
                <ComboBox x:Name="stretch" Header="Stretch">
                    <ComboBoxItem Content="None" />
                    <ComboBoxItem Content="Fill" />
                    <ComboBoxItem Content="Uniform" IsSelected="True" />
                </ComboBox>
                <ComboBox x:Name="orientation" Header="Orientation">
                    <ComboBoxItem Content="Vertical" />
                    <ComboBoxItem Content="Horizontal" IsSelected="True" />
                </ComboBox>
            </StackPanel>
            <Slider
                x:Name="maxColumns"
                Header="MaxRowsOrColumns"
                Maximum="10"
                Minimum="1"
                Value="3" />
        </StackPanel>
    </Grid>
</Page>
