<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.ButtonTestsControl.RadioButton_With_GroupName"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d not_win">

    <controls:SampleControl SampleDescription="Radio Buttons with named groups. A selected radio button cannot be unchecked if already checked.">
        <controls:SampleControl.SampleContent>
            <DataTemplate>
                <StackPanel Background="CornflowerBlue">
                    <Border BorderBrush="Black" BorderThickness="2">
                        <StackPanel>
                            <TextBlock Text="First StackPanel" />
                            <RadioButton
                                Command="{Binding [CheckBox01_Command]}"
                                Content="Cat"
                                Foreground="Brown"
                                GroupName="Animal" />
                            <RadioButton
                                Command="{Binding [CheckBox02_Command]}"
                                Content="Apple"
                                Foreground="Green"
                                GroupName="Fruits" />
                            <RadioButton
                                Command="{Binding [CheckBox03_Command]}"
                                Content="Orange"
                                Foreground="Green"
                                GroupName="Fruits" />
                        </StackPanel>
                    </Border>
                    <Border BorderBrush="White" BorderThickness="2">
                        <StackPanel>
                            <TextBlock Text="Second StackPanel" />
                            <RadioButton
                                Command="{Binding [CheckBox01_Command]}"
                                Content="Banana"
                                Foreground="Green"
                                GroupName="Fruits" />
                            <RadioButton
                                Command="{Binding [CheckBox02_Command]}"
                                Content="Dog"
                                Foreground="Brown"
                                GroupName="Animal" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DataTemplate>
        </controls:SampleControl.SampleContent>
    </controls:SampleControl>
</UserControl>
