<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.ButtonTestsControl.Button_Opacity_Automated"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Uno.UI.Samples.Content.UITests.ButtonTestsControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <!--  Click Count value  -->
            <TextBlock
                x:Name="TotalClicks"
                HorizontalAlignment="Center"
                FontSize="20"
                Text="0" />

            <!--  Add button  -->
            <Button
                x:Name="ButtonToChangeOpacity"
                Margin="0,32,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="Black"
                Click="AddButtonClick"
                Content="Add"
                Foreground="Blue"
                IsEnabled="True" />

            <!--  Label : Enter a number  -->
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="20"
                Text="Enter an opacity value :" />

            <!--  TextBox Value of opacity  -->
            <TextBox
                x:Name="ValueOfOpacity"
                Width="200"
                HorizontalAlignment="Center"
                FontSize="20"
                Text="1" />

            <!--  Apply button  -->
            <Button
                x:Name="ApplyOpacityButton"
                Margin="0,32,0,0"
                HorizontalAlignment="Center"
                Click="ApplyButtonClick"
                Content="Apply"
                IsEnabled="True" />

        </StackPanel>
    </Grid>
</UserControl>
