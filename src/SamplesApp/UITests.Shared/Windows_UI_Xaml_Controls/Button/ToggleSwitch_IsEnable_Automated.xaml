<UserControl x:Class="Uno.UI.Samples.Content.UITests.ButtonTestsControl.ToggleSwitch_IsEnable_Automated"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="using:Uno.UI.Samples.Content.UITests.ButtonTestsControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    mc:Ignorable="not_win ios android">

	<ScrollViewer>
		<StackPanel HorizontalAlignment="Center"
		    VerticalAlignment="Center">

			<!--  ToggleSwitch_1 State  -->
			<TextBlock x:Name="ToggleSwitch_1_IsOn"
			    Margin="0,0,0,2"
			    HorizontalAlignment="Center"
			    FontSize="20" />

			<!--  ToggleSwitch_1  -->
			<ToggleSwitch x:Name="MyToggleSwitch_1"
			    MinWidth="0"
			    HorizontalAlignment="Center"
			    Toggled="ToggleSwitch_1_Toggled" />

			<!--  ToggleSwitch_2 State  -->
			<TextBlock x:Name="ToggleSwitch_2_IsOn"
			    Margin="0,24,0,2"
			    HorizontalAlignment="Center"
			    FontSize="20" />

			<!--  ToggleSwitch_2  -->
			<ToggleSwitch x:Name="MyToggleSwitch_2"
			    MinWidth="0"
			    HorizontalAlignment="Center"
			    IsEnabled="False"
			    Toggled="ToggleSwitch_2_Toggled" />
		</StackPanel>
	</ScrollViewer>
</UserControl>