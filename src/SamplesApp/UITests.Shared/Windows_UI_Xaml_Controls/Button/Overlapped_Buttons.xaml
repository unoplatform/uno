<Page x:Class="UITests.Shared.Windows_UI_Xaml_Controls.Button.Overlapped_Buttons"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_Xaml_Controls.Button"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uno="using:Uno.UI.Samples.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<Grid.RowDefinitions>
			<RowDefinition Height="*"
			    MinHeight="325" />
			<RowDefinition Height="Auto"
			    MinHeight="120" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<Button x:Name="layer1"
		    Grid.Column="0"
		    Grid.ColumnSpan="2"
		    Margin="0,0,0,100"
		    HorizontalAlignment="Stretch"
		    VerticalAlignment="Stretch"
		    HorizontalContentAlignment="Stretch"
		    VerticalContentAlignment="Stretch"
		    Background="Aquamarine"
		    Click="OnClick"
		    Opacity="0.75"
		    Tapped="OnTapped">
			<Grid HorizontalAlignment="Stretch"
			    VerticalAlignment="Stretch">
				<TextBlock VerticalAlignment="Top">layer1 (lowest)</TextBlock>
				<Button x:Name="layer1_inner"
				    Margin="40"
				    HorizontalAlignment="Stretch"
				    VerticalAlignment="Stretch"
				    Background="Navy"
				    Click="OnClick"
				    Tapped="OnTapped">
					layer1-inner
				</Button>
			</Grid>
		</Button>
		<Button x:Name="layer2"
		    Grid.Column="1"
		    Grid.ColumnSpan="3"
		    Margin="0,50,0,50"
		    HorizontalAlignment="Stretch"
		    VerticalAlignment="Stretch"
		    VerticalContentAlignment="Top"
		    Background="HotPink"
		    Click="OnClick"
		    Opacity="0.75"
		    Tapped="OnTapped">
			layer2 (middle)
		</Button>
		<Button x:Name="layer3"
		    Grid.Column="3"
		    Grid.ColumnSpan="2"
		    Margin="0,100,0,0"
		    HorizontalAlignment="Stretch"
		    VerticalAlignment="Stretch"
		    VerticalContentAlignment="Bottom"
		    Background="LawnGreen"
		    Click="OnClick"
		    Opacity="0.75"
		    Tapped="OnTapped">
			layer3 (top most)
		</Button>

		<uno:StarStackPanel Grid.ColumnSpan="5"
		    Height="70"
		    Sizes="*,*">
			<Border x:Name="hitInvisible"
			    Background="DarkSalmon"
			    IsHitTestVisible="False"
			    Opacity=".5">
				<Viewbox Stretch="Fill">
					<TextBlock>--- IsHitTestVisible="False" ---</TextBlock>
				</Viewbox>
			</Border>
			<Border x:Name="hitVisible"
			    Background="LightGoldenrodYellow"
			    IsHitTestVisible="True"
			    Opacity=".5">
				<Viewbox Stretch="Fill">
					<TextBlock>--- IsHitTestVisible="True" ---</TextBlock>
				</Viewbox>
			</Border>
		</uno:StarStackPanel>

		<Border Grid.Row="1"
		    Grid.ColumnSpan="5"
		    Margin="2"
		    Padding="4"
		    BorderBrush="DarkCyan"
		    BorderThickness="1">
			<TextBlock x:Name="msgs"
			    FontSize="8" />
		</Border>

		<Button Grid.Row="2"
		    Grid.ColumnSpan="5"
		    Tapped="ClearMsgs">
			CLEAR
		</Button>

		<uno:StarStackPanel Grid.Row="0"
		    Grid.ColumnSpan="5"
		    VerticalAlignment="Bottom"
		    IsHitTestVisible="False"
		    Orientation="Horizontal"
		    Sizes="Auto">
			<TextBlock>layer1 clicks:</TextBlock>
			<TextBlock x:Name="l1Clicks"
			    FontWeight="Bold" />
			<TextBlock>, layer1_inner clicks:</TextBlock>
			<TextBlock x:Name="l1innerClicks"
			    FontWeight="Bold" />
			<TextBlock>, layer2 clicks:</TextBlock>
			<TextBlock x:Name="l2Clicks"
			    FontWeight="Bold" />
			<TextBlock>, layer3 clicks:</TextBlock>
			<TextBlock x:Name="l3Clicks"
			    FontWeight="Bold" />
		</uno:StarStackPanel>

	</Grid>
</Page>
