<UserControl x:Class="Uno.UI.Samples.Content.UITests.ButtonTestsControl.Buttons"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>
		<StackPanel Grid.Column="0">
			<HyperlinkButton Click="OnClick"
			    Command="{Binding Command}"
			    CommandParameter="Microsoft.UI.Xaml.Controls.HyperlinkButton"
			    Content="HyperlinkButton"
			    IsEnabled="{Binding IsEnabled}"
			    Tapped="OnTapped" />
			<HyperlinkButton Click="OnClick"
			    Command="{Binding Command}"
			    CommandParameter="Microsoft.UI.Xaml.Controls.HyperlinkButton"
			    Content="HyperlinkButton (NavigateUri)"
			    IsEnabled="{Binding IsEnabled}"
			    NavigateUri="http://nventive.com"
			    Tapped="OnTapped" />
			<Button Click="OnClick"
			    Command="{Binding Command}"
			    CommandParameter="Microsoft.UI.Xaml.Controls.Button"
			    Content="Button"
			    IsEnabled="{Binding IsEnabled}"
			    Tapped="OnTapped" />
			<ToggleButton Click="OnClick"
			    Command="{Binding Command}"
			    CommandParameter="Microsoft.UI.Xaml.Controls.Primitives.ToggleButton"
			    Content="ToggleButton"
			    IsChecked="{Binding IsChecked}"
			    IsEnabled="{Binding IsEnabled}"
			    Tapped="OnTapped" />
			<CheckBox Click="OnClick"
			    Command="{Binding Command}"
			    CommandParameter="Microsoft.UI.Xaml.Controls.CheckBox"
			    Content="CheckBox"
			    IsChecked="{Binding IsChecked}"
			    IsEnabled="{Binding IsEnabled}"
			    Tapped="OnTapped" />
			<RadioButton Click="OnClick"
			    Command="{Binding Command}"
			    CommandParameter="Microsoft.UI.Xaml.Controls.RadioButton"
			    Content="RadioButton"
			    IsChecked="{Binding IsChecked}"
			    IsEnabled="{Binding IsEnabled}"
			    Tapped="OnTapped" />
			<TextBlock Margin="0,20,0,0"
			    Text="Native styles (if applicable)" />
			<Button android:Style="{StaticResource AndroidButtonStyle}"
			    ios:Style="{StaticResource iOSButtonStyle}"
			    Click="OnClick"
			    Command="{Binding Command}"
			    CommandParameter="Microsoft.UI.Xaml.Controls.Button"
			    Content="Button"
			    IsEnabled="{Binding IsEnabled}"
			    Tapped="OnTapped" />
			<CheckBox android:Style="{StaticResource AndroidCheckBoxStyle}"
			    Click="OnClick"
			    Command="{Binding Command}"
			    CommandParameter="Microsoft.UI.Xaml.Controls.CheckBox"
			    Content="CheckBox"
			    IsChecked="{Binding IsChecked}"
			    IsEnabled="{Binding IsEnabled}"
			    Tapped="OnTapped" />
			<RadioButton android:Style="{StaticResource AndroidRadioButtonStyle}"
			    Click="OnClick"
			    Command="{Binding Command}"
			    CommandParameter="Microsoft.UI.Xaml.Controls.RadioButton"
			    Content="RadioButton"
			    IsChecked="{Binding IsChecked}"
			    IsEnabled="{Binding IsEnabled}"
			    Tapped="OnTapped" />
		</StackPanel>
		<StackPanel x:Name="myStackPanel"
		    Grid.Column="1">
			<CheckBox Content="IsEnabled"
			    IsChecked="{Binding IsEnabled, Mode=TwoWay}" />
			<CheckBox Content="IsChecked"
			    IsChecked="{Binding IsChecked, Mode=TwoWay}" />
			<Button Command="{Binding ClearCommand}"
			    Content="Clear" />
			<ItemsControl x:Name="myItemsControl"
			    ItemsSource="{Binding Output}" />
			<TextBlock Margin="0,20,0,0"
			    Text="This button changes foreground when hovered or pressed when fluent styles are enabled" />
			<Button Content="Change Button Foreground">
				<Button.Resources>
					<ResourceDictionary>
						<SolidColorBrush x:Key="ButtonForeground"
						    Color="Yellow" />
						<SolidColorBrush x:Key="ButtonForegroundPointerOver"
						    Color="Red" />
						<SolidColorBrush x:Key="ButtonForegroundPressed"
						    Color="Purple" />
					</ResourceDictionary>
				</Button.Resources>
			</Button>
			<TextBlock Margin="0,20,0,0"
			    Text="This button changes background when hovered or pressed when fluent styles are enabled" />
			<Button Content="Change Button Background">
				<Button.Resources>
					<ResourceDictionary>
						<SolidColorBrush x:Key="ButtonBackground"
						    Color="Yellow" />
						<SolidColorBrush x:Key="ButtonBackgroundPointerOver"
						    Color="Red" />
						<SolidColorBrush x:Key="ButtonBackgroundPressed"
						    Color="Purple" />
					</ResourceDictionary>
				</Button.Resources>
			</Button>
		</StackPanel>
	</Grid>
</UserControl>
