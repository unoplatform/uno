<UserControl x:Class="Uno.UI.Samples.Content.UITests.ButtonTestsControl.CheckBox_Button"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d not_win ios android">

	<controls:SampleControl SampleDescription="CheckBox_Button">
		<controls:SampleControl.SampleContent>
			<DataTemplate>

				<StackPanel>

					<TextBlock Text="Native Checkbox" />
					<CheckBox android:Style="{StaticResource AndroidCheckBoxStyle}"
					    Command="{Binding [SampleCommand]}"
					    Content="Checkbox" />
					<CheckBox android:Style="{StaticResource AndroidCheckBoxStyle}"
					    Command="{Binding [SampleCommand]}"
					    Content="Checkbox"
					    IsChecked="true" />

					<TextBlock Text="Checkbox with the default style from UWA" />
					<CheckBox Command="{Binding [SampleCommand]}"
					    Content="UWACheckbox" />
					<CheckBox Command="{Binding [SampleCommand]}"
					    Content="UWACheckbox"
					    IsChecked="true" />

					<TextBlock Text="Checkbox with the default style from UWA Disabled" />
					<CheckBox Command="{Binding [SampleCommand]}"
					    Content="UWACheckbox"
					    IsEnabled="False" />
					<CheckBox Command="{Binding [SampleCommand]}"
					    Content="UWACheckbox"
					    IsChecked="true"
					    IsEnabled="False" />

				</StackPanel>
			</DataTemplate>
		</controls:SampleControl.SampleContent>
	</controls:SampleControl>
</UserControl>
