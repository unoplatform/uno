    xmlns:local="using:UITests.Shared.Windows_UI_Xaml_Controls.ContentDialogTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
