<Page x:Class="UITests.Windows_UI_Xaml.UIElementTests.UIElement_Alignments"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<StackPanel Spacing="10">
		<TextBlock FontSize="15">
			HorizontalAlignment
		</TextBlock>
		<StackPanel Orientation="Horizontal"
		    Spacing="10">
			<Border Width="100"
			    Height="100"
			    Background="Yellow">
				<Border HorizontalAlignment="Left"
				    VerticalAlignment="Center"
				    Background="LightBlue">
					<TextBlock>Left</TextBlock>
				</Border>
			</Border>
			<Border Width="100"
			    Height="100"
			    Background="Yellow">
				<Border HorizontalAlignment="Center"
				    VerticalAlignment="Center"
				    Background="LightBlue">
					<TextBlock>Center</TextBlock>
				</Border>
			</Border>
			<Border Width="100"
			    Height="100"
			    Background="Yellow">
				<Border HorizontalAlignment="Right"
				    VerticalAlignment="Center"
				    Background="LightBlue">
					<TextBlock>Right</TextBlock>
				</Border>
			</Border>
			<Border Width="100"
			    Height="100"
			    Background="Yellow">
				<Border HorizontalAlignment="Stretch"
				    VerticalAlignment="Center"
				    Background="LightBlue">
					<TextBlock>Stretch</TextBlock>
				</Border>
			</Border>
		</StackPanel>
		<TextBlock FontSize="15">
			VerticalAlignment
		</TextBlock>
		<StackPanel Orientation="Horizontal"
		    Spacing="10">
			<Border Width="100"
			    Height="100"
			    Background="Yellow">
				<Border HorizontalAlignment="Center"
				    VerticalAlignment="Top"
				    Background="LightBlue">
					<TextBlock>Top</TextBlock>
				</Border>
			</Border>
			<Border Width="100"
			    Height="100"
			    Background="Yellow">
				<Border HorizontalAlignment="Center"
				    VerticalAlignment="Center"
				    Background="LightBlue">
					<TextBlock>Center</TextBlock>
				</Border>
			</Border>
			<Border Width="100"
			    Height="100"
			    Background="Yellow">
				<Border HorizontalAlignment="Center"
				    VerticalAlignment="Bottom"
				    Background="LightBlue">
					<TextBlock>Bottom</TextBlock>
				</Border>
			</Border>
			<Border Width="100"
			    Height="100"
			    Background="Yellow">
				<Border HorizontalAlignment="Center"
				    VerticalAlignment="Stretch"
				    Background="LightBlue">
					<TextBlock>Stretch</TextBlock>
				</Border>
			</Border>
		</StackPanel>
		<TextBlock FontSize="15">
			HorizontalAlignment.Right in Grid cells
		</TextBlock>
		<Grid Width="100"
		    HorizontalAlignment="Left"
		    BorderBrush="Blue"
		    BorderThickness="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<TextBlock Grid.Column="0"
			    HorizontalAlignment="Right">
				R0
			</TextBlock>
			<TextBlock Grid.Column="1"
			    HorizontalAlignment="Right">
				R1
			</TextBlock>
		</Grid>

	</StackPanel>
</Page>
