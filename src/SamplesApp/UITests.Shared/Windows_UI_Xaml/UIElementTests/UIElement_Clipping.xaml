<UserControl x:Class="UITests.Windows_UI_Xaml.UIElementTests.UIElement_Clipping"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml.UIElementTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mux="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<TextBlock Margin="5"
		    FontSize="20">
			All following squares MUST BE identical
		</TextBlock>
		<StackPanel Grid.Row="1"
		    HorizontalAlignment="Left"
		    Orientation="Horizontal"
		    Spacing="10">
			<Border x:Name="Square1"
			    Width="75"
			    Height="75"
			    Padding="10"
			    Background="Orange">
				<Rectangle Fill="Green" />
			</Border>
			<Border x:Name="Square2"
			    Width="75"
			    Height="75"
			    Padding="10"
			    Background="Orange">
				<Rectangle Width="2000"
				    Height="2000"
				    Fill="Green" />
			</Border>
			<Canvas x:Name="Square3"
			    Width="75"
			    Height="75"
			    Background="Orange">
				<Rectangle Canvas.Left="10"
				    Canvas.Top="10"
				    Width="55"
				    Height="55"
				    Fill="Green" />
			</Canvas>
			<Canvas x:Name="Square4"
			    Width="75"
			    Height="75">
				<Rectangle Width="75"
				    Height="75"
				    Fill="Orange" />
				<Rectangle Canvas.Left="-1000"
				    Canvas.Top="-1000"
				    Width="1"
				    Height="1"
				    Fill="Green">
					<Rectangle.RenderTransform>
						<CompositeTransform ScaleX="55"
						    ScaleY="55"
						    TranslateX="1010"
						    TranslateY="1010" />
					</Rectangle.RenderTransform>
				</Rectangle>
			</Canvas>
			<Border x:Name="Square5"
			    Width="75"
			    Height="75"
			    Padding="10"
			    Background="Orange">
				<StackPanel Spacing="10">
					<Rectangle Height="10"
					    Fill="Green">
						<Rectangle.RenderTransform>
							<ScaleTransform ScaleY="2" />
						</Rectangle.RenderTransform>
					</Rectangle>
					<Rectangle Height="10"
					    Fill="Green">
						<Rectangle.RenderTransform>
							<ScaleTransform ScaleY="2" />
						</Rectangle.RenderTransform>
					</Rectangle>
					<Rectangle Height="10"
					    Fill="Green">
						<Rectangle.RenderTransform>
							<ScaleTransform ScaleY="1.5" />
						</Rectangle.RenderTransform>
					</Rectangle>
				</StackPanel>
			</Border>
		</StackPanel>
	</Grid>
</UserControl>
