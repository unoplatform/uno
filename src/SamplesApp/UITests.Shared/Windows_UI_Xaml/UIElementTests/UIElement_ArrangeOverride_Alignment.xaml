<Page x:Class="UITests.Windows_UI_Xaml.UIElementTests.UIElement_ArrangeOverride_Alignment"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml.UIElementTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<StackPanel Margin="20"
	    Spacing="10">
		<TextBlock FontSize="14"
		    FontWeight="Bold">
			Using a 100x100 arranged control, measured at 75x75:
		</TextBlock>

		<TextBlock FontSize="14">
			No constrains (using measured size):<LineBreak />
			(result height should be 75 height, bottom clipped)</TextBlock>
		<Border BorderBrush="Blue"
		    BorderThickness="1">
			<local:RectArranged100x100 />
		</Border>

		<TextBlock FontSize="14">
			Stretch arranged in a 150 height border:<LineBreak />
			(square shouldn't be clipped, vertically centered)</TextBlock>
		<Border Height="150"
		    BorderBrush="Blue"
		    BorderThickness="1">
			<local:RectArranged100x100 VerticalAlignment="Stretch" />
		</Border>

		<TextBlock FontSize="14">
			Bottom aligned in a 150 height border:<LineBreak />
			(square shouldn't be clipped, bottom aligned)</TextBlock>
		<Border Height="150"
		    HorizontalAlignment="Stretch"
		    BorderBrush="Blue"
		    BorderThickness="1">
			<local:RectArranged100x100 VerticalAlignment="Bottom" />
		</Border>

	</StackPanel>
</Page>
