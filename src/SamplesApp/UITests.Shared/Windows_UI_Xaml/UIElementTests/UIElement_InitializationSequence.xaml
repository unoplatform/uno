<Page x:Class="UITests.Windows_UI_Xaml.UIElementTests.UIElement_InitializationSequence"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uiElementTests="using:UITests.Windows_UI_Xaml.UIElementTests"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Page.Resources>
		<Style x:Name="testControlStyle"
		    TargetType="uiElementTests:UIElement_InitializationSequence_TestControl">
			<Setter Property="Width" Value="200" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="uiElementTests:UIElement_InitializationSequence_TestControl">
						<Border Margin="10"
						    Background="Yellow">
							<StackPanel>
								<TextBlock Text="{TemplateBinding Name}" />
								<uiElementTests:UIElement_InitializationSequence_Materializer />
								<ContentPresenter Content="{TemplateBinding Content}" />
							</StackPanel>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
			<Setter Property="Tag" Value="tag-value" />
		</Style>

	</Page.Resources>

	<Grid HorizontalAlignment="Left"
	    ColumnSpacing="15"
	    RowSpacing="10">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<TextBlock Grid.Column="0"
		    FontSize="16">
			Result
		</TextBlock>

		<TextBlock Grid.Column="1"
		    FontSize="16">
			Reference Result on UWP
		</TextBlock>

		<ScrollViewer Grid.Row="1"
		    Grid.Column="0">
			<TextBlock x:Name="log"
			    FontSize="12"
			    IsTextSelectionEnabled="True" />
		</ScrollViewer>

		<ScrollViewer Grid.Row="1"
		    Grid.Column="1">
			<TextBlock x:Name="reference"
			    FontSize="12"
			    IsTextSelectionEnabled="True" />
		</ScrollViewer>

		<Border x:Name="testZone"
		    Grid.Row="2"
		    Grid.ColumnSpan="2"
		    Width="520"
		    Height="50" />
	</Grid>
</Page>
