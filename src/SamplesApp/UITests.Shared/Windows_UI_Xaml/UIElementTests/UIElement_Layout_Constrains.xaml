<Page x:Class="UITests.Shared.Windows_UI_Xaml.UIElementTests.UIElement_Layout_Constrains"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:Uno.UI.Toolkit"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<ScrollViewer>
		<StackPanel toolkit:VisibleBoundsPadding.PaddingMask="All"
		    Spacing="8">
			<TextBlock FontSize="18">Following 6 buttons should be of same look &amp; size:</TextBlock>

			<Border Height="40"
			    Background="Aquamarine">

				<StackPanel Orientation="Horizontal"
				    Spacing="10">
					<Button Width="80"
					    Padding="5"
					    VerticalAlignment="Stretch">
						BUTTON
					</Button>
					<Button Width="80"
					    Height="60"
					    Padding="5"
					    VerticalAlignment="Center">
						BUTTON
					</Button>
					<Button Width="80"
					    Height="40"
					    MinWidth="50"
					    MinHeight="10"
					    Padding="5">
						BUTTON
					</Button>
					<Button Width="40"
					    Height="20"
					    MinWidth="80"
					    MinHeight="40"
					    Padding="5">
						BUTTON
					</Button>
					<Button Width="100"
					    Height="120"
					    MaxWidth="80"
					    MaxHeight="40"
					    Padding="5">
						BUTTON
					</Button>
					<Border>
						<ContentControl Width="40"
						    Height="20"
						    MinWidth="80"
						    MinHeight="40">
							<ContentControl.Template>
								<ControlTemplate>
									<Button Padding="5"
									    HorizontalAlignment="Stretch"
									    VerticalAlignment="Stretch">
										BUTTON
									</Button>
								</ControlTemplate>
							</ContentControl.Template>
						</ContentControl>
					</Border>
				</StackPanel>
			</Border>

			<StackPanel Orientation="Horizontal"
			    Spacing="10">
				<Rectangle Width="80"
				    Height="5"
				    Fill="Gray" />
				<Rectangle Width="80"
				    Height="5"
				    Fill="Gray" />
				<Rectangle Width="80"
				    Height="5"
				    Fill="Gray" />
				<Rectangle Width="80"
				    Height="5"
				    Fill="Gray" />
				<Rectangle Width="80"
				    Height="5"
				    Fill="Gray" />
				<Rectangle Width="80"
				    Height="5"
				    Fill="Gray" />
			</StackPanel>

			<TextBlock FontSize="18">Following 4 buttons should be of same look &amp; size:</TextBlock>

			<Border Height="28"
			    Background="Orange">
				<StackPanel Orientation="Horizontal"
				    Spacing="10">
					<Button Width="65"
					    Padding="0"
					    VerticalAlignment="Stretch">
						<Border BorderBrush="Blue"
						    BorderThickness="2">
							<TextBlock Padding="0"
							    FontSize="8">
								BUTTON
							</TextBlock>
						</Border>
					</Button>
					<Button Width="65"
					    Height="36"
					    Padding="0">
						<Border BorderBrush="Blue"
						    BorderThickness="2">
							<TextBlock Padding="0"
							    FontSize="8">
								BUTTON
							</TextBlock>
						</Border>
					</Button>
					<Button Width="65"
					    Height="36"
					    Padding="0"
					    VerticalAlignment="Center">
						<Border BorderBrush="Blue"
						    BorderThickness="2">
							<TextBlock Padding="0"
							    FontSize="8">
								BUTTON
							</TextBlock>
						</Border>
					</Button>
					<Button Width="30"
					    Height="60"
					    MinWidth="65"
					    MinHeight="36"
					    MaxHeight="25"
					    Padding="0"
					    VerticalAlignment="Center">
						<Border BorderBrush="Blue"
						    BorderThickness="2">
							<TextBlock Padding="0"
							    FontSize="8">
								BUTTON
							</TextBlock>
						</Border>
					</Button>
				</StackPanel>
			</Border>

			<TextBlock FontSize="18">Following 9 rectangles should be of same look &amp; size:</TextBlock>

			<StackPanel Height="26"
			    Orientation="Horizontal"
			    Spacing="10">
				<Border Width="60"
				    Background="ForestGreen">
					<Rectangle Margin="8"
					    Fill="Blue" />
				</Border>
				<Border Width="60"
				    Background="ForestGreen">
					<Rectangle MinWidth="90"
					    Margin="8"
					    HorizontalAlignment="Center"
					    Fill="Blue" />
				</Border>
				<Border Width="60"
				    Background="ForestGreen">
					<Rectangle MinWidth="90"
					    Margin="8"
					    HorizontalAlignment="Stretch"
					    Fill="Blue" />
				</Border>
				<Border Width="60"
				    Padding="8"
				    Background="ForestGreen">
					<Rectangle MinWidth="80"
					    Fill="Blue" />
				</Border>
				<Border Width="60"
				    Background="ForestGreen">
					<Rectangle MinHeight="30"
					    Margin="8"
					    Fill="Blue" />
				</Border>
				<Border Width="60"
				    Background="ForestGreen">
					<Border Margin="8">
						<StackPanel VerticalAlignment="Top">
							<Rectangle Width="200"
							    Height="200"
							    Fill="Blue" />
							<Rectangle Width="200"
							    Height="200"
							    Fill="Yellow" />
						</StackPanel>
					</Border>
				</Border>
				<Border Width="60"
				    Padding="8"
				    Background="ForestGreen">
					<StackPanel VerticalAlignment="Center">
						<Rectangle Width="200"
						    Height="200"
						    Fill="Yellow" />
						<Rectangle Width="200"
						    Height="200"
						    Fill="Blue" />
						<Rectangle Width="200"
						    Height="200"
						    Fill="Orange" />
					</StackPanel>
				</Border>
				<Border Width="60"
				    Padding="8"
				    Background="ForestGreen">
					<StackPanel VerticalAlignment="Bottom">
						<Rectangle Width="200"
						    Height="200"
						    Fill="Yellow" />
						<Rectangle Width="200"
						    Height="200"
						    Fill="Blue" />
					</StackPanel>
				</Border>
				<Border Width="60">
					<Rectangle Fill="Blue"
					    Stroke="ForestGreen"
					    StrokeThickness="8" />
				</Border>
			</StackPanel>

			<StackPanel Orientation="Horizontal"
			    Spacing="10">
				<Border Width="60"
				    Height="5"
				    Background="Blue"
				    BorderBrush="ForestGreen"
				    BorderThickness="8,0" />
				<Border Width="60"
				    Height="5"
				    Background="Blue"
				    BorderBrush="ForestGreen"
				    BorderThickness="8,0" />
				<Border Width="60"
				    Height="5"
				    Background="Blue"
				    BorderBrush="ForestGreen"
				    BorderThickness="8,0" />
				<Border Width="60"
				    Height="5"
				    Background="Blue"
				    BorderBrush="ForestGreen"
				    BorderThickness="8,0" />
				<Border Width="60"
				    Height="5"
				    Background="Blue"
				    BorderBrush="ForestGreen"
				    BorderThickness="8,0" />
				<Border Width="60"
				    Height="5"
				    Background="Blue"
				    BorderBrush="ForestGreen"
				    BorderThickness="8,0" />
				<Border Width="60"
				    Height="5"
				    Background="Blue"
				    BorderBrush="ForestGreen"
				    BorderThickness="8,0" />
				<Border Width="60"
				    Height="5"
				    Background="Blue"
				    BorderBrush="ForestGreen"
				    BorderThickness="8,0" />
				<Border Width="60"
				    Height="5"
				    Background="Blue"
				    BorderBrush="ForestGreen"
				    BorderThickness="8,0" />
			</StackPanel>

			<Grid ColumnSpacing="10">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<Rectangle Width="100"
				    HorizontalAlignment="Left"
				    Fill="DarkSeaGreen" />
				<StackPanel Spacing="3">
					<TextBlock>green width is 100</TextBlock>
					<Border MaxWidth="100"
					    HorizontalAlignment="Left"
					    BorderBrush="Blue"
					    BorderThickness="2">
						<TextBlock>Max=100</TextBlock>
					</Border>
					<Border MaxWidth="100"
					    HorizontalAlignment="Left"
					    BorderBrush="Blue"
					    BorderThickness="2">
						<TextBlock TextWrapping="NoWrap">Max=100 + very long text</TextBlock>
					</Border>
					<Border MinWidth="80"
					    MaxWidth="40"
					    HorizontalAlignment="Left"
					    BorderBrush="Blue"
					    BorderThickness="2">
						<TextBlock TextWrapping="NoWrap">
							Max=40<LineBreak />
							Min=80</TextBlock>
					</Border>
					<Border Width="100"
					    HorizontalAlignment="Left"
					    BorderBrush="Blue"
					    BorderThickness="2">
						<TextBlock>Width=100</TextBlock>
					</Border>
					<Border MinWidth="80"
					    MaxWidth="120"
					    HorizontalAlignment="Left"
					    BorderBrush="Blue"
					    BorderThickness="2">
						<TextBlock>
							min/max<LineBreak />
							80/120</TextBlock>
					</Border>
					<Border MinWidth="80"
					    MaxWidth="40"
					    HorizontalAlignment="Left"
					    BorderBrush="Blue"
					    BorderThickness="2">
						<TextBlock>
							min/max<LineBreak />
							80/40</TextBlock>
					</Border>
					<Border MinWidth="80"
					    MaxWidth="120"
					    HorizontalAlignment="Left"
					    BorderBrush="Blue"
					    BorderThickness="2">
						<TextBlock TextWrapping="NoWrap">
							min/max<LineBreak />
							80/120 + very very very long text</TextBlock>
					</Border>
				</StackPanel>
				<Rectangle Grid.Column="1"
				    Height="100"
				    VerticalAlignment="Top"
				    Fill="LightPink" />
				<StackPanel Grid.Column="1"
				    Orientation="Horizontal"
				    Spacing="3">
					<TextBlock>pink height is 100</TextBlock>
					<Border MaxHeight="100"
					    VerticalAlignment="Top"
					    BorderBrush="Blue"
					    BorderThickness="2">
						<TextBlock>
							MaxH=100<LineBreak />
							+<LineBreak />
							very<LineBreak />
							very<LineBreak />
							very<LineBreak />
							very<LineBreak />
							very<LineBreak />
							long<LineBreak />
							text</TextBlock>
					</Border>
					<Border MaxHeight="100"
					    VerticalAlignment="Top"
					    BorderBrush="Blue"
					    BorderThickness="2">
						<TextBlock>MaxH=100</TextBlock>
					</Border>
					<Border MinHeight="50"
					    MaxHeight="10"
					    VerticalAlignment="Top"
					    BorderBrush="Blue"
					    BorderThickness="2">
						<TextBlock>
							MaxH=100, MinH=50<LineBreak />
							+<LineBreak />
							very<LineBreak />
							very<LineBreak />
							very<LineBreak />
							very<LineBreak />
							very<LineBreak />
							long<LineBreak />
							text</TextBlock>
					</Border>
					<Border Height="100"
					    VerticalAlignment="Top"
					    BorderBrush="Blue"
					    BorderThickness="2">
						<TextBlock>H=100</TextBlock>
					</Border>
					<Border MinHeight="80"
					    MaxHeight="120"
					    VerticalAlignment="Top"
					    BorderBrush="Blue"
					    BorderThickness="2">
						<TextBlock>
							min/max<LineBreak />
							80/120</TextBlock>
					</Border>
					<Border MinHeight="80"
					    MaxHeight="40"
					    VerticalAlignment="Top"
					    BorderBrush="Blue"
					    BorderThickness="2">
						<TextBlock>
							min/max<LineBreak />
							80/40</TextBlock>
					</Border>
					<Border MinHeight="80"
					    MaxHeight="120"
					    VerticalAlignment="Top"
					    BorderBrush="Blue"
					    BorderThickness="2">
						<TextBlock>
							min/max<LineBreak />
							80/120<LineBreak />
							+<LineBreak />
							very<LineBreak />
							very<LineBreak />
							very<LineBreak />
							very<LineBreak />
							very<LineBreak />
							very<LineBreak />
							long<LineBreak />
							text</TextBlock>
					</Border>
				</StackPanel>
			</Grid>

		</StackPanel>
	</ScrollViewer>
</Page>
