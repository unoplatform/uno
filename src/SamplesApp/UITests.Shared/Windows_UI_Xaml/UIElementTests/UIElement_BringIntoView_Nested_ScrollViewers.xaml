<Page x:Class="UITests.Windows_UI_Xaml.UIElementTests.UIElement_BringIntoView_Nested_ScrollViewers"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml.UIElementTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mux="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Grid Padding="12"
	    RowSpacing="8">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<Button Click="BringItemIntoView_Click">Bring into view</Button>
		<ScrollViewer Grid.Row="1"
		    Height="300"
		    Padding="20"
		    Background="Yellow">
			<ScrollViewer Height="200"
			    Margin="0,400,0,0"
			    Padding="20"
			    Background="Blue">
				<Border x:Name="Item"
				    Width="100"
				    Height="100"
				    Margin="0,600,0,0"
				    Background="Red" />
			</ScrollViewer>
		</ScrollViewer>
	</Grid>
</Page>
