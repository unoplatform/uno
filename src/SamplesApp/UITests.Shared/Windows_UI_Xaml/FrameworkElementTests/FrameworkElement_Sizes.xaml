<Page x:Class="UITests.Windows_UI_Xaml.FrameworkElementTests.FrameworkElement_Sizes"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml.FrameworkElementTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Page.Resources>
		<Style x:Name="autoStyle"
		    TargetType="FrameworkElement">
			<Setter Property="Width" Value="Auto" />
		</Style>
		<Style x:Name="nanStyle"
		    TargetType="FrameworkElement">
			<Setter Property="Width" Value="NaN" />
		</Style>
		<Style x:Name="fixedStyle"
		    TargetType="FrameworkElement">
			<Setter Property="Width" Value="200" />
		</Style>
	</Page.Resources>

	<StackPanel Spacing="8">
		<Border x:Name="text1"
		    Background="DarkSeaGreen"
		    Style="{StaticResource autoStyle}">
			<TextBlock>
				Auto (style setter):<Run Text="{Binding Width, ElementName=text1}" /></TextBlock>
		</Border>

		<Border x:Name="text2"
		    Background="DarkSeaGreen"
		    Style="{StaticResource nanStyle}">
			<TextBlock>
				Nan (style setter):<Run Text="{Binding Width, ElementName=text2}" /></TextBlock>
		</Border>

		<Border x:Name="text3"
		    Background="DarkSeaGreen"
		    Style="{StaticResource fixedStyle}">
			<TextBlock>
				Fixed (style setter):<Run Text="{Binding Width, ElementName=text3}" /></TextBlock>
		</Border>

		<Border x:Name="text4"
		    Width="Auto"
		    Background="DarkSeaGreen">
			<TextBlock>
				Auto (direct):<Run Text="{Binding Width, ElementName=text4}" /></TextBlock>
		</Border>

		<Border x:Name="text5"
		    Width="auto"
		    Background="DarkSeaGreen">
			<TextBlock>
				auto (direct):<Run Text="{Binding Width, ElementName=text5}" /></TextBlock>
		</Border>

		<Border x:Name="text6"
		    Width="{Binding Tag, ElementName=text6}"
		    Background="DarkSeaGreen"
		    Tag="Auto">
			<TextBlock>
				Auto (string bound):<Run Text="{Binding Width, ElementName=text6}" /></TextBlock>
		</Border>

		<Border x:Name="text7"
		    Width="{Binding Tag, ElementName=text7}"
		    Background="DarkSeaGreen"
		    Tag="auto">
			<TextBlock>
				auto (string bound):<Run Text="{Binding Width, ElementName=text7}" /></TextBlock>
		</Border>

		<Border x:Name="text8"
		    Width="NaN"
		    Background="DarkSeaGreen">
			<TextBlock>
				Nan (direct):<Run Text="{Binding Width, ElementName=text8}" /></TextBlock>
		</Border>

		<Border x:Name="text9"
		    Width="nan"
		    Background="DarkSeaGreen">
			<TextBlock>
				nan (direct):<Run Text="{Binding Width, ElementName=text9}" /></TextBlock>
		</Border>

		<Border x:Name="text10"
		    Width="{Binding Tag, ElementName=text10}"
		    Background="DarkSeaGreen"
		    Tag="nan">
			<TextBlock>
				nan (string bound):<Run Text="{Binding Width, ElementName=text10}" /></TextBlock>
		</Border>

		<Border x:Name="text11"
		    Width="{Binding Tag, ElementName=text11}"
		    Background="DarkSeaGreen"
		    Tag="Nan">
			<TextBlock>
				nan (string bound):<Run Text="{Binding Width, ElementName=text11}" /></TextBlock>
		</Border>

		<Border x:Name="text12"
		    Width="200"
		    Background="DarkSeaGreen">
			<TextBlock>
				Fixed (direct):<Run Text="{Binding Width, ElementName=text12}" /></TextBlock>
		</Border>

	</StackPanel>
</Page>
