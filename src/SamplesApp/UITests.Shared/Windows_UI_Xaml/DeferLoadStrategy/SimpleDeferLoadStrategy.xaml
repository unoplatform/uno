<UserControl x:Class="Uno.UI.Samples.Content.UITests.DeferLoadStrategy.SimpleDeferLoadStrategy"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="Uno.UI.Samples.Content.UITests.DeferLoadStrategy"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

	<StackPanel>
		<TextBlock Text="Immediate content" />
		<Border x:Name="LazyLoadedBorder"
		    x:DeferLoadStrategy="Lazy"
		    Loaded="OnBorderLoaded"
		    Visibility="{Binding [LateVisibility], TargetNullValue=Collapsed, FallbackValue=Collapsed}">
			<TextBlock Text="Content created when it becomes visible" />
		</Border>
		<TextBlock x:Name="loadedResult"
		    Text="Should say loaded after 3s" />
	</StackPanel>
</UserControl>
