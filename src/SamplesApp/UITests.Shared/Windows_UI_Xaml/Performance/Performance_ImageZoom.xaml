<Page x:Class="UITests.Windows_UI_Xaml.Performance.Performance_ImageZoom"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml.Performance"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d not_win">
	<Page.Resources>
		<SolidColorBrush x:Key="ColorAnimation_Background_Brush"
		    Color="Blue" />
		<Storyboard x:Name="colorStoryboard">
			<ColorAnimation Duration="0:00:05"
			    RepeatBehavior="Forever"
			    To="Red"
			    Storyboard.TargetName="TargetBorder"
			    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" />
		</Storyboard>
	</Page.Resources>

	<StackPanel>
		<Slider Header="ScaleX"
		    Maximum="4"
		    Minimum="0.25"
		    StepFrequency="0.1"
		    Value="{x:Bind ScaleTransform.ScaleX, Mode=TwoWay}" />
		<Slider Header="ScaleY"
		    Maximum="4"
		    Minimum="0.25"
		    StepFrequency="0.1"
		    Value="{x:Bind ScaleTransform.ScaleY, Mode=TwoWay}" />
		<StackPanel Orientation="Horizontal">
			<TextBlock Text="Number of Columns: " />
			<NumberBox x:Name="nb"
			    Minimum="1"
			    Value="5"
			    ValueChanged="NumberBoxValueChanged" />
			<TextBlock Text="Image type: " />
			<ComboBox x:Name="cb"
			    Width="120"
			    SelectionChanged="OnSelectionChanged"
			    TabIndex="4">
				<ComboBoxItem Content="Image With a BitmapImage source"
				    IsSelected="True" />
				<ComboBoxItem Content="Border with a BitmapImage background" />
			</ComboBox>
		</StackPanel>
		<StackPanel Orientation="Horizontal">
			<TextBlock Text="A border that has a ColorAnimation to keep rendering active: " />
			<Border x:Name="TargetBorder"
			    Width="10"
			    Height="10"
			    Background="{StaticResource ColorAnimation_Background_Brush}" />
		</StackPanel>
		<Grid x:Name="grid">
			<Grid.RenderTransform>
				<ScaleTransform x:Name="ScaleTransform" />
			</Grid.RenderTransform>
		</Grid>
	</StackPanel>
</Page>
