<Page
    x:Class="UITests.Windows_UI_Xaml.Performance.Performance_1000ButtonsContinuousRendering"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml.Performance"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d not_win">
    <Page.Resources>
        <SolidColorBrush x:Key="ColorAnimation_Background_Brush" Color="Blue" />
        <Storyboard x:Name="colorStoryboard">
            <ColorAnimation
                RepeatBehavior="Forever"
                Storyboard.TargetName="TargetBorder"
                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                To="Red"
                Duration="0:00:05" />
        </Storyboard>
    </Page.Resources>

    <StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="A border that has a ColorAnimation to keep rendering active: " />
            <Border
                x:Name="TargetBorder"
                Width="10"
                Height="10"
                Background="{StaticResource ColorAnimation_Background_Brush}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Number of Buttons: " />
            <NumberBox
                Minimum="1"
                ValueChanged="NumberBoxValueChanged"
                Value="100" />
        </StackPanel>
        <TextBlock x:Name="tb" Text="Number of visuals in WrapPanel: N/A" />
        <Viewbox Width="500" Height="300">
            <not_win:WrapPanel
                x:Name="wp"
                Width="500"
                Orientation="Horizontal" />
        </Viewbox>
    </StackPanel>
</Page>
