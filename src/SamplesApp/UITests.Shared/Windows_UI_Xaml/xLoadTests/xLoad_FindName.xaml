<UserControl x:Class="UITests.Windows_UI_Xaml.xLoadTests.xLoad_FindName"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml.xLoadTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<StackPanel>
		<TextBlock Text="Clicking on the Load button should make a Green box appear in the Red border" />
		<Button x:Name="LoadButton"
		    Content="Load" />
		<Border Width="60"
		    Height="60"
		    BorderBrush="Red"
		    BorderThickness="1">
			<Border x:Name="LoadBorder"
			    Width="50"
			    Height="50"
			    x:Load="False"
			    Background="Green" />
		</Border>
	</StackPanel>
</UserControl>
