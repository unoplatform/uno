<UserControl x:Class="UITests.Windows_UI_Xaml.XamlRoot.XamlRoot_Properties"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml.XamlRoot"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<StackPanel Padding="8"
		    Spacing="8">
			<TextBlock>
				<Run FontWeight="Bold"
				    Text="RasterizationScale:" />
				<Run x:Name="RasterizationScaleRun" />
			</TextBlock>
			<TextBlock>
				<Run FontWeight="Bold"
				    Text="IsHostVisible:" />
				<Run x:Name="IsHostVisibleRun" />
			</TextBlock>
			<TextBlock>
				<Run FontWeight="Bold"
				    Text="Size:" />
				<Run x:Name="SizeRun" />
			</TextBlock>
			<TextBlock Margin="0,16,0,0"
			    FontWeight="Bold"
			    Text="Change log:" />
			<Button Click="{x:Bind ClearClick}">Clear</Button>
		</StackPanel>
		<ListView Grid.Row="1"
		    ItemsSource="{x:Bind ChangeLog}" />
	</Grid>
</UserControl>
