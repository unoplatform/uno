<UserControl x:Class="UITests.Windows_UI_Xaml.DragAndDrop.DragDrop_TestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml.DragAndDrop"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_skia="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<Grid>
		<Grid.Resources>
			<DataTemplate x:Key="EventDataTemplate"
			    x:DataType="local:EventDetails">
				<Border Margin="1"
				    Background="{Binding EventBackground}"
				    BorderBrush="{ThemeResource TextBoxDisabledForegroundThemeBrush}"
				    BorderThickness="1"
				    CornerRadius="3">
					<Grid Grid.RowSpan="3"
					    Grid.Column="0"
					    Margin="5,0,5,0"
					    VerticalAlignment="Top"
					    ColumnSpacing="5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>
						<TextBlock Grid.Row="0"
						    Grid.ColumnSpan="2"
						    HorizontalAlignment="Left"
						    FontWeight="Bold"
						    Text="{Binding EventName}" />
						<TextBlock Grid.Row="0"
						    Grid.ColumnSpan="2"
						    HorizontalAlignment="Right"
						    FontSize="10"
						    Text="{Binding Timestamp}" />
						<!--  DragEventArgs.DataView.AvailableFormats  -->
						<TextBlock Grid.Row="1"
						    Grid.Column="0"
						    HorizontalAlignment="Right"
						    Text="Std. AvailableFormats: " />
						<TextBlock Grid.Row="1"
						    Grid.Column="1"
						    HorizontalAlignment="Left"
						    Text="{Binding AvailableStdFormats}" />
						<!--  DragEventArgs.DataView.RequestedOperation  -->
						<TextBlock Grid.Row="2"
						    Grid.Column="0"
						    HorizontalAlignment="Right"
						    Text="RequestedOperation: " />
						<TextBlock Grid.Row="2"
						    Grid.Column="1"
						    HorizontalAlignment="Left"
						    Text="{Binding RequestedOperation}" />
					</Grid>
				</Border>
			</DataTemplate>
		</Grid.Resources>

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<!--  Drag & Drop event details side pane (large displays only)  -->
		<Grid x:Name="LargeDragDropEventsGrid"
		    Grid.RowSpan="3"
		    Grid.Column="0"
		    BorderBrush="{ThemeResource TextBoxDisabledForegroundThemeBrush}"
		    BorderThickness="0,0,1,0">
			<Grid.RowDefinitions>
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
			<ListView Grid.Row="0"
			    Width="325"
			    ItemTemplate="{StaticResource EventDataTemplate}"
			    ItemsSource="{Binding DragDropEvents}"
			    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
			    ScrollViewer.VerticalScrollBarVisibility="Auto">
				<ListView.ItemContainerStyle>
					<Style BasedOn="{StaticResource ListViewItemRevealStyle}"
					    TargetType="ListViewItem">
						<Setter Property="HorizontalContentAlignment" Value="Stretch" />
					</Style>
				</ListView.ItemContainerStyle>
			</ListView>
			<CheckBox Grid.Row="1"
			    Margin="5"
			    Content="Show duplicate events"
			    IsChecked="{Binding ShowDuplicateEvents, Mode=TwoWay}" />
			<Button Grid.Row="1"
			    Margin="5"
			    HorizontalAlignment="Right"
			    Click="ClearDragDropEventsButton_Click"
			    Content="Clear" />
		</Grid>
		<!--  Drag source  -->
		<Grid Grid.Row="0"
		    Grid.Column="1"
		    MaxWidth="700"
		    Margin="5">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>
			<TextBlock Grid.Row="0"
			    HorizontalAlignment="Center"
			    FontSize="16"
			    FontWeight="SemiBold"
			    Text="Drag Source"
			    TextTrimming="CharacterEllipsis" />
			<Border Grid.Row="1"
			    MinHeight="30"
			    MaxHeight="200"
			    Padding="5"
			    HorizontalAlignment="Stretch"
			    VerticalAlignment="Stretch"
			    BorderBrush="{ThemeResource TextBoxDisabledForegroundThemeBrush}"
			    BorderThickness="1"
			    CornerRadius="10">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>
					<TextBlock Grid.Row="0"
					    Grid.Column="0"
					    HorizontalAlignment="Center"
					    FontWeight="Bold"
					    Text="Text" />
					<TextBlock x:Name="DragTextSourceTextBlock"
					    Grid.Row="1"
					    Grid.Column="0"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Center"
					    CanDrag="True"
					    DragStarting="DragSource_DragStarting"
					    DropCompleted="DragSource_DropCompleted"
					    Text="Plain text that can be dragged"
					    TextWrapping="Wrap" />
					<TextBlock Grid.Row="0"
					    Grid.Column="1"
					    HorizontalAlignment="Center"
					    FontWeight="Bold"
					    Text="Bitmap" />
					<Image x:Name="DragImageSourceImage"
					    Grid.Row="1"
					    Grid.Column="1"
					    Height="100"
					    CanDrag="True"
					    DragStarting="DragSource_DragStarting"
					    DropCompleted="DragSource_DropCompleted"
					    Source="https://upload.wikimedia.org/wikipedia/commons/thumb/d/da/Rain_over_Beinn_Eich%2C_Luss_Hills%2C_Scotland.jpg/2560px-Rain_over_Beinn_Eich%2C_Luss_Hills%2C_Scotland.jpg"
					    Stretch="Uniform" />
					<TextBlock Grid.Row="0"
					    Grid.Column="2"
					    HorizontalAlignment="Center"
					    FontWeight="Bold"
					    Text="WebLink" />
					<HyperlinkButton Grid.Row="1"
					    Grid.Column="2"
					    HorizontalAlignment="Center"
					    VerticalAlignment="Center">
						<TextBlock x:Name="DragWebLinkSourceTextBlock"
						    CanDrag="True"
						    DragStarting="DragSource_DragStarting"
						    DropCompleted="DragSource_DropCompleted"
						    Text="https://www.wikipedia.org/"
						    TextWrapping="Wrap" />
					</HyperlinkButton>
				</Grid>
			</Border>
		</Grid>
		<!--  Drop target  -->
		<Border x:Name="DropBorder"
		    Grid.Row="1"
		    Grid.Column="1"
		    MaxWidth="700"
		    MaxHeight="500"
		    Margin="5"
		    HorizontalAlignment="Stretch"
		    VerticalAlignment="Stretch"
		    AllowDrop="True"
		    Background="Transparent"
		    DragEnter="DropBorder_DragEnter"
		    DragLeave="DropBorder_DragLeave"
		    DragOver="DropBorder_DragOver"
		    Drop="DropBorder_Drop">
			<Grid IsHitTestVisible="False">
				<Rectangle HorizontalAlignment="Stretch"
				    VerticalAlignment="Stretch"
				    IsHitTestVisible="False"
				    RadiusX="10"
				    RadiusY="10"
				    Stroke="{ThemeResource TextBoxForegroundThemeBrush}"
				    StrokeDashArray="4"
				    StrokeDashCap="Round"
				    StrokeDashOffset="0"
				    StrokeThickness="2" />
				<StackPanel HorizontalAlignment="Center"
				    VerticalAlignment="Center"
				    IsHitTestVisible="False"
				    Orientation="Vertical">
					<FontIcon x:Name="FileFontIcon"
					    FontSize="40"
					    Foreground="{ThemeResource TextBoxDisabledForegroundThemeBrush}"
					    Glyph="&#xE7C3;"
					    IsHitTestVisible="False" />
					<TextBlock x:Name="FileDropTextBlock"
					    x:Uid="VisualImportControl_FileDropTextBlock"
					    FontSize="20"
					    Foreground="{ThemeResource TextBoxDisabledForegroundThemeBrush}"
					    IsHitTestVisible="False"
					    Text="Drop Here"
					    TextAlignment="Center" />
					<TextBlock x:Name="FileFormatsTextBlock"
					    Grid.Row="0"
					    Margin="0,10,0,0"
					    FontSize="12"
					    Foreground="{ThemeResource TextBoxDisabledForegroundThemeBrush}"
					    IsHitTestVisible="False"
					    Text="Plain Text, Images, HTML, RTF, Links &amp; Files"
					    TextAlignment="Center"
					    TextWrapping="Wrap" />
				</StackPanel>
			</Grid>
		</Border>
		<!--  Drop details  -->
		<Grid Grid.Row="2"
		    Grid.Column="1"
		    MaxWidth="700"
		    Margin="5">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>
			<TextBlock x:Name="DropTitleTextBlock"
			    Grid.Row="0"
			    Grid.Column="0"
			    HorizontalAlignment="Center"
			    FontSize="16"
			    FontWeight="SemiBold"
			    Text="Last Drop Details"
			    TextTrimming="CharacterEllipsis" />
			<TextBlock x:Name="DropPositionTextBlock"
			    Grid.Row="0"
			    Grid.Column="1"
			    HorizontalAlignment="Right"
			    VerticalAlignment="Center"
			    FontSize="9"
			    Text=""
			    TextTrimming="CharacterEllipsis" />
			<Border Grid.Row="1"
			    Grid.Column="0"
			    Grid.ColumnSpan="2"
			    MinHeight="30"
			    MaxWidth="700"
			    MaxHeight="200"
			    Padding="5"
			    HorizontalAlignment="Stretch"
			    VerticalAlignment="Stretch"
			    BorderBrush="{ThemeResource TextBoxDisabledForegroundThemeBrush}"
			    BorderThickness="1"
			    CornerRadius="10">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>
					<TextBlock x:Name="DropDetailsTextBlock"
					    Grid.Row="0"
					    Text="None"
					    TextWrapping="Wrap" />
					<Image x:Name="DropDetailsImage"
					    Grid.Row="1"
					    Height="150"
					    HorizontalAlignment="Stretch"
					    VerticalAlignment="Stretch"
					    Stretch="Uniform"
					    Visibility="Collapsed" />
				</Grid>
			</Border>
		</Grid>
		<!--  Drag & Drop event details side pane (small displays only)  -->
		<Grid x:Name="SmallDragDropEventsGrid"
		    Grid.Row="3"
		    Grid.Column="1"
		    Height="200"
		    BorderBrush="{ThemeResource TextBoxDisabledForegroundThemeBrush}"
		    BorderThickness="0,1,0,0"
		    Visibility="Collapsed">
			<Grid.RowDefinitions>
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
			<ListView Grid.Row="0"
			    Width="325"
			    ItemTemplate="{StaticResource EventDataTemplate}"
			    ItemsSource="{Binding DragDropEvents}"
			    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
			    ScrollViewer.VerticalScrollBarVisibility="Auto">
				<ListView.ItemContainerStyle>
					<Style BasedOn="{StaticResource ListViewItemRevealStyle}"
					    TargetType="ListViewItem">
						<Setter Property="HorizontalContentAlignment" Value="Stretch" />
					</Style>
				</ListView.ItemContainerStyle>
			</ListView>
			<CheckBox Grid.Row="1"
			    Margin="5"
			    Content="Show duplicate events"
			    IsChecked="{Binding ShowDuplicateEvents, Mode=TwoWay}" />
			<Button Grid.Row="1"
			    Margin="5"
			    HorizontalAlignment="Right"
			    Click="ClearDragDropEventsButton_Click"
			    Content="Clear" />
		</Grid>
		<not_skia:VisualStateManager.VisualStateGroups>
			<VisualStateGroup>
				<VisualState x:Name="SmallState">
					<VisualState.StateTriggers>
						<AdaptiveTrigger MinWindowWidth="0" />
					</VisualState.StateTriggers>
					<VisualState.Setters>
						<Setter Target="LargeDragDropEventsGrid.Visibility" Value="Collapsed" />
						<Setter Target="SmallDragDropEventsGrid.Visibility" Value="Visible" />
						<Setter Target="DragImageSourceImage.Height" Value="60" />
						<Setter Target="DropDetailsImage.Height" Value="60" />
						<Setter Target="FileFontIcon.Visibility" Value="Collapsed" />
						<Setter Target="FileFormatsTextBlock.Visibility" Value="Collapsed" />
					</VisualState.Setters>
				</VisualState>
				<VisualState x:Name="LargeState">
					<VisualState.StateTriggers>
						<AdaptiveTrigger MinWindowWidth="1000" />
					</VisualState.StateTriggers>
					<VisualState.Setters>
						<Setter Target="LargeDragDropEventsGrid.Visibility" Value="Visible" />
						<Setter Target="SmallDragDropEventsGrid.Visibility" Value="Collapsed" />
						<Setter Target="DragImageSourceImage.Height" Value="100" />
						<Setter Target="DropDetailsImage.Height" Value="150" />
						<Setter Target="FileFontIcon.Visibility" Value="Visible" />
						<Setter Target="FileFormatsTextBlock.Visibility" Value="Visible" />
					</VisualState.Setters>
				</VisualState>
			</VisualStateGroup>
		</not_skia:VisualStateManager.VisualStateGroups>
	</Grid>
</UserControl>
