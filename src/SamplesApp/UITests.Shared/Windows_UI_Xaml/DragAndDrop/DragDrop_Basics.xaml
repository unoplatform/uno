<UserControl
    x:Class="UITests.Windows_UI_Xaml.DragAndDrop.DragDrop_Basics"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml.DragAndDrop"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid x:Name="_theRoot">

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition Width="20" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="0" Text="Drag sources" />
        <Border
            Grid.Row="1"
            Grid.Column="0"
            Padding="15"
            Background="DeepPink">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <Border
                    x:Name="BasicDragSource"
                    Grid.Row="0"
                    Width="100"
                    Height="100"
                    Background="LightPink"
                    CanDrag="True" />
                <TextBlock
                    x:Name="TextDragSource"
                    Grid.Row="1"
                    CanDrag="True"
                    Text="Some text that can be dragged and dropped" />
                <HyperlinkButton
                    x:Name="LinkDragSource"
                    Grid.Row="2"
                    CanDrag="True"
                    Content="A link that can be dragged and dropped"
                    NavigateUri="https://platform.uno" />
                <Image
                    x:Name="ImageDragSource"
                    Grid.Row="3"
                    CanDrag="True"
                    Source="https://picsum.photos/300/300" />
            </Grid>
        </Border>

        <TextBlock Grid.Column="1" Text="Drop target" />
        <Border
            x:Name="DropTarget"
            Grid.Row="1"
            Grid.Column="1"
            AllowDrop="True"
            Background="DeepSkyBlue">
            <TextBlock
                x:Name="Output"
                Foreground="White"
                TextWrapping="Wrap" />
        </Border>

        <CheckBox
            x:Name="Automated"
            HorizontalAlignment="Right"
            Content="Automated"
            IsChecked="False" />
    </Grid>
</UserControl>
