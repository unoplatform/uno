<Page x:Class="SamplesApp.Windows_UI_Xaml.Clipping.UIElementClipping"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Page.Resources>
		<Storyboard x:Name="RotateStoryboard">
			<DoubleAnimation AutoReverse="False"
			    Duration="0:0:1.25"
			    From="5"
			    To="365"
			    Storyboard.TargetName="RotateTransform"
			    Storyboard.TargetProperty="Angle">
				<DoubleAnimation.EasingFunction>
					<BounceEase />
				</DoubleAnimation.EasingFunction>
			</DoubleAnimation>
		</Storyboard>
		<Storyboard x:Name="RotateClipStoryboard">
			<DoubleAnimation AutoReverse="False"
			    Duration="0:0:15"
			    From="5"
			    To="365"
			    Storyboard.TargetName="ClipRotateTransform"
			    Storyboard.TargetProperty="Angle" />
		</Storyboard>
	</Page.Resources>

	<Border>
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

			<StackPanel>
				<StackPanel Orientation="Horizontal">
					<Button Click="Open">OPEN Y</Button>
					<Button Click="Close">CLOSE Y</Button>
					<Button Click="Rotate">ROTATE</Button>
					<Button Click="RotateClip">ROTATE CLIP</Button>
				</StackPanel>
				<StackPanel Orientation="Horizontal">
					<Button Click="FixHeight">FIX HEIGHT (50)</Button>
					<Button Click="FixHeight300">FIX HEIGHT (300)</Button>
					<Button Click="ReleaseHeight">RELEASE HEIGHT</Button>
				</StackPanel>
				<StackPanel Orientation="Horizontal">
					<Button Click="FixWidth">FIX WIDTH (50)</Button>
					<Button Click="FixWidth300">FIX WIDTH (300)</Button>
					<Button Click="ReleaseWidth">RELEASE WIDTH</Button>
				</StackPanel>
			</StackPanel>

			<Border x:Name="ContainingBorder"
			    Grid.Row="1"
			    HorizontalAlignment="Center"
			    VerticalAlignment="Top"
			    BorderBrush="BlueViolet"
			    BorderThickness="5">
				<Border.Clip>
					<RectangleGeometry Rect="-50,-50,300,300">
						<RectangleGeometry.Transform>
							<RotateTransform x:Name="ClipRotateTransform" Angle="0" CenterX="150" CenterY="200" />
						</RectangleGeometry.Transform>
					</RectangleGeometry>
				</Border.Clip>
				<StackPanel x:Name="sp1Horz"
				    Orientation="Horizontal">
					<StackPanel.RenderTransform>
						<TranslateTransform X="15" Y="15" />
					</StackPanel.RenderTransform>
					<StackPanel x:Name="sp2Vert">
						<Border x:Name="rect"
						    Width="200"
						    Height="200"
						    Background="Red">
							<Border.RenderTransform>
								<RotateTransform x:Name="RotateTransform" Angle="5" />
							</Border.RenderTransform>
						</Border>
					</StackPanel>
				</StackPanel>
			</Border>

		</Grid>
		<VisualStateManager.VisualStateGroups>
			<VisualStateGroup x:Name="OpenStates">
				<VisualState x:Name="Closed" />
				<VisualState x:Name="Opened" />

				<VisualStateGroup.Transitions>
					<VisualTransition From="Opened"
					    To="Closed">
						<Storyboard>
							<DoubleAnimation Duration="00:00:00.6"
							    EnableDependentAnimation="True"
							    To="50"
							    Storyboard.TargetName="ContainingBorder"
							    Storyboard.TargetProperty="Height">
								<DoubleAnimation.EasingFunction>
									<CubicEase EasingMode="EaseOut" />
								</DoubleAnimation.EasingFunction>
							</DoubleAnimation>
						</Storyboard>
					</VisualTransition>
					<VisualTransition From="Closed"
					    To="Opened">
						<Storyboard>
							<DoubleAnimation Duration="00:00:00.6"
							    EnableDependentAnimation="True"
							    To="150"
							    Storyboard.TargetName="ContainingBorder"
							    Storyboard.TargetProperty="Height">
								<DoubleAnimation.EasingFunction>
									<CubicEase EasingMode="EaseOut" />
								</DoubleAnimation.EasingFunction>
							</DoubleAnimation>
						</Storyboard>
					</VisualTransition>
				</VisualStateGroup.Transitions>
			</VisualStateGroup>
		</VisualStateManager.VisualStateGroups>
	</Border>
</Page>
