<Page x:Class="UITests.Windows_UI_Xaml.Clipping.CornerRadiusControls"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    FontSize="10"
    mc:Ignorable="d">

	<StackPanel x:Name="TestRoot"
	    Margin="8"
	    Spacing="10">
		<TextBlock FontSize="18">CornerRadius test page</TextBlock>
		<Slider x:Name="cornerRadius"
		    Maximum="40"
		    Minimum="0"
		    Value="20" />
		<TextBlock FontSize="14">Controls honoring their CornerRadius properties: (default templates)</TextBlock>
		<Grid>
			<StackPanel Height="100"
			    Orientation="Horizontal"
			    Spacing="8">
				<Border x:Name="ctl1"
				    Width="80"
				    Background="Green"
				    CornerRadius="{x:Bind ToRadius(cornerRadius.Value), Mode=OneWay}">
					<TextBlock HorizontalAlignment="Center"
					    Foreground="Yellow">
						Border
					</TextBlock>
				</Border>
				<ContentPresenter x:Name="ctl2"
				    Width="80"
				    Background="Green"
				    CornerRadius="{x:Bind ToRadius(cornerRadius.Value), Mode=OneWay}">
					<TextBlock HorizontalAlignment="Center"
					    Foreground="Yellow">
						ContentPresenter
					</TextBlock>
				</ContentPresenter>
				<ToolTip x:Name="ctl3"
				    Width="80"
				    Background="Green"
				    CornerRadius="{x:Bind ToRadius(cornerRadius.Value), Mode=OneWay}">
					<TextBlock HorizontalAlignment="Center"
					    Foreground="Yellow">
						ToolTip<LineBreak />
						(Control)</TextBlock>
				</ToolTip>
				<Button x:Name="ctl4"
				    Width="80"
				    Height="100"
				    Background="Green"
				    BorderThickness="0"
				    CornerRadius="{x:Bind ToRadius(cornerRadius.Value), Mode=OneWay}">
					<TextBlock HorizontalAlignment="Center"
					    Foreground="Yellow">
						Button<LineBreak />
						(Control)</TextBlock>
				</Button>
				<ScrollViewer x:Name="ctl5"
				    Width="80"
				    Background="Green"
				    CornerRadius="{x:Bind ToRadius(cornerRadius.Value), Mode=OneWay}">
					<TextBlock HorizontalAlignment="Center"
					    Foreground="Yellow">
						ScrollViewer<LineBreak />
						(Control)</TextBlock>
				</ScrollViewer>
				<Grid x:Name="ctl6"
				    Width="80"
				    Background="Green"
				    CornerRadius="{x:Bind ToRadius(cornerRadius.Value), Mode=OneWay}">
					<TextBlock HorizontalAlignment="Center"
					    Foreground="Yellow">
						Grid
					</TextBlock>
				</Grid>
				<RelativePanel x:Name="ctl7"
				    Width="80"
				    Background="Green"
				    CornerRadius="{x:Bind ToRadius(cornerRadius.Value), Mode=OneWay}">
					<TextBlock HorizontalAlignment="Center"
					    Foreground="Yellow">
						RelativePanel
					</TextBlock>
				</RelativePanel>
				<StackPanel x:Name="ctl8"
				    Width="80"
				    Height="100"
				    Background="Green"
				    CornerRadius="{x:Bind ToRadius(cornerRadius.Value), Mode=OneWay}">
					<TextBlock HorizontalAlignment="Center"
					    Foreground="Yellow">
						StackPanel
					</TextBlock>
				</StackPanel>
			</StackPanel>
			<Rectangle Height="1"
			    VerticalAlignment="Top"
			    Fill="Blue">
				<Rectangle.RenderTransform>
					<TranslateTransform Y="{Binding Value, ElementName=cornerRadius}" />
				</Rectangle.RenderTransform>
			</Rectangle>
			<Rectangle Height="1"
			    VerticalAlignment="Bottom"
			    Fill="Blue">
				<Rectangle.RenderTransform>
					<TranslateTransform Y="{x:Bind Negate(cornerRadius.Value), Mode=OneWay}" />
				</Rectangle.RenderTransform>
			</Rectangle>
		</Grid>
		<TextBlock FontSize="14">Controls honoring their CornerRadius properties: (custom templates - not rounded corners)</TextBlock>
		<Grid>
			<StackPanel Height="100"
			    Orientation="Horizontal"
			    Spacing="8">
				<ToolTip x:Name="ctl1_rect"
				    Width="80"
				    Background="Green"
				    CornerRadius="{x:Bind ToRadius(cornerRadius.Value), Mode=OneWay}">
					<ToolTip.Template>
						<ControlTemplate TargetType="ToolTip">
							<ContentPresenter Background="{TemplateBinding Background}"
							    Content="{TemplateBinding Content}" />
						</ControlTemplate>
					</ToolTip.Template>
					<TextBlock HorizontalAlignment="Center"
					    Foreground="Yellow">
						ToolTip<LineBreak />
						(Control)</TextBlock>
				</ToolTip>
				<Button x:Name="ctl2_rect"
				    Width="80"
				    Height="100"
				    Background="Green"
				    CornerRadius="{x:Bind ToRadius(cornerRadius.Value), Mode=OneWay}">
					<Button.Template>
						<ControlTemplate TargetType="Button">
							<ContentPresenter Background="{TemplateBinding Background}"
							    Content="{TemplateBinding Content}" />
						</ControlTemplate>
					</Button.Template>
					<TextBlock HorizontalAlignment="Center"
					    Foreground="Yellow">
						Button<LineBreak />
						(Control)</TextBlock>
				</Button>
				<ScrollViewer x:Name="ctl3_rect"
				    Width="80"
				    Background="Green"
				    CornerRadius="{x:Bind ToRadius(cornerRadius.Value), Mode=OneWay}">
					<ScrollViewer.Template>
						<ControlTemplate TargetType="ScrollViewer">
							<ContentPresenter Background="{TemplateBinding Background}"
							    Content="{TemplateBinding Content}" />
						</ControlTemplate>
					</ScrollViewer.Template>
					<TextBlock HorizontalAlignment="Center"
					    Foreground="Yellow">
						ScrollViewer<LineBreak />
						(Control)</TextBlock>
				</ScrollViewer>
			</StackPanel>
			<Rectangle Height="1"
			    VerticalAlignment="Top"
			    Fill="Blue">
				<Rectangle.RenderTransform>
					<TranslateTransform Y="{Binding Value, ElementName=cornerRadius}" />
				</Rectangle.RenderTransform>
			</Rectangle>
			<Rectangle Height="1"
			    VerticalAlignment="Bottom"
			    Fill="Blue">
				<Rectangle.RenderTransform>
					<TranslateTransform Y="{x:Bind Negate(cornerRadius.Value), Mode=OneWay}" />
				</Rectangle.RenderTransform>
			</Rectangle>
		</Grid>
		<TextBlock FontSize="14">
			ContentControl should<Run FontWeight="ExtraBold">NOT</Run>
			apply its CornerRadius property:</TextBlock>
		<Grid>
			<StackPanel Height="100"
			    Orientation="Horizontal"
			    Spacing="8">
				<ContentControl Width="80"
				    HorizontalContentAlignment="Stretch"
				    VerticalContentAlignment="Stretch"
				    Background="Red"
				    CornerRadius="{x:Bind ToRadius(cornerRadius.Value), Mode=OneWay}">
					<Border Background="Green">
						<TextBlock HorizontalAlignment="Center"
						    Foreground="Yellow">
							ContentControl
						</TextBlock>
					</Border>
				</ContentControl>
			</StackPanel>
			<Rectangle Height="1"
			    VerticalAlignment="Top"
			    Fill="Blue">
				<Rectangle.RenderTransform>
					<TranslateTransform Y="{Binding Value, ElementName=cornerRadius}" />
				</Rectangle.RenderTransform>
			</Rectangle>
			<Rectangle Height="1"
			    VerticalAlignment="Bottom"
			    Fill="Blue">
				<Rectangle.RenderTransform>
					<TranslateTransform Y="{x:Bind Negate(cornerRadius.Value), Mode=OneWay}" />
				</Rectangle.RenderTransform>
			</Rectangle>
		</Grid>
	</StackPanel>
</Page>
