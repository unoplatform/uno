<Page x:Class="UITests.Shared.Windows_UI_Xaml.Clipping.ClippingWithOpacity"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_Xaml.Clipping"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<StackPanel Padding="5"
	    Spacing="5">
		<!--  Text should wrap  -->
		<TextBlock FontSize="20"
		    TextWrapping="Wrap">
			Those 2 rectangles should look the same (red one should be completed, never clipped)
		</TextBlock>

		<Border HorizontalAlignment="Center"
		    Background="Blue"
		    Opacity=".5">
			<Rectangle Width="100"
			    Height="100"
			    Fill="Red">
				<Rectangle.RenderTransform>
					<RotateTransform Angle="34" />
				</Rectangle.RenderTransform>
			</Rectangle>
		</Border>

		<Border x:Name="borderWithOpacity"
		    Padding="30"
		    Opacity=".5">
			<Border x:Name="borderWithoutOpacity"
			    HorizontalAlignment="Center"
			    Background="Blue">
				<Rectangle Width="100"
				    Height="100"
				    Fill="Red">
					<Rectangle.RenderTransform>
						<RotateTransform Angle="34" />
					</Rectangle.RenderTransform>
				</Rectangle>
			</Border>
		</Border>

	</StackPanel>
</Page>
