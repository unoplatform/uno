<Page x:Class="UITests.Microsoft_UI_Windowing.OverlappedPresenterTests"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Microsoft_UI_Windowing"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<ScrollViewer Padding="8">
		<StackPanel Spacing="4">
			<TextBlock FontWeight="Bold"
			    Text="Overlapped presenter types" />
			<Button Click="{x:Bind ViewModel.SetDefault}">Default</Button>
			<Button Click="{x:Bind ViewModel.SetDialog}">Dialog</Button>
			<Button Click="{x:Bind ViewModel.SetContextMenu}">Context menu</Button>
			<Button Click="{x:Bind ViewModel.SetToolWindow}">Tool window</Button>

			<TextBlock FontWeight="Bold"
			    Text="Operations" />
			<CheckBox Content="Should activate window"
			    IsChecked="{x:Bind ViewModel.ShouldActivateWindow, Mode=TwoWay}" />
			<Button Click="{x:Bind ViewModel.Minimize}">Minimize</Button>
			<Button Click="{x:Bind ViewModel.Maximize}">Maximize</Button>
			<Button Click="{x:Bind ViewModel.Restore}">Restore</Button>
			<Button Click="{x:Bind ViewModel.RestoreAfter2Seconds}">Restore After 2 Seconds</Button>

			<TextBlock FontWeight="Bold"
			    Text="Window size constraints" />
			<NumberBox x:Name="MinWidthNumberBox"
			    Header="MinWidth"
			    Value="{x:Bind ViewModel.MinWidth, Mode=TwoWay}" />
			<StackPanel Orientation="Horizontal"
			    Spacing="8">
				<Button Click="{x:Bind ViewModel.SetMinWidth}">Set MinWidth</Button>
				<Button Click="{x:Bind ViewModel.ResetMinWidth}">Reset MinWidth</Button>
			</StackPanel>

			<NumberBox x:Name="MinHeightNumberBox"
			    Header="MinHeight"
			    Value="{x:Bind ViewModel.MinHeight, Mode=TwoWay}" />
			<StackPanel Orientation="Horizontal"
			    Spacing="8">
				<Button Click="{x:Bind ViewModel.SetMinHeight}">Set MinHeight</Button>
				<Button Click="{x:Bind ViewModel.ResetMinHeight}">Reset MinHeight</Button>
			</StackPanel>

			<NumberBox x:Name="MaxWidthNumberBox"
			    Header="MaxWidth"
			    Value="{x:Bind ViewModel.MaxWidth, Mode=TwoWay}" />
			<StackPanel Orientation="Horizontal"
			    Spacing="8">
				<Button Click="{x:Bind ViewModel.SetMaxWidth}">Set MaxWidth</Button>
				<Button Click="{x:Bind ViewModel.ResetMaxWidth}">Reset MaxWidth</Button>
			</StackPanel>

			<NumberBox x:Name="MaxHeightNumberBox"
			    Header="MaxHeight"
			    Value="{x:Bind ViewModel.MaxHeight, Mode=TwoWay}" />
			<StackPanel Orientation="Horizontal"
			    Spacing="8">
				<Button Click="{x:Bind ViewModel.SetMaxHeight}">Set MaxHeight</Button>
				<Button Click="{x:Bind ViewModel.ResetMaxHeight}">Reset MaxHeight</Button>
			</StackPanel>

			<TextBlock FontWeight="Bold"
			    Text="Properties" />
			<CheckBox IsChecked="{x:Bind ViewModel.IsAlwaysOnTop, Mode=TwoWay}">Is always on top</CheckBox>
			<CheckBox IsChecked="{x:Bind ViewModel.IsMinimizable, Mode=TwoWay}">Is minimizable</CheckBox>
			<CheckBox IsChecked="{x:Bind ViewModel.IsMaximizable, Mode=TwoWay}">Is maximizable</CheckBox>
			<CheckBox IsChecked="{x:Bind ViewModel.IsResizable, Mode=TwoWay}">Is resizable</CheckBox>
			<CheckBox IsChecked="{x:Bind ViewModel.IsModal, Mode=TwoWay}">Is modal</CheckBox>
			<CheckBox IsChecked="{x:Bind ViewModel.HasBorder, Mode=TwoWay}">Has border</CheckBox>
			<CheckBox IsChecked="{x:Bind ViewModel.HasTitleBar, Mode=TwoWay}">Has title bar</CheckBox>
			<Button Click="{x:Bind ViewModel.SetBorderAndTitleBar}">Set border and title bar</Button>
		</StackPanel>
	</ScrollViewer>
</Page>
