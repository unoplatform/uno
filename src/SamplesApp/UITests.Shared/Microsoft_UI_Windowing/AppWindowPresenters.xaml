<Page x:Class="UITests.Microsoft_UI_Windowing.AppWindowPresenters"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Microsoft_UI_Windowing"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:DefaultBindMode="OneWay"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<StackPanel Spacing="4">
		<TextBlock>
			<Run FontWeight="Bold"
			    Text="Current presenter: " />
			<Run Text="{x:Bind ViewModel.CurrentPresenter}" />
		</TextBlock>
		<Button Click="{x:Bind ViewModel.FullScreen}"
		    Content="FullScreen" />
		<Button Click="{x:Bind ViewModel.CompactOverlay}"
		    Content="CompactOverlay" />
		<Button Click="{x:Bind ViewModel.Overlapped}"
		    Content="Overlapped" />
		<Button Click="{x:Bind ViewModel.Default}"
		    Content="Default" />
	</StackPanel>
</Page>
