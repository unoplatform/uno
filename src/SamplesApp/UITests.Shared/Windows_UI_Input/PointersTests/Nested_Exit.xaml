<Page x:Class="UITests.Windows_UI_Input.PointersTests.Nested_Exit"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Input.PointersTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition />
			<ColumnDefinition />
		</Grid.ColumnDefinitions>

		<Grid.RowDefinitions>
			<RowDefinition />
			<RowDefinition />
		</Grid.RowDefinitions>

		<TextBlock Text="With intermediate non hit-testable object" />

		<Border x:Name="Case1_Pink"
		    Width="128"
		    Height="128"
		    Background="DeepPink"
		    PointerExited="Case1_OnPointerExited">
			<Border Width="160"
			    Height="160"
			    Margin="-32"
			    Background="{x:Null}">
				<Border x:Name="Case1_Blue"
				    Width="128"
				    Height="128"
				    Background="DeepSkyBlue"
				    PointerExited="Case1_OnPointerExited"
				    Tapped="Case1_InitTest">
					<TextBlock Text="Click here to reset/init, then move out of the blue square."
					    TextWrapping="Wrap" />
				</Border>
			</Border>
		</Border>

		<TextBlock x:Name="Case1_out"
		    VerticalAlignment="Bottom"
		    Text="--none--" />
	</Grid>
</Page>
