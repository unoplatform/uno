<Page x:Class="UITests.Shared.Windows_UI_Input.PointersTests.EventsSequences"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_Input.PointersTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<StackPanel Grid.Column="0">
			<ComboBox x:Name="_pointerType" />

			<StackPanel Orientation="Horizontal">
				<Border x:Name="TestTapTarget"
				    Width="100"
				    Height="100"
				    Background="#FF0018">
					<TextBlock Text="UIElement.Tapped" />
				</Border>
				<StackPanel>
					<Button x:Name="TestTapReset"
					    Click="ResetTapTest"
					    Content="Reset" />
					<Button x:Name="TestTapValidate"
					    Click="ValidateTapTest"
					    Content="Validate" />
					<TextBlock x:Name="TestTapResult"
					    Text="** no result **" />
				</StackPanel>
			</StackPanel>

			<StackPanel Orientation="Horizontal">
				<Button x:Name="TestClickTarget"
				    Width="100"
				    Height="100"
				    Background="#FFA52C">
					<TextBlock Text="Button.Click" />
				</Button>
				<StackPanel>
					<Button x:Name="TestClickReset"
					    Click="ResetClickTest"
					    Content="Reset" />
					<Button x:Name="TestClickValidate"
					    Click="ValidateClickTest"
					    Content="Validate" />
					<TextBlock x:Name="TestClickResult"
					    Text="** no result **" />
				</StackPanel>
			</StackPanel>

			<StackPanel Orientation="Horizontal">
				<Border x:Name="TestTranslatedTapTarget"
				    Width="100"
				    Height="100"
				    Background="#FFFF41"
				    ManipulationMode="All">
					<TextBlock Text="UIElement.tr-Tapped" />
				</Border>
				<StackPanel>
					<Button x:Name="TestTranslatedTapReset"
					    Click="ResetTranslatedTapTest"
					    Content="Reset" />
					<Button x:Name="TestTranslatedTapValidate"
					    Click="ValidateTranslatedTapTest"
					    Content="Validate" />
					<TextBlock x:Name="TestTranslatedTapResult"
					    Text="** no result **" />
				</StackPanel>
			</StackPanel>

			<StackPanel Orientation="Horizontal">
				<Button x:Name="TestTranslatedClickTarget"
				    Width="100"
				    Height="100"
				    Background="#008018"
				    ManipulationMode="All">
					<TextBlock Text="Button.tr-Click" />
				</Button>
				<StackPanel>
					<Button x:Name="TestTranslatedClickReset"
					    Click="ResetTranslatedClickTest"
					    Content="Reset" />
					<Button x:Name="TestTranslatedClickValidate"
					    Click="ValidateTranslatedClickTest"
					    Content="Validate" />
					<TextBlock x:Name="TestTranslatedClickResult"
					    Text="** no result **" />
				</StackPanel>
			</StackPanel>

			<StackPanel Orientation="Horizontal">
				<Border Width="100"
				    Height="100"
				    Background="#0000F9">
					<TextBlock x:Name="TestHyperlinkTarget"
					    TextWrapping="Wrap">
						<Hyperlink x:Name="TestHyperlinkInner">
							<Run Text="Hyperlink.Click" />
						</Hyperlink><Run Text=" event" />
						.</TextBlock>
				</Border>
				<StackPanel>
					<Button x:Name="TestHyperlinkReset"
					    Click="ResetHyperlinkTest"
					    Content="Reset" />
					<Button x:Name="TestHyperlinkValidate"
					    Click="ValidateHyperlinkTest"
					    Content="Validate" />
					<TextBlock x:Name="TestHyperlinkResult"
					    Text="** no result **" />
				</StackPanel>
			</StackPanel>

			<StackPanel Orientation="Horizontal">
				<Border Width="100"
				    Height="100"
				    Background="#86007D">
					<ListView x:Name="TestListViewTarget"
					    IsItemClickEnabled="True" />
				</Border>
				<StackPanel>
					<Button x:Name="TestListViewReset"
					    Click="ResetListViewTest"
					    Content="Reset" />
					<Button x:Name="TestListViewValidate"
					    Click="ValidateListViewTest"
					    Content="Validate" />
					<TextBlock x:Name="TestListViewResult"
					    Text="** no result **" />
				</StackPanel>
			</StackPanel>
		</StackPanel>

		<TextBlock x:Name="Output"
		    Grid.Column="1"
		    FontSize="8"
		    TextWrapping="Wrap" />
	</Grid>
</Page>
