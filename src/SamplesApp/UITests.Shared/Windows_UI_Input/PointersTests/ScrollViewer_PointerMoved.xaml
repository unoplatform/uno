<UserControl x:Class="UITests.Windows_UI_Input.PointersTests.ScrollViewer_PointerMoved"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Input.PointersTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<StackPanel>
		<Grid x:Name="HostGrid"
		    Width="300"
		    Height="400"
		    Background="Blue"
		    PointerCanceled="HostGrid_PointerCanceled"
		    PointerExited="HostGrid_PointerExited"
		    PointerMoved="HostGrid_PointerMoved"
		    PointerPressed="HostGrid_PointerPressed"
		    PointerReleased="HostGrid_PointerReleased">
			<ScrollViewer Width="100"
			    Margin="0,0,100,0"
			    HorizontalAlignment="Right"
			    Background="Beige">
				<Ellipse Width="80"
				    Height="800"
				    Fill="DarkGray" />
			</ScrollViewer>
			<ScrollViewer Width="100"
			    HorizontalAlignment="Right"
			    Background="DarkGray"
			    HorizontalScrollBarVisibility="Disabled"
			    HorizontalScrollMode="Disabled"
			    VerticalScrollBarVisibility="Disabled"
			    VerticalScrollMode="Disabled">
				<Ellipse Width="10"
				    Height="60"
				    Fill="Beige" />
			</ScrollViewer>
		</Grid>
		<Button Name="ResetColorButton"
		    Click="ResetColorButton_Click"
		    Content="Reset color" />
		<TextBlock x:Name="StatusTextBlock"
		    Text="Not dragged" />
	</StackPanel>
</UserControl>
