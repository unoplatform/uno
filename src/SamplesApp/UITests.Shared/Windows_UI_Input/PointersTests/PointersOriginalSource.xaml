<Page x:Class="UITests.Windows_UI_Input.PointersTests.PointersOriginalSource"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Input.PointersTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<Grid.ColumnDefinitions>
			<ColumnDefinition />
			<ColumnDefinition />
		</Grid.ColumnDefinitions>

		<TextBlock Grid.Column="0"
		    Text="Gestures" />
		<Border Grid.Row="1"
		    Grid.Column="0"
		    Width="300"
		    Height="300"
		    Background="DeepSkyBlue">
			<Border x:Name="GesturesTarget"
			    Width="200"
			    Height="200"
			    Background="DeepPink" />
		</Border>

		<TextBlock Grid.Column="1"
		    Text="Manipulations" />
		<Border Grid.Row="1"
		    Grid.Column="1"
		    Width="300"
		    Height="300"
		    Background="DeepSkyBlue">
			<Border x:Name="ManipulationTarget"
			    Width="200"
			    Height="200"
			    Background="DeepPink"
			    ManipulationMode="All" />
		</Border>

		<TextBlock x:Name="_output"
		    Grid.Row="2"
		    Grid.ColumnSpan="2"
		    Text="** not run**" />
	</Grid>
</Page>
