<Page x:Class="UITests.Shared.Windows_UI_Input.GestureRecognizer.PointersEvents"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://platform.uno"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    mc:Ignorable="not_win">

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition x:Name="_configColumn" />
			<ColumnDefinition x:Name="_benchColumn" />
			<ColumnDefinition x:Name="_outputColumn" />
		</Grid.ColumnDefinitions>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition />
		</Grid.RowDefinitions>

		<StackPanel x:Name="_tabs"
		    Grid.ColumnSpan="3"
		    Orientation="Horizontal">
			<RadioButton x:Name="_splitButton"
			    Content="Splitted"
			    GroupName="TabView"
			    IsChecked="True" />
			<RadioButton x:Name="_configButton"
			    Content="Config"
			    GroupName="TabView" />
			<RadioButton x:Name="_benchButton"
			    Content="Bench"
			    GroupName="TabView" />
			<RadioButton x:Name="_outputButton"
			    Content="Output"
			    GroupName="TabView" />

			<Button Grid.RowSpan="2"
			    Grid.ColumnSpan="3"
			    HorizontalAlignment="Right"
			    VerticalAlignment="Top"
			    Click="ClearLog"
			    Content="Clear" />
		</StackPanel>

		<ScrollViewer Grid.Row="1"
		    Grid.Column="0">
			<StackPanel Padding="10,0">
				<TextBlock Text="This is a test bench to check the expected properties of pointer events args. Configure below the pointer you are going to use, then test it in the pink zone on right."
				    TextWrapping="Wrap" />

				<ComboBox x:Name="_pointerType"
				    Header="Pointer type:"
				    SelectionChanged="OnPointerTypeChanged" />

				<TextBox x:Name="_pointerId"
				    Width="75"
				    HorizontalAlignment="Left"
				    Header="Pointer ID:" />

				<TextBlock Text="Expected buttons:" />
				<CheckBox x:Name="_leftButton"
				    Content="Left"
				    IsChecked="True"
				    IsThreeState="True" />
				<CheckBox x:Name="_middleButton"
				    Content="Middle"
				    IsChecked="False"
				    IsThreeState="True" />
				<CheckBox x:Name="_rightButton"
				    Content="Right"
				    IsChecked="False"
				    IsThreeState="True" />
				<CheckBox x:Name="_barrelButton"
				    Content="Pen's barrel"
				    IsChecked="False"
				    IsThreeState="True" />
				<CheckBox x:Name="_eraserButton"
				    Content="Pen's eraser"
				    IsChecked="False"
				    IsThreeState="True" />
				<CheckBox x:Name="_x1Button"
				    Content="X Button 1"
				    IsChecked="False"
				    IsThreeState="True" />
				<CheckBox x:Name="_x2Button"
				    Content="X Button 2"
				    IsChecked="False"
				    IsThreeState="True" />

				<TextBlock Text="Expected properties:" />
				<CheckBox x:Name="_inRange"
				    Content="In range"
				    IsChecked="True"
				    IsThreeState="True" />
				<CheckBox x:Name="_inContact"
				    Content="In contact"
				    IsChecked="{x:Null}"
				    IsThreeState="True" />

				<TextBlock Text="Bench config:" />
				<ToggleSwitch x:Name="_handledEventsToo"
				    Header="Handled events too"
				    OffContent="Unhandled events only"
				    OnContent="Handlers added w/ handledEventsToo"
				    Toggled="OnConfigChanged" />
				<ToggleSwitch x:Name="_allEventsOnParent"
				    Header="All events for parent"
				    IsOn="False"
				    OffContent="Parent subscribe as config"
				    OnContent="Parent subscribe to all events"
				    Toggled="OnConfigChanged" />
				<ToggleSwitch x:Name="_horizontalScroll"
				    Header="Horizontal scroll"
				    IsOn="True"
				    OffContent="Horizontal scroll disabled"
				    OnContent="Horizontal scroll enabled"
				    Toggled="OnConfigChanged" />
				<ToggleSwitch x:Name="_verticalScroll"
				    Header="Vertical scroll"
				    IsOn="True"
				    OffContent="Vertical scroll disabled"
				    OnContent="Vertical scroll enabled"
				    Toggled="OnConfigChanged" />

				<ToggleSwitch x:Name="_ptEntered"
				    Header="Pointer entered"
				    IsOn="True"
				    OffContent="Pointer entered muted"
				    OnContent="Subscribed to pointer entered"
				    Toggled="OnConfigChanged" />
				<CheckBox x:Name="_ptEnteredHandle"
				    Margin="20,0"
				    Content="Handle event"
				    Visibility="{Binding ElementName=_ptEntered, Path=IsOn}" />
				<ToggleSwitch x:Name="_ptPressed"
				    Header="Pointer pressed"
				    IsOn="True"
				    OffContent="Pointer pressed muted"
				    OnContent="Subscribed to pointer pressed"
				    Toggled="OnConfigChanged" />
				<CheckBox x:Name="_ptPressedHandle"
				    Margin="20,0"
				    Content="Handle event"
				    Visibility="{Binding ElementName=_ptPressed, Path=IsOn}" />
				<CheckBox x:Name="_ptPressedCapture"
				    Margin="20,0"
				    Content="Capture pointer"
				    Visibility="{Binding ElementName=_ptPressed, Path=IsOn}" />
				<ToggleSwitch x:Name="_ptMoved"
				    Header="Pointer moved"
				    IsOn="True"
				    OffContent="Pointer moved muted"
				    OnContent="Subscribed to pointer moved"
				    Toggled="OnConfigChanged" />
				<CheckBox x:Name="_ptMovedHandle"
				    Margin="20,0"
				    Content="Handle event"
				    Visibility="{Binding ElementName=_ptMoved, Path=IsOn}" />
				<ToggleSwitch x:Name="_ptReleased"
				    Header="Pointer released"
				    IsOn="True"
				    OffContent="Pointer released muted"
				    OnContent="Subscribed to pointer released"
				    Toggled="OnConfigChanged" />
				<CheckBox x:Name="_ptReleasedHandle"
				    Margin="20,0"
				    Content="Handle event"
				    Visibility="{Binding ElementName=_ptReleased, Path=IsOn}" />
				<ToggleSwitch x:Name="_ptExited"
				    Header="Pointer exited"
				    IsOn="True"
				    OffContent="Pointer exited muted"
				    OnContent="Subscribed to pointer exited"
				    Toggled="OnConfigChanged" />
				<CheckBox x:Name="_ptExitedHandle"
				    Margin="20,0"
				    Content="Handle event"
				    Visibility="{Binding ElementName=_ptExited, Path=IsOn}" />
				<ToggleSwitch x:Name="_ptCanceled"
				    Header="Pointer canceled"
				    IsOn="True"
				    OffContent="Pointer canceled muted"
				    OnContent="Subscribed to pointer canceled"
				    Toggled="OnConfigChanged" />
				<CheckBox x:Name="_ptCanceledHandle"
				    Margin="20,0"
				    Content="Handle event"
				    Visibility="{Binding ElementName=_ptCanceled, Path=IsOn}" />
				<ToggleSwitch x:Name="_ptCaptureLost"
				    Header="Pointer capture lost"
				    IsOn="True"
				    OffContent="Pointer capture lost muted"
				    OnContent="Subscribed to pointer capture lost"
				    Toggled="OnConfigChanged" />
				<CheckBox x:Name="_ptCaptureLostHandle"
				    Margin="20,0"
				    Content="Handle event"
				    Visibility="{Binding ElementName=_ptCaptureLost, Path=IsOn}" />
				<ToggleSwitch x:Name="_ptWheel"
				    Header="Pointer wheel changed"
				    IsOn="True"
				    OffContent="Pointer wheel muted"
				    OnContent="Subscribed to pointer wheel"
				    Toggled="OnConfigChanged" />
				<CheckBox x:Name="_ptWheelHandle"
				    Margin="20,0"
				    Content="Handle event"
				    Visibility="{Binding ElementName=_ptWheel, Path=IsOn}" />

				<ComboBox x:Name="_manipMode"
				    Header="Manipulation mode: "
				    SelectionChanged="OnManipModeChanged" />
				<ToggleSwitch x:Name="_manipStarting"
				    Header="Manipulation starting"
				    OffContent="Manip starting muted"
				    OnContent="Subscribed to manip starting"
				    Toggled="OnConfigChanged" />
				<CheckBox x:Name="_manipStartingHandle"
				    Margin="20,0"
				    Content="Handle event"
				    Visibility="{Binding ElementName=_manipStarting, Path=IsOn}" />
				<ToggleSwitch x:Name="_manipStarted"
				    Header="Manipulation started"
				    OffContent="Manip started muted"
				    OnContent="Subscribed to manip started"
				    Toggled="OnConfigChanged" />
				<CheckBox x:Name="_manipStartedHandle"
				    Margin="20,0"
				    Content="Handle event"
				    Visibility="{Binding ElementName=_manipStarted, Path=IsOn}" />
				<ToggleSwitch x:Name="_manipDelta"
				    Header="Manipulation delta"
				    OffContent="Manip delta muted"
				    OnContent="Subscribed to manip delta"
				    Toggled="OnConfigChanged" />
				<CheckBox x:Name="_manipDeltaHandle"
				    Margin="20,0"
				    Content="Handle event"
				    Visibility="{Binding ElementName=_manipDelta, Path=IsOn}" />
				<ToggleSwitch x:Name="_manipInertia"
				    Header="Manipulation inertia"
				    OffContent="Manip delta muted"
				    OnContent="Subscribed to manip inertia started"
				    Toggled="OnConfigChanged" />
				<CheckBox x:Name="_manipInertiaHandle"
				    Margin="20,0"
				    Content="Handle event"
				    Visibility="{Binding ElementName=_manipDelta, Path=IsOn}" />
				<ToggleSwitch x:Name="_manipCompleted"
				    Header="Manipulation completed"
				    OffContent="Manip completed muted"
				    OnContent="Subscribed to manip completed"
				    Toggled="OnConfigChanged" />
				<CheckBox x:Name="_manipCompletedHandle"
				    Margin="20,0"
				    Content="Handle event"
				    Visibility="{Binding ElementName=_manipCompleted, Path=IsOn}" />

				<ToggleSwitch x:Name="_gestureTapped"
				    Header="Tapped"
				    IsOn="False"
				    OffContent="Tap disabled"
				    OnContent="Subscribed to tap"
				    Toggled="OnConfigChanged" />
				<CheckBox x:Name="_gestureTappedHandle"
				    Margin="20,0"
				    Content="Handle event"
				    Visibility="{Binding ElementName=_gestureTapped, Path=IsOn}" />
				<ToggleSwitch x:Name="_gestureDoubleTapped"
				    Header="Double tapped"
				    IsOn="False"
				    OffContent="Double tap disabled"
				    OnContent="Subscribed to double tap"
				    Toggled="OnConfigChanged" />
				<CheckBox x:Name="_gestureDoubleTappedHandle"
				    Margin="20,0"
				    Content="Handle event"
				    Visibility="{Binding ElementName=_gestureDoubleTapped, Path=IsOn}" />
				<ToggleSwitch x:Name="_gestureRightTapped"
				    Header="Right tapped"
				    IsOn="False"
				    OffContent="Right tap disabled"
				    OnContent="Subscribed to right tap"
				    Toggled="OnConfigChanged" />
				<CheckBox x:Name="_gestureRightTappedHandle"
				    Margin="20,0"
				    Content="Handle event"
				    Visibility="{Binding ElementName=_gestureRightTapped, Path=IsOn}" />


				<Slider x:Name="_translateX"
				    Header="Translate X"
				    Maximum="300"
				    Minimum="-300"
				    Value="0" />
				<Slider x:Name="_translateY"
				    Header="Translate Y"
				    Maximum="300"
				    Minimum="-300"
				    Value="0" />
				<Slider x:Name="_rotate"
				    Header="Rotation"
				    Maximum="360"
				    Minimum="-360"
				    Value="0" />
				<Slider x:Name="_scaleX"
				    Header="Scale X"
				    Maximum="10"
				    Minimum=".01"
				    StepFrequency=".01"
				    Value="1" />
				<Slider x:Name="_scaleY"
				    Header="Scale Y"
				    Maximum="10"
				    Minimum=".01"
				    StepFrequency=".01"
				    Value="1" />
				<Slider x:Name="_skewX"
				    Header="Skew X"
				    Maximum="360"
				    Minimum="-360"
				    Value="0" />
				<Slider x:Name="_skewY"
				    Header="Skew Y"
				    Maximum="360"
				    Minimum="-360"
				    Value="0" />

			</StackPanel>
		</ScrollViewer>

		<ScrollViewer x:Name="_myScrollViewer"
		    Grid.Row="1"
		    Grid.Column="1">
			<Grid x:Name="TouchTargetParent"
			    MinWidth="2048"
			    MinHeight="2048"
			    Background="DeepSkyBlue">
				<Border x:Name="TouchTarget"
				    Width="200"
				    Height="200"
				    Margin="50,50,0,0"
				    HorizontalAlignment="Left"
				    VerticalAlignment="Top"
				    Background="DeepPink">
					<Border.RenderTransform>
						<CompositeTransform Rotation="{Binding ElementName=_rotate, Path=Value}"
						    ScaleX="{Binding ElementName=_scaleX, Path=Value}"
						    ScaleY="{Binding ElementName=_scaleY, Path=Value}"
						    SkewX="{Binding ElementName=_skewX, Path=Value}"
						    SkewY="{Binding ElementName=_skewY, Path=Value}"
						    TranslateX="{Binding ElementName=_translateX, Path=Value}"
						    TranslateY="{Binding ElementName=_translateY, Path=Value}" />
					</Border.RenderTransform>
				</Border>
			</Grid>
		</ScrollViewer>

		<ListView x:Name="_logs"
		    Grid.Row="1"
		    Grid.Column="2">
			<ItemsControl.ItemTemplate>
				<DataTemplate>
					<StackPanel>
						<TextBlock>
							<Run Foreground="{Binding Sender.Background}"
							    Text="{Binding Sender.Name}" />
							<Run Text="{Binding Name}" />
							<Run Text="{Binding ValidityBullet}" />
						</TextBlock>
						<TextBlock FontSize="8"
						    Text="{Binding Details}"
						    TextWrapping="Wrap" />
					</StackPanel>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ListView>
		<VisualStateManager.VisualStateGroups>
			<VisualStateGroup>
				<VisualState>
					<VisualState.StateTriggers>
						<!--<AdaptiveTrigger MinWindowWidth="700" />-->
						<StateTrigger IsActive="{Binding ElementName=_splitButton, Path=IsChecked}" />
					</VisualState.StateTriggers>
					<VisualState.Setters>
						<!--<Setter Target="_tabs.Visibility" Value="Collapsed" />-->
						<Setter Target="_configColumn.Width" Value="300" />
						<Setter Target="_benchColumn.Width" Value="*" />
						<Setter Target="_outputColumn.Width" Value="2*" />
					</VisualState.Setters>
				</VisualState>
				<win:VisualState x:Name="Config">
					<VisualState.StateTriggers>
						<StateTrigger IsActive="{Binding ElementName=_configButton, Path=IsChecked}" />
					</VisualState.StateTriggers>
					<VisualState.Setters>
						<Setter Target="_tabs.Visibility" Value="Visible" />
						<Setter Target="_configColumn.Width" Value="*" />
						<Setter Target="_benchColumn.Width" Value="0" />
						<Setter Target="_outputColumn.Width" Value="0" />
					</VisualState.Setters>
				</win:VisualState>
				<win:VisualState x:Name="Bench">
					<VisualState.StateTriggers>
						<StateTrigger IsActive="{Binding ElementName=_benchButton, Path=IsChecked}" />
					</VisualState.StateTriggers>
					<VisualState.Setters>
						<Setter Target="_tabs.Visibility" Value="Visible" />
						<Setter Target="_configColumn.Width" Value="0" />
						<Setter Target="_benchColumn.Width" Value="*" />
						<Setter Target="_outputColumn.Width" Value="0" />
					</VisualState.Setters>
				</win:VisualState>
				<win:VisualState x:Name="Output">
					<VisualState.StateTriggers>
						<StateTrigger IsActive="{Binding ElementName=_outputButton, Path=IsChecked}" />
					</VisualState.StateTriggers>
					<VisualState.Setters>
						<Setter Target="_tabs.Visibility" Value="Visible" />
						<Setter Target="_configColumn.Width" Value="0" />
						<Setter Target="_benchColumn.Width" Value="0" />
						<Setter Target="_outputColumn.Width" Value="*" />
					</VisualState.Setters>
				</win:VisualState>
			</VisualStateGroup>
		</VisualStateManager.VisualStateGroups>
	</Grid>
</Page>
