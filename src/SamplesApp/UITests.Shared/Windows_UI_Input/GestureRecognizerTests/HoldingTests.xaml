<Page x:Class="UITests.Shared.Windows_UI_Input.GestureRecognizerTests.HoldingTests"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_Input.GestureRecognizerTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition />
			<RowDefinition Height="Auto" />
			<RowDefinition />
			<RowDefinition Height="Auto" />
			<RowDefinition />
		</Grid.RowDefinitions>

		<Grid.ColumnDefinitions>
			<ColumnDefinition />
			<ColumnDefinition />
		</Grid.ColumnDefinitions>

		<TextBlock Grid.Row="0"
		    Grid.ColumnSpan="2"
		    Text="Long press (touch), right click (mouse), use barrel button (pen) on each zones. Last right tapped:"
		    TextWrapping="Wrap" />
		<TextBlock x:Name="LastHeld"
		    Grid.Row="1"
		    Grid.ColumnSpan="2"
		    Text="__none__" />

		<TextBlock Grid.Row="2"
		    Grid.Column="0"
		    HorizontalAlignment="Center"
		    Text="Basic" />
		<Border x:Name="Basic_Target"
		    Grid.Row="3"
		    Grid.Column="0"
		    Width="150"
		    Height="150"
		    Background="#FF0018"
		    Holding="TargetHeld" />

		<TextBlock Grid.Row="2"
		    Grid.Column="1"
		    HorizontalAlignment="Center"
		    Text="With transformation" />
		<Border x:Name="Transformed_Parent"
		    Grid.Row="3"
		    Grid.Column="1"
		    Width="150"
		    Height="150"
		    Background="#FFA52C">
			<Border x:Name="Transformed_Target"
			    Width="50"
			    Height="50"
			    HorizontalAlignment="Left"
			    VerticalAlignment="Top"
			    Background="#33000000"
			    Holding="TargetHeld">
				<Border.RenderTransform>
					<CompositeTransform Rotation="45"
					    TranslateX="100"
					    TranslateY="100" />
				</Border.RenderTransform>
			</Border>
		</Border>

		<TextBlock Grid.Row="4"
		    Grid.Column="0"
		    HorizontalAlignment="Center"
		    Text="In ScrollViewer" />
		<Border Grid.Row="5"
		    Grid.Column="0"
		    Width="150"
		    Height="150"
		    Background="#FFFF41">
			<ScrollViewer x:Name="InScroll_ScrollViewer"
			    HorizontalScrollBarVisibility="Visible"
			    HorizontalScrollMode="Enabled"
			    VerticalScrollBarVisibility="Visible"
			    VerticalScrollMode="Enabled">
				<Grid Width="300"
				    Height="300">
					<Border x:Name="InScroll_Target"
					    Width="100"
					    Height="100"
					    HorizontalAlignment="Right"
					    VerticalAlignment="Bottom"
					    Background="#33000000"
					    Holding="TargetHeld" />
				</Grid>
			</ScrollViewer>
		</Border>

		<TextBlock Grid.Row="4"
		    Grid.Column="1"
		    HorizontalAlignment="Center"
		    Text="In button" />
		<Button Grid.Row="5"
		    Grid.Column="1"
		    Width="150"
		    Height="150"
		    HorizontalAlignment="Center"
		    VerticalAlignment="Center"
		    Background="#008018">
			<Border x:Name="InButton_Target"
			    Width="100"
			    Height="100"
			    HorizontalAlignment="Center"
			    VerticalAlignment="Center"
			    Background="#33000000"
			    Holding="TargetHeld" />
		</Button>

		<TextBlock Grid.Row="6"
		    Grid.Column="0"
		    HorizontalAlignment="Center"
		    Text="ListView" />
		<Border Grid.Row="7"
		    Grid.Column="0"
		    Width="150"
		    Height="150"
		    Background="#0000F9">
			<ListView x:Name="ListViewWithItemClick"
			    IsItemClickEnabled="True"
			    ItemsSource="0123456789abcdef"
			    SelectionMode="Single">
				<ListView.ItemTemplate>
					<DataTemplate>
						<Border Width="125"
						    Height="50"
						    Margin="3"
						    Background="#11000000"
						    BorderBrush="#33000000"
						    BorderThickness="3"
						    Holding="ItemHeld">
							<TextBlock HorizontalAlignment="Center"
							    VerticalAlignment="Center"
							    Text="{Binding}" />
						</Border>
					</DataTemplate>
				</ListView.ItemTemplate>
			</ListView>
		</Border>


		<TextBlock Grid.Row="6"
		    Grid.Column="1"
		    HorizontalAlignment="Center"
		    Text="ListView item click disabled" />
		<Border Grid.Row="7"
		    Grid.Column="1"
		    Width="150"
		    Height="150"
		    Background="#86007D">
			<ListView x:Name="ListViewWithoutItemClick"
			    IsItemClickEnabled="False"
			    ItemsSource="0123456789abcdef"
			    SelectionMode="None">
				<ListView.ItemTemplate>
					<DataTemplate>
						<Border Width="125"
						    Height="50"
						    Margin="3"
						    Background="#11000000"
						    BorderBrush="#33000000"
						    BorderThickness="3"
						    Holding="ItemHeld">
							<TextBlock HorizontalAlignment="Center"
							    VerticalAlignment="Center"
							    Text="{Binding}" />
						</Border>
					</DataTemplate>
				</ListView.ItemTemplate>
			</ListView>
		</Border>
	</Grid>
</Page>
