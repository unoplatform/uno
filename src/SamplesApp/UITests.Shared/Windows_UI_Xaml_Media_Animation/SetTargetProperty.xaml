<Page
    x:Class="UITests.Shared.Windows_UI_Xaml_Media_Animation.SetTargetProperty"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Media_Animation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="AnimationState" />
            <Button
                x:Name="playButton"
                Click="{x:Bind PlayAnimation}"
                Content="Play/Replay" />
            <ToggleSwitch
                x:Name="IsDirectionHorizontalToggle"
                Header="Direction"
                OffContent="Horizontal"
                OnContent="Vertical"
                Toggled="{x:Bind OnDirectionOrRectChanged}" />
            <ToggleSwitch
                x:Name="AnimatedRectSwitch"
                Header="AnimatedRect"
                OffContent="Pink"
                OnContent="Yellow"
                Toggled="{x:Bind OnDirectionOrRectChanged}" />
        </StackPanel>

        <Border
            x:Name="Container"
            Grid.Row="1"
            Margin="16"
            Background="Pink"
            BorderBrush="Black"
            BorderThickness="1">
            <Rectangle
                x:Name="AnimatedRect"
                Width="50"
                Height="50"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Fill="SkyBlue" />
        </Border>

        <Border
            x:Name="Container2"
            Grid.Row="2"
            Margin="16"
            Background="Yellow"
            BorderBrush="Black"
            BorderThickness="1">
            <Rectangle
                x:Name="AnimatedRect2"
                Width="50"
                Height="50"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Fill="SkyBlue" />
        </Border>

    </Grid>
</Page>
