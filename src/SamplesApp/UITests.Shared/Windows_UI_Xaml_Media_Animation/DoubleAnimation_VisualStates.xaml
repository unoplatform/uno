<UserControl x:Class="Uno.UI.Samples.Content.UITests.Animations.DoubleAnimation_VisualStates"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d not_win">

	<Grid>
		<StackPanel HorizontalAlignment="Left"
		    VerticalAlignment="Top">
			<Button Content="State One"
			    Tapped="LaunchAnimation1" />
			<Button Content="State Two"
			    Tapped="LaunchAnimation2" />
			<Button Content="Set .5"
			    Tapped="SetOpacity" />
		</StackPanel>

		<!--<Border
			Background="Red"
			Width="100"
			Height="100"
			HorizontalAlignment="Center"
			VerticalAlignment="Center">
			<Border.RenderTransform>
				<TranslateTransform x:Name="_transform" Y="0" />
			</Border.RenderTransform>
		</Border>
		<Border
			Background="Black"
			Width="100"
			Height="1"
			HorizontalAlignment="Center"
			VerticalAlignment="Center" />-->

		<ContentControl x:Name="_myControl"
		    Width="300"
		    Height="300"
		    HorizontalAlignment="Center"
		    VerticalAlignment="Center">
			<ContentControl.Template>
				<ControlTemplate TargetType="ContentControl">
					<Grid Background="DeepPink">
						<ContentPresenter />

						<Border x:Name="StateTwoContent"
						    HorizontalAlignment="Center"
						    VerticalAlignment="Center"
						    Background="Orange"
						    Opacity="0">
							<TextBlock Text="Pressed" />
						</Border>

						<StackPanel HorizontalAlignment="Right"
						    VerticalAlignment="Top">
							<TextBlock Text="Binding two-way" />
							<TextBlock Text="{Binding ElementName=StateTwoContent, Path=Opacity}" />
							<TextBlock Text="Pulled" />
							<TextBlock x:Name="PullingOutput"
							    Text="N/A" />
						</StackPanel>
						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="TestStates">
								<VisualState x:Name="StateOne" />
								<VisualState x:Name="StateTwo">
									<Storyboard>
										<DoubleAnimation BeginTime="0"
										    Duration="0:0:10"
										    To="1"
										    Storyboard.TargetName="StateTwoContent"
										    Storyboard.TargetProperty="Opacity" />
									</Storyboard>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>
					</Grid>
				</ControlTemplate>
			</ContentControl.Template>


			<TextBlock Text="Content" />

		</ContentControl>


	</Grid>
</UserControl>
