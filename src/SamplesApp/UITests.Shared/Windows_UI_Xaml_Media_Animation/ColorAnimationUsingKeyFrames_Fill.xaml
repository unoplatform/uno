<Page x:Class="UITests.Windows_UI_Xaml_Media_Animation.ColorAnimationUsingKeyFrames_Fill"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Media_Animation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<Page.Resources>
		<Color x:Key="Color1">#FF0000</Color>
		<Color x:Key="Color2">#FF8000</Color>
		<Color x:Key="Color3">#FFFF00</Color>
		<Color x:Key="Color4">#008000</Color>
		<Color x:Key="Color5">#0000FF</Color>
		<Color x:Key="Color6">#A000C0</Color>
		<SolidColorBrush x:Key="Brush1"
		    Color="{StaticResource Color1}" />
		<SolidColorBrush x:Key="Brush2"
		    Color="{StaticResource Color2}" />
		<SolidColorBrush x:Key="Brush3"
		    Color="{StaticResource Color3}" />
		<SolidColorBrush x:Key="Brush4"
		    Color="{StaticResource Color4}" />
		<SolidColorBrush x:Key="Brush5"
		    Color="{StaticResource Color5}" />
		<SolidColorBrush x:Key="Brush6"
		    Color="{StaticResource Color6}" />
	</Page.Resources>

	<StackPanel Spacing="10">
		<TextBlock>Original Colors: (should never change)</TextBlock>
		<StackPanel Height="40"
		    Orientation="Horizontal">
			<Border Width="20"
			    Background="{StaticResource Brush1}" />
			<Rectangle Width="20"
			    Fill="{StaticResource Brush1}" />
			<Border Width="20"
			    Background="{StaticResource Brush2}" />
			<Rectangle Width="20"
			    Fill="{StaticResource Brush2}" />
			<Border Width="20"
			    Background="{StaticResource Brush3}" />
			<Rectangle Width="20"
			    Fill="{StaticResource Brush3}" />
			<Border Width="20"
			    Background="{StaticResource Brush4}" />
			<Rectangle Width="20"
			    Fill="{StaticResource Brush4}" />
			<Border Width="20"
			    Background="{StaticResource Brush5}" />
			<Rectangle Width="20"
			    Fill="{StaticResource Brush5}" />
			<Border Width="20"
			    Background="{StaticResource Brush6}" />
			<Rectangle Width="20"
			    Fill="{StaticResource Brush6}" />
		</StackPanel>

		<StackPanel Orientation="Horizontal"
		    Spacing="20">
			<Button x:Name="btn1"
			    Background="Transparent"
			    Click="GoToState"
			    Tag="StateOff">
				-&gt;StateOff
			</Button>
			<Button x:Name="btn2"
			    Background="Transparent"
			    Click="GoToState"
			    Tag="StateCool">
				-&gt;StateCool
			</Button>
			<Button x:Name="btn3"
			    Background="Transparent"
			    Click="GoToState"
			    Tag="StateGray">
				-&gt;StateGray
			</Button>
			<Button x:Name="btn4"
			    Background="Transparent"
			    Click="GoToState"
			    Tag="StateStrobe">
				-&gt;StateStrobe
			</Button>
			<Button x:Name="btn6"
			    Background="Transparent"
			    Click="GoToState"
			    Tag="StateXmas">
				-&gt;StateXmas
			</Button>
		</StackPanel>

		<TextBlock>Animated block:</TextBlock>
		<StackPanel Height="40"
		    Orientation="Horizontal">
			<Border x:Name="border1"
			    Width="40"
			    Background="{StaticResource Brush1}" />
			<Border x:Name="border2"
			    Width="40"
			    Background="{StaticResource Brush2}" />
			<Border x:Name="border3"
			    Width="40"
			    Background="{StaticResource Brush3}" />
			<Border x:Name="border4"
			    Width="40"
			    Background="{StaticResource Brush4}" />
			<Border x:Name="border5"
			    Width="40"
			    Background="{StaticResource Brush5}" />
			<Border x:Name="border6"
			    Width="40"
			    Background="{StaticResource Brush6}" />
		</StackPanel>
		<VisualStateManager.VisualStateGroups>
			<VisualStateGroup x:Name="States">
				<VisualState x:Name="StateOff" />
				<VisualState x:Name="StateCool">
					<Storyboard RepeatBehavior="Forever">
						<ColorAnimationUsingKeyFrames Storyboard.TargetName="btn2"
						    Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)">
							<LinearColorKeyFrame KeyTime="0:0:0.25"
							    Value="{StaticResource Color1}" />
							<LinearColorKeyFrame KeyTime="0:0:0.5"
							    Value="{StaticResource Color2}" />
							<LinearColorKeyFrame KeyTime="0:0:0.75"
							    Value="{StaticResource Color3}" />
							<LinearColorKeyFrame KeyTime="0:0:1.0"
							    Value="{StaticResource Color4}" />
							<LinearColorKeyFrame KeyTime="0:0:1.25"
							    Value="{StaticResource Color5}" />
							<LinearColorKeyFrame KeyTime="0:0:1.5"
							    Value="{StaticResource Color6}" />
						</ColorAnimationUsingKeyFrames>
					</Storyboard>

				</VisualState>
				<VisualState x:Name="StateGray">
					<Storyboard RepeatBehavior="Forever">
						<ColorAnimationUsingKeyFrames Storyboard.TargetName="border1"
						    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)">
							<DiscreteColorKeyFrame KeyTime="0:0:0.15"
							    Value="White" />
							<LinearColorKeyFrame KeyTime="0:0:0.30"
							    Value="LightGray" />
							<LinearColorKeyFrame KeyTime="0:0:0.45"
							    Value="DarkGray" />
							<DiscreteColorKeyFrame KeyTime="0:0:0.60"
							    Value="Black" />
							<LinearColorKeyFrame KeyTime="0:0:0.75"
							    Value="DarkGray" />
							<LinearColorKeyFrame KeyTime="0:0:0.90"
							    Value="LightGray" />
						</ColorAnimationUsingKeyFrames>
						<ColorAnimationUsingKeyFrames Storyboard.TargetName="border2"
						    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)">
							<LinearColorKeyFrame KeyTime="0:0:0.15"
							    Value="LightGray" />
							<DiscreteColorKeyFrame KeyTime="0:0:0.30"
							    Value="White" />
							<LinearColorKeyFrame KeyTime="0:0:0.45"
							    Value="LightGray" />
							<LinearColorKeyFrame KeyTime="0:0:0.60"
							    Value="DarkGray" />
							<DiscreteColorKeyFrame KeyTime="0:0:0.75"
							    Value="Black" />
							<LinearColorKeyFrame KeyTime="0:0:0.90"
							    Value="DarkGray" />
						</ColorAnimationUsingKeyFrames>
						<ColorAnimationUsingKeyFrames Storyboard.TargetName="border3"
						    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)">
							<LinearColorKeyFrame KeyTime="0:0:0.15"
							    Value="DarkGray" />
							<LinearColorKeyFrame KeyTime="0:0:0.30"
							    Value="LightGray" />
							<DiscreteColorKeyFrame KeyTime="0:0:0.45"
							    Value="White" />
							<LinearColorKeyFrame KeyTime="0:0:0.60"
							    Value="LightGray" />
							<LinearColorKeyFrame KeyTime="0:0:0.75"
							    Value="DarkGray" />
							<DiscreteColorKeyFrame KeyTime="0:0:0.90"
							    Value="Black" />
						</ColorAnimationUsingKeyFrames>
						<ColorAnimationUsingKeyFrames Storyboard.TargetName="border4"
						    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)">
							<DiscreteColorKeyFrame KeyTime="0:0:0.15"
							    Value="Black" />
							<LinearColorKeyFrame KeyTime="0:0:0.30"
							    Value="DarkGray" />
							<LinearColorKeyFrame KeyTime="0:0:0.45"
							    Value="LightGray" />
							<DiscreteColorKeyFrame KeyTime="0:0:0.60"
							    Value="White" />
							<LinearColorKeyFrame KeyTime="0:0:0.75"
							    Value="LightGray" />
							<LinearColorKeyFrame KeyTime="0:0:0.90"
							    Value="DarkGray" />
						</ColorAnimationUsingKeyFrames>
						<ColorAnimationUsingKeyFrames Storyboard.TargetName="border5"
						    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)">
							<LinearColorKeyFrame KeyTime="0:0:0.15"
							    Value="DarkGray" />
							<DiscreteColorKeyFrame KeyTime="0:0:0.30"
							    Value="Black" />
							<LinearColorKeyFrame KeyTime="0:0:0.45"
							    Value="DarkGray" />
							<LinearColorKeyFrame KeyTime="0:0:0.60"
							    Value="LightGray" />
							<DiscreteColorKeyFrame KeyTime="0:0:0.75"
							    Value="White" />
							<LinearColorKeyFrame KeyTime="0:0:0.90"
							    Value="LightGray" />
						</ColorAnimationUsingKeyFrames>
						<ColorAnimationUsingKeyFrames Storyboard.TargetName="border6"
						    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)">
							<LinearColorKeyFrame KeyTime="0:0:0.15"
							    Value="LightGray" />
							<LinearColorKeyFrame KeyTime="0:0:0.30"
							    Value="DarkGray" />
							<DiscreteColorKeyFrame KeyTime="0:0:0.45"
							    Value="Black" />
							<LinearColorKeyFrame KeyTime="0:0:0.60"
							    Value="DarkGray" />
							<LinearColorKeyFrame KeyTime="0:0:0.75"
							    Value="LightGray" />
							<DiscreteColorKeyFrame KeyTime="0:0:0.90"
							    Value="White" />
						</ColorAnimationUsingKeyFrames>
					</Storyboard>

				</VisualState>
				<VisualState x:Name="StateStrobe">
					<Storyboard RepeatBehavior="Forever">
						<ColorAnimationUsingKeyFrames Storyboard.TargetName="border1"
						    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)">
							<DiscreteColorKeyFrame KeyTime="0:0:0.12"
							    Value="White" />
							<DiscreteColorKeyFrame KeyTime="0:0:0.24"
							    Value="Black" />
						</ColorAnimationUsingKeyFrames>
						<ColorAnimationUsingKeyFrames Storyboard.TargetName="border2"
						    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)">
							<DiscreteColorKeyFrame KeyTime="0:0:0.8"
							    Value="White" />
							<DiscreteColorKeyFrame KeyTime="0:0:0.31"
							    Value="Black" />
						</ColorAnimationUsingKeyFrames>
						<ColorAnimationUsingKeyFrames Storyboard.TargetName="border3"
						    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)">
							<DiscreteColorKeyFrame KeyTime="0:0:0.23"
							    Value="Black" />
							<DiscreteColorKeyFrame KeyTime="0:0:0.5"
							    Value="White" />
						</ColorAnimationUsingKeyFrames>
						<ColorAnimationUsingKeyFrames Storyboard.TargetName="border4"
						    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)">
							<DiscreteColorKeyFrame KeyTime="0:0:0.17"
							    Value="Black" />
							<DiscreteColorKeyFrame KeyTime="0:0:0.34"
							    Value="White" />
						</ColorAnimationUsingKeyFrames>
						<ColorAnimationUsingKeyFrames Storyboard.TargetName="border5"
						    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)">
							<DiscreteColorKeyFrame KeyTime="0:0:0.9"
							    Value="Black" />
							<DiscreteColorKeyFrame KeyTime="0:0:0.19"
							    Value="White" />
						</ColorAnimationUsingKeyFrames>
						<ColorAnimationUsingKeyFrames Storyboard.TargetName="border6"
						    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)">
							<DiscreteColorKeyFrame KeyTime="0:0:0.20"
							    Value="White" />
							<DiscreteColorKeyFrame KeyTime="0:0:0.40"
							    Value="Black" />
						</ColorAnimationUsingKeyFrames>
					</Storyboard>

				</VisualState>
				<VisualState x:Name="StateXmas">
					<Storyboard RepeatBehavior="Forever">
						<ColorAnimationUsingKeyFrames Storyboard.TargetName="border6"
						    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)">
							<DiscreteColorKeyFrame KeyTime="0:0:2"
							    Value="Green" />
							<DiscreteColorKeyFrame KeyTime="0:0:4"
							    Value="Red" />
							<DiscreteColorKeyFrame KeyTime="0:0:6"
							    Value="Yellow" />
							<DiscreteColorKeyFrame KeyTime="0:0:8"
							    Value="Purple" />
						</ColorAnimationUsingKeyFrames>
					</Storyboard>

				</VisualState>
			</VisualStateGroup>

		</VisualStateManager.VisualStateGroups>
	</StackPanel>
</Page>
