<Page
    x:Class="UITests.Windows_UI_Xaml_Media_Animation.Showcase.ThemeAnimationsShowcase"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="ShowcaseSectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,16,0,4" />
        </Style>
        <Style x:Key="ShowcaseDescription" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Opacity" Value="0.75" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Storyboard x:Name="FadeInStoryboard">
            <FadeInThemeAnimation Storyboard.TargetName="FadeTarget" />
        </Storyboard>
        <Storyboard x:Name="FadeOutStoryboard">
            <FadeOutThemeAnimation Storyboard.TargetName="FadeTarget" />
        </Storyboard>

        <Storyboard x:Name="RepositionStoryboard">
            <RepositionThemeAnimation
                FromHorizontalOffset="200"
                FromVerticalOffset="0"
                Storyboard.TargetName="RepositionTarget" />
        </Storyboard>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="12">
            <TextBlock
                FontSize="28"
                FontWeight="Bold"
                Text="Theme Animations Showcase" />
            <TextBlock
                MaxWidth="700"
                HorizontalAlignment="Left"
                Style="{StaticResource ShowcaseDescription}"
                Text="System theme animations expose the platform's standard transitions in one line of XAML: FadeInThemeAnimation, FadeOutThemeAnimation and RepositionThemeAnimation." />

            <TextBlock Style="{StaticResource ShowcaseSectionHeader}" Text="FadeIn / FadeOut" />
            <Border
                x:Name="FadeTarget"
                Width="200"
                Height="80"
                HorizontalAlignment="Left"
                Background="{ThemeResource SystemAccentColor}"
                CornerRadius="6">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="Fade me" />
            </Border>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Click="DoFadeIn" Content="FadeIn" />
                <Button Click="DoFadeOut" Content="FadeOut" />
            </StackPanel>

            <TextBlock Style="{StaticResource ShowcaseSectionHeader}" Text="Reposition" />
            <TextBlock Style="{StaticResource ShowcaseDescription}" Text="Reveals an element by sliding it into place from the specified offset." />
            <Border
                x:Name="RepositionTarget"
                Width="200"
                Height="80"
                HorizontalAlignment="Left"
                Background="MediumSeaGreen"
                CornerRadius="6">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="Slide me" />
            </Border>
            <Button Click="DoReposition" Content="Reposition (200, 0)" />
        </StackPanel>
    </ScrollViewer>
</Page>
