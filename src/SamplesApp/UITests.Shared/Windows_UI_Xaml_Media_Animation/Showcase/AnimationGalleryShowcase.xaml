<Page
    x:Class="UITests.Windows_UI_Xaml_Media_Animation.Showcase.AnimationGalleryShowcase"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <!--  Pulsating dot — opacity + scale  -->
        <Storyboard x:Name="PulseStoryboard" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PulseDotTransform" Storyboard.TargetProperty="ScaleX">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.6" />
                <EasingDoubleKeyFrame KeyTime="0:0:1" Value="1.4">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <SineEase EasingMode="EaseOut" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:2" Value="0.6">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <SineEase EasingMode="EaseIn" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PulseDotTransform" Storyboard.TargetProperty="ScaleY">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.6" />
                <EasingDoubleKeyFrame KeyTime="0:0:1" Value="1.4">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <SineEase EasingMode="EaseOut" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:2" Value="0.6">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <SineEase EasingMode="EaseIn" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PulseDot" Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1.0" />
                <LinearDoubleKeyFrame KeyTime="0:0:1" Value="0.4" />
                <LinearDoubleKeyFrame KeyTime="0:0:2" Value="1.0" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!--  Indeterminate progress bar  -->
        <Storyboard x:Name="ProgressStoryboard" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ProgressFillTransform" Storyboard.TargetProperty="X">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="-200" />
                <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="200">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseInOut" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:2.5" Value="200" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!--  Card hover effect  -->
        <Storyboard x:Name="CardEnterStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="CardTransform"
                Storyboard.TargetProperty="TranslateY"
                To="-8"
                Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="CardTransform"
                Storyboard.TargetProperty="ScaleX"
                To="1.02"
                Duration="0:0:0.25" />
            <DoubleAnimation
                Storyboard.TargetName="CardTransform"
                Storyboard.TargetProperty="ScaleY"
                To="1.02"
                Duration="0:0:0.25" />
        </Storyboard>
        <Storyboard x:Name="CardLeaveStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="CardTransform"
                Storyboard.TargetProperty="TranslateY"
                To="0"
                Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="CardTransform"
                Storyboard.TargetProperty="ScaleX"
                To="1.0"
                Duration="0:0:0.25" />
            <DoubleAnimation
                Storyboard.TargetName="CardTransform"
                Storyboard.TargetProperty="ScaleY"
                To="1.0"
                Duration="0:0:0.25" />
        </Storyboard>

        <!--  Aurora background  -->
        <Storyboard x:Name="AuroraStoryboard" RepeatBehavior="Forever">
            <ColorAnimation
                AutoReverse="True"
                Storyboard.TargetName="AuroraStop1"
                Storyboard.TargetProperty="Color"
                From="#5B21B6"
                To="#0EA5E9"
                Duration="0:0:4" />
            <ColorAnimation
                AutoReverse="True"
                BeginTime="0:0:1"
                Storyboard.TargetName="AuroraStop2"
                Storyboard.TargetProperty="Color"
                From="#0EA5E9"
                To="#22C55E"
                Duration="0:0:4" />
            <ColorAnimation
                AutoReverse="True"
                BeginTime="0:0:2"
                Storyboard.TargetName="AuroraStop3"
                Storyboard.TargetProperty="Color"
                From="#F472B6"
                To="#FBBF24"
                Duration="0:0:4" />
        </Storyboard>

        <!--  Loading dots cascade  -->
        <Storyboard x:Name="DotsStoryboard" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot1Transform" Storyboard.TargetProperty="Y">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="-12">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BounceEase Bounces="1" EasingMode="EaseOut" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="0" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot2Transform" Storyboard.TargetProperty="Y">
                <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="0" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.45" Value="-12">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.75" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BounceEase Bounces="1" EasingMode="EaseOut" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="0" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot3Transform" Storyboard.TargetProperty="Y">
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="0" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="-12">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.9" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <BounceEase Bounces="1" EasingMode="EaseOut" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="0" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="20">
            <TextBlock
                FontSize="28"
                FontWeight="Bold"
                Text="Animation Gallery" />
            <TextBlock
                MaxWidth="700"
                HorizontalAlignment="Left"
                FontSize="13"
                Opacity="0.75"
                Text="A curated set of polished, real-world micro-animations driven by the new Skia animation pipeline. Tap Start All to play them in parallel."
                TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Click="StartAll" Content="Start all" />
                <Button Click="StopAll" Content="Stop all" />
            </StackPanel>

            <!--  Aurora hero  -->
            <Border Height="120" CornerRadius="12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop x:Name="AuroraStop1" Offset="0.0" Color="#5B21B6" />
                        <GradientStop x:Name="AuroraStop2" Offset="0.5" Color="#0EA5E9" />
                        <GradientStop x:Name="AuroraStop3" Offset="1.0" Color="#F472B6" />
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="28"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="Aurora — animated gradient" />
            </Border>

            <!--  Pulse + Loading dots  -->
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Height="160"
                    Background="{ThemeResource SystemListLowColor}"
                    CornerRadius="12">
                    <Grid>
                        <TextBlock
                            Margin="16"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            FontSize="14"
                            Opacity="0.7"
                            Text="Pulse" />
                        <Ellipse
                            x:Name="PulseDot"
                            Width="48"
                            Height="48"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Fill="{ThemeResource SystemAccentColor}"
                            RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="PulseDotTransform" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="1"
                    Height="160"
                    Background="{ThemeResource SystemListLowColor}"
                    CornerRadius="12">
                    <Grid>
                        <TextBlock
                            Margin="16"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            FontSize="14"
                            Opacity="0.7"
                            Text="Loading dots" />
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="10">
                            <Ellipse
                                Width="14"
                                Height="14"
                                Fill="MediumSeaGreen">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="Dot1Transform" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse
                                Width="14"
                                Height="14"
                                Fill="MediumSeaGreen">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="Dot2Transform" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse
                                Width="14"
                                Height="14"
                                Fill="MediumSeaGreen">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="Dot3Transform" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!--  Indeterminate progress  -->
            <TextBlock
                Margin="0,8,0,0"
                FontSize="14"
                Opacity="0.7"
                Text="Indeterminate progress" />
            <Border
                Height="6"
                Background="{ThemeResource SystemListLowColor}"
                CornerRadius="3">
                <Border CornerRadius="3">
                    <Border.Clip>
                        <RectangleGeometry Rect="0,0,400,6" />
                    </Border.Clip>
                    <Border
                        Width="80"
                        Height="6"
                        HorizontalAlignment="Left"
                        Background="{ThemeResource SystemAccentColor}"
                        CornerRadius="3">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="ProgressFillTransform" X="-200" />
                        </Border.RenderTransform>
                    </Border>
                </Border>
            </Border>

            <!--  Hover card  -->
            <TextBlock
                Margin="0,16,0,0"
                FontSize="14"
                Opacity="0.7"
                Text="Hover card" />
            <Border
                x:Name="HoverCardBorder"
                Width="240"
                Height="120"
                HorizontalAlignment="Left"
                Background="{ThemeResource SystemAccentColor}"
                CornerRadius="12"
                PointerEntered="OnCardEntered"
                PointerExited="OnCardExited"
                RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <CompositeTransform x:Name="CardTransform" />
                </Border.RenderTransform>
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="Hover me" />
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
