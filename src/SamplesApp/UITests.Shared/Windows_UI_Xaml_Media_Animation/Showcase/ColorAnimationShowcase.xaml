<Page
    x:Class="UITests.Windows_UI_Xaml_Media_Animation.Showcase.ColorAnimationShowcase"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="ShowcaseSectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,16,0,4" />
        </Style>
        <Style x:Key="ShowcaseDescription" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Opacity" Value="0.75" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <!--  XAML-only autoplay storyboard for the bottom showcase  -->
        <Storyboard x:Name="StripeStoryboard" RepeatBehavior="Forever">
            <ColorAnimation
                AutoReverse="True"
                Storyboard.TargetName="StripeABrush"
                Storyboard.TargetProperty="Color"
                From="#FF6F61"
                To="#FFD166"
                Duration="0:0:1.5" />
            <ColorAnimation
                AutoReverse="True"
                BeginTime="0:0:0.5"
                Storyboard.TargetName="StripeBBrush"
                Storyboard.TargetProperty="Color"
                From="#06D6A0"
                To="#118AB2"
                Duration="0:0:1.5" />
            <ColorAnimation
                AutoReverse="True"
                BeginTime="0:0:1.0"
                Storyboard.TargetName="StripeCBrush"
                Storyboard.TargetProperty="Color"
                From="#073B4C"
                To="#EF476F"
                Duration="0:0:1.5" />
        </Storyboard>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="12">
            <TextBlock
                FontSize="28"
                FontWeight="Bold"
                Text="ColorAnimation Showcase" />
            <TextBlock
                MaxWidth="700"
                HorizontalAlignment="Left"
                Style="{StaticResource ShowcaseDescription}"
                Text="ColorAnimation interpolates SolidColorBrush.Color. Demonstrates Background, Fill, Stroke, Foreground targets, EasingFunction, and AutoReverse looping." />

            <!--  Background  -->
            <TextBlock Style="{StaticResource ShowcaseSectionHeader}" Text="1. Border Background" />
            <TextBlock Style="{StaticResource ShowcaseDescription}" Text="Animates the Color of a SolidColorBrush set on Border.Background." />
            <Border
                x:Name="BackgroundBorder"
                Height="64"
                HorizontalAlignment="Stretch"
                CornerRadius="8">
                <Border.Background>
                    <SolidColorBrush x:Name="BackgroundBrush" Color="#3F51B5" />
                </Border.Background>
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="Background animates" />
            </Border>
            <Button Click="RunBackground" Content="Animate Background" />

            <!--  Fill  -->
            <TextBlock Style="{StaticResource ShowcaseSectionHeader}" Text="2. Shape Fill" />
            <TextBlock Style="{StaticResource ShowcaseDescription}" Text="Animates the Fill of an Ellipse." />
            <Ellipse
                x:Name="FillEllipse"
                Width="80"
                Height="80"
                HorizontalAlignment="Left">
                <Ellipse.Fill>
                    <SolidColorBrush x:Name="FillBrush" Color="#E91E63" />
                </Ellipse.Fill>
            </Ellipse>
            <Button Click="RunFill" Content="Animate Fill" />

            <!--  Stroke  -->
            <TextBlock Style="{StaticResource ShowcaseSectionHeader}" Text="3. Shape Stroke" />
            <TextBlock Style="{StaticResource ShowcaseDescription}" Text="Animates the Stroke of a Rectangle (StrokeThickness held constant)." />
            <Rectangle
                x:Name="StrokeRect"
                Width="160"
                Height="64"
                HorizontalAlignment="Left"
                StrokeThickness="6">
                <Rectangle.Stroke>
                    <SolidColorBrush x:Name="StrokeBrush" Color="#009688" />
                </Rectangle.Stroke>
            </Rectangle>
            <Button Click="RunStroke" Content="Animate Stroke" />

            <!--  Foreground  -->
            <TextBlock Style="{StaticResource ShowcaseSectionHeader}" Text="4. TextBlock Foreground" />
            <TextBlock Style="{StaticResource ShowcaseDescription}" Text="Animates the Foreground of text — even on glyph rendering targets the new pipeline applies the value per-tick." />
            <TextBlock
                x:Name="ForegroundText"
                FontSize="32"
                FontWeight="Bold"
                Text="Animated Text">
                <TextBlock.Foreground>
                    <SolidColorBrush x:Name="ForegroundBrush" Color="#FF5722" />
                </TextBlock.Foreground>
            </TextBlock>
            <Button Click="RunForeground" Content="Animate Foreground" />

            <!--  EasingFunction  -->
            <TextBlock Style="{StaticResource ShowcaseSectionHeader}" Text="5. ColorAnimation + EasingFunction" />
            <TextBlock Style="{StaticResource ShowcaseDescription}" Text="Bottom-eased (CubicEase EaseInOut) versus linear color transition. Both go from blue to red over 2 seconds — observe the curve." />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Border
                    x:Name="EaseLinearBorder"
                    Width="160"
                    Height="64"
                    CornerRadius="8">
                    <Border.Background>
                        <SolidColorBrush x:Name="EaseLinearBrush" Color="#1976D2" />
                    </Border.Background>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Text="Linear" />
                </Border>
                <Border
                    x:Name="EaseCurvedBorder"
                    Width="160"
                    Height="64"
                    CornerRadius="8">
                    <Border.Background>
                        <SolidColorBrush x:Name="EaseCurvedBrush" Color="#1976D2" />
                    </Border.Background>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Text="CubicEase" />
                </Border>
            </StackPanel>
            <Button Click="RunEasing" Content="Animate both" />

            <!--  Looping showcase  -->
            <TextBlock Style="{StaticResource ShowcaseSectionHeader}" Text="6. Looping color stripes (XAML autoplay)" />
            <TextBlock Style="{StaticResource ShowcaseDescription}" Text="Three color animations with staggered BeginTime, AutoReverse, RepeatBehavior=Forever — driven entirely from XAML." />
            <Grid Height="100">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0">
                    <Border.Background>
                        <SolidColorBrush x:Name="StripeABrush" Color="#FF6F61" />
                    </Border.Background>
                </Border>
                <Border Grid.Row="1">
                    <Border.Background>
                        <SolidColorBrush x:Name="StripeBBrush" Color="#06D6A0" />
                    </Border.Background>
                </Border>
                <Border Grid.Row="2">
                    <Border.Background>
                        <SolidColorBrush x:Name="StripeCBrush" Color="#073B4C" />
                    </Border.Background>
                </Border>
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Click="StartStripes" Content="Start stripes" />
                <Button Click="StopStripes" Content="Stop stripes" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
