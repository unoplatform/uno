<Page
    x:Class="UITests.Windows_UI_Xaml_Media_Animation.Showcase.TransformAnimationShowcase"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="ShowcaseSectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,16,0,4" />
        </Style>
        <Style x:Key="ShowcaseDescription" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Opacity" Value="0.75" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="DemoTile" TargetType="Border">
            <Setter Property="Width" Value="80" />
            <Setter Property="Height" Value="80" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        </Style>

        <!--  Composite transform XAML autoplay  -->
        <Storyboard x:Name="CompositeStoryboard" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CompositeTransform" Storyboard.TargetProperty="Rotation">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                <EasingDoubleKeyFrame KeyTime="0:0:2" Value="360">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseInOut" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CompositeTransform" Storyboard.TargetProperty="ScaleX">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                <EasingDoubleKeyFrame KeyTime="0:0:1" Value="1.4" />
                <EasingDoubleKeyFrame KeyTime="0:0:2" Value="1" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CompositeTransform" Storyboard.TargetProperty="ScaleY">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                <EasingDoubleKeyFrame KeyTime="0:0:1" Value="1.4" />
                <EasingDoubleKeyFrame KeyTime="0:0:2" Value="1" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CompositeTransform" Storyboard.TargetProperty="TranslateY">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                <EasingDoubleKeyFrame KeyTime="0:0:1" Value="-30" />
                <EasingDoubleKeyFrame KeyTime="0:0:2" Value="0" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CompositeTransform" Storyboard.TargetProperty="SkewX">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="20" />
                <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="-20" />
                <EasingDoubleKeyFrame KeyTime="0:0:2" Value="0" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="12">
            <TextBlock
                FontSize="28"
                FontWeight="Bold"
                Text="Transform Animation Showcase" />
            <TextBlock
                MaxWidth="700"
                HorizontalAlignment="Left"
                Style="{StaticResource ShowcaseDescription}"
                Text="Animates the five transform types: TranslateTransform, ScaleTransform, RotateTransform, SkewTransform, and CompositeTransform — each via DoubleAnimation on the relevant property." />

            <TextBlock Style="{StaticResource ShowcaseSectionHeader}" Text="1. TranslateTransform" />
            <Grid Height="120">
                <Border Background="{ThemeResource SystemAccentColor}" Style="{StaticResource DemoTile}">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="TranslateTarget" />
                    </Border.RenderTransform>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="T" />
                </Border>
            </Grid>
            <Button Click="RunTranslate" Content="Run Translate" />

            <TextBlock Style="{StaticResource ShowcaseSectionHeader}" Text="2. ScaleTransform" />
            <Grid Height="180">
                <Border Background="MediumSeaGreen" Style="{StaticResource DemoTile}">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="ScaleTarget" />
                    </Border.RenderTransform>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="S" />
                </Border>
            </Grid>
            <Button Click="RunScale" Content="Run Scale" />

            <TextBlock Style="{StaticResource ShowcaseSectionHeader}" Text="3. RotateTransform" />
            <Grid Height="120">
                <Border Background="MediumPurple" Style="{StaticResource DemoTile}">
                    <Border.RenderTransform>
                        <RotateTransform x:Name="RotateTarget" />
                    </Border.RenderTransform>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="R" />
                </Border>
            </Grid>
            <Button Click="RunRotate" Content="Run Rotate" />

            <TextBlock Style="{StaticResource ShowcaseSectionHeader}" Text="4. SkewTransform" />
            <Grid Height="120">
                <Border Background="OrangeRed" Style="{StaticResource DemoTile}">
                    <Border.RenderTransform>
                        <SkewTransform x:Name="SkewTarget" />
                    </Border.RenderTransform>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="K" />
                </Border>
            </Grid>
            <Button Click="RunSkew" Content="Run Skew" />

            <TextBlock Style="{StaticResource ShowcaseSectionHeader}" Text="5. CompositeTransform (auto-playing)" />
            <TextBlock Style="{StaticResource ShowcaseDescription}" Text="Five animations target a single CompositeTransform: Rotation, ScaleX, ScaleY, TranslateY and SkewX — yielding a continuous bounce + spin effect." />
            <Grid Height="180">
                <Border Background="DodgerBlue" Style="{StaticResource DemoTile}">
                    <Border.RenderTransform>
                        <CompositeTransform x:Name="CompositeTransform" />
                    </Border.RenderTransform>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="C" />
                </Border>
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Click="StartComposite" Content="Start" />
                <Button Click="StopComposite" Content="Stop" />
            </StackPanel>

            <TextBlock Style="{StaticResource ShowcaseSectionHeader}" Text="6. RenderTransformOrigin" />
            <TextBlock Style="{StaticResource ShowcaseDescription}" Text="Two boxes rotate 360°, one with origin (0,0) and one with origin (0.5,0.5)." />
            <StackPanel Orientation="Horizontal" Spacing="32">
                <StackPanel Spacing="6">
                    <TextBlock HorizontalAlignment="Center" Text="(0,0)" />
                    <Border
                        Width="80"
                        Height="80"
                        Background="DarkCyan"
                        CornerRadius="6"
                        RenderTransformOrigin="0,0">
                        <Border.RenderTransform>
                            <RotateTransform x:Name="OriginTopLeftTarget" />
                        </Border.RenderTransform>
                    </Border>
                </StackPanel>
                <StackPanel Spacing="6">
                    <TextBlock HorizontalAlignment="Center" Text="(0.5,0.5)" />
                    <Border
                        Width="80"
                        Height="80"
                        Background="DarkCyan"
                        CornerRadius="6"
                        RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <RotateTransform x:Name="OriginCenterTarget" />
                        </Border.RenderTransform>
                    </Border>
                </StackPanel>
            </StackPanel>
            <Button Click="RunOriginCompare" Content="Run both" />
        </StackPanel>
    </ScrollViewer>
</Page>
