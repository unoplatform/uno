<Page
    x:Class="UITests.Windows_UI_Xaml_Media_Animation.Showcase.ObjectAnimationShowcase"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="ShowcaseSectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,16,0,4" />
        </Style>
        <Style x:Key="ShowcaseDescription" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Opacity" Value="0.75" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <SolidColorBrush x:Key="BrushStateA" Color="#1E88E5" />
        <SolidColorBrush x:Key="BrushStateB" Color="#43A047" />
        <SolidColorBrush x:Key="BrushStateC" Color="#FB8C00" />
        <SolidColorBrush x:Key="BrushStateD" Color="#E53935" />

        <!--  XAML autoplay storyboard cycling Visibility, Brush, Text  -->
        <Storyboard x:Name="CycleStoryboard" RepeatBehavior="Forever">
            <!--  Visibility cycle  -->
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="VisibilityTarget" Storyboard.TargetProperty="Visibility">
                <DiscreteObjectKeyFrame KeyTime="0:0:0">
                    <DiscreteObjectKeyFrame.Value>
                        <Visibility>Visible</Visibility>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>
                <DiscreteObjectKeyFrame KeyTime="0:0:1">
                    <DiscreteObjectKeyFrame.Value>
                        <Visibility>Collapsed</Visibility>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>
                <DiscreteObjectKeyFrame KeyTime="0:0:2">
                    <DiscreteObjectKeyFrame.Value>
                        <Visibility>Visible</Visibility>
                    </DiscreteObjectKeyFrame.Value>
                </DiscreteObjectKeyFrame>
            </ObjectAnimationUsingKeyFrames>

            <!--  Brush cycle  -->
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BrushTarget" Storyboard.TargetProperty="Background">
                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{StaticResource BrushStateA}" />
                <DiscreteObjectKeyFrame KeyTime="0:0:0.6" Value="{StaticResource BrushStateB}" />
                <DiscreteObjectKeyFrame KeyTime="0:0:1.2" Value="{StaticResource BrushStateC}" />
                <DiscreteObjectKeyFrame KeyTime="0:0:1.8" Value="{StaticResource BrushStateD}" />
            </ObjectAnimationUsingKeyFrames>

            <!--  Text cycle  -->
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="TextTarget" Storyboard.TargetProperty="Text">
                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="Ready" />
                <DiscreteObjectKeyFrame KeyTime="0:0:0.6" Value="Loading…" />
                <DiscreteObjectKeyFrame KeyTime="0:0:1.2" Value="Almost there" />
                <DiscreteObjectKeyFrame KeyTime="0:0:1.8" Value="Done!" />
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="12">
            <TextBlock
                FontSize="28"
                FontWeight="Bold"
                Text="ObjectAnimation Showcase" />
            <TextBlock
                MaxWidth="700"
                HorizontalAlignment="Left"
                Style="{StaticResource ShowcaseDescription}"
                Text="ObjectAnimationUsingKeyFrames switches reference-typed values at discrete key times. Use it for Visibility flips, brush swaps, text changes, and template swaps." />

            <TextBlock Style="{StaticResource ShowcaseSectionHeader}" Text="Visibility, Brush and Text driven from one Storyboard" />
            <TextBlock Style="{StaticResource ShowcaseDescription}" Text="When started, the row blinks Visibility, the second tile cycles between four brushes, and the text label cycles four states — all on a single Storyboard with RepeatBehavior=Forever." />

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    x:Name="VisibilityTarget"
                    Grid.Column="0"
                    Height="80"
                    Background="{ThemeResource SystemAccentColor}"
                    CornerRadius="8">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Blink" />
                </Border>

                <Border
                    x:Name="BrushTarget"
                    Grid.Column="1"
                    Height="80"
                    Background="{StaticResource BrushStateA}"
                    CornerRadius="8">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Brush" />
                </Border>

                <Border
                    Grid.Column="2"
                    Height="80"
                    Background="{ThemeResource SystemListLowColor}"
                    CornerRadius="8">
                    <TextBlock
                        x:Name="TextTarget"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="Ready" />
                </Border>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Click="StartCycle" Content="Start" />
                <Button Click="StopCycle" Content="Stop" />
            </StackPanel>

            <!--  Code-driven  -->
            <TextBlock Style="{StaticResource ShowcaseSectionHeader}" Text="Code-driven swap" />
            <TextBlock Style="{StaticResource ShowcaseDescription}" Text="Click to swap CornerRadius, Background and FontIcon glyph at three discrete key times — all driven from C#." />
            <Border
                x:Name="CodeTarget"
                Width="120"
                Height="120"
                HorizontalAlignment="Left"
                Background="LightSlateGray"
                CornerRadius="0">
                <FontIcon
                    x:Name="CodeIcon"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="48"
                    Foreground="White"
                    Glyph="&#xE701;" />
            </Border>
            <Button Click="RunCodeSwap" Content="Run swap" />
        </StackPanel>
    </ScrollViewer>
</Page>
