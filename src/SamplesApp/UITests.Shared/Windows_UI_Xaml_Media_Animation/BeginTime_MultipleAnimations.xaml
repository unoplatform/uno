<Page x:Class="UITests.Windows_UI_Xaml_Media_Animation.BeginTime_MultipleAnimations"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Media_Animation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

	<StackPanel HorizontalAlignment="Stretch">
		<StackPanel Margin="0,0,0,20"
		    Orientation="Horizontal">
			<TextBlock Text="The effective animation" />
			<Button Margin="10,0,0,0"
			    Click="StartAnimation"
			    Content="Start" />
		</StackPanel>

		<Rectangle Width="100"
		    Height="100"
		    HorizontalAlignment="Left"
		    Fill="Red">
			<Rectangle.RenderTransform>
				<TranslateTransform x:Name="TheRedSquareTransform" />
			</Rectangle.RenderTransform>
		</Rectangle>

		<Rectangle Width="100"
		    Height="100"
		    HorizontalAlignment="Left"
		    Fill="Blue">
			<Rectangle.RenderTransform>
				<TranslateTransform x:Name="TheBlueSquareTransform" />
			</Rectangle.RenderTransform>
		</Rectangle>

		<TextBlock Margin="0,20"
		    Text="The expected result (you should see an animated GIF below if supported by the platform)" />
		<Image Source="BeginTime_MultipleAnimations_Expected.gif" />
	</StackPanel>
</Page>
