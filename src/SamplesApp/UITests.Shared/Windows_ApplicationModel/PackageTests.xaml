<UserControl x:Class="UITests.Shared.Windows_ApplicationModel.PackageTests"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_ApplicationModel"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">
	<UserControl.Resources>
		<Style x:Key="LabelStyle"
		    TargetType="TextBlock">
			<Setter Property="FontWeight" Value="Bold" />
		</Style>
	</UserControl.Resources>
	<StackPanel Margin="12"
	    Spacing="4">
		<TextBlock Style="{StaticResource LabelStyle}"
		    Text="Display Name" />
		<TextBlock Text="{x:Bind DisplayName}" />
		<TextBlock Style="{StaticResource LabelStyle}"
		    Text="Installed Path" />
		<TextBlock Text="{x:Bind InstalledPath}" />
		<TextBlock Style="{StaticResource LabelStyle}"
		    Text="Architecture" />
		<TextBlock Text="{x:Bind Architecture}" />
		<TextBlock Style="{StaticResource LabelStyle}"
		    Text="FamilyName" />
		<TextBlock Text="{x:Bind FamilyName}" />
		<TextBlock Style="{StaticResource LabelStyle}"
		    Text="FullName" />
		<TextBlock Text="{x:Bind FullName}" />
		<TextBlock Style="{StaticResource LabelStyle}"
		    Text="Name" />
		<TextBlock Text="{x:Bind Name}" />
		<TextBlock Style="{StaticResource LabelStyle}"
		    Text="ProductId" />
		<TextBlock Text="{x:Bind ProductId}" />
		<TextBlock Style="{StaticResource LabelStyle}"
		    Text="Publisher" />
		<TextBlock Text="{x:Bind Publisher}" />
		<TextBlock Style="{StaticResource LabelStyle}"
		    Text="PublisherId" />
		<TextBlock Text="{x:Bind PublisherId}" />
		<TextBlock Style="{StaticResource LabelStyle}"
		    Text="ResourceId" />
		<TextBlock Text="{x:Bind ResourceId}" />
		<TextBlock Style="{StaticResource LabelStyle}"
		    Text="Version" />
		<TextBlock Text="{x:Bind Version}" />
	</StackPanel>
</UserControl>
