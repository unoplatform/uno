<UserControl
    x:Class="UITests.Shared.Windows_ApplicationModel.Calls.PhoneCallHistoryEntryReaderTests"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:calls="using:Windows.ApplicationModel.Calls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_ApplicationModel.Calls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Button Click="ReadCallLog_Click">Read call log batch</Button>
        <TextBlock
            Name="uiErrorMsg"
            Grid.Row="1"
            Foreground="Red"
            Text=""
            TextWrapping="Wrap" />
        <ListView
            Grid.Row="2"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            ItemsSource="{x:Bind History}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="calls:PhoneCallHistoryEntry">
                    <Grid
                        Padding="8"
                        HorizontalAlignment="Stretch"
                        ColumnSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock>
                            <Run FontWeight="Bold" Text="Display name:" />
                            <Run Text="{x:Bind Address.DisplayName}" />
                        </TextBlock>
                        <TextBlock Grid.Row="1">
                            <Run FontWeight="Bold" Text="Raw address:" />
                            <Run Text="{x:Bind Address.RawAddress}" />
                        </TextBlock>
                        <TextBlock Grid.Row="2">
                            <Run FontWeight="Bold" Text="Start time:" />
                            <Run Text="{x:Bind StartTime}" />
                        </TextBlock>
                        <TextBlock Grid.Column="1">
                            <Run FontWeight="Bold" Text="Duration:" />
                            <Run Text="{x:Bind Duration}" />
                        </TextBlock>
                        <TextBlock Grid.Row="1" Grid.Column="1">
                            <Run FontWeight="Bold" Text="IsIncoming:" />
                            <Run Text="{x:Bind IsIncoming}" />
                        </TextBlock>
                        <TextBlock Grid.Row="2" Grid.Column="1">
                            <Run FontWeight="Bold" Text="IsMissed:" />
                            <Run Text="{x:Bind IsMissed}" />
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</UserControl>
