<UserControl x:Class="UITests.Shared.Windows_ApplicationModel.Chat.ComposeSms"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>
		<StackPanel Margin="0,0,0,0"
		    Orientation="Vertical">
			<TextBox PlaceholderText="Phone number"
			    Text="{x:Bind PhoneNumber, Mode=TwoWay}" />
			<Button Click="AddNumber_Click">Add phone number</Button>
			<TextBox Header="Message body"
			    PlaceholderText="Body"
			    Text="{x:Bind Body, Mode=TwoWay}" />
			<Button Click="ClearNumbers_Click">Clear phone numbers</Button>
			<Button Click="Compose_Click">Compose SMS</Button>
		</StackPanel>
		<ListView Grid.Row="1"
		    ItemsSource="{x:Bind PhoneNumbers}" />




	</Grid>
</UserControl>
