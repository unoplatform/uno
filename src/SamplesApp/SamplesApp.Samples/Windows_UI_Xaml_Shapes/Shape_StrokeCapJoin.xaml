<Page
    x:Class="SamplesApp.Windows_UI_Xaml_Shapes.Shape_StrokeCapJoin"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="16" Spacing="16">

            <!--  Line Caps  -->
            <TextBlock FontWeight="Bold" Text="StrokeStartLineCap / StrokeEndLineCap" />

            <StackPanel Spacing="8">
                <TextBlock Text="Flat (default)" />
                <Line
                    Stroke="Black"
                    StrokeEndLineCap="Flat"
                    StrokeStartLineCap="Flat"
                    StrokeThickness="10"
                    X1="20"
                    X2="200"
                    Y1="20"
                    Y2="20" />

                <TextBlock Text="Round" />
                <Line
                    Stroke="Blue"
                    StrokeEndLineCap="Round"
                    StrokeStartLineCap="Round"
                    StrokeThickness="10"
                    X1="20"
                    X2="200"
                    Y1="20"
                    Y2="20" />

                <TextBlock Text="Square" />
                <Line
                    Stroke="Green"
                    StrokeEndLineCap="Square"
                    StrokeStartLineCap="Square"
                    StrokeThickness="10"
                    X1="20"
                    X2="200"
                    Y1="20"
                    Y2="20" />

                <TextBlock Text="Triangle" />
                <Line
                    Stroke="Red"
                    StrokeEndLineCap="Triangle"
                    StrokeStartLineCap="Triangle"
                    StrokeThickness="10"
                    X1="20"
                    X2="200"
                    Y1="20"
                    Y2="20" />

                <TextBlock Text="Different: Start=Round, End=Square" />
                <Line
                    Stroke="Purple"
                    StrokeEndLineCap="Square"
                    StrokeStartLineCap="Round"
                    StrokeThickness="10"
                    X1="20"
                    X2="200"
                    Y1="20"
                    Y2="20" />
            </StackPanel>

            <!--  Line Joins  -->
            <TextBlock
                Margin="0,16,0,0"
                FontWeight="Bold"
                Text="StrokeLineJoin" />

            <StackPanel Spacing="8">
                <TextBlock Text="Miter (default)" />
                <Polyline
                    Fill="Transparent"
                    Points="20,50 60,10 100,50 140,10 180,50"
                    Stroke="Black"
                    StrokeLineJoin="Miter"
                    StrokeThickness="8" />

                <TextBlock Text="Bevel" />
                <Polyline
                    Fill="Transparent"
                    Points="20,50 60,10 100,50 140,10 180,50"
                    Stroke="Blue"
                    StrokeLineJoin="Bevel"
                    StrokeThickness="8" />

                <TextBlock Text="Round" />
                <Polyline
                    Fill="Transparent"
                    Points="20,50 60,10 100,50 140,10 180,50"
                    Stroke="Green"
                    StrokeLineJoin="Round"
                    StrokeThickness="8" />
            </StackPanel>

            <!--  Dash Caps  -->
            <TextBlock
                Margin="0,16,0,0"
                FontWeight="Bold"
                Text="StrokeDashCap" />

            <StackPanel Spacing="8">
                <TextBlock Text="Flat dash cap" />
                <Line
                    Stroke="Black"
                    StrokeDashArray="3 2"
                    StrokeDashCap="Flat"
                    StrokeThickness="8"
                    X1="20"
                    X2="280"
                    Y1="20"
                    Y2="20" />

                <TextBlock Text="Round dash cap" />
                <Line
                    Stroke="Blue"
                    StrokeDashArray="3 2"
                    StrokeDashCap="Round"
                    StrokeThickness="8"
                    X1="20"
                    X2="280"
                    Y1="20"
                    Y2="20" />

                <TextBlock Text="Square dash cap" />
                <Line
                    Stroke="Green"
                    StrokeDashArray="3 2"
                    StrokeDashCap="Square"
                    StrokeThickness="8"
                    X1="20"
                    X2="280"
                    Y1="20"
                    Y2="20" />

                <TextBlock Text="Triangle dash cap" />
                <Line
                    Stroke="Red"
                    StrokeDashArray="3 2"
                    StrokeDashCap="Triangle"
                    StrokeThickness="8"
                    X1="20"
                    X2="280"
                    Y1="20"
                    Y2="20" />
            </StackPanel>

            <!--  Dash Offset  -->
            <TextBlock
                Margin="0,16,0,0"
                FontWeight="Bold"
                Text="StrokeDashOffset" />

            <StackPanel Spacing="8">
                <TextBlock Text="Offset=0" />
                <Line
                    Stroke="Black"
                    StrokeDashArray="4 2"
                    StrokeDashOffset="0"
                    StrokeThickness="6"
                    X1="20"
                    X2="280"
                    Y1="20"
                    Y2="20" />

                <TextBlock Text="Offset=2" />
                <Line
                    Stroke="Black"
                    StrokeDashArray="4 2"
                    StrokeDashOffset="2"
                    StrokeThickness="6"
                    X1="20"
                    X2="280"
                    Y1="20"
                    Y2="20" />

                <TextBlock Text="Offset=4" />
                <Line
                    Stroke="Black"
                    StrokeDashArray="4 2"
                    StrokeDashOffset="4"
                    StrokeThickness="6"
                    X1="20"
                    X2="280"
                    Y1="20"
                    Y2="20" />
            </StackPanel>

            <!--  Dashed Endpoint Caps: WinUI uses StartCap/EndCap at path endpoints, DashCap only at internal boundaries  -->
            <TextBlock
                Margin="0,16,0,0"
                FontWeight="Bold"
                Text="Dashed Endpoint Caps (DashCap vs StartCap/EndCap)" />

            <StackPanel Spacing="8">
                <TextBlock Text="DashCap=Round, Start/EndCap=Flat (default) — endpoints should be FLAT" />
                <Grid Height="40" Background="LightGray">
                    <Line
                        Stroke="DarkRed"
                        StrokeDashArray="3 2"
                        StrokeDashCap="Round"
                        StrokeThickness="16"
                        X1="30"
                        X2="270"
                        Y1="20"
                        Y2="20" />
                </Grid>

                <TextBlock Text="DashCap=Round, StartCap=Round, EndCap=Round — all caps round (reference)" />
                <Grid Height="40" Background="LightGray">
                    <Line
                        Stroke="DarkBlue"
                        StrokeDashArray="3 2"
                        StrokeDashCap="Round"
                        StrokeEndLineCap="Round"
                        StrokeStartLineCap="Round"
                        StrokeThickness="16"
                        X1="30"
                        X2="270"
                        Y1="20"
                        Y2="20" />
                </Grid>

                <TextBlock Text="DashCap=Round, StartCap=Square, EndCap=Flat — start=square, end=flat" />
                <Grid Height="40" Background="LightGray">
                    <Line
                        Stroke="DarkGreen"
                        StrokeDashArray="3 2"
                        StrokeDashCap="Round"
                        StrokeEndLineCap="Flat"
                        StrokeStartLineCap="Square"
                        StrokeThickness="16"
                        X1="30"
                        X2="270"
                        Y1="20"
                        Y2="20" />
                </Grid>

                <TextBlock Text="DashCap=Square, Start/EndCap=Flat — endpoints should be FLAT" />
                <Grid Height="40" Background="LightGray">
                    <Line
                        Stroke="Purple"
                        StrokeDashArray="3 2"
                        StrokeDashCap="Square"
                        StrokeThickness="16"
                        X1="30"
                        X2="270"
                        Y1="20"
                        Y2="20" />
                </Grid>

                <TextBlock Text="DashCap=Flat, StartCap=Round, EndCap=Round — endpoints round, internal flat" />
                <Grid Height="40" Background="LightGray">
                    <Line
                        Stroke="Teal"
                        StrokeDashArray="3 2"
                        StrokeDashCap="Flat"
                        StrokeEndLineCap="Round"
                        StrokeStartLineCap="Round"
                        StrokeThickness="16"
                        X1="30"
                        X2="270"
                        Y1="20"
                        Y2="20" />
                </Grid>

                <TextBlock Text="Path: DashCap=Round, Start/EndCap=Flat — endpoints should be FLAT" />
                <Grid Height="100" Background="LightGray">
                    <Path
                        Data="M 30,50 L 120,20 L 220,80"
                        Stroke="Crimson"
                        StrokeDashArray="2 1"
                        StrokeDashCap="Round"
                        StrokeThickness="12" />
                </Grid>
            </StackPanel>

            <!--  Zero-Length Dash at Endpoint Edge Cases  -->
            <!--  When a dashed line's endpoint falls in a gap (or at a gap/dash boundary),  -->
            <!--  WinUI creates a zero-length dash: DashCap facing backward + EndCap facing forward.  -->
            <!--  Line length=240, pattern [48,32] (StrokeDashArray="3 2", Thickness=16):  -->
            <!--  240/80=3 exactly. Dashes at [0-48],[80-128],[160-208]. Gap ends at 240=endpoint.  -->
            <TextBlock
                Margin="0,16,0,0"
                FontWeight="Bold"
                Text="Zero-Length Dash at Endpoint (gap boundary)" />

            <StackPanel Spacing="8">
                <!--  Case 1: All caps Round — endpoint at gap end  -->
                <!--  Previously broken: calling condition skipped when all caps matched  -->
                <TextBlock Text="All Round caps, endpoint in gap — full circle at end (backward+forward)" />
                <Grid Height="40" Background="LightGray">
                    <Line
                        Stroke="DarkRed"
                        StrokeDashArray="3 2"
                        StrokeDashCap="Round"
                        StrokeEndLineCap="Round"
                        StrokeStartLineCap="Round"
                        StrokeThickness="16"
                        X1="30"
                        X2="270"
                        Y1="20"
                        Y2="20" />
                </Grid>

                <!--  Case 2: DashCap=Round, EndCap=Flat — only backward semicircle at end  -->
                <TextBlock Text="DashCap=Round, EndCap=Flat, endpoint in gap — semicircle at end (backward only)" />
                <Grid Height="40" Background="LightGray">
                    <Line
                        Stroke="DarkBlue"
                        StrokeDashArray="3 2"
                        StrokeDashCap="Round"
                        StrokeThickness="16"
                        X1="30"
                        X2="270"
                        Y1="20"
                        Y2="20" />
                </Grid>

                <!--  Case 3: DashCap=Square, EndCap=Round — Square backward + Round forward  -->
                <TextBlock Text="DashCap=Square, EndCap=Round, endpoint in gap — square back + round fwd" />
                <Grid Height="40" Background="LightGray">
                    <Line
                        Stroke="DarkGreen"
                        StrokeDashArray="3 2"
                        StrokeDashCap="Square"
                        StrokeEndLineCap="Round"
                        StrokeThickness="16"
                        X1="30"
                        X2="270"
                        Y1="20"
                        Y2="20" />
                </Grid>

                <!--  Case 4: DashCap=Flat, EndCap=Round — only forward semicircle at end  -->
                <TextBlock Text="DashCap=Flat, EndCap=Round, endpoint in gap — semicircle at end (forward only)" />
                <Grid Height="40" Background="LightGray">
                    <Line
                        Stroke="Teal"
                        StrokeDashArray="3 2"
                        StrokeDashCap="Flat"
                        StrokeEndLineCap="Round"
                        StrokeThickness="16"
                        X1="30"
                        X2="270"
                        Y1="20"
                        Y2="20" />
                </Grid>

                <!--  Case 5: All Flat — nothing extra at endpoint (optimization: skip entirely)  -->
                <TextBlock Text="All Flat caps, endpoint in gap — no protrusion at end" />
                <Grid Height="40" Background="LightGray">
                    <Line
                        Stroke="Gray"
                        StrokeDashArray="3 2"
                        StrokeDashCap="Flat"
                        StrokeThickness="16"
                        X1="30"
                        X2="270"
                        Y1="20"
                        Y2="20" />
                </Grid>
            </StackPanel>

            <!--  Endpoint at exact dash end — IsEndpointInRenderedDash should return true  -->
            <!--  Line length=208, pattern [48,32]: dashes at [0-48],[80-128],[160-208]. Endpoint at 208 = dash end.  -->
            <TextBlock
                Margin="0,16,0,0"
                FontWeight="Bold"
                Text="Endpoint at Exact Dash End (no zero-length dash)" />

            <StackPanel Spacing="8">
                <!--  Case 6: Endpoint at dash end, DashCap=Round, EndCap=Flat — swap to Flat  -->
                <TextBlock Text="DashCap=Round, EndCap=Flat, endpoint at dash end — flat end (cap swap)" />
                <Grid Height="40" Background="LightGray">
                    <Line
                        Stroke="DarkRed"
                        StrokeDashArray="3 2"
                        StrokeDashCap="Round"
                        StrokeThickness="16"
                        X1="30"
                        X2="238"
                        Y1="20"
                        Y2="20" />
                </Grid>

                <!--  Case 7: Endpoint at dash end, all Round — no swap needed, just Round  -->
                <TextBlock Text="All Round, endpoint at dash end — round end (no change needed)" />
                <Grid Height="40" Background="LightGray">
                    <Line
                        Stroke="DarkBlue"
                        StrokeDashArray="3 2"
                        StrokeDashCap="Round"
                        StrokeEndLineCap="Round"
                        StrokeStartLineCap="Round"
                        StrokeThickness="16"
                        X1="30"
                        X2="238"
                        Y1="20"
                        Y2="20" />
                </Grid>
            </StackPanel>

            <!--  Short line where endpoint lands in gap  -->
            <!--  Line length=60, pattern [48,32]: one dash [0-48], gap [48-60]. Endpoint in gap.  -->
            <TextBlock
                Margin="0,16,0,0"
                FontWeight="Bold"
                Text="Short Line — Endpoint in Gap" />

            <StackPanel Spacing="8">
                <TextBlock Text="Short line (60px), DashCap=Round — no extra at end (mid-gap)" />
                <Grid Height="40" Background="LightGray">
                    <Line
                        Stroke="Purple"
                        StrokeDashArray="3 2"
                        StrokeDashCap="Round"
                        StrokeThickness="16"
                        X1="30"
                        X2="90"
                        Y1="20"
                        Y2="20" />
                </Grid>

                <TextBlock Text="Short line (60px), all Round — no extra at end (mid-gap)" />
                <Grid Height="40" Background="LightGray">
                    <Line
                        Stroke="Crimson"
                        StrokeDashArray="3 2"
                        StrokeDashCap="Round"
                        StrokeEndLineCap="Round"
                        StrokeStartLineCap="Round"
                        StrokeThickness="16"
                        X1="30"
                        X2="90"
                        Y1="20"
                        Y2="20" />
                </Grid>
            </StackPanel>

            <!--  Dash offset shifting endpoint into gap  -->
            <!--  Line length=208, pattern [48,32], offset=1.5 (24px).  -->
            <!--  Shifted pattern starts at -24: dash[-24,24], gap[24,56], dash[56,104], gap[104,136], dash[136,184], gap[184,216].  -->
            <!--  Endpoint 208 is in gap [184,216] — zero-length dash needed.  -->
            <TextBlock
                Margin="0,16,0,0"
                FontWeight="Bold"
                Text="Dash Offset Shifting Endpoint into Gap" />

            <StackPanel Spacing="8">
                <TextBlock Text="Length=208, offset=1.5 — endpoint in mid-gap (no extra at end)" />
                <Grid Height="40" Background="LightGray">
                    <Line
                        Stroke="DarkOrange"
                        StrokeDashArray="3 2"
                        StrokeDashCap="Round"
                        StrokeDashOffset="1.5"
                        StrokeThickness="16"
                        X1="30"
                        X2="238"
                        Y1="20"
                        Y2="20" />
                </Grid>
            </StackPanel>

            <!--  Multi-segment path endpoint in gap  -->
            <TextBlock
                Margin="0,16,0,0"
                FontWeight="Bold"
                Text="Path Endpoint in Gap" />

            <StackPanel Spacing="8">
                <TextBlock Text="Path, DashCap=Round — zero-length dash at path endpoint" />
                <Grid Height="100" Background="LightGray">
                    <Path
                        Data="M 30,50 L 150,20 L 270,50"
                        Stroke="DarkViolet"
                        StrokeDashArray="3 2"
                        StrokeDashCap="Round"
                        StrokeEndLineCap="Round"
                        StrokeStartLineCap="Round"
                        StrokeThickness="12" />
                </Grid>

                <TextBlock Text="Path, DashCap=Square, EndCap=Round — square back + round fwd at end" />
                <Grid Height="100" Background="LightGray">
                    <Path
                        Data="M 30,50 L 150,20 L 270,50"
                        Stroke="Maroon"
                        StrokeDashArray="3 2"
                        StrokeDashCap="Square"
                        StrokeEndLineCap="Round"
                        StrokeThickness="12" />
                </Grid>
            </StackPanel>

            <!--  Issue #5426 repro: Path with round caps and joins  -->
            <TextBlock
                Margin="0,16,0,0"
                FontWeight="Bold"
                Text="Issue #5426 repro: Path with Round caps and joins" />
            <Path
                Data="M 20,80 L 80,20 L 140,80 L 200,20"
                Stroke="DarkBlue"
                StrokeEndLineCap="Round"
                StrokeLineJoin="Round"
                StrokeStartLineCap="Round"
                StrokeThickness="8" />

            <!--  StrokeMiterLimit  -->
            <TextBlock
                Margin="0,16,0,0"
                FontWeight="Bold"
                Text="StrokeMiterLimit" />

            <StackPanel Spacing="8">
                <!--  Sharp angle (V shape ~53°)  -->
                <TextBlock Text="Sharp V (53°) — MiterLimit=10 (default)" />
                <Grid Height="70" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="20,60 50,10 80,60"
                        Stroke="Black"
                        StrokeLineJoin="Miter"
                        StrokeMiterLimit="10"
                        StrokeThickness="10" />
                </Grid>

                <TextBlock Text="Sharp V (53°) — MiterLimit=4" />
                <Grid Height="70" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="20,60 50,10 80,60"
                        Stroke="Black"
                        StrokeLineJoin="Miter"
                        StrokeMiterLimit="4"
                        StrokeThickness="10" />
                </Grid>

                <TextBlock Text="Sharp V (53°) — MiterLimit=2" />
                <Grid Height="70" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="20,60 50,10 80,60"
                        Stroke="Black"
                        StrokeLineJoin="Miter"
                        StrokeMiterLimit="2"
                        StrokeThickness="10" />
                </Grid>

                <TextBlock Text="Sharp V (53°) — MiterLimit=1 (bevel fallback)" />
                <Grid Height="70" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="20,60 50,10 80,60"
                        Stroke="Black"
                        StrokeLineJoin="Miter"
                        StrokeMiterLimit="1"
                        StrokeThickness="10" />
                </Grid>

                <!--  Very sharp angle (~15°) — miter extends far  -->
                <TextBlock Text="Very sharp (~15°) — MiterLimit=10 (default)" />
                <Grid Height="90" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="20,80 50,10 80,80"
                        Stroke="Red"
                        StrokeLineJoin="Miter"
                        StrokeMiterLimit="10"
                        StrokeThickness="14" />
                </Grid>

                <TextBlock Text="Very sharp (~15°) — MiterLimit=4" />
                <Grid Height="90" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="20,80 50,10 80,80"
                        Stroke="Red"
                        StrokeLineJoin="Miter"
                        StrokeMiterLimit="4"
                        StrokeThickness="14" />
                </Grid>

                <TextBlock Text="Very sharp (~15°) — MiterLimit=2" />
                <Grid Height="90" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="20,80 50,10 80,80"
                        Stroke="Red"
                        StrokeLineJoin="Miter"
                        StrokeMiterLimit="2"
                        StrokeThickness="14" />
                </Grid>

                <TextBlock Text="Very sharp (~15°) — MiterLimit=1" />
                <Grid Height="90" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="20,80 50,10 80,80"
                        Stroke="Red"
                        StrokeLineJoin="Miter"
                        StrokeMiterLimit="1"
                        StrokeThickness="14" />
                </Grid>

                <!--  Wide angle (~120°) — miter is short  -->
                <TextBlock Text="Wide angle (~120°) — MiterLimit=10 (default)" />
                <Grid Height="60" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="20,20 100,50 180,20"
                        Stroke="Blue"
                        StrokeLineJoin="Miter"
                        StrokeMiterLimit="10"
                        StrokeThickness="10" />
                </Grid>

                <TextBlock Text="Wide angle (~120°) — MiterLimit=1" />
                <Grid Height="60" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="20,20 100,50 180,20"
                        Stroke="Blue"
                        StrokeLineJoin="Miter"
                        StrokeMiterLimit="1"
                        StrokeThickness="10" />
                </Grid>

                <!--  Multiple joins with different angles  -->
                <TextBlock Text="Zigzag (mixed angles) — MiterLimit=10 (default)" />
                <Grid Height="80" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="10,60 40,10 70,60 100,10 130,60 160,10 190,60"
                        Stroke="DarkGreen"
                        StrokeLineJoin="Miter"
                        StrokeMiterLimit="10"
                        StrokeThickness="8" />
                </Grid>

                <TextBlock Text="Zigzag (mixed angles) — MiterLimit=2" />
                <Grid Height="80" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="10,60 40,10 70,60 100,10 130,60 160,10 190,60"
                        Stroke="DarkGreen"
                        StrokeLineJoin="Miter"
                        StrokeMiterLimit="2"
                        StrokeThickness="8" />
                </Grid>

                <!--  Thick stroke to exaggerate miter differences  -->
                <TextBlock Text="Thick stroke (20px), sharp angle — MiterLimit=10" />
                <Grid Height="100" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="30,80 80,15 130,80"
                        Stroke="Crimson"
                        StrokeLineJoin="Miter"
                        StrokeMiterLimit="10"
                        StrokeThickness="20" />
                </Grid>

                <TextBlock Text="Thick stroke (20px), sharp angle — MiterLimit=4" />
                <Grid Height="100" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="30,80 80,15 130,80"
                        Stroke="Crimson"
                        StrokeLineJoin="Miter"
                        StrokeMiterLimit="4"
                        StrokeThickness="20" />
                </Grid>

                <TextBlock Text="Thick stroke (20px), sharp angle — MiterLimit=2" />
                <Grid Height="100" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="30,80 80,15 130,80"
                        Stroke="Crimson"
                        StrokeLineJoin="Miter"
                        StrokeMiterLimit="2"
                        StrokeThickness="20" />
                </Grid>

                <!--  Right angle (90°)  -->
                <TextBlock Text="Right angle (90°) — MiterLimit=10" />
                <Grid Height="80" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="20,20 20,60 80,60"
                        Stroke="Teal"
                        StrokeLineJoin="Miter"
                        StrokeMiterLimit="10"
                        StrokeThickness="12" />
                </Grid>

                <TextBlock Text="Right angle (90°) — MiterLimit=1" />
                <Grid Height="80" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="20,20 20,60 80,60"
                        Stroke="Teal"
                        StrokeLineJoin="Miter"
                        StrokeMiterLimit="1"
                        StrokeThickness="12" />
                </Grid>

                <!--  Path with MiterLimit  -->
                <TextBlock Text="Path zigzag — Miter, MiterLimit=10" />
                <Grid Height="100" Background="LightGray">
                    <Path
                        Data="M 20,80 L 60,15 L 100,80 L 140,15 L 180,80"
                        Stroke="DarkBlue"
                        StrokeLineJoin="Miter"
                        StrokeMiterLimit="10"
                        StrokeThickness="10" />
                </Grid>

                <TextBlock Text="Path zigzag — Miter, MiterLimit=2" />
                <Grid Height="100" Background="LightGray">
                    <Path
                        Data="M 20,80 L 60,15 L 100,80 L 140,15 L 180,80"
                        Stroke="DarkBlue"
                        StrokeLineJoin="Miter"
                        StrokeMiterLimit="2"
                        StrokeThickness="10" />
                </Grid>
            </StackPanel>

            <!--  Round Join comparison  -->
            <TextBlock
                Margin="0,16,0,0"
                FontWeight="Bold"
                Text="StrokeLineJoin=Round (comparison)" />

            <StackPanel Spacing="8">
                <TextBlock Text="Sharp V (53°) — Round" />
                <Grid Height="70" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="20,60 50,10 80,60"
                        Stroke="Black"
                        StrokeLineJoin="Round"
                        StrokeThickness="10" />
                </Grid>

                <TextBlock Text="Very sharp (~15°) — Round" />
                <Grid Height="90" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="20,80 50,10 80,80"
                        Stroke="Red"
                        StrokeLineJoin="Round"
                        StrokeThickness="14" />
                </Grid>

                <TextBlock Text="Wide angle (~120°) — Round" />
                <Grid Height="60" Background="LightGray">
                    <Polyline
                        Fill="Transparent"
                        Points="20,20 100,50 180,20"
                        Stroke="Blue"
                        StrokeLineJoin="Round"
                        StrokeThickness="10" />
                </Grid>

                <TextBlock Text="Zigzag — Round" />
