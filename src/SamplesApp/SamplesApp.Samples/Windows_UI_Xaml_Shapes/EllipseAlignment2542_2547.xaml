<Page
    x:Class="UITests.Windows_UI_Xaml_Shapes.EllipseAlignment2542_2547"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Margin="10" Spacing="10">
        <TextBlock FontSize="15">
            This is an illustration of Github bugs<Hyperlink NavigateUri="https://github.com/unoplatform/uno/issues/2542">#2542 (iOS)</Hyperlink>
            and<Hyperlink NavigateUri="https://github.com/unoplatform/uno/issues/2547">#2547 (Android)</Hyperlink>
        </TextBlock>

        <TextBlock FontSize="14" Foreground="BlueViolet">
            --> You should see a white circle, containing an outlined red circle. THEY SHOULD BE PERFECTLY CENTERED.
        </TextBlock>

        <Border Height="100" Background="Blue">
            <Grid
                Width="74"
                Height="74"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <!--  [iOS] BUG #2542 : This White ellipse isn't visible on iOS with latest Uno.UI dev  -->
                <Ellipse
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Fill="White" />

                <!--  [Android] BUG #2547 : This Red stroked ellipse isn't correctly centered on Android with latest Uno.UI dev  -->
                <Ellipse
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Fill="Transparent"
                    Opacity=".5"
                    Stroke="Red"
                    StrokeThickness="5" />

                <Rectangle
                    Width="3"
                    VerticalAlignment="Stretch"
                    Fill="DarkGreen"
                    Opacity="0.25" />
                <Rectangle
                    Height="3"
                    HorizontalAlignment="Stretch"
                    Fill="DarkGreen"
                    Opacity="0.25" />
            </Grid>
        </Border>

        <Border Height="100" Background="Blue">
            <Grid
                Width="74"
                Height="74"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <Ellipse
                    Width="74"
                    Height="74"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Fill="White" />

                <Ellipse
                    Width="64"
                    Height="64"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Fill="Red" />

                <Ellipse
                    Width="54"
                    Height="54"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Fill="White" />

                <Rectangle
                    Width="3"
                    VerticalAlignment="Stretch"
                    Fill="DarkGreen"
                    Opacity="0.25" />
                <Rectangle
                    Height="3"
                    HorizontalAlignment="Stretch"
                    Fill="DarkGreen"
                    Opacity="0.25" />
            </Grid>
        </Border>

    </StackPanel>
</Page>
