<Page
    x:Class="SamplesApp.Windows_UI_Xaml_Shapes.StretchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel>
            <TextBlock FontWeight="ExtraBold">None</TextBlock>
            <Slider
                x:Name="sliderNone"
                Maximum="300"
                Minimum="25"
                Value="150" />
            <Border
                HorizontalAlignment="Center"
                Background="DarkSeaGreen"
                BorderBrush="BlueViolet"
                BorderThickness="3">
                <Path
                    x:Name="None"
                    Width="{Binding Value, ElementName=sliderNone}"
                    Height="100"
                    Data="M20,20 L130,20 L130,80 L20,80 Z"
                    Fill="Cornsilk"
                    Stretch="None"
                    Stroke="Blue"
                    StrokeThickness="10" />
            </Border>
            <Border
                HorizontalAlignment="Center"
                Background="DarkSeaGreen"
                BorderBrush="BlueViolet"
                BorderThickness="3">
                <Path
                    x:Name="NoneNormal"
                    Data="M20,20 L130,20 L130,80 L20,80 Z"
                    Fill="Cornsilk"
                    Stretch="None"
                    Stroke="Blue"
                    StrokeDashArray=".1,.2,.3"
                    StrokeThickness="10" />
            </Border>
            <Border
                HorizontalAlignment="Center"
                Background="DarkSeaGreen"
                BorderBrush="BlueViolet"
                BorderThickness="3">
                <Path
                    x:Name="NoneBig"
                    Width="300"
                    Data="M20,20 L130,20 L130,80 L20,80 Z"
                    Fill="Cornsilk"
                    Stretch="None"
                    Stroke="Blue"
                    StrokeThickness="10" />
            </Border>
            <Border
                HorizontalAlignment="Center"
                Background="DarkSeaGreen"
                BorderBrush="BlueViolet"
                BorderThickness="3">
                <Path
                    x:Name="NoneSmall"
                    Data="M20,20 L130,20 L130,80 L20,80 Z"
                    Fill="Cornsilk"
                    Stretch="None"
                    Stroke="Blue"
                    StrokeThickness="2" />
            </Border>
            <TextBlock FontWeight="ExtraBold">Fill</TextBlock>
            <Slider
                x:Name="sliderFillNormal"
                Maximum="600"
                Minimum="100"
                Value="450" />
            <Border
                HorizontalAlignment="Center"
                Background="DarkSeaGreen"
                BorderBrush="BlueViolet"
                BorderThickness="3">
                <Path
                    x:Name="FillNormal"
                    Width="{Binding Value, ElementName=sliderFillNormal}"
                    Height="100"
                    Data="M20,20 L130,20 L130,80 L20,80 Z"
                    Fill="Cornsilk"
                    Stretch="Fill"
                    Stroke="Blue"
                    StrokeThickness="10" />
            </Border>
            <Border
                HorizontalAlignment="Center"
                Background="DarkSeaGreen"
                BorderBrush="BlueViolet"
                BorderThickness="3">
                <Path
                    x:Name="FillBig"
                    Width="300"
                    Height="30"
                    Data="M20,20 L130,20 L130,80 L20,80 Z"
                    Fill="Cornsilk"
                    Stretch="Fill"
                    Stroke="Blue"
                    StrokeThickness="10" />
            </Border>
            <Border
                HorizontalAlignment="Center"
                Background="DarkSeaGreen"
                BorderBrush="BlueViolet"
                BorderThickness="3">
                <Path
                    x:Name="FillSmall"
                    Width="50"
                    Height="10"
                    Data="M20,20 L130,20 L130,80 L20,80 Z"
                    Fill="Cornsilk"
                    Stretch="Fill"
                    Stroke="Blue"
                    StrokeThickness="2" />
            </Border>
            <TextBlock FontWeight="ExtraBold">UniformToFill</TextBlock>
            <Slider
                x:Name="sliderUniformToFillNormal"
                Maximum="300"
                Minimum="100"
                Value="125" />
            <Border
                HorizontalAlignment="Center"
                Background="DarkSeaGreen"
                BorderBrush="BlueViolet"
                BorderThickness="3">
                <Path
                    x:Name="UniformToFillNormal"
                    Width="{Binding Value, ElementName=sliderUniformToFillNormal}"
                    Height="100"
                    Data="M20,20 L130,20 L130,80 L20,80 Z"
                    Fill="Cornsilk"
                    Stretch="UniformToFill"
                    Stroke="Blue"
                    StrokeThickness="10" />
            </Border>
            <Border
                HorizontalAlignment="Center"
                Background="DarkSeaGreen"
                BorderBrush="BlueViolet"
                BorderThickness="3">
                <Path
                    x:Name="UniformToFillBig"
                    Width="600"
                    Height="150"
                    Data="M20,20 L130,20 L130,80 L20,80 Z"
                    Fill="Cornsilk"
                    Stretch="UniformToFill"
                    Stroke="Blue"
                    StrokeThickness="10" />
            </Border>
            <Border
                HorizontalAlignment="Center"
                Background="DarkSeaGreen"
                BorderBrush="BlueViolet"
                BorderThickness="3">
                <Path
                    x:Name="UniformToFillSmall"
                    Width="50"
                    Height="100"
                    Data="M20,20 L130,20 L130,80 L20,80 Z"
                    Fill="Cornsilk"
                    Stretch="UniformToFill"
                    Stroke="Blue"
                    StrokeThickness="10" />
            </Border>
            <TextBlock FontWeight="ExtraBold">Uniform</TextBlock>
            <Slider
                x:Name="sliderUniformNormal"
                Maximum="800"
                Minimum="40"
                Value="150" />
            <Border
                HorizontalAlignment="Center"
                Background="DarkSeaGreen"
                BorderBrush="BlueViolet"
                BorderThickness="3">
                <Path
                    x:Name="UniformNormal"
                    Width="{Binding Value, ElementName=sliderUniformNormal}"
                    Height="100"
                    Data="M20,20 L130,20 L130,80 L20,80 Z"
                    Fill="Cornsilk"
                    Stretch="Uniform"
                    Stroke="Blue"
                    StrokeThickness="10" />
            </Border>
            <Border
                HorizontalAlignment="Center"
                Background="DarkSeaGreen"
                BorderBrush="BlueViolet"
                BorderThickness="3">
                <Path
                    x:Name="UniformBig"
                    Width="600"
                    Height="200"
                    Data="M20,20 L130,20 L130,80 L20,80 Z"
                    Fill="Cornsilk"
                    Stretch="Uniform"
                    Stroke="Blue"
                    StrokeThickness="10" />
            </Border>
            <Border
                HorizontalAlignment="Center"
                Background="DarkSeaGreen"
                BorderBrush="BlueViolet"
                BorderThickness="3">
                <Path
                    x:Name="UniformSmall"
                    Width="50"
                    Height="100"
                    Data="M20,20 L130,20 L130,80 L20,80 Z"
                    Fill="Cornsilk"
                    Stretch="Uniform"
                    Stroke="Blue"
                    StrokeThickness="10" />
            </Border>
            <TextBlock FontWeight="ExtraBold">Polygon</TextBlock>
            <Border
                HorizontalAlignment="Center"
                BorderBrush="BlueViolet"
                BorderThickness="3">
                <Polygon
                    Width="300"
                    Height="100"
                    Fill="Red"
                    FillRule="EvenOdd"
                    Points="144,48 200,222 53,114 235,114 88,222"
                    Stretch="Uniform" />
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,.75">
                        <GradientStop Offset=".2" Color="Pink" />
                        <GradientStop Offset=".6" Color="White" />
                        <GradientStop Offset="1" Color="Red" />
                    </LinearGradientBrush>
                    <!--<ImageBrush ImageSource="https://pbs.twimg.com/profile_images/908795482067144705/xFHjZZNS_400x400.jpg" />-->
                </Border.Background>
            </Border>
            <Border
                HorizontalAlignment="Center"
                Background="Pink"
                BorderBrush="BlueViolet"
                BorderThickness="3">
                <Polygon
                    Width="130"
                    Height="100"
                    Points="144,48 200,222 53,114 235,114 88,222"
                    Stretch="UniformToFill">
                    <Polygon.Fill>
                        <LinearGradientBrush StartPoint="0,.75">
                            <GradientStop Offset=".2" Color="Red" />
                            <GradientStop Offset=".4" Color="Blue" />
                            <GradientStop Offset="1" Color="#FF51FF70" />
                        </LinearGradientBrush>
                        <!--<ImageBrush ImageSource="https://pbs.twimg.com/profile_images/908795482067144705/xFHjZZNS_400x400.jpg" />-->
                    </Polygon.Fill>
                </Polygon>
            </Border>
            <Border
                HorizontalAlignment="Center"
                Background="Pink"
                BorderBrush="BlueViolet"
                BorderThickness="3">
                <Ellipse
                    Width="145"
                    Height="100"
                    Fill="Green"
                    Stretch="UniformToFill" />
            </Border>

            <Canvas
                Width="300"
                Height="80"
                Background="LightBlue">
                <Line
                    Stroke="Black"
                    StrokeThickness="4"
                    X1="10"
                    X2="50"
                    Y1="10"
                    Y2="50" />

                <Line
                    Canvas.Left="100"
                    Stroke="Blue"
                    StrokeThickness="4"
                    X1="10"
                    X2="50"
                    Y1="10"
                    Y2="50" />

                <Line
                    Stroke="Black"
                    StrokeThickness="4"
                    X1="10"
                    X2="150"
                    Y1="60"
                    Y2="60" />
            </Canvas>

            <Ellipse
                Width="50"
                Height="50"
                Fill="Orange" />

            <Rectangle
                Width="50"
                Height="50"
                Fill="LightSeaGreen"
                RadiusX="10"
                RadiusY="10" />

            <Polygon
                Width="50"
                Fill="Gold"
                Points="98,118,122,130,117,104,136,86,110,82,98,58,86,82,60,86,79,104,74,130,98,118"
                Stretch="Uniform" />

            <Path
                Width="50"
                Data="M492.719,166.008c0-73.486-59.573-133.056-133.059-133.056c-47.985,0-89.891,25.484-113.302,63.569 c-23.408-38.085-65.332-63.569-113.316-63.569C59.556,32.952,0,92.522,0,166.008c0,40.009,17.729,75.803,45.671,100.178 l188.545,188.553c3.22,3.22,7.587,5.029,12.142,5.029c4.555,0,8.922-1.809,12.142-5.029l188.545-188.553 C474.988,241.811,492.719,206.017,492.719,166.008z"
                Fill="Crimson"
                Stretch="Uniform" />

            <Path
                Width="50"
                Data="M492.719,166.008c0-73.486-59.573-133.056-133.059-133.056c-47.985,0-89.891,25.484-113.302,63.569 c-23.408-38.085-65.332-63.569-113.316-63.569C59.556,32.952,0,92.522,0,166.008c0,40.009,17.729,75.803,45.671,100.178 l188.545,188.553c3.22,3.22,7.587,5.029,12.142,5.029c4.555,0,8.922-1.809,12.142-5.029l188.545-188.553 C474.988,241.811,492.719,206.017,492.719,166.008z"
                Fill="Crimson"
                Stretch="UniformToFill"
                Stroke="DarkCyan"
                StrokeThickness="89" />

            <Path
                Width="50"
                Data="M492.719,166.008c0-73.486-59.573-133.056-133.059-133.056c-47.985,0-89.891,25.484-113.302,63.569 c-23.408-38.085-65.332-63.569-113.316-63.569C59.556,32.952,0,92.522,0,166.008c0,40.009,17.729,75.803,45.671,100.178 l188.545,188.553c3.22,3.22,7.587,5.029,12.142,5.029c4.555,0,8.922-1.809,12.142-5.029l188.545-188.553 C474.988,241.811,492.719,206.017,492.719,166.008z"
                Fill="Crimson"
                Stretch="UniformToFill"
                Stroke="ForestGreen"
                StrokeThickness="2.5" />

        </StackPanel>
    </ScrollViewer>
</Page>
