<Page
    x:Class="UITests.Shared.Windows_UI_Xaml_Input.RoutedEvents.RoutedEvent_Focus"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UITests.Shared.Windows_UI_Xaml_Input.RoutedEvents"
    x:Name="focusPage">

    <Grid>
        <TextBlock>
            Root:<LineBreak />
            <Run x:Name="txtRoot" />
        </TextBlock>

        <local:RoutedEvent_FocusControl
            Width="300"
            Height="300"
            Opacity="0.85" />

        <Button
            x:Name="btnOut"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom">
            (btnOut) Focus this
        </Button>
    </Grid>
</Page>
