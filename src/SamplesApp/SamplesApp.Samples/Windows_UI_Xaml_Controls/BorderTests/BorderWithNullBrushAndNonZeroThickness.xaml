<Page
    x:Class="UITests.Windows_UI_Xaml_Controls.BorderTests.BorderWithNullBrushAndNonZeroThickness"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.BorderTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel Spacing="50">
        <TextBlock Text="The expected result here is that both all TextBlocks below are aligned together (both are centered horizontally)" />
        <TextBlock Text="Initially, the first two have no borders, and the next two have red borders with different thickness" />
        <Button Click="Button_Click" Content="Click this button to toggle the state of the first two with the next two. Alignment should still be perserved." />
        <Button Click="Button2_Click" Content="Click this button to swap border thicknesses. Alignment should still be perserved." />

        <Border
            x:Name="border1"
            BorderBrush="{x:Null}"
            BorderThickness="10">
            <TextBlock HorizontalAlignment="Center" Text="Text" />
        </Border>
        <Border
            x:Name="border2"
            BorderBrush="{x:Null}"
            BorderThickness="30">
            <TextBlock HorizontalAlignment="Center" Text="Text" />
        </Border>

        <Border
            x:Name="border3"
            BorderBrush="Red"
            BorderThickness="10">
            <TextBlock HorizontalAlignment="Center" Text="Text" />
        </Border>
        <Border
            x:Name="border4"
            BorderBrush="Red"
            BorderThickness="30">
            <TextBlock HorizontalAlignment="Center" Text="Text" />
        </Border>
    </StackPanel>
</Page>
