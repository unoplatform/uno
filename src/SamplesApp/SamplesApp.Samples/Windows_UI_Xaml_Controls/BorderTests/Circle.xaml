<Page
    x:Class="Uno.UI.Samples.UITests.BorderTestsControl.Circle"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="using:Uno.UI.Samples.UITests.BorderTestsControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    mc:Ignorable="d ios android">

    <controls:SampleControl SampleDescription="This sample shows a border with corner radius that should make a circle">
        <controls:SampleControl.SampleContent>
            <DataTemplate>
                <StackPanel>
                    <Border
                        Width="200"
                        Height="200"
                        Background="CornflowerBlue"
                        BorderBrush="Black"
                        BorderThickness="2"
                        CornerRadius="100">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="Black"
                            Text="Hi!" />
                    </Border>
                </StackPanel>
            </DataTemplate>
        </controls:SampleControl.SampleContent>
    </controls:SampleControl>
</Page>
