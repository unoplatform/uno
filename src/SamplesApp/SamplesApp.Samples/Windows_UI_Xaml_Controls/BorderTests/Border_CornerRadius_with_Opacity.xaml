<UserControl
    x:Class="Uno.UI.Samples.UITests.BorderTestsControl.Border_CornerRadius_with_Opacity"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="Uno.UI.Samples.UITests.BorderTestsControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <controls:SampleControl SampleDescription="Border with non-zero CornerRadius and semi-transparent color.">
        <controls:SampleControl.SampleContent>
            <DataTemplate>

                <Border
                    Width="400"
                    Height="200"
                    Background="#80FF0000"
                    CornerRadius="40" />
            </DataTemplate>
        </controls:SampleControl.SampleContent>
    </controls:SampleControl>
</UserControl>