<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.TextBlockControl.TextBlock_Padding"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <StackPanel>
        <Border Width="200" Background="CornflowerBlue">
            <TextBlock FontSize="20" Text="This is my text" />
        </Border>
        <Border Width="200" Background="Bisque">
            <TextBlock
                Padding="50"
                FontSize="20"
                Text="This is my text with padding" />
        </Border>
        <Border Width="200" Background="Tomato">
            <TextBlock
                Padding="50"
                FontSize="20"
                Text="This is my text with padding and wrap"
                TextWrapping="Wrap" />
        </Border>
    </StackPanel>

</UserControl>
