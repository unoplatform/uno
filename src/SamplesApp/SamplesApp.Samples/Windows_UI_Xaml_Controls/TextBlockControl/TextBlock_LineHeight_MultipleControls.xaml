<Page
    x:Class="UITests.Shared.Windows_UI_Xaml_Controls.TextBlockControl.TextBlock_LineHeight_MultipleControls"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel>
        <TextBlock Margin="5,25" FontSize="22">
            left/right should be identical:
        </TextBlock>
        <Grid BorderBrush="Red" BorderThickness="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel
                x:Name="stackPanel1"
                Grid.Column="0"
                Background="Yellow"
                BorderBrush="Blue"
                BorderThickness="4">
                <TextBlock
                    x:Name="txt1_1"
                    FontSize="22"
                    Text="Uno is" />
                <TextBlock
                    x:Name="hidden"
                    FontSize="50"
                    Text="THIS SHOULDN'T AFFECT LAYOUT AND NOT VISIBLE!!"
                    Visibility="Collapsed" />
                <Rectangle
                    x:Name="rect1"
                    Height="40"
                    Fill="Orange" />
                <TextBlock
                    x:Name="txt1_2"
                    FontSize="22"
                    Text="very impressive" />
            </StackPanel>

            <StackPanel
                x:Name="stackPanel2"
                Grid.Column="1"
                Background="Yellow"
                BorderBrush="Blue"
                BorderThickness="4">
                <TextBlock
                    x:Name="txt2_1"
                    FontSize="22"
                    Text="Uno is" />
                <Rectangle
                    x:Name="rect2"
                    Height="40"
                    Fill="Orange" />
                <TextBlock
                    x:Name="txt2_2"
                    FontSize="22"
                    Text="very impressive" />
            </StackPanel>
        </Grid>
    </StackPanel>
</Page>
