<Page
    x:Class="UITests.Windows_UI_Xaml_Controls.TextBlockControl.TextBlock_RelativeTextSize"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel Padding="40" Spacing="5">
        <TextBlock FontSize="18" TextWrapping="Wrap">
            Following text characters should fill the blue boxes or be pretty close to it
        </TextBlock>
        <TextBlock TextWrapping="Wrap">
            The red rectangle should be very close to orange dotted lines.<LineBreak />
            First control is a &lt;TextBlock&gt;, second is a &lt;TextBox&gt;.<LineBreak />
            Note: The height of the text is MORE IMPORTANT than its width which could vary according to the font.</TextBlock>
        <TextBlock x:Name="result" />
        <ToggleButton x:Name="guides" IsChecked="True">
            Hide/Show Guides
        </ToggleButton>
        <StackPanel Orientation="Horizontal" Spacing="20">
            <Canvas
                Width="180"
                Margin="10"
                HorizontalAlignment="Left"
                VerticalAlignment="Top">
                <Grid
                    x:Name="textBlock"
                    Margin="20"
                    BorderBrush="Red"
                    BorderThickness="2">
                    <TextBlock FontSize="120" Text="Aa" />
                </Grid>
                <Rectangle
                    Canvas.Left="20"
                    Canvas.Top="65"
                    Width="80"
                    Height="90"
                    Opacity="0.65"
                    Stroke="Blue"
                    StrokeDashArray="1"
                    StrokeThickness="6"
                    Visibility="{Binding IsChecked, ElementName=guides}" />
                <Rectangle
                    Canvas.Left="102"
                    Canvas.Top="87"
                    Width="55"
                    Height="68"
                    Opacity="0.65"
                    Stroke="Blue"
                    StrokeDashArray="1"
                    StrokeThickness="6"
                    Visibility="{Binding IsChecked, ElementName=guides}" />
                <Line
                    Opacity="0.65"
                    Stroke="Orange"
                    StrokeDashArray="1"
                    StrokeThickness="10"
                    Visibility="{Binding IsChecked, ElementName=guides}"
                    X1="0"
                    X2="190"
                    Y1="20"
                    Y2="20" />
                <Line
                    Opacity="0.65"
                    Stroke="Orange"
                    StrokeDashArray="1"
                    StrokeThickness="10"
                    Visibility="{Binding IsChecked, ElementName=guides}"
                    X1="0"
                    X2="190"
                    Y1="185"
                    Y2="185" />
                <Line
                    Opacity="0.65"
                    Stroke="Orange"
                    StrokeDashArray="1"
                    StrokeThickness="10"
                    Visibility="{Binding IsChecked, ElementName=guides}"
                    X1="20"
                    X2="20"
                    Y1="0"
                    Y2="210" />
                <Line
                    Opacity="0.65"
                    Stroke="Orange"
                    StrokeDashArray="1"
                    StrokeThickness="10"
                    Visibility="{Binding IsChecked, ElementName=guides}"
                    X1="163"
                    X2="163"
                    Y1="0"
                    Y2="210" />
            </Canvas>
            <Canvas
                Width="120"
                Height="200"
                Margin="10"
                HorizontalAlignment="Left"
                VerticalAlignment="Top">
                <Border x:Name="textBox">
                    <TextBox
                        Margin="20"
                        Padding="0"
                        BorderBrush="Red"
                        BorderThickness="2"
                        FontSize="120"
                        Text="Aa" />
                </Border>
                <Rectangle
                    Canvas.Left="20"
                    Canvas.Top="65"
                    Width="80"
                    Height="90"
                    Opacity="0.65"
                    Stroke="Blue"
                    StrokeDashArray="1"
                    StrokeThickness="6"
                    Visibility="{Binding IsChecked, ElementName=guides}" />
                <Rectangle
                    Canvas.Left="102"
                    Canvas.Top="87"
                    Width="55"
                    Height="68"
                    Opacity="0.65"
                    Stroke="Blue"
                    StrokeDashArray="1"
                    StrokeThickness="6"
                    Visibility="{Binding IsChecked, ElementName=guides}" />
                <Line
                    Opacity="0.65"
                    Stroke="Orange"
                    StrokeDashArray="1"
                    StrokeThickness="10"
                    Visibility="{Binding IsChecked, ElementName=guides}"
                    X1="0"
                    X2="190"
                    Y1="20"
                    Y2="20" />
                <Line
                    Opacity="0.65"
                    Stroke="Orange"
                    StrokeDashArray="1"
                    StrokeThickness="10"
                    Visibility="{Binding IsChecked, ElementName=guides}"
                    X1="0"
                    X2="190"
                    Y1="185"
                    Y2="185" />
                <Line
                    Opacity="0.65"
                    Stroke="Orange"
                    StrokeDashArray="1"
                    StrokeThickness="10"
                    Visibility="{Binding IsChecked, ElementName=guides}"
                    X1="20"
                    X2="20"
                    Y1="0"
                    Y2="210" />
                <Line
                    Opacity="0.65"
                    Stroke="Orange"
                    StrokeDashArray="1"
                    StrokeThickness="10"
                    Visibility="{Binding IsChecked, ElementName=guides}"
                    X1="163"
                    X2="163"
                    Y1="0"
                    Y2="210" />
            </Canvas>
        </StackPanel>
    </StackPanel>
</Page>
