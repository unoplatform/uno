<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.TextBlockControl.TextBlock_Multiline_In_StarStackPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="using:Uno.UI.Samples.Content.UITests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d ios android not_win">

    <u:StarStackPanel Orientation="Vertical">
        <u:StarStackPanel Width="300" Orientation="Horizontal">
            <TextBlock
                Margin="0,15"
                VerticalAlignment="Stretch"
                u:StarStackPanel.Size="*"
                MaxLines="0"
                TextWrapping="Wrap"><Run Text="{Binding [AlternatingLongText]}" /><Run Text="that should wrap on multiple lines" /></TextBlock>
            <TextBlock u:StarStackPanel.Size="auto" Text="Small Text" />
        </u:StarStackPanel>
        <Border Background="Red" />
    </u:StarStackPanel>

</UserControl>
