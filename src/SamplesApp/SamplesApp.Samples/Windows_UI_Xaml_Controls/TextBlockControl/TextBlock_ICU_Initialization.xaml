<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.TextBlockControl.TextBlock_ICU_Initialization"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="16" Spacing="12">

            <TextBlock
                FontSize="18"
                FontWeight="Bold"
                Text="ICU Text Rendering Validation" />

            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                Text="Validates ICU initialization and text features (BiDi, line breaking, scripts)."
                TextWrapping="Wrap" />

            <!--  Latin text  -->
            <Border
                Padding="12"
                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="4">
                <StackPanel Spacing="4">
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="Latin Text" />
                    <TextBlock
                        x:Name="LatinText"
                        FontSize="16"
                        Text="Hello World" />
                </StackPanel>
            </Border>

            <!--  Arabic RTL text (BiDi)  -->
            <Border
                Padding="12"
                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="4">
                <StackPanel Spacing="4">
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="Arabic (RTL BiDi)" />
                    <TextBlock
                        x:Name="ArabicText"
                        FontSize="16"
                        Text="اللغة العربية" />
                </StackPanel>
            </Border>

            <!--  Hebrew RTL text (BiDi)  -->
            <Border
                Padding="12"
                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="4">
                <StackPanel Spacing="4">
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="Hebrew (RTL BiDi)" />
                    <TextBlock
                        x:Name="HebrewText"
                        FontSize="16"
                        Text="שלום עולם" />
                </StackPanel>
            </Border>

            <!--  Mixed BiDi text  -->
            <Border
                Padding="12"
                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="4">
                <StackPanel Spacing="4">
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="Mixed BiDi (LTR + RTL)" />
                    <TextBlock
                        x:Name="MixedBiDiText"
                        FontSize="16"
                        Text="Hello مرحبا World" />
                </StackPanel>
            </Border>

            <!--  CJK text  -->
            <Border
                Padding="12"
                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="4">
                <StackPanel Spacing="4">
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="CJK (Chinese)" />
                    <TextBlock
                        x:Name="CJKText"
                        FontSize="16"
                        Text="示例文本" />
                </StackPanel>
            </Border>

            <!--  Line breaking / wrapping  -->
            <Border
                Padding="12"
                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="4">
                <StackPanel Spacing="4">
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="Line Breaking (Wrap)" />
                    <TextBlock
                        x:Name="WrappingText"
                        Width="200"
                        FontSize="16"
                        Text="This is a long sentence that should wrap to multiple lines when constrained by width."
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!--  RTL FlowDirection  -->
            <Border
                Padding="12"
                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="4">
                <StackPanel Spacing="4">
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="RTL FlowDirection" />
                    <TextBlock
                        x:Name="RTLFlowText"
                        FlowDirection="RightToLeft"
                        FontSize="16"
                        Text="مرحبا بالعالم" />
                </StackPanel>
            </Border>

            <!--  Status indicator  -->
            <TextBlock
                x:Name="StatusText"
                FontSize="14"
                FontWeight="Bold"
                Foreground="Green"
                Text="All text blocks rendered successfully - ICU is working." />

        </StackPanel>
    </ScrollViewer>

</UserControl>
