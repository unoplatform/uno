<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.Slider.Slider_Inside_ListViewHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="400"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!--  Permormance slider  -->
        <Grid Margin="15,5">
            <ListView Header="{Binding Parent}" ItemsSource="{Binding [SampleItems]}">
                <ListView.HeaderTemplate>
                    <DataTemplate>
                        <StackPanel x:Name="SP" Orientation="Vertical">

                            <!--  Slider  -->
                            <Slider
                                x:Name="PerformanceSlider"
                                Maximum="10"
                                Minimum="0"
                                SnapsTo="StepValues"
                                StepFrequency="1"
                                Value="{Binding [OverallPerformance], Mode=TwoWay, FallbackValue=10}" />

                            <!--  Slider Value  -->
                            <TextBlock
                                x:Name="tb"
                                Width="25"
                                VerticalAlignment="Center"
                                CharacterSpacing="42"
                                FontSize="16"
                                FontStyle="Normal"
                                FontWeight="Normal"
                                Foreground="#ffffff"
                                LineHeight="20"
                                Text="{Binding ElementName=PerformanceSlider, Path=Value}"
                                TextAlignment="Right" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.HeaderTemplate>
            </ListView>

        </Grid>
    </Grid>
</UserControl>
