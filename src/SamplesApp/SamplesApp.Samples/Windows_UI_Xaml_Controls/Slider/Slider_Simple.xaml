<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.Slider.Slider_Simple"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="400"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <Grid>
        <StackPanel>
            <Slider
                x:Name="mySlider"
                Background="Green"
                Foreground="Red"
                Header="My Slider" />
            <TextBlock>
                <Run Text="Horizontal Value: " /><Run Text="{Binding Value, ElementName=mySlider}" />
            </TextBlock>
            <Slider
                x:Name="mySlider2"
                Height="200"
                Background="Green"
                Foreground="Red"
                Header="My Slider"
                Orientation="Vertical" />
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Vertical Value: " />
                <TextBlock x:Name="mySlider2Value" Text="{Binding Value, ElementName=mySlider2}" />
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
