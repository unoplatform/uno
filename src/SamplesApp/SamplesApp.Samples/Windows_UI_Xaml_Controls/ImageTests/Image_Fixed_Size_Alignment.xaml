<Page
    x:Class="Uno.UI.Samples.UITests.ImageTestsControl.Image_Fixed_Size_Alignment"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Uno.UI.Samples.UITests.ImageTestsControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <ScrollViewer>

        <StackPanel Width="300" Background="LightGray">

            <TextBlock Text="Local source" />

            <TextBlock Text="None" />
            <Image
                x:Name="imageNone"
                Width="400"
                Height="250"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Source="ms-appx:///Assets/colors300.png"
                Stretch="None" />

            <TextBlock Text="Uniform" />
            <Image
                x:Name="imageUniform"
                Width="300"
                Height="250"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Source="ms-appx:///Assets/colors300.png"
                Stretch="Uniform" />

            <TextBlock Text="UniformToFill" />
            <Image
                x:Name="imageUniformToFill"
                Width="300"
                Height="250"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Source="ms-appx:///Assets/colors300.png"
                Stretch="UniformToFill" />

            <TextBlock Text="Fill" />
            <Image
                x:Name="imageFill"
                Width="300"
                Height="250"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Source="ms-appx:///Assets/colors300.png"
                Stretch="Fill" />

            <TextBlock Text="Remote source" />

            <TextBlock Text="None" />
            <Image
                Width="300"
                Height="250"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Source="https://blog.xenproject.org/wp-content/uploads/2014/10/Testing.jpg"
                Stretch="None" />

            <TextBlock Text="Uniform" />
            <Image
                Width="300"
                Height="250"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Source="https://blog.xenproject.org/wp-content/uploads/2014/10/Testing.jpg"
                Stretch="Uniform" />

            <TextBlock Text="UniformToFill" />
            <Image
                Width="300"
                Height="250"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Source="https://blog.xenproject.org/wp-content/uploads/2014/10/Testing.jpg"
                Stretch="UniformToFill" />

            <TextBlock Text="Fill" />
            <Image
                Width="300"
                Height="250"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Source="https://blog.xenproject.org/wp-content/uploads/2014/10/Testing.jpg"
                Stretch="Fill" />

        </StackPanel>

    </ScrollViewer>

</Page>
