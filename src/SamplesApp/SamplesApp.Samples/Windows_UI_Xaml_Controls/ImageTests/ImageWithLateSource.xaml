<UserControl
    x:Class="Uno.UI.Samples.UITests.ImageTestsControl.ImageWithLateSource"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="GenericApp.Views.Content.UITests.ImageTestsControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android not_win">

    <StackPanel>
        <Button Command="{Binding [SetSource]}" Content="Set image source" />
        <Border
            Background="Firebrick"
            BorderBrush="Azure"
            BorderThickness="2">
            <Image
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Source="{Binding [SourceUri]}" />
        </Border>
    </StackPanel>
</UserControl>
