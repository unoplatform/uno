<Page
    x:Class="Uno.UI.Samples.UITests.Image.Image_Stretch"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <ScrollViewer>
        <StackPanel Width="300" Background="LightBlue">
            <TextBlock HorizontalAlignment="Center" Text="Sample for Image_Stretch" />

            <!--  UniformToFill  -->
            <TextBlock HorizontalAlignment="Center" Text="Stretch = UniformToFill" />
            <Border
                Width="300"
                Height="300"
                Background="Red">
                <Image
                    Width="300"
                    Height="300"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Source="https://upload.wikimedia.org/wikipedia/commons/b/b3/1606_Hondius_and_Mercator_Map_of_Mexico_-_Geographicus_-_HispaniaeNovaMexico-mercator-1606.jpg"
                    Stretch="UniformToFill" />
            </Border>

            <!--  Uniform  -->
            <TextBlock HorizontalAlignment="Center" Text="Stretch = Uniform" />
            <Border
                Width="300"
                Height="300"
                Background="Red">
                <Image
                    Width="300"
                    Height="300"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Source="https://upload.wikimedia.org/wikipedia/commons/b/b3/1606_Hondius_and_Mercator_Map_of_Mexico_-_Geographicus_-_HispaniaeNovaMexico-mercator-1606.jpg"
                    Stretch="Uniform" />
            </Border>

            <!--  Fill  -->
            <TextBlock HorizontalAlignment="Center" Text="Stretch = Fill" />
            <Border
                Width="300"
                Height="300"
                Background="Red">
                <Image
                    Width="300"
                    Height="300"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Source="https://upload.wikimedia.org/wikipedia/commons/b/b3/1606_Hondius_and_Mercator_Map_of_Mexico_-_Geographicus_-_HispaniaeNovaMexico-mercator-1606.jpg"
                    Stretch="Fill" />
            </Border>

            <!--  None  -->
            <TextBlock HorizontalAlignment="Center" Text="Stretch = None" />
            <Border
                Width="300"
                Height="300"
                Background="Red">
                <Image
                    Width="300"
                    Height="300"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Source="https://upload.wikimedia.org/wikipedia/commons/b/b3/1606_Hondius_and_Mercator_Map_of_Mexico_-_Geographicus_-_HispaniaeNovaMexico-mercator-1606.jpg"
                    Stretch="None" />
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
