<UserControl
    x:Class="UITests.Shared.Windows_UI_Xaml_Controls.Buttons_Native"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_Xaml_Controls.Button"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wasm="http://uno.ui/wasm"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d wasm">

    <UserControl.Resources>
        <wasm:Style
            x:Key="NativeDefaultButton"
            BasedOn="{StaticResource DefaultXamlButton}"
            TargetType="Button" />
        <wasm:Style
            x:Key="NativeDefaultToggleSwitch"
            BasedOn="{StaticResource DefaultXamlToggleSwitch}"
            TargetType="ToggleSwitch" />

        <win:Style x:Key="NativeDefaultButton" TargetType="Button" />
        <win:Style x:Key="NativeDefaultToggleSwitch" TargetType="ToggleSwitch" />
    </UserControl.Resources>

    <Grid>
        <StackPanel>
            <TextBlock Text="This sample is only valid on platforms providing native styles" />
            <TextBlock x:Name="result" Text="No value" />
            <TextBlock x:Name="resultTapped" Text="No value" />
            <TextBlock x:Name="resultCommand" Text="No command" />

            <Button
                x:Name="button01"
                Click="OnClick"
                Command="{x:Bind ClickCommand}"
                CommandParameter="Button 01"
                Content="Button 01"
                Style="{StaticResource NativeDefaultButton}"
                Tapped="OnTapped" />

            <Button
                x:Name="button02"
                Click="OnClick"
                Command="{x:Bind ClickCommand}"
                CommandParameter="Button 02"
                Content="Button 02"
                IsEnabled="False"
                Style="{StaticResource NativeDefaultButton}"
                Tapped="OnTapped" />

            <Button
                x:Name="enableButton02"
                Click="OnClickEnableButton02"
                Content="Enable Button 02"
                Style="{StaticResource NativeDefaultButton}" />

            <ToggleSwitch
                x:Name="toggleSwitch01"
                OffContent="Off Content"
                OnContent="On Content"
                Style="{StaticResource NativeDefaultToggleSwitch}"
                Toggled="OnToggled" />

            <ToggleSwitch
                x:Name="toggleSwitch02"
                IsEnabled="False"
                OffContent="Off Content"
                OnContent="On Content"
                Style="{StaticResource NativeDefaultToggleSwitch}"
                Toggled="OnToggled" />

            <Button
                x:Name="enableToggleSwitch02"
                Click="OnClickEnableToggleSwitch02"
                Content="Enable ToggleSwitch 02"
                Style="{StaticResource NativeDefaultButton}" />
        </StackPanel>
    </Grid>
</UserControl>
