<Page
    x:Class="UITests.Windows_UI_Xaml_Controls.CheckBoxTests.CheckBox_States"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.CheckBoxTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel>
        <CheckBox
            Content="UncheckedNormal"
            IsChecked="False"
            IsEnabled="True"
            IsThreeState="False" />
        <CheckBox
            Content="UncheckedDisabled"
            IsChecked="False"
            IsEnabled="False"
            IsThreeState="False" />
        <CheckBox
            Content="CheckedNormal"
            IsChecked="True"
            IsEnabled="True"
            IsThreeState="False" />
        <CheckBox
            Content="CheckedDisabled"
            IsChecked="True"
            IsEnabled="False"
            IsThreeState="False" />
        <CheckBox
            Content="IndeterminateNormal"
            IsChecked="{x:Null}"
            IsEnabled="True"
            IsThreeState="True" />
        <CheckBox
            Content="IndeterminateDisabled"
            IsChecked="{x:Null}"
            IsEnabled="False"
            IsThreeState="True" />
    </StackPanel>
</Page>
