<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.GridTestsControl.Grid_with_TextBlock_VerticalAlignment"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <controls:SampleControl SampleDescription="The TextBlock and its Border should be aligned to the bottom of the Grid">
        <controls:SampleControl.SampleContent>
            <DataTemplate>
                <Grid
                    Height="60"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Background="Red">
                    <Border VerticalAlignment="Bottom" Background="DeepPink">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Text="Text aligned to the bottom"
                            TextAlignment="Center" />
                    </Border>
                </Grid>
            </DataTemplate>
        </controls:SampleControl.SampleContent>
    </controls:SampleControl>
</UserControl>
