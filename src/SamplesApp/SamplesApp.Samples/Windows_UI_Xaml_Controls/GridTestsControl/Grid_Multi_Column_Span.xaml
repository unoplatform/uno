<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.GridTestsControl.Grid_Multi_Column_Span"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="3000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <controls:SampleControl>
        <controls:SampleControl.Resources>
            <Style x:Key="GridTestStyle" TargetType="Border">
                <Setter Property="Height" Value="30" />
                <Setter Property="Width" Value="50" />
                <Setter Property="Background" Value="Blue" />
                <Setter Property="BorderBrush" Value="White" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </controls:SampleControl.Resources>
        <controls:SampleControl.SampleContent>
            <DataTemplate>
                <Grid
                    Width="300"
                    Height="400"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="0"
                        Grid.ColumnSpan="4"
                        Margin="0,0,0,20"
                        HorizontalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center" Text="Text spans multiple columns" />

                        <Border
                            Width="150"
                            Height="50"
                            Background="Red" />
                    </StackPanel>

                    <Border
                        Grid.Row="1"
                        Grid.Column="0"
                        Style="{StaticResource GridTestStyle}">
                        <TextBlock Text="1" />
                    </Border>
                    <Border
                        Grid.Row="1"
                        Grid.Column="1"
                        Style="{StaticResource GridTestStyle}">
                        <TextBlock Text="2" />
                    </Border>
                    <Border
                        Grid.Row="1"
                        Grid.Column="2"
                        Style="{StaticResource GridTestStyle}">
                        <TextBlock Text="3" />
                    </Border>
                    <Border
                        Grid.Row="1"
                        Grid.Column="3"
                        Style="{StaticResource GridTestStyle}">
                        <TextBlock Text="3a" />
                    </Border>
                    <Border
                        Grid.Row="2"
                        Grid.Column="0"
                        Style="{StaticResource GridTestStyle}">
                        <TextBlock Text="4" />
                    </Border>
                    <Border
                        Grid.Row="2"
                        Grid.Column="1"
                        Style="{StaticResource GridTestStyle}">
                        <TextBlock Text="5" />
                    </Border>
                    <Border
                        Grid.Row="2"
                        Grid.Column="2"
                        Style="{StaticResource GridTestStyle}">
                        <TextBlock Text="6" />
                    </Border>
                    <Border
                        Grid.Row="2"
                        Grid.Column="3"
                        Style="{StaticResource GridTestStyle}">
                        <TextBlock Text="6a" />
                    </Border>
                    <Border
                        Grid.Row="3"
                        Grid.Column="0"
                        Style="{StaticResource GridTestStyle}">
                        <TextBlock Text="7" />
                    </Border>
                    <Border
                        Grid.Row="3"
                        Grid.Column="1"
                        Style="{StaticResource GridTestStyle}">
                        <TextBlock Text="8" />
                    </Border>
                    <Border
                        Grid.Row="3"
                        Grid.Column="2"
                        Style="{StaticResource GridTestStyle}">
                        <TextBlock Text="9" />
                    </Border>
                    <Border
                        Grid.Row="3"
                        Grid.Column="3"
                        Style="{StaticResource GridTestStyle}">
                        <TextBlock Text="9a" />
                    </Border>
                    <Border
                        Grid.Row="3"
                        Grid.Column="0"
                        Style="{StaticResource GridTestStyle}">
                        <TextBlock Text="7" />
                    </Border>
                    <Border
                        Grid.Row="3"
                        Grid.Column="1"
                        Style="{StaticResource GridTestStyle}">
                        <TextBlock Text="8" />
                    </Border>
                    <Border
                        Grid.Row="3"
                        Grid.Column="2"
                        Style="{StaticResource GridTestStyle}">
                        <TextBlock Text="9" />
                    </Border>

                </Grid>
            </DataTemplate>
        </controls:SampleControl.SampleContent>
    </controls:SampleControl>
</UserControl>
