<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.GridTestsControl.Grid_with_Stack_Panel_and_Trimming"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="3000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <Grid Width="300" Background="#FFFF0000">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>
        <TextBlock
            x:Name="TrimmedLeft"
            Grid.Row="0"
            Grid.Column="0"
            Text="Small 01" />
        <StackPanel
            x:Name="InnerStack"
            Grid.Row="0"
            Grid.Column="1">
            <TextBlock
                x:Name="TrimmedMiddle"
                FontFamily="Helvetica"
                FontSize="30"
                Text="This is a veeery loooong text that should trim at the end because it does not fit"
                TextTrimming="CharacterEllipsis" />
        </StackPanel>
        <TextBlock
            x:Name="TrimmedRight"
            Grid.Row="0"
            Grid.Column="2"
            Text="Small 02" />
    </Grid>

</UserControl>
