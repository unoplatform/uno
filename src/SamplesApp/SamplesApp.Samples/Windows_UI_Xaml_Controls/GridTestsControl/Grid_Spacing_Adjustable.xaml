<UserControl
    x:Class="UITests.Shared.Windows_UI_Xaml_Controls.GridTestsControl.Grid_Spacing_Adjustable"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_Xaml_Controls.GridTestsControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <StackPanel>
        <Slider
            x:Name="ColumnSpacingSlider"
            Width="100"
            Margin="20"
            Maximum="100"
            Minimum="-20"
            Value="10" />
        <Slider
            x:Name="RowSpacingSlider"
            Width="100"
            Margin="20"
            Maximum="100"
            Minimum="-20"
            Value="10" />
        <Grid
            Width="300"
            Height="300"
            Background="Beige"
            ColumnSpacing="{Binding ElementName=ColumnSpacingSlider, Path=Value}"
            RowSpacing="{Binding ElementName=RowSpacingSlider, Path=Value}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border
                Grid.Row="0"
                Grid.Column="0"
                Height="20"
                HorizontalAlignment="Stretch"
                Background="Red"
                CornerRadius="5" />
            <Border
                Grid.Row="0"
                Grid.Column="1"
                Width="30"
                Height="20"
                Background="Red"
                CornerRadius="5" />
            <Border
                Grid.Row="0"
                Grid.Column="2"
                Height="20"
                HorizontalAlignment="Stretch"
                Background="Red"
                CornerRadius="5" />

            <Border
                Grid.Row="1"
                Grid.RowSpan="2"
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Blue"
                CornerRadius="5" />
            <Border
                Grid.Row="1"
                Grid.Column="1"
                Width="30"
                VerticalAlignment="Stretch"
                Background="Red"
                CornerRadius="5" />
            <Border
                Grid.Row="1"
                Grid.Column="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Red"
                CornerRadius="5" />

            <Border
                Grid.Row="2"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Blue"
                CornerRadius="5" />
        </Grid>
    </StackPanel>
</UserControl>
