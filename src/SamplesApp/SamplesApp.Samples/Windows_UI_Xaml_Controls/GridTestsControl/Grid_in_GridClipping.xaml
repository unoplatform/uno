<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.GridTestsControl.Grid_in_GridClipping"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <controls:SampleControl SampleDescription="All Text should be visible">
        <controls:SampleControl.SampleContent>
            <DataTemplate>
                <StackPanel>
                    <Grid
                        Grid.Row="1"
                        Width="500"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                FontSize="22"
                                Text="First Row Should Be Visible" />
                            <TextBlock
                                Grid.Row="1"
                                Margin="0,12,0,0"
                                FontSize="22"
                                Text="First Row Should Be Visible Aswell" />
                            <TextBlock
                                Grid.Column="1"
                                FontSize="14"
                                Text="Second Row should be visible" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="0,12,0,0"
                                FontSize="14"
                                Text="Second Row should be visible Aswell" />
                        </Grid>
                    </Grid>
                    <TextBlock Margin="20" Text="Under here is how it should behave" />
                    <Grid
                        Grid.Row="1"
                        Width="500"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            FontSize="22"
                            Text="First Row Should Be Visible" />
                        <TextBlock
                            Grid.Row="1"
                            Margin="0,12,0,0"
                            FontSize="22"
                            Text="First Row Should Be Visible Aswell" />
                        <TextBlock
                            Grid.Column="1"
                            FontSize="14"
                            Text="Second Row should be visible" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,12,0,0"
                            FontSize="14"
                            Text="Second Row should be visible Aswell" />
                    </Grid>
                </StackPanel>
            </DataTemplate>
        </controls:SampleControl.SampleContent>
    </controls:SampleControl>
</UserControl>
