<UserControl
    x:Class="SamplesApp.Windows_UI_Xaml_Controls.ListView.ListViewItem_PressedState"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">
    <UserControl.Resources>
        <Style x:Key="PressedStateListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
                            <Border
                                x:Name="BorderElement"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="ForestGreen"
                                Opacity="0" />
                            <Border
                                x:Name="InnerBorderElement"
                                Margin="10"
                                Background="SkyBlue"
                                Opacity="0" />
                            <ContentPresenter
                                x:Name="ContentPresenter"
                                Margin="0"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="BorderElement.Opacity" Value="0.7" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Target="InnerBorderElement.Opacity" Value="0.7" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="PressedSelected">
                                        <VisualState.Setters>
                                            <Setter Target="BorderElement.Opacity" Value="0.7" />
                                            <Setter Target="InnerBorderElement.Opacity" Value="0.7" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="DisabledStates">
                                    <VisualState x:Name="Enabled" />
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="ContentPresenter.Opacity" Value="0.3" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <controls:SampleControl SampleDescription="Demonstrates Pressed and Selected states on ListViewItem">
        <controls:SampleControl.SampleContent>
            <DataTemplate>
                <StackPanel>
                    <Border BorderBrush="Black" BorderThickness="2">
                        <ListView
                            Width="150"
                            Height="200"
                            Margin="5"
                            ItemContainerStyle="{StaticResource PressedStateListViewItemStyle}"
                            ItemsSource="123456789"
                            SelectionMode="Single" />
                    </Border>
                    <TextBlock Foreground="Brown" Text="SelectionMode=None" />
                    <Border BorderBrush="Brown" BorderThickness="2">
                        <ListView
                            Width="150"
                            Height="200"
                            Margin="5"
                            ItemContainerStyle="{StaticResource PressedStateListViewItemStyle}"
                            ItemsSource="123456789"
                            SelectionMode="None" />
                    </Border>
                    <TextBlock Foreground="Black" Text="SelectionMode=Multiple" />
                    <Border BorderBrush="Black" BorderThickness="2">
                        <ListView
                            Width="150"
                            Height="200"
                            Margin="5"
                            ItemContainerStyle="{StaticResource PressedStateListViewItemStyle}"
                            ItemsSource="123456789"
                            SelectionMode="Multiple" />
                    </Border>
                </StackPanel>
            </DataTemplate>
        </controls:SampleControl.SampleContent>
    </controls:SampleControl>
</UserControl>
