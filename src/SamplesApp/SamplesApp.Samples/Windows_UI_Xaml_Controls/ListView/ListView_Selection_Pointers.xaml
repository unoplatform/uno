<Page
    x:Class="UITests.Windows_UI_Xaml_Controls.ListView.ListView_Selection_Pointers"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.ListView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <TextBlock
            Grid.Row="0"
            Grid.Column="0"
            Text="No selection" />
        <ListView
            x:Name="_noSelection_noClick"
            Grid.Row="1"
            Grid.Column="0"
            HorizontalAlignment="Left"
            IsItemClickEnabled="False"
            ItemClick="OnItemClicked"
            ItemsSource="ABCDEFGHIJKLMNOPQRSTUVWXYZ"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border
                        x:Name="_noSelection_noClick_item"
                        Width="50"
                        Height="50"
                        Margin="0,0,3,3"
                        Background="#99FF0000"
                        BorderBrush="#FF0000"
                        BorderThickness="3"
                        PointerEntered="OnItemEntered"
                        PointerExited="OnItemExited"
                        PointerPressed="OnItemPressed"
                        PointerReleased="OnItemReleased"
                        Tapped="OnItemTapped">
                        <TextBlock Text="{Binding}" />
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock
            Grid.Row="0"
            Grid.Column="1"
            Text="Single selection" />
        <ListView
            x:Name="_singleSelection_noClick"
            Grid.Row="1"
            Grid.Column="1"
            HorizontalAlignment="Left"
            IsItemClickEnabled="False"
            ItemClick="OnItemClicked"
            ItemsSource="ABCDEFGHIJKLMNOPQRSTUVWXYZ"
            SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border
                        x:Name="_singleSelection_noClick_item"
                        Width="50"
                        Height="50"
                        Margin="0,0,3,3"
                        Background="#99FF8000"
                        BorderBrush="#FF8000"
                        BorderThickness="3"
                        PointerEntered="OnItemEntered"
                        PointerExited="OnItemExited"
                        PointerPressed="OnItemPressed"
                        PointerReleased="OnItemReleased"
                        Tapped="OnItemTapped">
                        <TextBlock Text="{Binding}" />
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock
            Grid.Row="0"
            Grid.Column="2"
            Text="Multiple selection" />
        <ListView
            x:Name="_multipleSelection_noClick"
            Grid.Row="1"
            Grid.Column="2"
            HorizontalAlignment="Left"
            IsItemClickEnabled="False"
            ItemClick="OnItemClicked"
            ItemsSource="ABCDEFGHIJKLMNOPQRSTUVWXYZ"
            SelectionMode="Multiple">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border
                        x:Name="_multipleSelection_noClick_item"
                        Width="50"
                        Height="50"
                        Margin="0,0,3,3"
                        Background="#99FFFF00"
                        BorderBrush="#FFFF00"
                        BorderThickness="3"
                        PointerEntered="OnItemEntered"
                        PointerExited="OnItemExited"
                        PointerPressed="OnItemPressed"
                        PointerReleased="OnItemReleased"
                        Tapped="OnItemTapped">
                        <TextBlock Text="{Binding}" />
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock
            Grid.Row="0"
            Grid.Column="3"
            Text="Extended selection" />
        <ListView
            x:Name="_extendedSelection_noClick"
            Grid.Row="1"
            Grid.Column="3"
            HorizontalAlignment="Left"
            IsItemClickEnabled="False"
            ItemClick="OnItemClicked"
            ItemsSource="ABCDEFGHIJKLMNOPQRSTUVWXYZ"
            SelectionMode="Extended">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border
                        x:Name="_extendedSelection_noClick_item"
                        Width="50"
                        Height="50"
                        Margin="0,0,3,3"
                        Background="#99008000"
                        BorderBrush="#008000"
                        BorderThickness="3"
                        PointerEntered="OnItemEntered"
                        PointerExited="OnItemExited"
                        PointerPressed="OnItemPressed"
                        PointerReleased="OnItemReleased"
                        Tapped="OnItemTapped">
                        <TextBlock Text="{Binding}" />
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock
            Grid.Row="0"
            Grid.Column="4"
            Text="Click without selection" />
        <ListView
            x:Name="_noSelection_withClick"
            Grid.Row="1"
            Grid.Column="4"
            HorizontalAlignment="Left"
            IsItemClickEnabled="True"
            ItemClick="OnItemClicked"
            ItemsSource="ABCDEFGHIJKLMNOPQRSTUVWXYZ"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border
                        x:Name="_noSelection_withClick_item"
                        Width="50"
                        Height="50"
                        Margin="0,0,3,3"
                        Background="#990000FF"
                        BorderBrush="#0000FF"
                        BorderThickness="3"
                        PointerEntered="OnItemEntered"
                        PointerExited="OnItemExited"
                        PointerPressed="OnItemPressed"
                        PointerReleased="OnItemReleased"
                        Tapped="OnItemTapped">
                        <TextBlock Text="{Binding}" />
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock
            Grid.Row="0"
            Grid.Column="5"
            Text="Click with selection" />
        <ListView
            x:Name="_singleSelection_withClick"
            Grid.Row="1"
            Grid.Column="5"
            HorizontalAlignment="Left"
            IsItemClickEnabled="True"
            ItemClick="OnItemClicked"
            ItemsSource="ABCDEFGHIJKLMNOPQRSTUVWXYZ"
            SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border
                        x:Name="_singleSelection_withClick_item"
                        Width="50"
                        Height="50"
                        Margin="0,0,3,3"
                        Background="#99A000C0"
                        BorderBrush="#A000C0"
                        BorderThickness="3"
                        PointerEntered="OnItemEntered"
                        PointerExited="OnItemExited"
                        PointerPressed="OnItemPressed"
                        PointerReleased="OnItemReleased"
                        Tapped="OnItemTapped">
                        <TextBlock Text="{Binding}" />
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel
            Grid.Row="2"
            Grid.ColumnSpan="6"
            Orientation="Horizontal">

            <TextBlock Margin="6,0,3,0" Text="Entered:" />
            <TextBlock x:Name="_pageEntered" Text="-" />
            <TextBlock Margin="3,0" Text="|" />
            <TextBlock x:Name="_itemEntered" Text="-" />

            <TextBlock Margin="12,0,3,0" Text="Exited:" />
            <TextBlock x:Name="_pageExited" Text="-" />
            <TextBlock Margin="3,0" Text="|" />
            <TextBlock x:Name="_itemExited" Text="-" />

            <TextBlock Margin="12,0,3,0" Text="Pressed:" />
            <TextBlock x:Name="_pagePressed" Text="-" />
            <TextBlock Margin="3,0" Text="|" />
            <TextBlock x:Name="_itemPressed" Text="-" />

            <TextBlock Margin="12,0,3,0" Text="Released:" />
            <TextBlock x:Name="_pageReleased" Text="-" />
            <TextBlock Margin="3,0" Text="|" />
            <TextBlock x:Name="_itemReleased" Text="-" />

            <TextBlock Margin="12,0,3,0" Text="Tapped:" />
            <TextBlock x:Name="_pageTapped" Text="-" />
            <TextBlock Margin="3,0" Text="|" />
            <TextBlock x:Name="_itemTapped" Text="-" />

            <TextBlock Margin="12,0,3,0" Text="Clicked:" />
            <TextBlock x:Name="_itemClicked" Text="-" />
        </StackPanel>
    </Grid>
</Page>
