<UserControl
    x:Class="SamplesApp.Windows_UI_Xaml_Controls.ListView.ListView_CacheLength_Slow_Load"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="using:SamplesApp.Windows_UI_Xaml_Controls.ListView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="DelayedImagePresenter/DelayedImagePresenter.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ListView
        x:Name="MyListView"
        Width="230"
        Height="300"
        Background="Gray"
        ItemsSource="{Binding GoogleBanners}">
        <ListView.ItemTemplate>
            <DataTemplate>
                <StackPanel
                    Width="200"
                    Height="140"
                    Margin="2"
                    BorderBrush="Blue"
                    BorderThickness="2">
                    <TextBlock Text="{Binding Tail}" />
                    <local:DelayedImagePresenter
                        Width="200"
                        Height="80"
                        Source="{Binding Uri}" />
                </StackPanel>
            </DataTemplate>
        </ListView.ItemTemplate>
        <ListView.ItemsPanel>
            <ItemsPanelTemplate>
                <ItemsStackPanel CacheLength="4" />
            </ItemsPanelTemplate>
        </ListView.ItemsPanel>
    </ListView>
</UserControl>
