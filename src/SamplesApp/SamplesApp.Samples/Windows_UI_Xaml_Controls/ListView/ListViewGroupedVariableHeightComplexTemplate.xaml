<UserControl
    x:Class="SamplesApp.Windows_UI_Xaml_Controls.ListView.ListViewGroupedVariableHeightComplexTemplate"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <controls:SampleControl SampleDescription="Grouped ListView with multiple variable-height elements in item template">
        <controls:SampleControl.SampleContent>
            <DataTemplate>
                <ListView
                    Width="250"
                    Height="200"
                    ItemsSource="{Binding [GroupedCompoundSampleItems]}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="3"
                                BorderBrush="Blue"
                                BorderThickness="2">
                                <StackPanel>
                                    <Rectangle Height="150" Fill="Red" />
                                    <TextBlock Foreground="Blue" Text="{Binding Group}" />
                                    <TextBlock
                                        Width="120"
                                        Text="{Binding Quote}"
                                        TextWrapping="Wrap" />
                                    <ItemsControl ItemsSource="{Binding Items}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="Green" BorderThickness="2">
                                        <TextBlock Height="80" Text="{Binding Key}" />
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>
                </ListView>
            </DataTemplate>
        </controls:SampleControl.SampleContent>
    </controls:SampleControl>
</UserControl>
