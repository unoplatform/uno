<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.GridView.GridViewUnfixedWidth"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="Uno.UI.Samples.Content.UITests.GridView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:nVentive.Umbrella.Views.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <controls:SampleControl SampleDescription="GridView without fixed width. Should take the width (light green) needed for the 3 columns that can fit.">
        <controls:SampleControl.SampleContent>
            <DataTemplate>
                <Border
                    Width="300"
                    Height="400"
                    Background="DarkSeaGreen">
                    <Border
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="LightSeaGreen">
                        <GridView ItemsSource="{Binding SampleColors}">
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid
                                        ItemHeight="150"
                                        ItemWidth="80"
                                        Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <Ellipse Width="70" Height="140">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding}" />
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </Border>
                </Border>
            </DataTemplate>
        </controls:SampleControl.SampleContent>
    </controls:SampleControl>
</UserControl>