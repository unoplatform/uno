<Page
    x:Class="UITests.Windows_UI_Xaml_Controls.DatePicker.DatePicker_DatePartVisibility"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d not_win">

    <ScrollViewer>
        <Grid ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="6">
                <DatePicker not_win:UseNativeStyle="False" Header="All parts shown" />
                <DatePicker
                    not_win:UseNativeStyle="False"
                    DayVisible="False"
                    Header="Month and year shown" />
                <DatePicker
                    not_win:UseNativeStyle="False"
                    Header="Month and day shown"
                    YearVisible="False" />
                <DatePicker
                    not_win:UseNativeStyle="False"
                    Header="Day and year shown"
                    MonthVisible="False" />
                <DatePicker
                    not_win:UseNativeStyle="False"
                    DayVisible="False"
                    Header="Only year shown"
                    MonthVisible="False" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="6">
                <DatePicker not_win:UseNativeStyle="True" Header="All parts shown (native)" />
                <DatePicker
                    not_win:UseNativeStyle="True"
                    DayVisible="False"
                    Header="Month and year shown (native)" />
                <DatePicker
                    not_win:UseNativeStyle="True"
                    Header="Month and day shown (native)"
                    YearVisible="False" />
                <DatePicker
                    not_win:UseNativeStyle="True"
                    Header="Day and year shown (native)"
                    MonthVisible="False" />
                <DatePicker
                    not_win:UseNativeStyle="True"
                    DayVisible="False"
                    Header="Only year shown (native)"
                    MonthVisible="False" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
