<ContentDialog
    x:Class="UITests.Windows_UI_Xaml_Controls.ContentDialogTests.Dialogs.ContentDialogRateApp"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Do you like our app?"
    CloseButtonText="Close"
    DefaultButton="Primary"
    IsSecondaryButtonEnabled="False"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    PrimaryButtonText="I love it!"
    SecondaryButtonClick="ContentDialog_SecondaryButtonClick"
    SecondaryButtonText="It's good"
    mc:Ignorable="d">

    <Grid>
        <Image
            Width="100"
            Height="100"
            Margin="10"
            Source="https://s3.amazonaws.com/uno-website-assets/wp-content/uploads/2018/08/22113759/UnoLogoSmall.png" />
    </Grid>
</ContentDialog>
