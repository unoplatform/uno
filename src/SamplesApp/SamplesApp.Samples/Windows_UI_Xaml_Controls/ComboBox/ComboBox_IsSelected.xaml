<UserControl
    x:Class="SamplesApp.Wasm.Windows_UI_Xaml_Controls.ComboBox.ComboBox_IsSelected"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Uno.UI.Samples.Content.UITests.ComboBox"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <ComboBox
            x:Name="NoSelected"
            Grid.Row="0"
            Width="120"
            Margin="0,12,0,0">
            <ComboBoxItem x:Name="RGBNoSelected" Content="RGB" />
            <ComboBoxItem x:Name="HSVNoSelected" Content="HSV" />
        </ComboBox>
        <ComboBox
            x:Name="SingleSelected"
            Grid.Row="1"
            Width="120"
            Margin="0,12,0,0">
            <ComboBoxItem
                x:Name="RGBSingleSelected"
                Content="RGB"
                IsSelected="True" />
            <ComboBoxItem x:Name="HSVSingleSelected" Content="HSV" />
        </ComboBox>
        <ComboBox
            x:Name="DuplicateSelected"
            Grid.Row="2"
            Width="120"
            Margin="0,12,0,0">
            <ComboBoxItem x:Name="RGBDuplicateSelected" Content="RGB" />
            <ComboBoxItem
                x:Name="RGB2DuplicateSelected"
                Content="RGB"
                IsSelected="True" />
            <ComboBoxItem x:Name="HSVDuplicateSelected" Content="HSV" />
        </ComboBox>
    </Grid>
</UserControl>
