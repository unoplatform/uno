<UserControl
    x:Class="UITests.Windows_UI_Xaml_Controls.TextBox.TextBox_Foreground_Changing"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.TextBox"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <UserControl.Resources>
        <SolidColorBrush x:Name="TextBoxForegroundBrush" Color="Tomato" />
    </UserControl.Resources>

    <StackPanel>
        <Button x:Name="DummyButton" Content="Dummy" />
        <Button
            x:Name="ChangeForegroundButton"
            Click="ChangeForeground"
            Content="Change Foreground" />
        <TextBlock
            x:Name="StatusTextBlock"
            Margin="5"
            Text="Status: unstarted" />
        <!--  Single-line  -->
        <TextBox
            x:Name="SingleLineTextBox"
            Margin="5"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            FontSize="96"
            Foreground="{StaticResource TextBoxForegroundBrush}"
            Text="▮" />
        <!--  Multiline  -->
        <TextBox
            x:Name="MultilineTextBox"
            Margin="5"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            AcceptsReturn="True"
            FontSize="96"
            Foreground="{StaticResource TextBoxForegroundBrush}"
            Text="▮"
            TextWrapping="Wrap" />
        <PasswordBox
            x:Name="TestPasswordBox"
            Margin="5"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            FontSize="96"
            Foreground="{StaticResource TextBoxForegroundBrush}"
            Password="Test" />
    </StackPanel>
</UserControl>
