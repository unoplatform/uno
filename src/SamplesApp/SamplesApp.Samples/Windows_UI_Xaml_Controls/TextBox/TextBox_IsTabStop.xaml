<Page
    x:Class="UITests.Windows_UI_Xaml_Controls.TextBox.TextBox_IsTabStop"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.TextBox"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel>
        <TextBlock Text="Currently focused element" />
        <TextBlock
            x:Name="CurrentlyFocusedTextBlock"
            FontWeight="Bold"
            Text="NONE" />
        <TextBox x:Name="FocusableSingleLineTextBox" Text="This singleline TextBox should be focusable" />
        <TextBox
            x:Name="UnfocusableSingleLineTextBox"
            IsTabStop="False"
            Text="This singleline TextBox should not be focusable" />
        <TextBox
            x:Name="FocusableMultiLineTextBox"
            Height="100"
            AcceptsReturn="True"
            Text="This multiline TextBox should be focusable" />
        <TextBox
            x:Name="UnfocusableMultiLineTextBox"
            Height="100"
            AcceptsReturn="True"
            IsTabStop="False"
            Text="This multiline TextBox should not be focusable" />
    </StackPanel>
</Page>
