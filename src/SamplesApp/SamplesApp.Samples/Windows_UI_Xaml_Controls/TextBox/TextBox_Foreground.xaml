<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.TextBoxControl.TextBox_Foreground"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    mc:Ignorable="d not_win">

    <UserControl.Resources>
        <Style x:Key="FocusedTextboxStyle" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid x:Name="RootGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border
                                x:Name="BackgroundElement"
                                Grid.Row="1"
                                Grid.RowSpan="1"
                                Grid.ColumnSpan="2" />
                            <Border
                                x:Name="BorderElement"
                                Grid.Row="1"
                                Grid.RowSpan="1"
                                Grid.ColumnSpan="2" />

                            <win:ScrollViewer
                                x:Name="ContentElement"
                                Grid.Row="1"
                                VerticalAlignment="Center"
                                VerticalContentAlignment="Center"
                                IsTabStop="False"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                ZoomMode="Disabled" />

                            <not_win:ContentControl
                                x:Name="ContentElement"
                                Grid.Row="1"
                                VerticalAlignment="Center"
                                VerticalContentAlignment="Center"
                                Foreground="{TemplateBinding Foreground}"
                                IsTabStop="False" />

                            <ContentControl
                                x:Name="PlaceholderTextContentPresenter"
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Margin="{TemplateBinding BorderThickness}"
                                VerticalAlignment="Center"
                                VerticalContentAlignment="Center"
                                Content="{TemplateBinding PlaceholderText}"
                                IsHitTestVisible="False"
                                IsTabStop="False" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="Focused">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BackgroundElement" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Red" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentElement" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Yellow" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>
    </UserControl.Resources>

    <StackPanel>
        <TextBlock>
            Sample:
        </TextBlock>

        <TextBox
            x:Name="tb1"
            Foreground="Blue"
            Style="{StaticResource FocusedTextboxStyle}"
            Text="Sample Text!" />
        <TextBox
            x:Name="tb2"
            AcceptsReturn="True"
            Foreground="Blue"
            Style="{StaticResource FocusedTextboxStyle}"
            Text="Multiline Sample Text!" />
    </StackPanel>

</UserControl>
