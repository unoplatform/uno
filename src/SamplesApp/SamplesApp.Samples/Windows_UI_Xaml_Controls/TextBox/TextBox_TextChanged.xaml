<UserControl
    x:Class="UITests.Shared.Windows_UI_Xaml_Controls.TextBoxTests.TextBox_TextChanged"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <StackPanel MaxWidth="300" Background="Beige">
        <TextBlock Margin="50" Text="UnoTestbed4" />
        <TextBox
            x:Name="AppendTextBox"
            Margin="20"
            PlaceholderText="will append..."
            TextChanged="AppendTextBox_TextChanged" />
        <TextBlock x:Name="AppendTextBlock" Text="{Binding ElementName=AppendTextBox, Path=Text}" />
        <TextBox
            x:Name="CapitalizeTextBox"
            Margin="20"
            PlaceholderText="will capitalize..."
            TextChanged="CapitalizeTextBox_TextChanged" />
        <TextBlock x:Name="CapitalizeTextBlock" Text="{Binding ElementName=CapitalizeTextBox, Path=Text}" />
    </StackPanel>
</UserControl>
