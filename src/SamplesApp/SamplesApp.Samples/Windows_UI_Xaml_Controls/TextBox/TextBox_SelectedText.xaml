<UserControl
    x:Class="UITests.Shared.Windows_UI_Xaml_Controls.TextBoxTests.TextBox_SelectedText"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.TextBox"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="500" />
        </Grid.RowDefinitions>
        <TextBox
            x:Name="txbBase"
            Grid.Row="0"
            SelectionChanged="txbBase_SelectionChanged"
            Text="ABCDEFGHIJKLMNOPQRSTUVWXYZ" />
        <Button
            x:Name="btnEmpty"
            Grid.Row="1"
            Click="btnEmpty_Click"
            Content="Select String.Empty" />
        <Button
            x:Name="btnSelectDEF"
            Grid.Row="2"
            Click="btnSelectDEF_Click"
            Content="Select DEF" />
        <Button
            x:Name="btnSelectZXY"
            Grid.Row="3"
            Click="btnSelectZXY_Click"
            Content="Select ZXY" />
        <Button
            x:Name="btnSelectedText"
            Grid.Row="4"
            Click="btnSelection_Click"
            Content="Get SelectedText" />
        <TextBlock
            x:Name="txkResult"
            Grid.Row="5"
            Text="...Waiting..." />
    </Grid>
</UserControl>
