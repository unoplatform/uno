<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.TextBoxControl.TextBox_Header"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <controls:SampleControl SampleDescription="Sample TextBox with and without header">
        <controls:SampleControl.SampleContent>
            <DataTemplate>
                <StackPanel Background="White">
                    <TextBox
                        Margin="10"
                        Header="{Binding [Header]}"
                        PlaceholderText="With header" />
                    <Button Command="{Binding [ToggleHeader]}" Content="Toggle header" />
                    <TextBox Margin="10" PlaceholderText="{Binding [Placeholder]}" />
                </StackPanel>
            </DataTemplate>
        </controls:SampleControl.SampleContent>
    </controls:SampleControl>
</UserControl>
