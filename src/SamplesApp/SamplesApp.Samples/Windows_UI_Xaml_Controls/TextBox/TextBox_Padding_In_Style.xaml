<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.TextBoxControl.TextBox_Padding_In_Style"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <UserControl.Resources>
        <ResourceDictionary>
            <Style x:Key="TextBoxWithLabelStyle" TargetType="TextBox">

                <Setter Property="TextAlignment" Value="Right" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Bottom" />
                <Setter Property="MinHeight" Value="0" />

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <StackPanel
                                x:Name="Root"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <!--  HEADER/LABEL  -->
                                <TextBlock
                                    x:Name="HeaderContentPresenter"
                                    Margin="0,14"
                                    VerticalAlignment="Top"
                                    FontWeight="Normal"
                                    MaxLines="2"
                                    Text="{TemplateBinding Header}" />

                                <Rectangle />

                                <Grid
                                    MinWidth="40"
                                    Margin="0,14"
                                    VerticalAlignment="Bottom">
                                    <!--  PLACE HOLDER TEXT  -->
                                    <TextBlock
                                        x:Name="PlaceholderTextContentPresenter"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Bottom"
                                        IsHitTestVisible="False"
                                        MaxLines="1"
                                        Opacity="0.5"
                                        Text="{TemplateBinding PlaceholderText}"
                                        TextAlignment="Right" />

                                    <!--  CONTENT PRESENTER  -->
                                    <ScrollViewer
                                        x:Name="ContentElement"
                                        Padding="0"
                                        AutomationProperties.AccessibilityView="Raw"
                                        IsTabStop="False"
                                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                        ZoomMode="Disabled" />
                                </Grid>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Opacity" Value="0.5" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </StackPanel>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <controls:SampleControl SampleDescription="TextBox with paddings applied in style">
        <controls:SampleControl.SampleContent>
            <DataTemplate>
                <StackPanel
                    VerticalAlignment="Center"
                    Background="Beige"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,14"
                        FontSize="11"
                        Foreground="Red"
                        Text=" TextBlockText" />
                    <TextBox
                        FontSize="11"
                        Header="TextBoxHeader2"
                        Style="{StaticResource TextBoxWithLabelStyle}"
                        Text="TextBoxText" />
                </StackPanel>
            </DataTemplate>
        </controls:SampleControl.SampleContent>
    </controls:SampleControl>
</UserControl>
