<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.TextBoxControl.TextBox_TextProperty"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <StackPanel>

        <TextBox
            x:Name="TextBox1"
            Header="TextBox1"
            PlaceholderText="TextBox1"
            Text="{Binding [MyInput], Mode=TwoWay}" />
        <TextBox
            x:Name="TextBox2"
            Margin="0,10,0,0"
            Header="TextBox2"
            PlaceholderText="TextBox2" />

        <TextBlock
            Margin="0,10,0,0"
            FontWeight="Bold"
            Text="TextBox1 value (ElementName binding, updated when text changes)"
            TextWrapping="Wrap" />
        <TextBlock x:Name="TextChangedTextBlock" Text="{Binding Text, ElementName=TextBox1}" />
        <TextBlock
            Margin="0,10,0,0"
            FontWeight="Bold"
            Text="TextBox1 value (ViewModel binding, updated when focus is lost)"
            TextWrapping="Wrap" />
        <TextBlock x:Name="LostFocusTextBlock" Text="{Binding [MyInput]}" />

    </StackPanel>
</UserControl>
