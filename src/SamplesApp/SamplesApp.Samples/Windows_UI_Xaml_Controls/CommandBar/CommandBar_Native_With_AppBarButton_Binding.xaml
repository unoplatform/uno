<Page
    x:Class="UITests.Windows_UI_Xaml_Controls.CommandBar.CommandBar_Native_With_AppBarButton_Binding"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://nventive.com/android"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://nventive.com/ios"
    xmlns:local="using:UITests.Windows_UI_Xaml_Controls.CommandBar"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d not_win ios android">

    <Page.Resources>
        <Style
            x:Name="NativeCommandbarStyle"
            not_win:BasedOn="{StaticResource NativeDefaultCommandBar}"
            TargetType="CommandBar">
            <Setter Property="Background" Value="Blue" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <local:FromNullableBoolToCustomValueConverter
            x:Key="IsCheckedToIcon"
            NullOrFalseValue="ms-appx:///Assets/filter.png"
            TrueValue="ms-appx:///Assets/closeIcon.png" />
    </Page.Resources>

    <StackPanel Background="White">
        <not_win:Grid>
            <CommandBar
                Grid.Row="0"
                Content="CommandBar with DataContext Set"
                Style="{StaticResource NativeCommandbarStyle}">
                <CommandBar.PrimaryCommands>
                    <AppBarButton
                        Command="{Binding [ToggleChecked]}"
                        Foreground="White"
                        Label="Order">
                        <AppBarButton.Icon>
                            <BitmapIcon ShowAsMonochrome="True" UriSource="{Binding [IsChecked], Converter={StaticResource IsCheckedToIcon}}" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar.PrimaryCommands>
            </CommandBar>
        </not_win:Grid>
    </StackPanel>
</Page>
