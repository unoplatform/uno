<Page
    x:Class="Uno.UI.Samples.Content.UITests.CommandBar.BackGesture.BackGesture_Collapsed"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="Green">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <CommandBar Content="Collapsed" Visibility="Collapsed" />

        <TextBlock
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Text="Here the CommandBar is collapsed. The back gesture SHOULD work."
            TextWrapping="Wrap" />

        <Button
            x:Name="GoBack"
            Grid.Row="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="GoBack_Click"
            Content="Go back" />

    </Grid>
</Page>
