<Page
    x:Class="Uno.UI.Samples.Content.UITests.RichEditBoxControl.RichEditBox_Events"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel
        MaxWidth="560"
        Padding="16"
        HorizontalAlignment="Left"
        Spacing="8">
        <TextBlock
            FontWeight="SemiBold"
            Text="RichEditBox events (Skia): type to raise TextChanging/TextChanged, move the caret to raise SelectionChanging/SelectionChanged, and use Ctrl+C/X/V to raise CopyingToClipboard/CuttingToClipboard/Paste. Toggle the switches to cancel or suppress the corresponding operation."
            TextWrapping="Wrap" />
        <RichEditBox
            x:Name="Editor"
            Height="120"
            Header="Editable content"
            PlaceholderText="Start typing…" />
        <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleSwitch x:Name="CancelSelectionToggle" Header="Cancel SelectionChanging" />
            <ToggleSwitch x:Name="SuppressCopyToggle" Header="Suppress copy" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleSwitch x:Name="SuppressCutToggle" Header="Suppress cut" />
            <ToggleSwitch x:Name="SuppressPasteToggle" Header="Suppress paste" />
        </StackPanel>
        <Button
            x:Name="ClearLogButton"
            Click="OnClearLogClick"
            Content="Clear log" />
        <TextBlock FontWeight="SemiBold" Text="Event log (newest first):" />
        <TextBlock
            x:Name="Log"
            FontFamily="Consolas"
            Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
            TextWrapping="Wrap" />
    </StackPanel>
</Page>
