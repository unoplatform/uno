<Page
    x:Class="Uno.UI.Samples.Content.UITests.RichEditBoxControl.RichEditBox_ParagraphFormatting"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="OnLoaded"
    mc:Ignorable="d">

    <StackPanel
        MaxWidth="520"
        Padding="16"
        HorizontalAlignment="Left"
        Spacing="8">
        <TextBlock
            FontWeight="SemiBold"
            Text="Functional RichEditBox (Skia): apply a uniform paragraph alignment to the whole document through the Text Object Model. Because the shared surface is a single TextBlock, a uniform Left/Center/Right/Justify alignment renders (visible across the wrapped lines); per-paragraph divergence, indents and spacing round-trip in the model but are not shown yet."
            TextWrapping="Wrap" />

        <RichEditBox
            x:Name="Editor"
            Width="360"
            Height="160"
            HorizontalAlignment="Left"
            Header="Document"
            IsReadOnly="True" />

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button
                x:Name="LeftButton"
                Click="OnLeftClick"
                Content="Left" />
            <Button
                x:Name="CenterButton"
                Click="OnCenterClick"
                Content="Center" />
            <Button
                x:Name="RightButton"
                Click="OnRightClick"
                Content="Right" />
            <Button
                x:Name="JustifyButton"
                Click="OnJustifyClick"
                Content="Justify" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button
                x:Name="UndoButton"
                Click="OnUndoClick"
                Content="Undo" />
            <Button
                x:Name="RedoButton"
                Click="OnRedoClick"
                Content="Redo" />
            <Button
                x:Name="ResetButton"
                Click="OnResetClick"
                Content="Reset" />
        </StackPanel>

        <TextBlock
            x:Name="Output"
            Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
            TextWrapping="Wrap" />
    </StackPanel>
</Page>
