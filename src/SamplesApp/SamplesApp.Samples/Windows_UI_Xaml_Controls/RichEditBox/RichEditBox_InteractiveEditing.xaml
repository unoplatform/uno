<Page
    x:Class="Uno.UI.Samples.Content.UITests.RichEditBoxControl.RichEditBox_InteractiveEditing"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel
        MaxWidth="520"
        Padding="16"
        HorizontalAlignment="Left"
        Spacing="8">
        <TextBlock
            FontWeight="SemiBold"
            Text="Interactive RichEditBox (Skia): type to edit, click to place the caret, drag or Shift+click to select, double-click to select a word. Arrows/Home/End navigate, Ctrl+A selects all, Ctrl+Z/Y undo/redo."
            TextWrapping="Wrap" />
        <RichEditBox
            x:Name="Editor"
            Height="140"
            Header="Editable content"
            PlaceholderText="Start typing…" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button
                x:Name="SnapshotButton"
                Click="OnSnapshotClick"
                Content="Snapshot state" />
            <Button
                x:Name="UndoButton"
                Click="OnUndoClick"
                Content="Undo" />
            <Button
                x:Name="RedoButton"
                Click="OnRedoClick"
                Content="Redo" />
        </StackPanel>
        <TextBlock
            x:Name="Output"
            FontFamily="Consolas"
            Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
            TextWrapping="Wrap" />
    </StackPanel>
</Page>
