<Page
    x:Class="Uno.UI.Samples.Content.UITests.RichEditBoxControl.RichEditBox_FormattingAccelerators"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel
        MaxWidth="520"
        Padding="16"
        HorizontalAlignment="Left"
        Spacing="8">
        <TextBlock
            FontWeight="SemiBold"
            Text="Formatting accelerators (Skia): select some text in the editor, then press Ctrl+B, Ctrl+I or Ctrl+U to toggle bold, italic or underline over the selection. Use the checkboxes to disable individual accelerators via DisabledFormattingAccelerators."
            TextWrapping="Wrap" />
        <RichEditBox
            x:Name="Editor"
            Height="140"
            Header="Editable content"
            PlaceholderText="Start typing…" />
        <StackPanel Orientation="Horizontal" Spacing="12">
            <CheckBox
                x:Name="DisableBold"
                Checked="OnDisabledAcceleratorsChanged"
                Content="Disable Ctrl+B"
                Unchecked="OnDisabledAcceleratorsChanged" />
            <CheckBox
                x:Name="DisableItalic"
                Checked="OnDisabledAcceleratorsChanged"
                Content="Disable Ctrl+I"
                Unchecked="OnDisabledAcceleratorsChanged" />
            <CheckBox
                x:Name="DisableUnderline"
                Checked="OnDisabledAcceleratorsChanged"
                Content="Disable Ctrl+U"
                Unchecked="OnDisabledAcceleratorsChanged" />
        </StackPanel>
        <Button
            x:Name="InspectButton"
            Click="OnInspectClick"
            Content="Inspect selection format" />
        <TextBlock
            x:Name="Output"
            FontFamily="Consolas"
            Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
            TextWrapping="Wrap" />
    </StackPanel>
</Page>
