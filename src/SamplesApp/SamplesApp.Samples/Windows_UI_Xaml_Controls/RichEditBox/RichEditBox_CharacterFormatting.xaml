<Page
    x:Class="Uno.UI.Samples.Content.UITests.RichEditBoxControl.RichEditBox_CharacterFormatting"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Loaded="OnLoaded"
    mc:Ignorable="d">

    <StackPanel
        MaxWidth="520"
        Padding="16"
        HorizontalAlignment="Left"
        Spacing="8">
        <TextBlock
            FontWeight="SemiBold"
            Text="Functional RichEditBox (Skia): apply character formatting to a range through the Document Text Object Model. The runs render as TextBlock inlines."
            TextWrapping="Wrap" />

        <RichEditBox
            x:Name="Editor"
            Height="120"
            Header="Document"
            IsReadOnly="True" />

        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox
                x:Name="StartBox"
                Width="96"
                Header="Start"
                Text="4" />
            <TextBox
                x:Name="EndBox"
                Width="96"
                Header="End"
                Text="9" />
            <TextBlock
                VerticalAlignment="Bottom"
                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                Text="Character offsets into the document."
                TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button
                x:Name="BoldButton"
                Click="OnBoldClick"
                Content="Bold" />
            <Button
                x:Name="ItalicButton"
                Click="OnItalicClick"
                Content="Italic" />
            <Button
                x:Name="UnderlineButton"
                Click="OnUnderlineClick"
                Content="Underline" />
            <Button
                x:Name="StrikethroughButton"
                Click="OnStrikethroughClick"
                Content="Strikethrough" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button
                x:Name="RedButton"
                Click="OnRedClick"
                Content="Red" />
            <Button
                x:Name="GreenButton"
                Click="OnGreenClick"
                Content="Green" />
            <Button
                x:Name="BiggerButton"
                Click="OnBiggerClick"
                Content="A+" />
            <Button
                x:Name="SmallerButton"
                Click="OnSmallerClick"
                Content="A−" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button
                x:Name="UndoButton"
                Click="OnUndoClick"
                Content="Undo" />
            <Button
                x:Name="RedoButton"
                Click="OnRedoClick"
                Content="Redo" />
            <Button
                x:Name="ResetButton"
                Click="OnResetClick"
                Content="Reset" />
        </StackPanel>

        <TextBlock
            x:Name="Output"
            Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
            TextWrapping="Wrap" />
    </StackPanel>
</Page>
