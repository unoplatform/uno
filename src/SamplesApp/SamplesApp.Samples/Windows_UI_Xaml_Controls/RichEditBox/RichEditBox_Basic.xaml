<Page
    x:Class="Uno.UI.Samples.Content.UITests.RichEditBoxControl.RichEditBox_Basic"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel
        MaxWidth="480"
        Padding="16"
        HorizontalAlignment="Left"
        Spacing="8">
        <TextBlock
            FontWeight="SemiBold"
            Text="Functional RichEditBox (Skia): set/get plain text through Document, with a Header, PlaceholderText and IsReadOnly toggle."
            TextWrapping="Wrap" />
        <RichEditBox
            x:Name="Editor"
            Height="120"
            Header="Notes"
            PlaceholderText="Nothing here yet…" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button
                x:Name="SetButton"
                Click="OnSetTextClick"
                Content="Set text" />
            <Button
                x:Name="GetButton"
                Click="OnGetTextClick"
                Content="Get text" />
            <ToggleSwitch
                x:Name="ReadOnlyToggle"
                Header="IsReadOnly"
                Toggled="OnReadOnlyToggled" />
        </StackPanel>
        <TextBlock
            x:Name="Output"
            Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
            TextWrapping="Wrap" />
    </StackPanel>
</Page>
