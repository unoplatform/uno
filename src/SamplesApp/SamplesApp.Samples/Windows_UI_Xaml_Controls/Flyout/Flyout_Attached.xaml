<UserControl
    x:Class="UITests.Shared.Windows_UI_Xaml_Controls.Flyout.Flyout_Attached"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_Xaml_Controls.Flyout"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid>
        <StackPanel>
            <Button
                x:Name="ShowFlyoutButton"
                Margin="10,20,10,100"
                Click="ShowFlyoutButton_Click"
                Content="Show flyout" />
            <Border
                x:Name="FlyoutTarget"
                Margin="50"
                HorizontalAlignment="Left"
                Background="LightPink">
                <FlyoutBase.AttachedFlyout>
                    <Flyout Placement="Bottom">
                        <Border
                            Width="100"
                            Height="100"
                            Background="Blue"
                            Opacity="0.9">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="LightPink"
                                Text="I am a flyout!" />
                        </Border>
                    </Flyout>
                </FlyoutBase.AttachedFlyout>
                <TextBlock Text="Flyout here" />
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
