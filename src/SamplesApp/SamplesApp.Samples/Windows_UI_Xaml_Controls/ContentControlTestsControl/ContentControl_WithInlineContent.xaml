<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.ContentControlTestsControl.ContentControl_WithInlineContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Uno.UI.Samples.Content.UITests.ContentControlTestsControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid>
        <StackPanel>
            <Button Style="{StaticResource XamlDefaultButton}">Some implicit content</Button>
            <Button Style="{StaticResource XamlDefaultButton}">
                <TextBlock>Some TextBlock Implicit Content</TextBlock>
            </Button>
            <Button Style="{StaticResource XamlDefaultButton}">
                <Button.Content>
                    Some explicit content
                </Button.Content>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
