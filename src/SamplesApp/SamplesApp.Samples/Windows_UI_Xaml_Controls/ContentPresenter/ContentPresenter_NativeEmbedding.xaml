<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.ContentPresenter.ContentPresenter_NativeEmbedding"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Uno.UI.Samples.Content.UITests.ContentPresenter"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_skia="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:skia="http://uno.ui/skia"
    xmlns:uc="using:Uno.UI.Samples.Converters"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d skia">

    <UserControl.Resources>
        <uc:FromNullableBoolToVisibilityConverter x:Key="FromNullableBoolToVisibilityConverter" VisibilityIfTrue="Visible" />
    </UserControl.Resources>
    <skia:StackPanel>
        <ScrollViewer Height="300">
            <StackPanel>
                <Button x:Name="FullFlyoutButton" Content="Show a big Flyout. The native elements should NOT be visible through the flyout.">
                    <Button.Flyout>
                        <Flyout Placement="Full">
                            <Border
                                Background="Gray"
                                BorderBrush="Tomato"
                                BorderThickness="2" />
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button x:Name="BottomFlyoutButton" Content="Show a small Flyout below">
                    <Button.Flyout>
                        <Flyout Placement="Bottom">
                            <Border
                                Width="200"
                                Height="200"
                                Background="Gray"
                                BorderBrush="Tomato"
                                BorderThickness="2" />
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <ListView ItemsSource="0123456">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <local:NativeControlHostWithText
                                        Width="300"
                                        Height="200"
                                        Text="{Binding}" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <ToggleSwitch x:Name="ToggleSwitch" IsOn="True">
                            Visible
                        </ToggleSwitch>
                        <Slider
                            x:Name="slider"
                            Maximum="1"
                            Minimum="0"
                            StepFrequency="0.01"
                            Value="1" />
                        <TextBlock>Opacity</TextBlock>
                        <local:NativeControlHostWithText
                            x:Name="visibleHost"
                            Width="300"
                            Height="200"
                            Opacity="{Binding Value, ElementName=slider}"
                            Text="I'm visible if you can see me"
                            Visibility="{Binding IsOn, ElementName=ToggleSwitch, Converter={StaticResource FromNullableBoolToVisibilityConverter}}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
        <TextBlock>Expected outcome: X11 (left) and WPF (right)</TextBlock>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Source="Assets/x11embedding.png" />
            <Image Grid.Column="1" Source="Assets/wpfembedding.png" />
        </Grid>
    </skia:StackPanel>
    <not_skia:TextBlock>This sample is only supported on platforms with native embedding support.</not_skia:TextBlock>
</UserControl>
