<Page
    x:Class="UITests.Microsoft_UI_Windowing.MicaBackdropTests"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:DefaultBindMode="OneWay"
    Background="Transparent"
    mc:Ignorable="d">

    <StackPanel Padding="16" Spacing="8">
        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="Window.SystemBackdrop" />
        <TextBlock Text="Sets the system backdrop material on the current window. On macOS this uses NSVisualEffectView with the corresponding vibrancy material. On Windows 11 this uses the native Mica API. Set the page Background to Transparent to see the effect." TextWrapping="Wrap" />

        <TextBlock FontWeight="SemiBold">
            <Run Text="IsSupported: " />
            <Run Text="{x:Bind ViewModel.IsMicaSupported}" />
        </TextBlock>

        <TextBlock FontWeight="SemiBold">
            <Run Text="Current backdrop: " />
            <Run Text="{x:Bind ViewModel.CurrentBackdrop}" />
        </TextBlock>

        <Button Click="{x:Bind ViewModel.SetMicaBase}" Content="Mica (Base)" />
        <Button Click="{x:Bind ViewModel.SetMicaBaseAlt}" Content="Mica (BaseAlt)" />
        <Button Click="{x:Bind ViewModel.SetDesktopAcrylic}" Content="Desktop Acrylic" />
        <Button Click="{x:Bind ViewModel.ClearBackdrop}" Content="None (clear backdrop)" />
    </StackPanel>
</Page>
