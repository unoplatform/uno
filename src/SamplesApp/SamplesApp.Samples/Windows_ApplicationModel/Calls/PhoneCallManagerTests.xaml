<UserControl
    x:Class="UITests.Shared.Windows_ApplicationModel.Calls.PhoneCallManagerTests"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_ApplicationModel.Calls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <StackPanel>
        <CheckBox
            x:Name="IsCallActiveCheckBox"
            Content="IsCallActive"
            IsHitTestVisible="False" />
        <CheckBox
            x:Name="IsCallIncomingCheckBox"
            Content="IsCallIncoming"
            IsHitTestVisible="False" />
        <Button Click="ShowPhoneSettings_Click">Show Phone settings</Button>
        <TextBox
            x:Name="PhoneNumberTextBox"
            Margin="0,20,0,0"
            PlaceholderText="Enter a number..." />
        <Button Click="Dial_Click">Dial</Button>
        <TextBlock
            x:Name="ErrorMessage"
            Margin="0,20,0,0"
            Foreground="Red" />
    </StackPanel>
</UserControl>
