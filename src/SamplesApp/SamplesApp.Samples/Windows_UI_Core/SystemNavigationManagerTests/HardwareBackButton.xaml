<Page
    x:Class="UITests.Windows_UI_Core.SystemNavigationManagerTests.HardwareBackButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Core.SystemNavigationManagerTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel>
        <Button Content="Enable" Tapped="Enable" />
        <Button Content="Disable" Tapped="Disable" />
        <CheckBox
            x:Name="HandleCheckBox"
            Content="Handle event"
            IsChecked="False"
            IsThreeState="False" />
        <TextBlock x:Name="OutputTextBlock" />
    </StackPanel>
</Page>
