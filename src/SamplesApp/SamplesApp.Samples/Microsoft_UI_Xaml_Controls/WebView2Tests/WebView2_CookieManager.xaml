<Page
    x:Class="UITests.Microsoft_UI_Xaml_Controls.WebView2Tests.WebView2_CookieManager"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Microsoft_UI_Xaml_Controls.WebView2Tests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            FontSize="18"
            FontWeight="SemiBold"
            Text="CoreWebView2.CookieManager" />

        <TextBlock
            Grid.Row="1"
            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
            Text="Add/list/delete cookies via the CoreWebView2.CookieManager API. The WebView2 below is bound to httpbin.org which returns the set cookies in JSON."
            TextWrapping="Wrap" />

        <Grid Grid.Row="2" ColumnSpacing="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBox
                x:Name="NameInput"
                Grid.Column="0"
                PlaceholderText="name"
                Text="uno_demo" />
            <TextBox
                x:Name="ValueInput"
                Grid.Column="1"
                PlaceholderText="value"
                Text="hello" />
            <TextBox
                x:Name="DomainInput"
                Grid.Column="2"
                PlaceholderText="domain"
                Text="httpbin.org" />
            <TextBox
                x:Name="PathInput"
                Grid.Column="3"
                PlaceholderText="path"
                Text="/" />
        </Grid>

        <StackPanel
            Grid.Row="3"
            Orientation="Horizontal"
            Spacing="6">
            <Button Click="OnAddClick" Content="Add/Update" />
            <Button Click="OnListClick" Content="List cookies for httpbin.org" />
            <Button Click="OnDeleteClick" Content="Delete by name" />
            <Button Click="OnDeleteAllClick" Content="Delete all" />
            <Button Click="OnVisitClick" Content="Visit /cookies" />
        </StackPanel>

        <TextBlock
            x:Name="OutputText"
            Grid.Row="4"
            FontFamily="Consolas, Courier New, monospace"
            TextWrapping="Wrap" />

        <controls:WebView2
            x:Name="WebView"
            Grid.Row="5"
            Source="https://httpbin.org/cookies" />
    </Grid>
</Page>
