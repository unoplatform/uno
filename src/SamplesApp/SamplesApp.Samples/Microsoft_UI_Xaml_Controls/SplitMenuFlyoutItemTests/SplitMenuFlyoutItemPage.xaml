<Page
    x:Class="UITests.Shared.Microsoft_UI_Xaml_Controls.SplitMenuFlyoutItemTests.SplitMenuFlyoutItemPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    mc:Ignorable="d not_win">

    <not_win:ScrollViewer>
        <StackPanel Padding="16" Spacing="16">
            <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="SplitMenuFlyoutItem Manual Tests" />

            <!--  Basic usage  -->
            <TextBlock FontWeight="SemiBold" Text="1. Basic Split Menu Flyout Item" />
            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                Text="Click left side = primary action, hover/click right chevron = submenu" />
            <Button
                x:Name="BasicButton"
                AutomationProperties.Name="BasicButton"
                Content="File Menu">
                <Button.Flyout>
                    <MenuFlyout>
                        <SplitMenuFlyoutItem
                            x:Name="SaveItem"
                            AutomationProperties.Name="SaveItem"
                            Text="Save">
                            <SplitMenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Save" />
                            </SplitMenuFlyoutItem.Icon>
                            <SplitMenuFlyoutItem.Items>
                                <MenuFlyoutItem
                                    x:Name="SaveAsItem"
                                    AutomationProperties.Name="SaveAsItem"
                                    Text="Save As..." />
                                <MenuFlyoutItem Text="Save a Copy..." />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Export..." />
                            </SplitMenuFlyoutItem.Items>
                        </SplitMenuFlyoutItem>
                        <SplitMenuFlyoutItem
                            x:Name="OpenWithItem"
                            AutomationProperties.Name="OpenWithItem"
                            Text="Open With Photos">
                            <SplitMenuFlyoutItem.Items>
                                <MenuFlyoutItem Text="Paint" />
                                <MenuFlyoutItem Text="Paint 3D" />
                                <MenuFlyoutItem Text="Snipping Tool" />
                            </SplitMenuFlyoutItem.Items>
                        </SplitMenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Regular Item" />
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
            <TextBlock
                x:Name="BasicStatus"
                AutomationProperties.Name="BasicStatus"
                Text="(no action yet)" />

            <!--  Click event test  -->
            <TextBlock
                Margin="0,16,0,0"
                FontWeight="SemiBold"
                Text="2. Primary Click Event" />
            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                Text="Primary click should update status text and close the flyout" />
            <Button
                x:Name="ClickTestButton"
                AutomationProperties.Name="ClickTestButton"
                Content="Click Test">
                <Button.Flyout>
                    <MenuFlyout>
                        <SplitMenuFlyoutItem
                            x:Name="ClickTestItem"
                            AutomationProperties.Name="ClickTestItem"
                            Text="Click Me">
                            <SplitMenuFlyoutItem.Items>
                                <MenuFlyoutItem Text="Sub Option A" />
                                <MenuFlyoutItem Text="Sub Option B" />
                            </SplitMenuFlyoutItem.Items>
                        </SplitMenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
            <TextBlock
                x:Name="ClickStatus"
                AutomationProperties.Name="ClickStatus"
                Text="(waiting for click)" />

            <!--  SubMenuItemStyle test  -->
            <TextBlock
                Margin="0,16,0,0"
                FontWeight="SemiBold"
                Text="3. SubMenuItemStyle" />
            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                Text="Sub-items should have red foreground from SubMenuItemStyle" />
            <Button
                x:Name="StyleTestButton"
                AutomationProperties.Name="StyleTestButton"
                Content="Styled Sub-Items">
                <Button.Flyout>
                    <MenuFlyout>
                        <SplitMenuFlyoutItem Text="Styled Split Item">
                            <SplitMenuFlyoutItem.SubMenuItemStyle>
                                <Style TargetType="MenuFlyoutItem">
                                    <Setter Property="Foreground" Value="Red" />
                                </Style>
                            </SplitMenuFlyoutItem.SubMenuItemStyle>
                            <SplitMenuFlyoutItem.Items>
                                <MenuFlyoutItem Text="Red Item 1" />
                                <MenuFlyoutItem Text="Red Item 2" />
                                <MenuFlyoutItem Text="Red Item 3" />
                            </SplitMenuFlyoutItem.Items>
                        </SplitMenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>

            <!--  Empty items test  -->
            <TextBlock
                Margin="0,16,0,0"
                FontWeight="SemiBold"
                Text="4. Empty Items Collection" />
            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                Text="Split item with no sub-items (chevron area should still render)" />
            <Button
                x:Name="EmptyItemsButton"
                AutomationProperties.Name="EmptyItemsButton"
                Content="Empty Sub-Items">
                <Button.Flyout>
                    <MenuFlyout>
                        <SplitMenuFlyoutItem Text="No Sub-Items" />
                        <MenuFlyoutItem Text="Regular Item" />
                    </MenuFlyout>
                </Button.Flyout>
            </Button>

            <!--  Mixed items test  -->
            <TextBlock
                Margin="0,16,0,0"
                FontWeight="SemiBold"
                Text="5. Mixed with Other Item Types" />
            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                Text="SplitMenuFlyoutItem mixed with regular items, toggles, and separators" />
            <Button
                x:Name="MixedButton"
                AutomationProperties.Name="MixedButton"
                Content="Mixed Menu">
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Cut">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Cut" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Copy">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Copy" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <SplitMenuFlyoutItem Text="Paste">
                            <SplitMenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Paste" />
                            </SplitMenuFlyoutItem.Icon>
                            <SplitMenuFlyoutItem.Items>
                                <MenuFlyoutItem Text="Paste Special..." />
                                <MenuFlyoutItem Text="Paste as Plain Text" />
                            </SplitMenuFlyoutItem.Items>
                        </SplitMenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <ToggleMenuFlyoutItem Text="Word Wrap" />
                    </MenuFlyout>
                </Button.Flyout>
            </Button>

            <!--  Disabled state  -->
            <TextBlock
                Margin="0,16,0,0"
                FontWeight="SemiBold"
                Text="6. Disabled State" />
            <Button
                x:Name="DisabledButton"
                AutomationProperties.Name="DisabledButton"
                Content="Disabled Item">
                <Button.Flyout>
                    <MenuFlyout>
                        <SplitMenuFlyoutItem Text="Enabled Item">
                            <SplitMenuFlyoutItem.Items>
                                <MenuFlyoutItem Text="Sub 1" />
                            </SplitMenuFlyoutItem.Items>
                        </SplitMenuFlyoutItem>
                        <SplitMenuFlyoutItem IsEnabled="False" Text="Disabled Item">
                            <SplitMenuFlyoutItem.Items>
                                <MenuFlyoutItem Text="Sub 1" />
                            </SplitMenuFlyoutItem.Items>
                        </SplitMenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>

            <!--  Separator in sub-items  -->
            <TextBlock
                Margin="0,16,0,0"
                FontWeight="SemiBold"
                Text="7. Separators in Sub-Items" />
            <Button
                x:Name="SeparatorButton"
                AutomationProperties.Name="SeparatorButton"
                Content="Sub-Items with Separators">
                <Button.Flyout>
                    <MenuFlyout>
                        <SplitMenuFlyoutItem Text="Compress">
                            <SplitMenuFlyoutItem.Items>
                                <MenuFlyoutItem Text="ZIP file" />
                                <MenuFlyoutItem Text="7z file" />
                                <MenuFlyoutItem Text="TAR file" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Additional Options..." />
                            </SplitMenuFlyoutItem.Items>
                        </SplitMenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </StackPanel>
    </not_win:ScrollViewer>
</Page>
