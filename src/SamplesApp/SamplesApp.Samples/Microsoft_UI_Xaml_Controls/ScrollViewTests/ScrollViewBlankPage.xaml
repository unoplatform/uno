<local:TestPage
    x:Class="MUXControlsTestApp.ScrollViewBlankPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        x:Name="rootGrid"
        Margin="4"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.ColumnSpan="4" Orientation="Horizontal">
            <CheckBox
                x:Name="chkCustomUI"
                Margin="2,0,0,0"
                Checked="ChkCustomUI_Checked"
                Content="Custom test UI"
                IsChecked="True"
                IsThreeState="False"
                Unchecked="ChkCustomUI_Unchecked" />
            <CheckBox
                x:Name="chkLogs"
                Margin="2,0,0,0"
                Checked="ChkLogs_Checked"
                Content="Logs"
                IsChecked="True"
                IsThreeState="False"
                Unchecked="ChkLogs_Unchecked" />
        </StackPanel>

        <controls:ScrollView
            x:Name="scrollView"
            Grid.Row="1"
            Width="300"
            Height="400"
            Margin="1"
            VerticalAlignment="Top"
            Background="AliceBlue">
            <!--  Replace Rectangle with your custom ScrollView content  -->
            <Rectangle Width="900" Height="900">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0.0" Color="Blue" />
                        <GradientStop Offset="0.5" Color="Yellow" />
                        <GradientStop Offset="1.0" Color="Red" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </controls:ScrollView>

        <Grid
            x:Name="grdCustomUI"
            Grid.Row="1"
            Grid.RowSpan="2"
            Grid.Column="1"
            Margin="2"
            Background="LightYellow">
            <!--  Put your custom scenario UI here  -->
        </Grid>

        <Grid
            x:Name="grdLogs"
            Grid.Row="1"
            Grid.RowSpan="2"
            Grid.Column="2"
            Margin="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Foreground="Red" Text="Logs" />

            <StackPanel Grid.Row="1" Orientation="Horizontal">
                <Button
                    x:Name="btnClearLogs"
                    Margin="1"
                    Click="BtnClearLogs_Click"
                    Content="Clear" />
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox
                            x:Name="chkLogScrollPresenterEvents"
                            Margin="1"
                            Checked="ChkLogScrollPresenterEvents_Checked"
                            Content="Log ScrollPresenter Events?"
                            Unchecked="ChkLogScrollPresenterEvents_Unchecked" />
                        <CheckBox
                            x:Name="chkLogScrollViewEvents"
                            Margin="1"
                            Checked="ChkLogScrollViewEvents_Checked"
                            Content="Log ScrollView Events?"
                            IsChecked="True"
                            Unchecked="ChkLogScrollViewEvents_Unchecked" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox
                            x:Name="chkLogScrollPresenterMessages"
                            Margin="1"
                            Checked="ChkLogScrollPresenterMessages_Checked"
                            Content="Log ScrollPresenter Messages?"
                            Unchecked="ChkLogScrollPresenterMessages_Unchecked" />
                        <CheckBox
                            x:Name="chkLogScrollViewMessages"
                            Margin="1"
                            Checked="ChkLogScrollViewMessages_Checked"
                            Content="Log ScrollView Messages?"
                            Unchecked="ChkLogScrollViewMessages_Unchecked" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <ListBox
                x:Name="lstLogs"
                Grid.Row="2"
                Margin="1" />
        </Grid>

        <StackPanel
            Grid.Row="3"
            Grid.ColumnSpan="4"
            Orientation="Horizontal">
            <TextBlock
                Margin="2"
                VerticalAlignment="Center"
                Text="Exception Report" />
            <Button
                x:Name="btnClearExceptionReport"
                Margin="2"
                Click="BtnClearExceptionReport_Click"
                Content="Clear Exception Report" />
            <TextBox
                x:Name="txtExceptionReport"
                Margin="2"
                IsReadOnly="True" />
        </StackPanel>
    </Grid>
</local:TestPage>
