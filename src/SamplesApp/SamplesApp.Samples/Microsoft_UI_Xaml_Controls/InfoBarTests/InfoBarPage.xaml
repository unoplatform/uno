<!--  MUX Reference InfoBarPage.xaml, commit b424312  -->
<local:TestPage
    x:Class="MUXControlsTestApp.InfoBarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:contract5Present="http://schemas.microsoft.com/winfx/2006/xaml/presentation?IsApiContractPresent(Windows.Foundation.UniversalApiContract,5)"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="InfoBarTestPage"
    mc:Ignorable="d">

    <Page.Resources>
        <Style
            x:Name="CustomCloseButtonStyle"
            BasedOn="{StaticResource InfoBarCloseButtonStyle}"
            TargetType="Button">
            <Style.Setters>
                <Setter Property="Background" Value="Red" />
            </Style.Setters>
        </Style>
    </Page.Resources>

    <Grid Margin="12" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid x:Name="InfoBarParent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <controls:InfoBar
                x:Name="TestInfoBar"
                Title="{x:Bind TitleTextBox.Text, Mode=OneWay}"
                AutomationProperties.Name="TestInfoBar"
                CloseButtonClick="OnCloseButtonClick"
                Closed="OnClosed"
                Closing="OnClosing"
                IsClosable="{x:Bind IsClosableCheckBox.IsChecked.Value, Mode=OneWay}"
                IsIconVisible="{x:Bind IsIconVisibleCheckBox.IsChecked.Value, Mode=OneWay}"
                IsOpen="True"
                Message="{x:Bind MessageTextBox.Text, Mode=OneWay}" />

            <Grid Grid.Row="1" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    HorizontalAlignment="Left"
                    contract5Present:Spacing="6"
                    Orientation="Vertical">
                    <ComboBox
                        x:Name="SeverityComboBox"
                        AutomationProperties.Name="SeverityComboBox"
                        Header="Severity"
                        SelectionChanged="SeverityComboBox_SelectionChanged">
                        <x:String>Error</x:String>
                        <x:String>Warning</x:String>
                        <x:String>Success</x:String>
                        <x:String>Informational</x:String>
                    </ComboBox>

                    <ComboBox
                        x:Name="IconComboBox"
                        AutomationProperties.Name="IconComboBox"
                        Header="Icon"
                        SelectedIndex="0"
                        SelectionChanged="IconComboBox_SelectionChanged">
                        <x:String>Default Icon</x:String>
                        <x:String>Custom Icon</x:String>
                    </ComboBox>

                    <TextBox
                        x:Name="TitleTextBox"
                        Width="250"
                        HorizontalAlignment="Left"
                        AutomationProperties.Name="TitleTextBox"
                        Header="Title"
                        Text="Title" />

                    <TextBox
                        x:Name="MessageTextBox"
                        Width="250"
                        HorizontalAlignment="Left"
                        AutomationProperties.Name="MessageTextBox"
                        Header="Message"
                        Text="Message" />

                    <ComboBox
                        x:Name="ActionButtonComboBox"
                        AutomationProperties.Name="ActionButtonComboBox"
                        Header="Action Button"
                        SelectedIndex="0"
                        SelectionChanged="ActionButtonComboBox_SelectionChanged">
                        <ComboBoxItem Content="None" />
                        <ComboBoxItem Content="Button" />
                        <ComboBoxItem Content="Hyperlink" />
                        <ComboBoxItem Content="RightAlignedButton" />
                        <ComboBoxItem Content="RightAlignedHyperlink" />
                    </ComboBox>

                    <Button
                        x:Name="CollpaseActionButtonAsynchronouslyButton"
                        Click="CollapseActionButtonAsynchronouslyClick"
                        Content="Collapse ActionButton async" />
                    <Button
                        x:Name="DisableActionButtonAsynchronouslyButton"
                        Click="DisableActionButtonAsynchronouslyClick"
                        Content="Disable ActionButton async" />
                    <Button
                        x:Name="ResetActionButtonAsynchronouslyButton"
                        Click="ResetActionButtonAsynchronouslyClick"
                        Content="Reset ActionButton async" />

                    <Button
                        x:Name="AddInfoBarButton"
                        Click="AddInfoBarClick"
                        Content="Add InfoBar"
                        IsEnabled="False" />
                    <Button
                        x:Name="RemoveInfoBarAsynchronouslyButton"
                        Click="RemoveInfoBarAsynchronouslyClick"
                        Content="Remove InfoBar async" />

                    <Button Click="SetForegroundClick" Content="Set Foreground" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    Margin="20,0,0,0"
                    HorizontalAlignment="Left"
                    Orientation="Vertical">
                    <CheckBox
                        x:Name="IsOpenCheckBox"
                        AutomationProperties.Name="IsOpenCheckBox"
                        Content="IsOpen"
                        IsChecked="{x:Bind TestInfoBar.IsOpen, Mode=TwoWay}" />

                    <CheckBox
                        x:Name="CancelCheckBox"
                        AutomationProperties.Name="CancelCheckBox"
                        Content="Cancel Close" />

                    <CheckBox
                        x:Name="IsIconVisibleCheckBox"
                        AutomationProperties.Name="IsIconVisibleCheckBox"
                        Content="IsIconVisible"
                        IsChecked="True" />

                    <CheckBox
                        x:Name="IsClosableCheckBox"
                        AutomationProperties.Name="IsClosableCheckBox"
                        Content="IsClosable"
                        IsChecked="True" />

                    <CheckBox
                        x:Name="HasCustomContentCheckBox"
                        AutomationProperties.Name="HasCustomContentCheckBox"
                        Checked="HasCustomContentChanged"
                        Content="Has Custom Content"
                        Unchecked="HasCustomContentChanged" />

                    <CheckBox
                        x:Name="CustomBackgroundCheckBox"
                        AutomationProperties.Name="CustomBackgroundCheckBox"
                        Checked="CustomBackgroundChanged"
                        Content="Custom Background Color"
                        Unchecked="CustomBackgroundChanged" />

                    <CheckBox
                        x:Name="CloseButtonStyleCheckBox"
                        AutomationProperties.Name="CloseButtonStyleCheckBox"
                        Checked="CloseStyleChanged"
                        Content="Custom Close Button Style"
                        Unchecked="CloseStyleChanged" />

                    <CheckBox
                        x:Name="RemoveActionButtonOnInvokeCheckBox"
                        AutomationProperties.Name="RemoveActionButtonOnInvokeCheckBox"
                        Content="Remove ActionButton on invoke" />
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    Margin="20,0,0,0"
                    HorizontalAlignment="Left"
                    Orientation="Vertical">
                    <TextBlock>Events:</TextBlock>
                    <ListBox
                        x:Name="EventListBox"
                        MinWidth="150"
                        MaxHeight="380"
                        AutomationProperties.Name="EventListBox">
                        <ListBox.Resources>
                            <Style TargetType="ListBoxItem">
                                <Style.Setters>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <TextBlock Text="{TemplateBinding Content}" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style.Setters>
                            </Style>
                        </ListBox.Resources>
                    </ListBox>
                    <Button
                        Margin="0,6,0,0"
                        AutomationProperties.Name="ClearButton"
                        Click="ClearButtonClick"
                        Content="Clear" />

                    <TextBlock Margin="0,20,0,0" Text="Default InfoBar (should be invisible):" />
                    <controls:InfoBar AutomationProperties.Name="DefaultInfoBar" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</local:TestPage>
