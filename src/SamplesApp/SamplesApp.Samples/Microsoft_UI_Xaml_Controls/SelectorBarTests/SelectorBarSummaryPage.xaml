<local:TestPage
    x:Class="MUXControlsTestApp.SelectorBarSummaryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        x:Name="root"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
        RowDefinitions="Auto, *, Auto">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="300" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.ColumnSpan="4" Orientation="Horizontal">
            <CheckBox
                x:Name="chkSelectorBarProperties"
                Margin="2,0,0,0"
                Checked="ChkSelectorBarProperties_Checked"
                Content="SelectorBar Properties"
                IsChecked="True"
                IsThreeState="False"
                Unchecked="ChkSelectorBarProperties_Unchecked" />
            <CheckBox
                x:Name="chkSelectorBarItems"
                Margin="2,0,0,0"
                Checked="ChkSelectorBarItems_Checked"
                Content="SelectorBar Items"
                IsChecked="True"
                IsThreeState="False"
                Unchecked="ChkSelectorBarItems_Unchecked" />
            <CheckBox
                x:Name="chkLogs"
                Margin="2,0,0,0"
                Checked="ChkLogs_Checked"
                Content="Logs"
                IsChecked="True"
                IsThreeState="False"
                Unchecked="ChkLogs_Unchecked" />
        </StackPanel>

        <StackPanel
            Grid.Row="1"
            Margin="1"
            VerticalAlignment="Top">
            <Button
                x:Name="btnBefore"
                Width="150"
                AutomationProperties.Name="btnBefore"
                Content="Button Before" />
            <SelectorBar
                x:Name="selectorBar"
                MaxWidth="600"
                AutomationProperties.Name="selectorBar" />
            <Button
                x:Name="btnAfter"
                Width="150"
                AutomationProperties.Name="btnAfter"
                Content="Button After" />
        </StackPanel>

        <ScrollViewer
            x:Name="svSelectorBarProperties"
            Grid.Row="1"
            Grid.Column="1">
            <Grid
                Margin="4,0,4,0"
                Padding="6"
                BorderBrush="{ThemeResource SystemChromeGrayColor}"
                BorderThickness="1"
                ColumnDefinitions="Auto, Auto, Auto, Auto"
                RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto">

                <TextBlock
                    Grid.ColumnSpan="4"
                    Foreground="Red"
                    Text="SelectorBar Properties" />
                <TextBlock
                    Grid.Row="1"
                    Grid.ColumnSpan="4"
                    Foreground="DarkOrange"
                    Text="Specific" />

                <TextBlock
                    Grid.Row="2"
                    VerticalAlignment="Center"
                    Text="SelectedItem:" />
                <ComboBox
                    x:Name="cmbSelectorBarSelectedItem"
                    Grid.Row="2"
                    Grid.Column="1"
                    MinWidth="300"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center" />
                <Button
                    x:Name="btnGetSelectorBarSelectedItem"
                    Grid.Row="2"
                    Grid.Column="2"
                    Margin="1"
                    VerticalAlignment="Center"
                    Click="BtnGetSelectorBarSelectedItem_Click"
                    Content="G" />
                <Button
                    x:Name="btnSetSelectorBarSelectedItem"
                    Grid.Row="2"
                    Grid.Column="3"
                    Margin="1"
                    VerticalAlignment="Center"
                    Click="BtnSetSelectorBarSelectedItem_Click"
                    Content="S" />

                <TextBlock
                    Grid.Row="3"
                    Grid.ColumnSpan="4"
                    Foreground="DarkOrange"
                    Text="Inherited" />

                <TextBlock
                    Grid.Row="4"
                    VerticalAlignment="Center"
                    Text="Background:" />
                <ComboBox
                    x:Name="cmbBackground"
                    Grid.Row="4"
                    Grid.Column="1"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    SelectionChanged="CmbBackground_SelectionChanged">
                    <ComboBoxItem>null</ComboBoxItem>
                    <ComboBoxItem>Transparent</ComboBoxItem>
                    <ComboBoxItem>AliceBlue</ComboBoxItem>
                    <ComboBoxItem>Aqua</ComboBoxItem>
                </ComboBox>

                <TextBlock
                    Grid.Row="5"
                    VerticalAlignment="Center"
                    Text="BorderBrush:" />
                <ComboBox
                    x:Name="cmbBorderBrush"
                    Grid.Row="5"
                    Grid.Column="1"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    SelectionChanged="CmbBorderBrush_SelectionChanged">
                    <ComboBoxItem>null</ComboBoxItem>
                    <ComboBoxItem>Transparent</ComboBoxItem>
                    <ComboBoxItem>Blue</ComboBoxItem>
                    <ComboBoxItem>Green</ComboBoxItem>
                </ComboBox>

                <TextBlock
                    Grid.Row="6"
                    VerticalAlignment="Center"
                    Text="TabNavigation:" />
                <ComboBox
                    x:Name="cmbTabNavigation"
                    Grid.Row="6"
                    Grid.Column="1"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    SelectionChanged="CmbTabNavigation_SelectionChanged">
                    <ComboBoxItem>Local</ComboBoxItem>
                    <ComboBoxItem>Cycle</ComboBoxItem>
                    <ComboBoxItem>Once</ComboBoxItem>
                </ComboBox>

                <TextBlock
                    Grid.Row="7"
                    VerticalAlignment="Center"
                    Text="XYFocusKeyboardNavigation:" />
                <ComboBox
                    x:Name="cmbXYFocusKeyboardNavigation"
                    Grid.Row="7"
                    Grid.Column="1"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    SelectionChanged="CmbXYFocusKeyboardNavigation_SelectionChanged">
                    <ComboBoxItem>Auto</ComboBoxItem>
                    <ComboBoxItem>Enabled</ComboBoxItem>
                    <ComboBoxItem>Disabled</ComboBoxItem>
                </ComboBox>

                <TextBlock
                    Grid.Row="8"
                    VerticalAlignment="Center"
                    Text="BorderThickness:" />
                <TextBox
                    x:Name="txtBorderThickness"
                    Grid.Row="8"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center" />
                <Button
                    x:Name="btnGetBorderThickness"
                    Grid.Row="8"
                    Grid.Column="2"
                    Margin="1"
                    VerticalAlignment="Center"
                    Click="BtnGetBorderThickness_Click"
                    Content="G" />
                <Button
                    x:Name="btnSetBorderThickness"
                    Grid.Row="8"
                    Grid.Column="3"
                    Margin="1"
                    VerticalAlignment="Center"
                    Click="BtnSetBorderThickness_Click"
                    Content="S" />

                <TextBlock
                    Grid.Row="9"
                    VerticalAlignment="Center"
                    Text="Margin:" />
                <TextBox
                    x:Name="txtMargin"
                    Grid.Row="9"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center" />
                <Button
                    x:Name="btnGetMargin"
                    Grid.Row="9"
                    Grid.Column="2"
                    Margin="1"
                    VerticalAlignment="Center"
                    Click="BtnGetMargin_Click"
                    Content="G" />
                <Button
                    x:Name="btnSetMargin"
                    Grid.Row="9"
                    Grid.Column="3"
                    Margin="1"
                    VerticalAlignment="Center"
                    Click="BtnSetMargin_Click"
                    Content="S" />

                <TextBlock
                    Grid.Row="10"
                    VerticalAlignment="Center"
                    Text="Padding:" />
                <TextBox
                    x:Name="txtPadding"
                    Grid.Row="10"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center" />
                <Button
                    x:Name="btnGetPadding"
                    Grid.Row="10"
                    Grid.Column="2"
                    Margin="1"
                    VerticalAlignment="Center"
                    Click="BtnGetPadding_Click"
                    Content="G" />
                <Button
                    x:Name="btnSetPadding"
                    Grid.Row="10"
                    Grid.Column="3"
                    Margin="1"
                    VerticalAlignment="Center"
                    Click="BtnSetPadding_Click"
                    Content="S" />

                <TextBlock
                    Grid.Row="11"
                    VerticalAlignment="Center"
                    Text="MaxWidth:" />
                <TextBox
                    x:Name="txtMaxWidth"
                    Grid.Row="11"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center" />
                <Button
                    x:Name="btnGetMaxWidth"
                    Grid.Row="11"
                    Grid.Column="2"
                    Margin="1"
                    VerticalAlignment="Center"
                    Click="BtnGetMaxWidth_Click"
                    Content="G" />
                <Button
                    x:Name="btnSetMaxWidth"
                    Grid.Row="11"
                    Grid.Column="3"
                    Margin="1"
                    VerticalAlignment="Center"
                    Click="BtnSetMaxWidth_Click"
                    Content="S" />

                <TextBlock
                    Grid.Row="12"
                    VerticalAlignment="Center"
                    Text="MaxHeight:" />
                <TextBox
                    x:Name="txtMaxHeight"
                    Grid.Row="12"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center" />
                <Button
                    x:Name="btnGetMaxHeight"
                    Grid.Row="12"
                    Grid.Column="2"
                    Margin="1"
                    VerticalAlignment="Center"
                    Click="BtnGetMaxHeight_Click"
                    Content="G" />
                <Button
                    x:Name="btnSetMaxHeight"
                    Grid.Row="12"
                    Grid.Column="3"
                    Margin="1"
                    VerticalAlignment="Center"
                    Click="BtnSetMaxHeight_Click"
                    Content="S" />

                <TextBlock
                    Grid.Row="13"
                    VerticalAlignment="Center"
                    Text="CornerRadius:" />
                <TextBox
                    x:Name="txtCornerRadius"
                    Grid.Row="13"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center" />
                <Button
                    x:Name="btnGetCornerRadius"
                    Grid.Row="13"
                    Grid.Column="2"
                    Margin="1"
                    VerticalAlignment="Center"
                    Click="BtnGetCornerRadius_Click"
                    Content="G" />
                <Button
                    x:Name="btnSetCornerRadius"
                    Grid.Row="13"
                    Grid.Column="3"
                    Margin="1"
                    VerticalAlignment="Center"
                    Click="BtnSetCornerRadius_Click"
                    Content="S" />

                <CheckBox
                    x:Name="chkIsEnabled"
                    Grid.Row="14"
                    Grid.ColumnSpan="4"
                    Margin="1"
                    Checked="ChkIsEnabled_CheckedChanged"
                    Content="IsEnabled?"
                    Unchecked="ChkIsEnabled_CheckedChanged" />
                <CheckBox
                    x:Name="chkIsTabStop"
                    Grid.Row="15"
                    Grid.ColumnSpan="4"
                    Margin="1"
                    Checked="ChkIsTabStop_CheckedChanged"
                    Content="IsTabStop?"
                    Unchecked="ChkIsTabStop_CheckedChanged" />
            </Grid>
        </ScrollViewer>

        <ScrollViewer
            x:Name="svSelectorBarItems"
            Grid.Row="1"
            Grid.Column="2">
            <Grid
                Margin="4,0,4,0"
                Padding="6"
                Background="{ThemeResource SystemListLowColor}"
                BorderBrush="{ThemeResource SystemChromeGrayColor}"
                BorderThickness="1"
                ColumnDefinitions="Auto, Auto, Auto, Auto"
                RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto">

                <TextBlock
                    Grid.ColumnSpan="2"
                    Foreground="Red"
                    Text="SelectorBar Items" />

                <TextBlock
                    Grid.Row="1"
                    VerticalAlignment="Center"
                    Text="Items Count:" />
                <TextBox
                    x:Name="txtSelectorBarItemsCount"
                    Grid.Row="1"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    IsReadOnly="True"
                    Text="0" />
                <Button
                    x:Name="btnGetSelectorBarItemsCount"
                    Grid.Row="1"
                    Grid.Column="2"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnGetSelectorBarItemsCount_Click"
                    Content="G" />

                <TextBlock
                    Grid.Row="2"
                    VerticalAlignment="Center"
                    Text="Index:" />
                <TextBox
                    x:Name="txtSelectorBarItemIndex"
                    Grid.Row="2"
                    Grid.Column="1"
                    Margin="1"
                    VerticalAlignment="Center"
                    Text="0" />

                <TextBlock
                    Grid.Row="3"
                    VerticalAlignment="Center"
                    Text="IsEnabled:" />
                <ComboBox
                    x:Name="cmbSelectorBarItemIsEnabled"
                    Grid.Row="3"
                    Grid.Column="1"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center">
                    <ComboBoxItem>False</ComboBoxItem>
                    <ComboBoxItem>True</ComboBoxItem>
                </ComboBox>
                <Button
                    x:Name="btnGetSelectorBarItemIsEnabled"
                    Grid.Row="3"
                    Grid.Column="2"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnGetSelectorBarItemIsEnabled_Click"
                    Content="G" />
                <Button
                    x:Name="btnSetSelectorBarItemIsEnabled"
                    Grid.Row="3"
                    Grid.Column="3"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnSetSelectorBarItemIsEnabled_Click"
                    Content="S" />

                <TextBlock
                    Grid.Row="4"
                    VerticalAlignment="Center"
                    Text="IsSelected:" />
                <ComboBox
                    x:Name="cmbSelectorBarItemIsSelected"
                    Grid.Row="4"
                    Grid.Column="1"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center">
                    <ComboBoxItem>False</ComboBoxItem>
                    <ComboBoxItem>True</ComboBoxItem>
                </ComboBox>
                <Button
                    x:Name="btnGetSelectorBarItemIsSelected"
                    Grid.Row="4"
                    Grid.Column="2"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnGetSelectorBarItemIsSelected_Click"
                    Content="G" />
                <Button
                    x:Name="btnSetSelectorBarItemIsSelected"
                    Grid.Row="4"
                    Grid.Column="3"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnSetSelectorBarItemIsSelected_Click"
                    Content="S" />

                <TextBlock
                    Grid.Row="5"
                    VerticalAlignment="Center"
                    Text="Visibility:" />
                <ComboBox
                    x:Name="cmbSelectorBarItemVisibility"
                    Grid.Row="5"
                    Grid.Column="1"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center">
                    <ComboBoxItem>Visible</ComboBoxItem>
                    <ComboBoxItem>Collpased</ComboBoxItem>
                </ComboBox>
                <Button
                    x:Name="btnGetSelectorBarItemVisibility"
                    Grid.Row="5"
                    Grid.Column="2"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnGetSelectorBarItemVisibility_Click"
                    Content="G" />
                <Button
                    x:Name="btnSetSelectorBarItemVisibility"
                    Grid.Row="5"
                    Grid.Column="3"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnSetSelectorBarItemVisibility_Click"
                    Content="S" />

                <TextBlock
                    Grid.Row="6"
                    VerticalAlignment="Center"
                    Text="Foreground:" />
                <ComboBox
                    x:Name="cmbSelectorBarItemForeground"
                    Grid.Row="6"
                    Grid.Column="1"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center">
                    <ComboBoxItem>null</ComboBoxItem>
                    <ComboBoxItem>Black</ComboBoxItem>
                    <ComboBoxItem>Red</ComboBoxItem>
                    <ComboBoxItem>Green</ComboBoxItem>
                </ComboBox>
                <Button
                    x:Name="btnGetSelectorBarItemForeground"
                    Grid.Row="6"
                    Grid.Column="2"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnGetSelectorBarItemForeground_Click"
                    Content="G" />
                <Button
                    x:Name="btnSetSelectorBarItemForeground"
                    Grid.Row="6"
                    Grid.Column="3"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnSetSelectorBarItemForeground_Click"
                    Content="S" />

                <TextBlock
                    Grid.Row="7"
                    VerticalAlignment="Center"
                    Text="Margin:" />
                <TextBox
                    x:Name="txtSelectorBarItemMargin"
                    Grid.Row="7"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center" />
                <Button
                    x:Name="btnGetSelectorBarItemMargin"
                    Grid.Row="7"
                    Grid.Column="2"
                    Margin="1"
                    VerticalAlignment="Center"
                    Click="BtnGetSelectorBarItemMargin_Click"
                    Content="G" />
                <Button
                    x:Name="btnSetSelectorBarItemMargin"
                    Grid.Row="7"
                    Grid.Column="3"
                    Margin="1"
                    VerticalAlignment="Center"
                    Click="BtnSetSelectorBarItemMargin_Click"
                    Content="S" />

                <TextBlock
                    Grid.Row="8"
                    VerticalAlignment="Center"
                    Text="Padding:" />
                <TextBox
                    x:Name="txtSelectorBarItemPadding"
                    Grid.Row="8"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center" />
                <Button
                    x:Name="btnGetSelectorBarItemPadding"
                    Grid.Row="8"
                    Grid.Column="2"
                    Margin="1"
                    VerticalAlignment="Center"
                    Click="BtnGetSelectorBarItemPadding_Click"
                    Content="G" />
                <Button
                    x:Name="btnSetSelectorBarItemPadding"
                    Grid.Row="8"
                    Grid.Column="3"
                    Margin="1"
                    VerticalAlignment="Center"
                    Click="BtnSetSelectorBarItemPadding_Click"
                    Content="S" />

                <TextBlock
                    Grid.Row="9"
                    Margin="0,6,0,0"
                    VerticalAlignment="Center"
                    Text="Text:" />
                <TextBox
                    x:Name="txtSelectorBarItemText"
                    Grid.Row="9"
                    Grid.Column="1"
                    MinWidth="150"
                    Margin="0,6,0,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Text="Text0" />
                <Button
                    x:Name="btnGetSelectorBarItemText"
                    Grid.Row="9"
                    Grid.Column="2"
                    Margin="1,6,1,1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnGetSelectorBarItemText_Click"
                    Content="G" />
                <Button
                    x:Name="btnSetSelectorBarItemText"
                    Grid.Row="9"
                    Grid.Column="3"
                    Margin="1,6,1,1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnSetSelectorBarItemText_Click"
                    Content="S" />

                <TextBlock
                    Grid.Row="10"
                    VerticalAlignment="Center"
                    Text="Icon:" />
                <ComboBox
                    x:Name="cmbSelectorBarItemIcon"
                    Grid.Row="10"
                    Grid.Column="1"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center">
                    <ComboBoxItem>null</ComboBoxItem>
                    <ComboBoxItem>Cut</ComboBoxItem>
                    <ComboBoxItem>Copy</ComboBoxItem>
                    <ComboBoxItem>Paste</ComboBoxItem>
                    <ComboBoxItem>Bold</ComboBoxItem>
                    <ComboBoxItem>Italic</ComboBoxItem>
                    <ComboBoxItem>Underline</ComboBoxItem>
                </ComboBox>
                <Button
                    x:Name="btnGetSelectorBarItemIcon"
                    Grid.Row="10"
                    Grid.Column="2"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnGetSelectorBarItemIcon_Click"
                    Content="G" />
                <Button
                    x:Name="btnSetSelectorBarItemIcon"
                    Grid.Row="10"
                    Grid.Column="3"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnSetSelectorBarItemIcon_Click"
                    Content="S" />

                <TextBlock
                    Grid.Row="11"
                    VerticalAlignment="Center"
                    Text="Child:" />
                <ComboBox
                    x:Name="cmbSelectorBarItemChild"
                    Grid.Row="11"
                    Grid.Column="1"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center">
                    <ComboBoxItem>null</ComboBoxItem>
                    <ComboBoxItem>TextBlock</ComboBoxItem>
                    <ComboBoxItem>TextBox</ComboBoxItem>
                </ComboBox>
                <Button
                    x:Name="btnGetSelectorBarItemChild"
                    Grid.Row="11"
                    Grid.Column="2"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnGetSelectorBarItemChild_Click"
                    Content="G" />
                <Button
                    x:Name="btnSetSelectorBarItemChild"
                    Grid.Row="11"
                    Grid.Column="3"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnSetSelectorBarItemChild_Click"
                    Content="S" />

                <Button
                    x:Name="btnAddSelectorBarItem"
                    Grid.Row="12"
                    Grid.ColumnSpan="4"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnAddSelectorBarItem_Click"
                    Content="Add Item" />
                <Button
                    x:Name="btnRemoveAllSelectorBarItems"
                    Grid.Row="13"
                    Grid.ColumnSpan="4"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnRemoveAllSelectorBarItems_Click"
                    Content="Remove All Items" />

                <Button
                    x:Name="btnReplaceSelectorBarItem"
                    Grid.Row="14"
                    Grid.ColumnSpan="4"
                    Margin="1,7,1,1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnReplaceSelectorBarItem_Click"
                    Content="Replace Item" />
                <Button
                    x:Name="btnInsertSelectorBarItem"
                    Grid.Row="15"
                    Grid.ColumnSpan="4"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnInsertSelectorBarItem_Click"
                    Content="Insert Item" />
                <Button
                    x:Name="btnRemoveSelectorBarItem"
                    Grid.Row="16"
                    Grid.ColumnSpan="4"
                    Margin="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Click="BtnRemoveSelectorBarItem_Click"
                    Content="Remove Item" />
            </Grid>
        </ScrollViewer>

        <Grid
            x:Name="grdLogs"
            Grid.Row="1"
            Grid.Column="3"
            Margin="4,0,4,0"
            Padding="6"
            BorderBrush="{ThemeResource SystemChromeGrayColor}"
            BorderThickness="1"
            ColumnDefinitions="*"
            RowDefinitions="Auto, Auto, *">

            <TextBlock Foreground="Red" Text="Logs" />

            <StackPanel Grid.Row="1">
                <StackPanel Orientation="Horizontal">
                    <Button
                        x:Name="btnGetFullLog"
                        Margin="6,2,2,2"
                        VerticalAlignment="Center"
                        AutomationProperties.AutomationId="btnGetFullLog"
                        Click="BtnGetFullLog_Click"
                        Content="Get log" />
                    <Button
                        x:Name="btnClearFullLog"
                        Margin="0,2,2,2"
                        VerticalAlignment="Center"
                        AutomationProperties.AutomationId="btnClearFullLog"
                        Click="BtnClearFullLog_Click"
                        Content="Clear log" />
                    <ComboBox
                        x:Name="cmbFullLog"
                        Width="175"
                        Margin="6,2,2,2"
                        VerticalAlignment="Center"
                        AutomationProperties.AutomationId="cmbFullLog" />
                    <CheckBox
                        x:Name="chkLogUpdated"
                        Margin="6,2,2,2"
                        VerticalAlignment="Center"
                        AutomationProperties.AutomationId="chkLogUpdated"
                        Content="Log Updated?"
                        IsChecked="True"
                        IsEnabled="False"
                        IsThreeState="False" />
                    <CheckBox
                        x:Name="chkLogCleared"
                        Margin="6,2,2,2"
                        VerticalAlignment="Center"
                        AutomationProperties.AutomationId="chkLogCleared"
                        Content="Log Cleared?"
                        IsChecked="True"
                        IsEnabled="False"
                        IsThreeState="False" />
                    <TextBox
                        x:Name="txtStatus"
                        Width="200"
                        VerticalAlignment="Center"
                        AutomationProperties.AutomationId="txtStatus"
                        IsReadOnly="True"
                        IsTabStop="False" />
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Button
                        x:Name="btnClearLogs"
                        Margin="1"
                        AutomationProperties.AutomationId="btnClearLogs"
                        Click="BtnClearLogs_Click"
                        Content="Clear list" />
                    <Button
                        x:Name="btnCopyEvents"
                        Margin="1"
                        Click="BtnCopyEvents_Click"
                        Content="Copy into Clipboard" />
                    <CheckBox
                        x:Name="chkOutputDebugString"
                        Margin="1"
                        Content="OutputDebugString?"
                        IsChecked="False" />
                </StackPanel>
                <Grid ColumnDefinitions="Auto, Auto" RowDefinitions="Auto, Auto, Auto, Auto">

                    <CheckBox
                        x:Name="chkLogSelectorBarMessages"
                        Margin="1"
                        Checked="ChkLogSelectorBarMessages_Checked"
                        Content="Log SelectorBar Messages?"
                        IsChecked="True"
                        Unchecked="ChkLogSelectorBarMessages_Unchecked" />
                    <CheckBox
                        x:Name="chkLogSelectorBarEvents"
                        Grid.Column="1"
                        Margin="1"
                        Checked="ChkLogSelectorBarEvents_Checked"
                        Content="Log SelectorBar Events?"
                        IsChecked="True"
                        Unchecked="ChkLogSelectorBarEvents_Unchecked" />
                    <CheckBox
                        x:Name="chkLogItemsViewMessages"
                        Grid.Row="1"
                        Margin="1"
                        Checked="ChkLogItemsViewMessages_Checked"
                        Content="Log ItemsView Messages?"
                        IsChecked="True"
                        Unchecked="ChkLogItemsViewMessages_Unchecked" />
                    <CheckBox
                        x:Name="chkLogItemsViewEvents"
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="1"
                        Checked="ChkLogItemsViewEvents_Checked"
