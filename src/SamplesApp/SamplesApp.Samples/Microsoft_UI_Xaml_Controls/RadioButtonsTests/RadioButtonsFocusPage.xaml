<Page
    x:Class="UITests.Microsoft_UI_Xaml_Controls.RadioButtonsTests.RadioButtonsFocusPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!--  RadioButtons test group 1  -->
        <controls:RadioButtons
            x:Name="TestRadioButtons1"
            Grid.Row="0"
            Grid.Column="0"
            GotFocus="TestRadioButtons_GotFocus"
            Header="TestRadioButtons"
            LostFocus="TestRadioButtons_LostFocus"
            SelectionChanged="TestRadioButtons_SelectionChanged">
            <x:String>Item 1</x:String>
            <x:String>Item 2</x:String>
            <x:String>Item 3</x:String>
        </controls:RadioButtons>

        <!--  Selected Index/Item and focus info UI  -->
        <Grid
            Grid.Row="0"
            Grid.Column="1"
            Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0">
                Selected Index:
            </TextBlock>
            <TextBlock
                x:Name="SelectedIndexTextBlock1"
                Grid.Row="0"
                Grid.Column="1"
                HorizontalAlignment="Left"
                AutomationProperties.Name="SelectedIndexTextBlock1">
                -1
            </TextBlock>
            <TextBlock Grid.Row="1" Grid.Column="0">
                Selected Item:
            </TextBlock>
            <TextBlock
                x:Name="SelectedItemTextBlock1"
                Grid.Row="1"
                Grid.Column="1"
                HorizontalAlignment="Left"
                AutomationProperties.Name="SelectedItemTextBlock1">
                null
            </TextBlock>

            <TextBlock Grid.Row="2" Grid.Column="0">
                Focused Index:
            </TextBlock>
            <TextBlock
                x:Name="FocusedIndexTextBlock1"
                Grid.Row="2"
                Grid.Column="1"
                HorizontalAlignment="Left"
                AutomationProperties.Name="FocusedIndexTextBlock1">
                -1
            </TextBlock>

            <TextBlock Grid.Row="3" Grid.Column="0">
                Has Focus:
            </TextBlock>
            <CheckBox
                x:Name="TestRadioButtons1HasFocusCheckBox"
                Grid.Row="3"
                Grid.Column="1"
                AutomationProperties.Name="TestRadioButtons1HasFocusCheckBox"
                IsTabStop="False" />
        </Grid>

        <!--  Select by index UI  -->
        <Grid
            Grid.Row="0"
            Grid.Column="2"
            Margin="10,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0">Index to select:</TextBlock>
            <TextBox
                x:Name="IndexToSelectTextBox1"
                Grid.Column="1"
                Margin="5,0,0,0"
                VerticalAlignment="Top"
                AutomationProperties.Name="IndexToSelectTextBox1"
                IsTabStop="False"
                Text="-1" />
            <Button
                x:Name="SelectByIndexButton1"
                Grid.Column="2"
                Margin="5,0,0,0"
                VerticalAlignment="Top"
                AutomationProperties.Name="SelectByIndexButton1"
                Click="SelectByIndexButton1_Click"
                IsTabStop="False">
                Select by index
            </Button>
        </Grid>

        <!--  RadioButtons test group 2  -->
        <controls:RadioButtons
            x:Name="TestRadioButtons2"
            Grid.Row="1"
            Grid.Column="0"
            Margin="0,10,0,0"
            GotFocus="TestRadioButtons2_GotFocus"
            Header="TestRadioButtons2"
            LostFocus="TestRadioButtons2_LostFocus"
            SelectionChanged="TestRadioButtons2_SelectionChanged">
            <x:String>Item 1</x:String>
            <x:String>Item 2</x:String>
            <x:String>Item 3</x:String>
        </controls:RadioButtons>

        <!--  Selected Index/Item and focus info UI  -->
        <Grid
            Grid.Row="1"
            Grid.Column="1"
            Margin="10,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0">
                Selected Index:
            </TextBlock>
            <TextBlock
                x:Name="SelectedIndexTextBlock2"
                Grid.Row="0"
                Grid.Column="1"
                HorizontalAlignment="Left"
                AutomationProperties.Name="SelectedIndexTextBlock2">
                -1
            </TextBlock>
            <TextBlock Grid.Row="1" Grid.Column="0">
                Selected Item:
            </TextBlock>
            <TextBlock
                x:Name="SelectedItemTextBlock2"
                Grid.Row="1"
                Grid.Column="1"
                HorizontalAlignment="Left"
                AutomationProperties.Name="SelectedItemTextBlock2">
                null
            </TextBlock>

            <TextBlock Grid.Row="2" Grid.Column="0">
                Focused Index:
            </TextBlock>
            <TextBlock
                x:Name="FocusedIndexTextBlock2"
                Grid.Row="2"
                Grid.Column="1"
                HorizontalAlignment="Left"
                AutomationProperties.Name="FocusedIndexTextBlock2">
                -1
            </TextBlock>

            <TextBlock Grid.Row="3" Grid.Column="0">
                Has Focus:
            </TextBlock>
            <CheckBox
                x:Name="TestRadioButtons2HasFocusCheckBox"
                Grid.Row="3"
                Grid.Column="1"
                AutomationProperties.Name="TestRadioButtons2HasFocusCheckBox"
                IsTabStop="False" />
        </Grid>

        <!--  Select by index UI  -->
        <Grid
            Grid.Row="1"
            Grid.Column="2"
            Margin="10,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0">Index to select:</TextBlock>
            <TextBox
                x:Name="IndexToSelectTextBox2"
                Grid.Column="1"
                Margin="5,0,0,0"
                VerticalAlignment="Top"
                AutomationProperties.Name="IndexToSelectTextBox2"
                IsTabStop="False"
                Text="-1" />
            <Button
                x:Name="SelectByIndexButton2"
                Grid.Column="2"
                Margin="5,0,0,0"
                VerticalAlignment="Top"
                AutomationProperties.Name="SelectByIndexButton2"
                Click="SelectByIndexButton2_Click"
                IsTabStop="False">
                Select by index
            </Button>
        </Grid>
    </Grid>
</Page>
