<local:TestPage
    x:Class="MUXControlsTestApp.PaneLayoutTestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <muxc:NavigationView x:Name="RootNavigationView">

        <StackPanel>
            <!--<muxc:RadioButtons SelectionChanged="TestCaseSelectionChanged" SelectedIndex="2">
                <RadioButton AutomationProperties.Name="NoItems">No items</RadioButton>
                <RadioButton AutomationProperties.Name="NoFooter">No footer</RadioButton>
                <RadioButton AutomationProperties.Name="Both">Both</RadioButton>
            </muxc:RadioButtons>-->

            <Button
                Margin="0,4,0,0"
                AutomationProperties.Name="AddMenuItemButton"
                Click="AddMenuItemButton_Click">
                Add menu item
            </Button>
            <Button AutomationProperties.Name="AddFooterItemButton" Click="AddFooterItemButton_Click">
                Add footer item
            </Button>
            <Button AutomationProperties.Name="ResetCollectionsButton" Click="ResetCollectionsButton_Click">
                Reset collections
            </Button>

            <Button
                Margin="0,4,0,0"
                AutomationProperties.Name="GetLayoutHeightsButton"
                Click="GetLayoutHeightsButton_Click">
                Get layout heights
            </Button>
            <TextBlock x:Name="LayoutHeightsReport" AutomationProperties.Name="LayoutHeightsReport" />
        </StackPanel>
    </muxc:NavigationView>

</local:TestPage>
