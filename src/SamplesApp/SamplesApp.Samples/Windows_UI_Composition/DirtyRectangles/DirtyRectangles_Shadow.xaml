<Page
    x:Class="UITests.Shared.Windows_UI_Composition.DirtyRectangles.DirtyRectangles_Shadow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:Uno.UI.Toolkit"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <!--
        A small element that casts a drop shadow (via toolkit Elevation) and moves across a static
        background on a timer. Verifies that the shadow extent is included in the dirty region: both the
        vacated and the new shadow regions must be repainted, with output identical to a full-frame repaint.
    -->
    <Canvas>
        <Border
            x:Name="Mover"
            Canvas.Left="0"
            Canvas.Top="100"
            Width="60"
            Height="60"
            toolkit:UIElementExtensions.Elevation="24"
            Background="{ThemeResource SystemControlBackgroundAccentBrush}" />
    </Canvas>
</Page>
