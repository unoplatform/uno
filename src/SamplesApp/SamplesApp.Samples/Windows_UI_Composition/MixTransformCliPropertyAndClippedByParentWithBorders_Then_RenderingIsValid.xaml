<UserControl
    x:Class="UITests.Windows_UI_Composition.MixTransformCliPropertyAndClippedByParentWithBorders_Then_RenderingIsValid"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Composition"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid
            Grid.Column="0"
            Width="230"
            Height="120"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">
            <Grid
                Width="100"
                Height="100"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="#7FFF0000"
                BorderBrush="Red"
                BorderThickness="6">
                <Grid.RenderTransform>
                    <CompositeTransform ScaleX="2" />
                </Grid.RenderTransform>
                <Grid.Clip>
                    <RectangleGeometry Rect="0, 0, 110, 110" />
                </Grid.Clip>
                <Rectangle
                    Width="150"
                    Height="100"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Fill="#7F0000FF"
                    Stroke="Blue"
                    StrokeThickness="5">
                    <Rectangle.RenderTransform>
                        <TranslateTransform X="50" Y="50" />
                    </Rectangle.RenderTransform>
                </Rectangle>
                <Border
                    Width="150"
                    Height="150"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="#7F00FF00"
                    BorderBrush="Green"
                    BorderThickness="6">
                    <Border.RenderTransform>
                        <TranslateTransform X="50" Y="-50" />
                    </Border.RenderTransform>
                    <Rectangle
                        Width="50"
                        Height="50"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Fill="Orange">
                        <Rectangle.RenderTransform>
                            <TranslateTransform X="25" Y="0" />
                        </Rectangle.RenderTransform>
                    </Rectangle>
                </Border>
            </Grid>
        </Grid>
        <Canvas
            Grid.Column="1"
            Width="230"
            Height="120"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">
            <Rectangle
                Width="200"
                Height="100"
                Fill="#7FFF0000" />
            <Line
                Stroke="Red"
                StrokeThickness="12"
                X1="6"
                X2="6"
                Y1="0"
                Y2="100" />
            <Line
                Stroke="Red"
                StrokeThickness="6"
                X1="0"
                X2="200"
                Y1="3"
                Y2="3" />
            <Line
                Stroke="Red"
                StrokeThickness="12"
                X1="194"
                X2="194"
                Y1="0"
                Y2="100" />
            <Line
                Stroke="Red"
                StrokeThickness="6"
                X1="200"
                X2="0"
                Y1="97"
                Y2="97" />
            <Rectangle
                Canvas.Left="112"
                Width="108"
                Height="44"
                Fill="#7F00FF00" />
            <Line
                Stroke="Green"
                StrokeThickness="12"
                X1="118"
                X2="118"
                Y1="0"
                Y2="44" />
            <Rectangle
                Canvas.Left="174"
                Width="46"
                Height="12"
                Fill="Orange" />
            <Rectangle
                Canvas.Left="112"
                Canvas.Top="56"
                Width="108"
                Height="54"
                Fill="#7F0000FF" />
            <Line
                Stroke="Blue"
                StrokeThickness="12"
                X1="118"
                X2="118"
                Y1="56"
                Y2="110" />
            <Line
                Stroke="Blue"
                StrokeThickness="6"
                X1="112"
                X2="220"
                Y1="59"
                Y2="59" />
        </Canvas>
    </Grid>
</UserControl>
