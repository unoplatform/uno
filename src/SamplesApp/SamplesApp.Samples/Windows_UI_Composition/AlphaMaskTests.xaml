<UserControl
    x:Class="UITests.Shared.Windows_UI_Composition.AlphaMaskTests"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="500"
    mc:Ignorable="d">

    <StackPanel
        Padding="20"
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Orientation="Vertical"
        Spacing="20">
        <!--  Header  -->
        <StackPanel Orientation="Horizontal" Spacing="40">
            <TextBlock
                Width="120"
                FontSize="20"
                FontWeight="SemiBold"
                Text="Source"
                TextAlignment="Center" />
            <TextBlock
                Width="120"
                FontSize="20"
                FontWeight="SemiBold"
                Text="Alpha Mask Result"
                TextAlignment="Center" />
        </StackPanel>

        <!--  Row 1: Shape (Ellipse) with solid color mask  -->
        <StackPanel Orientation="Horizontal" Spacing="40">
            <Ellipse
                x:Name="ellipse"
                Width="120"
                Height="120"
                Fill="Blue" />
            <Canvas
                x:Name="ellipseResultCanvas"
                Width="120"
                Height="120"
                Background="Transparent" />
        </StackPanel>

        <!--  Row 2: TextBlock with solid color mask  -->
        <StackPanel Orientation="Horizontal" Spacing="40">
            <TextBlock
                x:Name="textBlock"
                FontSize="36"
                FontWeight="Bold"
                Foreground="Blue"
                Text="AlphaMask" />
            <Canvas
                x:Name="textResultCanvas"
                Width="240"
                Height="50"
                Background="Transparent" />
        </StackPanel>

        <!--  Row 3: Image with solid color mask  -->
        <StackPanel Orientation="Horizontal" Spacing="40">
            <Image
                x:Name="img"
                Width="100"
                Height="100"
                Source="ms-appx:///Assets/test_image_100_100.png"
                Stretch="UniformToFill" />
            <Canvas
                x:Name="imageResultCanvas"
                Width="100"
                Height="100"
                Background="Transparent" />
        </StackPanel>

        <!--  Row 4: Shape (Ellipse) with gradient mask  -->
        <StackPanel Orientation="Horizontal" Spacing="40">
            <Ellipse
                x:Name="ellipseGradient"
                Width="120"
                Height="120"
                Fill="Blue" />
            <Canvas
                x:Name="gradientResultCanvas"
                Width="120"
                Height="120"
                Background="Transparent" />
        </StackPanel>
    </StackPanel>
</UserControl>
