<Page
    x:Class="UITests.Shared.Windows_UI_Composition.DamageRegion.DamageRegion_Scroll"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <!--
        Tall, visually-distinct content inside a ScrollViewer that is scrolled to a fixed offset on a timer.
        Scrolling shifts the whole viewport via a transform without repainting each item, so it verifies that
        moved-but-not-repainted content is dirtied. Output must stay identical to a full-frame repaint.
    -->
    <ScrollViewer
        x:Name="Scroller"
        Width="300"
        Height="400"
        HorizontalAlignment="Left"
        VerticalAlignment="Top">
        <StackPanel x:Name="Content" />
    </ScrollViewer>
</Page>
