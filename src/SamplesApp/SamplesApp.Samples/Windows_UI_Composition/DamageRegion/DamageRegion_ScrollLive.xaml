<Page
    x:Class="UITests.Shared.Windows_UI_Composition.DamageRegion.DamageRegion_ScrollLive"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!--
        A real ListView with nested item templates, auto-scrolled continuously. Diagnostic-only: run with
        UNO_DAMAGE_REGION_LOG=true to see, per frame, whether a live scroll stays a tight sub-region or
        coalesces to a full-frame repaint (region count hitting the cap).
    -->
    <ListView
        x:Name="List"
        Width="320"
        Height="720"
        HorizontalAlignment="Left"
        VerticalAlignment="Top">
        <ListView.ItemTemplate>
            <DataTemplate>
                <Border Margin="2"
                        Padding="6"
                        Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        CornerRadius="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="28"
                                Height="28"
                                Background="{ThemeResource SystemAccentColor}"
                                CornerRadius="14" />
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" />
                            <TextBlock Text="{Binding Subtitle}"
                                       Opacity="0.6" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ListView.ItemTemplate>
    </ListView>
</Page>
