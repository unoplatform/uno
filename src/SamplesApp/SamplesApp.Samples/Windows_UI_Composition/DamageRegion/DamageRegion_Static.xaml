<Page
	x:Class="UITests.Shared.Windows_UI_Composition.DamageRegion.DamageRegion_Static"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
	mc:Ignorable="d">

	<!--
		A rich, fully static scene (shapes, text, overlapping semi-transparent content).
		Used by the damage-region harness as a deterministic baseline: two captures must
		be identical, and enabling damage region must not change the output.
	-->
	<Grid>
		<Border Background="{ThemeResource SystemControlBackgroundAccentBrush}" />

		<StackPanel
			Margin="40"
			Spacing="12">
			<TextBlock
				FontSize="28"
				Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
				Text="Uno Platform — Damage Region" />
			<Rectangle
				Width="200"
				Height="60"
				Fill="{ThemeResource SystemControlBackgroundBaseMediumBrush}" />
			<Border
				Width="160"
				Height="80"
				Background="{ThemeResource SystemControlForegroundAccentBrush}"
				Opacity="0.5" />
		</StackPanel>
	</Grid>
</Page>
