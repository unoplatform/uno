<Page
    x:Class="UITests.Shared.Windows_UI_Composition.DamageRegion.DamageRegion_SmallUpdate"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <!--
        A large static background with a single small element that updates on a timer.
        Used by the damage-region harness to verify that only the small region is
        repainted while the static background is preserved (and that output stays
        identical to a full-frame repaint).
    -->
    <Grid>
        <Border Background="{ThemeResource SystemControlBackgroundAccentBrush}" />

        <TextBlock
            x:Name="Counter"
            Margin="24"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            FontSize="24"
            Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
            Text="0" />
    </Grid>
</Page>
