<UserControl
    x:Class="UITests.Windows_UI_Composition.EffectBrushTests"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Composition"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <GridView Padding="20" SelectionMode="None">
        <Grid
            x:Name="blurGrid"
            Width="200"
            Height="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ToolTipService.ToolTip="GaussianBlurEffect" />
        <Grid
            x:Name="grayGrid"
            Width="200"
            Height="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ToolTipService.ToolTip="GrayscaleEffect" />
        <Grid
            x:Name="invertGrid"
            Width="200"
            Height="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ToolTipService.ToolTip="InvertEffect" />
        <Grid
            x:Name="hueGrid"
            Width="200"
            Height="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ToolTipService.ToolTip="HueRotationEffect" />
        <Grid
            x:Name="aggregationGrid"
            Width="200"
            Height="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ToolTipService.ToolTip="Blur-Grayscale Aggregation Test" />
        <Grid
            x:Name="tintGrid"
            Width="200"
            Height="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ToolTipService.ToolTip="TintEffect" />
        <Grid
            x:Name="blendGrid"
            Width="200"
            Height="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ToolTipService.ToolTip="BlendEffect" />
        <Grid
            x:Name="compositeGrid"
            Width="200"
            Height="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ToolTipService.ToolTip="CompositeEffect" />
        <Grid
            x:Name="colorGrid"
            Width="200"
            Height="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ToolTipService.ToolTip="ColorSourceEffect" />
        <Grid
            x:Name="opacityGrid"
            Width="200"
            Height="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ToolTipService.ToolTip="OpacityEffect" />
        <Grid
            x:Name="contrastGrid"
            Width="200"
            Height="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ToolTipService.ToolTip="ContrastEffect" />
        <Grid
            x:Name="exposureGrid"
            Width="200"
            Height="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ToolTipService.ToolTip="ExposureEffect (Negative Value, -1)" />
