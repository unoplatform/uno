            x:Name="maskGrid"
            Width="200"
            Height="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ToolTipService.ToolTip="AlphaMaskEffect" />
        <Grid
            x:Name="saturationGrid"
            Width="200"
            Height="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ToolTipService.ToolTip="SaturationEffect" />
        <Grid
            x:Name="noiseGrid"
            Width="200"
            Height="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ToolTipService.ToolTip="WhiteNoiseEffect" />
