            x:Name="gammaXferGrid"
            Width="200"
            Height="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ToolTipService.ToolTip="GammaTransferEffect" />
        <Grid
            x:Name="borderGrid"
            Width="200"
            Height="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ToolTipService.ToolTip="BorderEffect" />
