            VerticalAlignment="Top"
            ToolTipService.ToolTip="DistantDiffuseEffect" />
        <Grid
            x:Name="dsGrid"
            Width="200"
            Height="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            ToolTipService.ToolTip="DistantSpecularEffect (Turn on Dark Mode)" />
