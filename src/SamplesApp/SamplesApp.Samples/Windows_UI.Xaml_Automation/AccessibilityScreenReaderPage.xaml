<UserControl
    x:Class="UITests.Shared.Windows_UI_Xaml_Automation.AccessibilityScreenReaderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="3000"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <ScrollViewer AutomationProperties.AutomationId="MobileAccessibilityRoot">
        <StackPanel Padding="20" Spacing="12">

            <!--  Page header  -->
            <TextBlock
                AutomationProperties.HeadingLevel="Level1"
                Style="{ThemeResource TitleTextBlockStyle}"
                Text="Accessibility - Screen Reader Support" />

            <TextBlock TextWrapping="WrapWholeWords">
                This sample demonstrates accessibility properties exposed to VoiceOver, TalkBack, and UI automation clients.
                Each section provides a stable cross-platform fixture for inspecting native names, roles, states, actions, and identifiers.
            </TextBlock>

            <!--  ==============================================  -->
            <!--  SECTION: Accessible Names  -->
            <!--  ==============================================  -->
            <TextBlock
                Margin="0,20,0,0"
                AutomationProperties.HeadingLevel="Level2"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="Accessible names" />

            <TextBlock TextWrapping="WrapWholeWords">
                An accessible name is a short, descriptive text string that a screen reader uses to describe a UI element.
                If the control's content can be converted to a string, an accessible name is automatically determined from the visible text.
            </TextBlock>

            <!--  Auto name from content  -->
            <TextBlock
                Margin="0,12,0,0"
                AutomationProperties.HeadingLevel="Level3"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="Getting an accessible name automatically" />

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <Button AutomationProperties.AutomationId="MobileA11yButton" Content="Download survey" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{ThemeResource CaptionTextBlockStyle}">
                        Screen readers announce this button as "Download survey". The name is automatically derived from the Button's Content.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  TextBox with Header and PlaceholderText  -->
            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBox
                        Width="200"
                        HorizontalAlignment="Left"
                        AutomationProperties.AutomationId="MobileA11yTextBox"
                        Header="Name" />

                    <TextBox
                        Width="200"
                        HorizontalAlignment="Left"
                        PlaceholderText="Nickname" />

                    <TextBox
                        MinWidth="200"
                        HorizontalAlignment="Left"
                        Header="Email"
                        PlaceholderText="test@example.com" />

                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        Screen readers announce these TextBoxes as "Name", "Nickname", and "Email".
                        When both Header and PlaceholderText are present, Header is used as name and PlaceholderText is used as description.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  Manual name via AutomationProperties.Name  -->
            <TextBlock
                Margin="0,12,0,0"
                AutomationProperties.HeadingLevel="Level3"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="Setting an accessible name manually" />

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <ListView
                        Width="300"
                        HorizontalAlignment="Left"
                        AutomationProperties.AutomationId="MobileA11yListView"
                        AutomationProperties.Name="Contacts">
                        <ListViewItem>Nathan Quinn</ListViewItem>
                        <ListViewItem>Jessica Lamber</ListViewItem>
                        <ListViewItem>Carl Bond</ListViewItem>
                        <ListViewItem>Jessica Russel</ListViewItem>
                    </ListView>
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        Screen readers announce this ListView as "Contacts", while each item uses its respective text content.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  Image with accessible name  -->
            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <Border
                        Width="150"
                        Height="150"
                        HorizontalAlignment="Left"
                        Background="{ThemeResource SystemAccentColor}"
                        CornerRadius="4">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="Grapes image placeholder"
                            FontSize="60"
                            Text="🍇" />
                    </Border>
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        The element above has AutomationProperties.Name="Grapes image placeholder" so screen readers announce it by name.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  LabeledBy  -->
            <TextBlock
                Margin="0,12,0,0"
                AutomationProperties.HeadingLevel="Level3"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="Using another control to provide an accessible name (LabeledBy)" />

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock
                        x:Name="InputLabel"
                        AutomationProperties.AccessibilityView="Raw"
                        AutomationProperties.AutomationId="MobileA11yLabeledByLabel"
                        Style="{ThemeResource BodyTextBlockStyle}"
                        Text="Searching Photos:" />
                    <TextBox
                        Width="200"
                        HorizontalAlignment="Left"
                        AutomationProperties.AutomationId="MobileA11yLabeledByTextBox"
                        AutomationProperties.LabeledBy="{x:Bind InputLabel}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        The TextBox above is labeled by the TextBlock and will be read as "Searching Photos".
                        The label TextBlock uses AccessibilityView="Raw" to hide it from screen readers and avoid redundancy.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  ==============================================  -->
            <!--  SECTION: Common Accessibility Properties  -->
            <!--  ==============================================  -->
            <TextBlock
                Margin="0,20,0,0"
                AutomationProperties.HeadingLevel="Level2"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="Common accessibility properties" />

            <TextBlock TextWrapping="WrapWholeWords">
                Besides accessible name, common accessibility properties include description and help text,
                position in set, headings and landmarks.
            </TextBlock>

            <!--  Description and HelpText  -->
            <TextBlock
                Margin="0,12,0,0"
                AutomationProperties.HeadingLevel="Level3"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="Description and help text" />

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <!--  FullDescription  -->
                    <StackPanel Spacing="8">
                        <CheckBox
                            AutomationProperties.AutomationId="MobileA11yFullDescriptionCheckBox"
                            AutomationProperties.FullDescription="{x:Bind ClearCacheDescription.Text}"
                            Content="Clear cache on exit" />
                        <TextBlock
                            x:Name="ClearCacheDescription"
                            AutomationProperties.AccessibilityView="Raw"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Deletes all cached items when closing the browser. This includes cookies, images, and browsing history."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <!--  HelpText and Tooltip  -->
                    <Button
                        AutomationProperties.HelpText="Launch the cancellation wizard"
                        Content="Cancel RSS subscriptions"
                        ToolTipService.ToolTip="Launch the cancellation wizard" />

                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        FullDescription provides an extended description. HelpText provides short contextual help.
                        Both are exposed to screen readers in addition to the control's name.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  Position in set  -->
            <TextBlock
                Margin="0,12,0,0"
                AutomationProperties.HeadingLevel="Level3"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="Position in set" />

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock
                        x:Name="StudentsLabel"
                        AutomationProperties.AccessibilityView="Raw"
                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                        Text="Students" />
                    <ListView AutomationProperties.LabeledBy="{x:Bind StudentsLabel}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{x:Bind}" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <x:String>Nathan Quinn</x:String>
                        <x:String>Jessica Lamber</x:String>
                        <x:String>Carl Bond</x:String>
                        <x:String>Jessica Russel</x:String>
                    </ListView>

                    <!--  Custom PositionInSet / SizeOfSet  -->
                    <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="Manual position in set:" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            AutomationProperties.PositionInSet="1"
                            AutomationProperties.SizeOfSet="3"
                            Content="View" />
                        <Button
                            AutomationProperties.PositionInSet="2"
                            AutomationProperties.SizeOfSet="3"
                            Content="Rename" />
                        <Button
                            AutomationProperties.PositionInSet="3"
                            AutomationProperties.SizeOfSet="3"
                            Content="Delete" />
                    </StackPanel>

                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        ListViews automatically provide position in set. For custom layouts, use PositionInSet and SizeOfSet.
                        Screen readers announce items as "1 of 3", "2 of 3", etc.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  ==============================================  -->
            <!--  SECTION: Visual tree (AccessibilityView)  -->
            <!--  ==============================================  -->
            <TextBlock
                Margin="0,20,0,0"
                AutomationProperties.HeadingLevel="Level2"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="Visual tree" />

            <TextBlock TextWrapping="WrapWholeWords">
                You can hide decorative or redundant elements from screen readers by setting AccessibilityView="Raw".
                This removes them from the accessibility tree so screen readers skip them.
            </TextBlock>

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border
                        Width="40"
                        Height="40"
                        AutomationProperties.AccessibilityView="Raw"
                        Background="{ThemeResource SystemAccentColor}"
                        CornerRadius="4">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="20"
                            Text="🌲" />
                    </Border>

                    <TextBlock
                        MaxWidth="400"
                        VerticalAlignment="Center"
                        TextWrapping="WrapWholeWords">
                        This is some demo text. The emoji on the left is just for decoration.
                        To prevent screen readers from announcing it, we set AccessibilityView to "Raw",
                        which removes it from the accessibility tree.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  ==============================================  -->
            <!--  SECTION: Landmarks and Headings  -->
            <!--  ==============================================  -->
            <TextBlock
                Margin="0,20,0,0"
                AutomationProperties.HeadingLevel="Level2"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="Landmarks and headings" />

            <TextBlock TextWrapping="WrapWholeWords">
                Landmarks and headings indicate, or label, different sections of a user interface for screen readers,
                just like visible headings do for visual users. Marking up your content with landmarks and headings
                lets screen reader users skim content similarly to sighted users.
            </TextBlock>

            <!--  Landmarks  -->
            <TextBlock
                Margin="0,12,0,0"
                AutomationProperties.HeadingLevel="Level3"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="Landmarks" />

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="WrapWholeWords">
                        The sample below showcases Navigation, Search, Main, and Custom landmarks.
                        Screen readers announce these as landmark regions.
                    </TextBlock>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="200" />
                        </Grid.ColumnDefinitions>

                        <!--  Navigation landmark  -->
                        <StackPanel
                            Grid.Column="0"
                            Padding="6"
                            AutomationProperties.LandmarkType="Navigation"
                            Background="{ThemeResource CardStrokeColorDefaultBrush}"
                            CornerRadius="4"
                            Spacing="8">
                            <AutoSuggestBox AutomationProperties.LandmarkType="Search" PlaceholderText="Search" />
                            <Button Content="Open settings" />
                        </StackPanel>

                        <!--  Main landmark  -->
                        <StackPanel
                            Grid.Column="1"
                            Padding="6"
                            AutomationProperties.LandmarkType="Main">
                            <TextBlock TextWrapping="WrapWholeWords">
                                Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
                                Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
                            </TextBlock>
                        </StackPanel>

                        <!--  Custom landmark with LocalizedLandmarkType  -->
                        <StackPanel
                            Grid.Column="2"
                            Padding="6"
                            AutomationProperties.LandmarkType="Custom"
                            AutomationProperties.LocalizedLandmarkType="Current viewers"
                            Background="{ThemeResource CardStrokeColorDefaultBrush}"
                            CornerRadius="4"
                            Spacing="8">
                            <TextBlock
                                AutomationProperties.HeadingLevel="Level1"
                                Style="{ThemeResource BodyStrongTextBlockStyle}"
                                Text="Current viewers" />
                            <TextBlock
                                FontStyle="Italic"
                                Style="{ThemeResource BodyTextBlockStyle}"
                                Text="(No other users viewing)" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!--  Headings  -->
            <TextBlock
                Margin="0,12,0,0"
                AutomationProperties.HeadingLevel="Level3"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="Headings" />

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel
                    MaxWidth="500"
                    HorizontalAlignment="Left"
                    Spacing="4">
                    <TextBlock
                        Margin="0,0,0,8"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        The sample below showcases headings at different levels.
                        Screen readers announce these as heading elements.
                    </TextBlock>

                    <TextBlock AutomationProperties.HeadingLevel="Level1" FontSize="26">
                        Lorem ipsums
                    </TextBlock>
                    <TextBlock AutomationProperties.HeadingLevel="Level2" FontSize="22">
                        Lorem ipsum
                    </TextBlock>
                    <TextBlock TextWrapping="WrapWholeWords">
                        Lorem ipsum dolor sit amet, consectetur adipiscing elit.
                        Pellentesque feugiat velit pulvinar, vehicula nisi at, molestie risus.
                    </TextBlock>

                    <TextBlock AutomationProperties.HeadingLevel="Level2" FontSize="22">
                        Cat ipsum
                    </TextBlock>
                    <TextBlock AutomationProperties.HeadingLevel="Level3" FontSize="18">
                        Standard
                    </TextBlock>
                    <TextBlock TextWrapping="WrapWholeWords">
                        Mice litter kitter kitty litty little kitten big roar roar feed me
                        but i will ruin the couch with my claws and hunt by meowing loudly at 5am next to human.
                    </TextBlock>
                    <TextBlock AutomationProperties.HeadingLevel="Level3" FontSize="18">
                        Cat breeds
                    </TextBlock>
                    <TextBlock TextWrapping="WrapWholeWords">
                        Tabby abyssinian for jaguar. Thai russian blue and ragdoll, ocicat.
                        Mouser puma so american bobtail for donskoy balinese. Scottish fold manx so siamese.
                    </TextBlock>

                    <TextBlock AutomationProperties.HeadingLevel="Level2" FontSize="22">
                        Bacon ipsum
                    </TextBlock>
                    <TextBlock TextWrapping="WrapWholeWords">
                        Bacon ipsum dolor amet meatball nulla labore,
                        tempor sirloin chicken frankfurter tail drumstick ex cupim ground round.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  ==============================================  -->
            <!--  SECTION: Grouping  -->
            <!--  ==============================================  -->
            <TextBlock
                Margin="0,20,0,0"
                AutomationProperties.HeadingLevel="Level2"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="Associating smaller groups of controls" />

            <TextBlock TextWrapping="WrapWholeWords">
                You can group controls together by adding an accessible name to the parent container.
                When entering a named region, screen readers announce the group name as context.
            </TextBlock>

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="WrapWholeWords">
                        The sample below groups items using accessible names.
                        Screen readers announce "My albums" or "Shared with me" when navigating between the groups.
                    </TextBlock>
                    <StackPanel AutomationProperties.Name="Album browser">
                        <StackPanel AutomationProperties.Name="My albums">
                            <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="My albums" />
                            <ListView>
                                <x:String>Trip to Redmond</x:String>
                                <x:String>Visiting Ben</x:String>
                            </ListView>
                        </StackPanel>
                        <StackPanel AutomationProperties.Name="Shared with me">
                            <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="Shared with me" />
                            <ListView>
                                <x:String>Valeria's cat</x:String>
                                <x:String>Paul's winter vacation</x:String>
                                <x:String>Cool street photography</x:String>
                            </ListView>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  ==============================================  -->
            <!--  SECTION: Interactive Controls  -->
            <!--  ==============================================  -->
            <TextBlock
                Margin="0,20,0,0"
                AutomationProperties.HeadingLevel="Level2"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="Interactive controls" />

            <TextBlock TextWrapping="WrapWholeWords">
                The following examples demonstrate accessible interactive controls:
                toggle/checkbox, slider, password field, combobox, and multi-line text.
            </TextBlock>

            <!--  Toggle / Checkbox  -->
            <TextBlock
                Margin="0,12,0,0"
                AutomationProperties.HeadingLevel="Level3"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="Toggle states (CheckBox, ToggleSwitch, RadioButton)" />

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <CheckBox
                        AutomationProperties.AutomationId="MobileA11yCheckBox"
                        Content="Enable notifications"
                        IsChecked="True" />
                    <CheckBox Content="Send analytics" IsChecked="False" />
                    <ToggleSwitch
                        AutomationProperties.AutomationId="MobileA11yToggleSwitch"
                        Header="Dark mode"
                        IsOn="True" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <RadioButton
                            AutomationProperties.AutomationId="MobileA11yRadioButton"
                            Content="Small"
                            GroupName="Size"
                            IsChecked="True" />
                        <RadioButton Content="Medium" GroupName="Size" />
                        <RadioButton Content="Large" GroupName="Size" />
                    </StackPanel>
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        Screen readers announce the checked/unchecked or on/off state of these controls.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  Slider / Range value  -->
            <TextBlock
                Margin="0,12,0,0"
                AutomationProperties.HeadingLevel="Level3"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="Slider (range value)" />

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <Slider
                        Width="300"
                        HorizontalAlignment="Left"
                        AutomationProperties.AutomationId="MobileA11ySlider"
                        Header="Volume"
                        Maximum="100"
                        Minimum="0"
                        Value="50" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        Screen readers announce the slider value and support increment/decrement gestures.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  Password field  -->
            <TextBlock
                Margin="0,12,0,0"
                AutomationProperties.HeadingLevel="Level3"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="Password field" />

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <PasswordBox
                        Width="200"
                        HorizontalAlignment="Left"
                        AutomationProperties.AutomationId="MobileA11yPasswordBox"
                        Header="Password"
                        PlaceholderText="Enter your password" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        Screen readers announce this as a secure text field and do not expose the password text.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  ComboBox  -->
            <TextBlock
                Margin="0,12,0,0"
                AutomationProperties.HeadingLevel="Level3"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="ComboBox (expand/collapse)" />

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <ComboBox
                        Width="200"
                        HorizontalAlignment="Left"
                        AutomationProperties.AutomationId="MobileA11yComboBox"
                        Header="Favorite color">
                        <ComboBoxItem Content="Red" />
                        <ComboBoxItem Content="Green" />
                        <ComboBoxItem Content="Blue" />
                        <ComboBoxItem Content="Yellow" />
                    </ComboBox>
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        Screen readers announce the ComboBox as expandable, read the selected value, and support expand/collapse actions.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  Multi-line text  -->
            <TextBlock
                Margin="0,12,0,0"
                AutomationProperties.HeadingLevel="Level3"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="Multi-line text editing" />

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBox
                        Width="300"
                        Height="100"
                        HorizontalAlignment="Left"
                        AcceptsReturn="True"
                        AutomationProperties.AutomationId="MobileA11yMultilineTextBox"
                        Header="Comments"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        Screen readers announce this as a text area instead of a text field because AcceptsReturn is true.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  Required field  -->
            <TextBlock
                Margin="0,12,0,0"
                AutomationProperties.HeadingLevel="Level3"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Text="Required field" />

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBox
                        Width="200"
                        HorizontalAlignment="Left"
                        AutomationProperties.AutomationId="MobileA11yRequiredTextBox"
                        AutomationProperties.IsRequiredForForm="True"
                        Header="Full name" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        Screen readers announce this field as required when IsRequiredForForm is true.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  ==============================================  -->
            <!--  SECTION: Live Regions  -->
            <!--  ==============================================  -->
            <TextBlock
                Margin="0,20,0,0"
                AutomationProperties.HeadingLevel="Level2"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="Live regions" />

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock
                        x:Name="LiveRegionText"
                        AutomationProperties.AutomationId="MobileA11yLiveRegion"
                        AutomationProperties.LiveSetting="Polite"
                        Style="{ThemeResource BodyTextBlockStyle}"
                        Text="Status: Ready" />
                    <Button
                        x:Name="LiveRegionButton"
                        AutomationProperties.AutomationId="MobileA11yLiveRegionButton"
                        Click="OnUpdateLiveRegion"
                        Content="Update status" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        When the status text changes, screen readers automatically announce the new text
                        because it is marked as a polite live region.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  ==============================================  -->
            <!--  SECTION: IsOffscreen (Visibility toggling)  -->
            <!--  ==============================================  -->
            <TextBlock
                Margin="0,20,0,0"
                AutomationProperties.HeadingLevel="Level2"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="IsOffscreen (visibility toggling)" />

            <TextBlock TextWrapping="WrapWholeWords">
                Use a platform accessibility inspector to verify that IsOffscreen changes
                when elements are collapsed or made visible. Offscreen elements should report
                IsOffscreen=True and an empty BoundingRectangle.
            </TextBlock>

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <Button
                        x:Name="VisibilityTargetButton"
                        AutomationProperties.AutomationId="VisibilityTargetButton"
                        Content="I can be hidden" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="OnCollapseTarget" Content="Collapse" />
                        <Button Click="OnShowTarget" Content="Show" />
                    </StackPanel>
                    <TextBlock
                        x:Name="VisibilityOffscreenResult"
                        AutomationProperties.AutomationId="VisibilityOffscreenResult"
                        FontWeight="SemiBold"
                        Text="IsOffscreen = …" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        The IsOffscreen value above is read live from the button's automation peer.
                        Click "Collapse" and it should report IsOffscreen=True; click "Show" and it reports IsOffscreen=False.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  Opacity-based offscreen  -->
            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <Button
                        x:Name="OpacityTargetButton"
                        AutomationProperties.AutomationId="OpacityTargetButton"
                        Content="Opacity test" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="OnSetOpacityZero" Content="Set Opacity=0" />
                        <Button Click="OnSetOpacityOne" Content="Set Opacity=1" />
                    </StackPanel>
                    <TextBlock
                        x:Name="OpacityOffscreenResult"
                        AutomationProperties.AutomationId="OpacityOffscreenResult"
                        FontWeight="SemiBold"
                        Text="IsOffscreen = …" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        An element with Opacity=0 should report IsOffscreen=True (shown live above) even though it is still Visible in the tree.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  Offscreen via hidden ancestor  -->
            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <StackPanel x:Name="AncestorPanel">
                        <Button
                            x:Name="AncestorChildButton"
                            AutomationProperties.AutomationId="ChildOfCollapsibleParent"
                            Content="Child of collapsible parent" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="OnCollapseAncestor" Content="Collapse parent" />
                        <Button Click="OnShowAncestor" Content="Show parent" />
                    </StackPanel>
                    <TextBlock
                        x:Name="AncestorOffscreenResult"
                        AutomationProperties.AutomationId="AncestorOffscreenResult"
                        FontWeight="SemiBold"
                        Text="IsOffscreen = …" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        When the parent StackPanel is collapsed, the child button should also report IsOffscreen=True (shown live above).
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  Offscreen via clipping (scrolled out of a ScrollViewer)  -->
            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <ScrollViewer
                        x:Name="ClippingScrollViewer"
                        Height="200"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        ViewChanged="OnClippingViewChanged">
                        <StackPanel Padding="8" Spacing="8">
                            <Button
                                x:Name="ClippedTargetButton"
                                AutomationProperties.AutomationId="ClippedTargetButton"
                                Content="Scroll me out of view" />
                            <Border
                                Height="1000"
                                Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                CornerRadius="4">
                                <TextBlock
                                    Margin="8"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Filler content — scroll down so the button above leaves the viewport."
                                    TextWrapping="WrapWholeWords" />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="OnScrollTargetOut" Content="Scroll out" />
                        <Button Click="OnScrollTargetIntoView" Content="Scroll into view" />
                        <Button Click="OnCheckClippedOffscreen" Content="Check IsOffscreen" />
                    </StackPanel>
                    <TextBlock
                        x:Name="ClippedOffscreenResult"
                        AutomationProperties.AutomationId="ClippedOffscreenResult"
                        FontWeight="SemiBold"
                        Text="IsOffscreen = (scroll or click Check)" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        The IsOffscreen value above is read directly from the element's automation peer
                        (FrameworkElementAutomationPeer.IsOffscreen()) and updates live as you scroll, so no
                        external accessibility inspector is required. Scroll the button out of the viewport
                        and it should report IsOffscreen=True (even though it is still Visible and in the live
                        tree); scroll it back into view and it reports IsOffscreen=False.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  ==============================================  -->
            <!--  SECTION: IsEnabled / IsKeyboardFocusable  -->
            <!--  ==============================================  -->
            <TextBlock
                Margin="0,20,0,0"
                AutomationProperties.HeadingLevel="Level2"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="IsEnabled and IsKeyboardFocusable" />

            <TextBlock TextWrapping="WrapWholeWords">
                Verify that IsEnabled and IsKeyboardFocusable update correctly when controls
                are enabled or disabled. A disabled control should report IsEnabled=False and
                IsKeyboardFocusable=False.
            </TextBlock>

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <Button
                        x:Name="EnabledTargetButton"
                        AutomationProperties.AutomationId="EnabledTargetButton"
                        Content="Enable/disable me" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="OnDisableTarget" Content="Disable" />
                        <Button Click="OnEnableTarget" Content="Enable" />
                    </StackPanel>
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        Click "Disable" and verify IsEnabled=False, IsKeyboardFocusable=False.
                        Click "Enable" and verify IsEnabled=True, IsKeyboardFocusable=True.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  AllowFocusWhenDisabled  -->
            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <Button
                        x:Name="FocusWhenDisabledButton"
                        AllowFocusWhenDisabled="True"
                        AutomationProperties.AutomationId="FocusWhenDisabledButton"
                        Content="AllowFocusWhenDisabled=True" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="OnDisableFocusWhenDisabled" Content="Disable" />
                        <Button Click="OnEnableFocusWhenDisabled" Content="Enable" />
                    </StackPanel>
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        With AllowFocusWhenDisabled=True, a disabled control should report
                        IsEnabled=False but IsKeyboardFocusable=True.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  Non-control elements  -->
            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock
                        AutomationProperties.AutomationId="PlainTextBlock"
                        AutomationProperties.Name="Static text element"
                        Text="I am a TextBlock (not a Control)" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="WrapWholeWords">
                        Non-control elements like TextBlock should report IsEnabled=True (always)
                        and IsKeyboardFocusable=False (not focusable).
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  ==============================================  -->
            <!--  SECTION: Combined state scenarios  -->
            <!--  ==============================================  -->
            <TextBlock
                Margin="0,20,0,0"
                AutomationProperties.HeadingLevel="Level2"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="Combined state scenarios" />

            <TextBlock TextWrapping="WrapWholeWords">
                These scenarios combine multiple property changes to test that all UIA properties
                stay consistent with each other.
            </TextBlock>

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBox
                        x:Name="CombinedTextBox"
                        Width="200"
                        HorizontalAlignment="Left"
                        AutomationProperties.AutomationId="CombinedTextBox"
                        Header="Editable field" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="OnDisableCombined" Content="Disable" />
                        <Button Click="OnEnableCombined" Content="Enable" />
                        <Button Click="OnCollapseCombined" Content="Collapse" />
                        <Button Click="OnShowCombined" Content="Show" />
                    </StackPanel>
                    <TextBlock
                        x:Name="CombinedStatusText"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="Use the buttons above to toggle states and verify properties with a platform accessibility inspector."
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <!--  Bottom padding  -->
            <Border Height="40" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
