<UserControl
    x:Class="UITests.Shared.Windows_UI_Xaml_Automation.AutomationProperties_Relations"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Padding="16" Spacing="12">
        <TextBlock Text="DescribedBy / ControllerFor UIA relation properties (set in code-behind)." TextWrapping="Wrap" />

        <TextBlock
            x:Name="DescriptionText"
            AutomationProperties.AutomationId="rel-desc-source"
            Text="This field is required" />
        <TextBox
            x:Name="DescribedField"
            AutomationProperties.AutomationId="rel-described"
            PlaceholderText="Described field" />

        <Button
            x:Name="ControllerButton"
            AutomationProperties.AutomationId="rel-controller"
            Content="Controller" />
        <TextBox
            x:Name="ControlledField"
            AutomationProperties.AutomationId="rel-controlled"
            PlaceholderText="Controlled field" />
    </StackPanel>
</UserControl>
