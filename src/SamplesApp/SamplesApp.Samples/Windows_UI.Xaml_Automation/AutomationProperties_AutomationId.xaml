<UserControl
    x:Class="UITests.Shared.Windows_UI.Xaml_Automation.AutomationProperties_AutomationId"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="720"
    d:DesignWidth="480"
    mc:Ignorable="d">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="8">
            <TextBlock
                AutomationProperties.HeadingLevel="Level2"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="Mobile automation fixtures" />
            <TextBlock Text="Each machine identifier is intentionally different from the spoken name. The controls below exercise invocation, toggle, range, text, secure text, and relation semantics." TextWrapping="WrapWholeWords" />

            <Button
                x:Name="ActionButton"
                AutomationProperties.AutomationId="MobileAutomationInvoke"
                AutomationProperties.Name="Run fixture action"
                Content="Run fixture action" />
            <CheckBox
                AutomationProperties.AutomationId="MobileAutomationToggle"
                AutomationProperties.Name="Enable fixture option"
                Content="Enable fixture option" />
            <Slider
                AutomationProperties.AutomationId="MobileAutomationRange"
                AutomationProperties.Name="Fixture volume"
                Header="Fixture volume"
                Maximum="100"
                Minimum="0"
                Value="40" />
            <TextBox
                x:Name="ControlledField"
                AutomationProperties.AutomationId="MobileAutomationText"
                Header="Account name"
                Text="Ada" />
            <PasswordBox
                AutomationProperties.AutomationId="MobileAutomationPassword"
                AutomationProperties.Name="Account password"
                Header="Account password"
                PasswordRevealMode="Hidden" />

            <TextBlock
                x:Name="RelationLabel"
                AutomationProperties.AccessibilityView="Raw"
                AutomationProperties.AutomationId="MobileAutomationRelationLabel"
                Text="Related search field" />
            <TextBox
                x:Name="RelatedField"
                AutomationProperties.AutomationId="MobileAutomationRelatedField"
                AutomationProperties.LabeledBy="{x:Bind RelationLabel}"
                Header="Search" />
        </StackPanel>

        <TextBlock
            x:Name="result"
            Grid.Row="1"
            AutomationProperties.AutomationId="MobileAutomationResult"
            AutomationProperties.LiveSetting="Polite"
            Text="No action has run."
            TextWrapping="WrapWholeWords" />

        <ListView
            x:Name="myList"
            Grid.Row="2"
            AutomationProperties.AutomationId="MobileAutomationList"
            AutomationProperties.Name="Automation identifier items"
            SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBlock
                        AutomationProperties.AutomationId="{Binding AutomationId}"
                        AutomationProperties.Name="{Binding Text}"
                        Text="{Binding Text}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
