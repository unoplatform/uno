<UserControl
    x:Class="UITests.Shared.Windows_System.Power.PowerManager"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <ContentControl IsEnabled="{x:Bind Model.IsInitialized, Mode=OneWay}">
        <Grid Padding="12" RowSpacing="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Spacing="8">
                <Button Command="{x:Bind Model.RefreshValuesCommand}" Content="Refresh values" />
                <TextBlock>
                    <Run FontWeight="Bold" Text="Battery status:" />
                    <Run Text="{x:Bind Model.BatteryStatus, Mode=OneWay}" />
                </TextBlock>
                <TextBlock>
                    <Run FontWeight="Bold" Text="Energy saver status:" />
                    <Run Text="{x:Bind Model.EnergySaverStatus, Mode=OneWay}" />
                </TextBlock>
                <TextBlock>
                    <Run FontWeight="Bold" Text="Power supply status:" />
                    <Run Text="{x:Bind Model.PowerSupplyStatus, Mode=OneWay}" />
                </TextBlock>
                <TextBlock>
                    <Run FontWeight="Bold" Text="Remaining charge percent:" />
                    <Run Text="{x:Bind Model.RemainingChargePercent, Mode=OneWay}" />
                </TextBlock>
                <TextBlock>
                    <Run FontWeight="Bold" Text="Remaining discharge time:" />
                    <Run Text="{x:Bind Model.RemainingDischargeTime, Mode=OneWay}" />
                </TextBlock>

                <TextBlock
                    FontWeight="Bold"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Text="Event subscriptions" />
                <ToggleButton Content="Battery status changed" IsChecked="{x:Bind Model.IsBatteryStatusChangedSubscribed, Mode=TwoWay}" />
                <ToggleButton Content="Energy saver status changed" IsChecked="{x:Bind Model.IsEnergySaverStatusChangedSubscribed, Mode=TwoWay}" />
                <ToggleButton Content="Power supply status changed" IsChecked="{x:Bind Model.IsPowerSupplyStatusChangedSubscribed, Mode=TwoWay}" />
                <ToggleButton Content="Remaining charge percent changed" IsChecked="{x:Bind Model.IsRemainingChargePercentChangedSubscribed, Mode=TwoWay}" />
                <ToggleButton Content="Remaining discharge time changed" IsChecked="{x:Bind Model.IsRemainingDischargeTimeChangedSubscribed, Mode=TwoWay}" />

                <Button
                    Margin="0,16,0,0"
                    Command="{x:Bind Model.ClearEventLogCommand}"
                    Content="Clear event log" />
            </StackPanel>
            <ListView Grid.Row="1" ItemsSource="{x:Bind Model.EventLog}" />
        </Grid>
    </ContentControl>
</UserControl>
