<Page
    x:Class="UITests.Windows_UI_Xaml.Performance.Performance_Dopes"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml.Performance"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="55" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Canvas
            x:Name="absolute"
            Grid.Row="0"
            Grid.RowSpan="2"
            Grid.Column="0" />

        <Grid
            x:Name="grid"
            Grid.Row="0"
            Grid.RowSpan="2"
            Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
        </Grid>

        <TextBlock
            x:Name="dopes"
            Grid.Row="0"
            Grid.Column="0"
            Margin="0,20,0,0"
            Padding="7,7,7,7"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Foreground="White"
            Text="Warming up.."
            Visibility="Collapsed" />

        <StackPanel
            x:Name="buttons"
            Grid.Row="1"
            Grid.Column="0"
            Margin="5,0,0,25"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Orientation="Horizontal">

            <Button
                x:Name="stop"
                HorizontalAlignment="Center"
                Background="Red"
                Click="Stop_Clicked"
                Content="@ Stop"
                Visibility="Collapsed" />

            <Button
                x:Name="startST"
                Background="Blue"
                Click="startST_Clicked"
                Content="@ Build" />
            <Button
                x:Name="startGridST"
                Background="Blue"
                Click="startGridST_Clicked"
                Content="@ Grid" />
            <Button
                x:Name="startChangeST"
                Background="Blue"
                Click="startChangeST_Clicked"
                Content="@ Change" />
            <Button
                x:Name="startReuseST"
                Background="Blue"
                Click="startChangeReuse_Clicked"
                Content="@ Reuse" />

        </StackPanel>

    </Grid>
</Page>
