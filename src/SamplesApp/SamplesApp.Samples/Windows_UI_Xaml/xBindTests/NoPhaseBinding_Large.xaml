<Page
    x:Class="Uno.UI.Samples.Content.UITests.XBind.NoPhaseBinding_Large"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:legacy="using:Uno.UI.Controls.Legacy"
    xmlns:local="using:Uno.UI.Samples.Content.UITests.Performance"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uloc="http://nventive.com/localization/1.0"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d not_win uloc">

    <UserControl.Resources>
        <ResourceDictionary>
            <Style x:Key="TitleLeftRectangleStyle" TargetType="Rectangle">
                <Setter Property="Height" Value="2" />
                <Setter Property="Margin" Value="10,0,20,0" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style
                x:Key="TitleRightRectangleStyle"
                BasedOn="{StaticResource TitleLeftRectangleStyle}"
                TargetType="Rectangle">
                <Setter Property="Margin" Value="20,0,10,0" />
            </Style>

            <DataTemplate x:Key="SimilarFlightsCheckInButtonTemplate">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Margin="0,0,5,0" Content="Similar Flight" />

                    <Button
                        Grid.Column="1"
                        Margin="5,0,0,0"
                        Content="Checkin" />
                </Grid>
            </DataTemplate>

            <DataTemplate x:Key="DirectFlightWithTitleAndButtonTemplate">
                <Grid Height="382">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26" />
                        <RowDefinition Height="300" />
                        <RowDefinition Height="56" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Rectangle Fill="Red" Style="{StaticResource TitleLeftRectangleStyle}" />

                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Text="{Binding}" />

                    <Rectangle
                        Grid.Column="2"
                        Fill="Red"
                        Style="{StaticResource TitleRightRectangleStyle}" />

                    <Grid
                        Grid.Row="1"
                        Grid.ColumnSpan="3"
                        Height="300">
                        <Grid.RowDefinitions>
                            <!--  0: Flight and status  -->
                            <RowDefinition Height="31" />

                            <!--  1: Detailed flight status  -->
                            <RowDefinition Height="17" />

                            <!--  2: Departure and Arrival airports  -->
                            <RowDefinition Height="18" />

                            <!--  3: Departure and Arrival times  -->
                            <RowDefinition Height="24" />

                            <!--  4: Date and flight length + separator  -->
                            <RowDefinition Height="36" />

                            <!--  5: Terminals  -->
                            <RowDefinition Height="66" />

                            <!--  6: Pass type  -->
                            <RowDefinition Height="32" />

                            <!--  7: JOY  -->
                            <RowDefinition Height="24" />

                            <!--  8: Waiting  -->
                            <RowDefinition Height="52" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Margin="40,5,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                            <Run Text="{Binding}" />
                            <Run Text="{Binding}" />
                        </TextBlock>

                        <TextBlock
                            Margin="0,5,35,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Text="{Binding}" />

                        <!--  Row 1  -->
                        <TextBlock
                            Grid.Row="1"
                            Margin="0,0,10,0"
                            HorizontalAlignment="Right"
                            Text="{Binding}" />

                        <!--  Row 2  -->
                        <TextBlock
                            Grid.Row="2"
                            Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Text="{Binding}" />

                        <TextBlock
                            Grid.Row="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Run
                                x:Uid="FlightTemplates_UpdateTime"
                                uloc:Localize="Text"
                                Text="Updated at: " />
                            <Run Text="{Binding}" />
                        </TextBlock>

                        <TextBlock
                            Grid.Row="2"
                            Margin="0,0,10,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Text="{Binding}" />


                        <!--  Row 4  -->
                        <TextBlock
                            Grid.Row="4"
                            Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Text="{Binding}" />

                        <TextBlock
                            Grid.Row="4"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Text="{Binding}" />

                        <TextBlock
                            Grid.Row="4"
                            Margin="0,0,10,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Text="{Binding}" />

                        <Rectangle Grid.Row="4" VerticalAlignment="Bottom" />

                        <!--  Row 5  -->

                        <!--  Departure terminal + gate  -->
                        <Grid
                            Grid.Row="5"
                            Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Terminal  -->
                            <TextBlock
                                x:Uid="FlightTemplates_Terminal"
                                Margin="0,0,5,5"
                                uloc:Localize="Text"
                                Text="TERMINAL" />

                            <TextBlock
                                Grid.Column="1"
                                Margin="0,0,0,5"
                                Text="{Binding}" />

                            <!--  Gate  -->
                            <TextBlock
                                x:Uid="FlightTemplates_Gate"
                                Grid.Row="1"
                                Margin="0,5,5,0"
                                uloc:Localize="Text"
                                Text="GATE" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="0,5,0,0"
                                Text="{Binding}" />
                        </Grid>

                        <!--  Seat  -->
                        <StackPanel
                            Grid.Row="5"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <TextBlock
                                x:Uid="FlightTemplates_Seat"
                                Margin="0,0,0,5"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                uloc:Localize="Text"
                                Text="SEAT" />

                            <!--  TODO: Task# 1765 Display Cabin info (seat is contained in cabin info)  -->
                            <TextBlock
                                Margin="0,5,0,0"
                                HorizontalAlignment="Center"
                                Text="{Binding}" />
                        </StackPanel>

                        <!--  Arrival terminal + gate  -->
                        <Grid
                            Grid.Row="5"
                            Margin="0,0,10,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Terminal  -->
                            <TextBlock
                                x:Uid="FlightTemplates_Terminal"
                                Margin="0,0,0,5"
                                HorizontalAlignment="Right"
                                uloc:Localize="Text"
                                Text="TERMINAL" />

                            <TextBlock
                                Grid.Column="1"
                                Margin="5,0,0,5"
                                Text="{Binding}" />

                            <!--  Gate  -->
                            <TextBlock
                                x:Uid="FlightTemplates_Gate"
                                Grid.Row="1"
                                Margin="0,5,0,0"
                                HorizontalAlignment="Right"
                                uloc:Localize="Text"
                                Text="GATE" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="5,5,0,0"
                                Text="{Binding}" />
                        </Grid>

                        <!--  Row 6  -->
                        <TextBlock
                            Grid.Row="6"
                            Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                            <Run
                                x:Uid="FlightTemplates_PassType"
                                uloc:Localize="Text"
                                Text="PASS TYPE" />
                            <Run Text="{Binding}" />
                        </TextBlock>

                        <TextBlock
                            Grid.Row="6"
                            Margin="0,0,10,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Text="{Binding}" />

                        <!--  Row 7  -->
                        <u:StarStackPanel
                            Grid.Row="7"
                            VerticalAlignment="Top"
                            Orientation="Horizontal">
                            <TextBlock>
                                <Run Text="{Binding}" />
                                <Run Text="{Binding}" />
                                <Run Text="/" />
                                <Run Text="{Binding}" />
                            </TextBlock>

                            <TextBlock>
                                <Run Text="{Binding}" />
                                <Run Text="{Binding}" />
                                <Run Text="/" />
                                <Run Text="{Binding}" />
                            </TextBlock>

                            <TextBlock>
                                <Run Text="{Binding}" />
                                <Run Text="{Binding}" />
                                <Run Text="/" />
                                <Run Text="{Binding}" />
                            </TextBlock>
                        </u:StarStackPanel>

                        <!--  Row 8  -->

                        <!--  Is not DCS  -->
                        <TextBlock Grid.Row="8" VerticalAlignment="Center">
                            <Run
                                x:Uid="FlightTemplates_PassengerWaiting"
                                uloc:Localize="Text"
                                Text="Standby:" />
                            <Run Text="{Binding}" />
                        </TextBlock>

                        <!--  Is DCS  -->
                        <u:StarStackPanel Grid.Row="8" Orientation="Horizontal">
                            <TextBlock>
                                <Run
                                    x:Uid="FlightTemplates_PassengerWaiting"
                                    uloc:Localize="Text"
                                    Text="Standby:" />
                                <Run Text="{Binding}" />
                                <Run
                                    x:Uid="FlightTemplates_PassengerInFront"
                                    uloc:Localize="Text"
                                    Text="In front:" />
                                <Run Text="{Binding}" />
                            </TextBlock>

                            <TextBlock>
                                <Run
                                    x:Uid="FlightTemplates_PassengerWaiting"
                                    uloc:Localize="Text"
                                    Text="Standby:" />
                                <Run Text="{Binding}" />
                                <Run
                                    x:Uid="FlightTemplates_PassengerInFront"
                                    uloc:Localize="Text"
                                    Text="          In front:" />
                                <Run Text="{Binding}" />
                            </TextBlock>

                            <TextBlock>
                                <Run
                                    x:Uid="FlightTemplates_PassengerWaiting"
                                    uloc:Localize="Text"
                                    Text="Standby:" />
                                <Run Text="{Binding}" />
                                <Run
                                    x:Uid="FlightTemplates_PassengerInFront"
                                    uloc:Localize="Text"
                                    Text="          In front:" />
                                <Run Text="{Binding}" />
                            </TextBlock>
                        </u:StarStackPanel>
                    </Grid>


                    <ContentControl
                        Grid.Row="2"
                        Grid.ColumnSpan="3"
                        HorizontalContentAlignment="Stretch"
                        Content="{Binding}"
                        ContentTemplate="{StaticResource SimilarFlightsCheckInButtonTemplate}" />
                </Grid>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <ListView ItemTemplate="{StaticResource DirectFlightWithTitleAndButtonTemplate}" ItemsSource="{x:Bind MyItems}">
        <ListView.ItemContainerStyle>
            <not_win:Style x:Key="ListViewItemExpanded" TargetType="ListViewItem">
                <Setter Property="FontFamily" Value="{ThemeResource ContentControlThemeFontFamily}" />
                <Setter Property="FontSize" Value="{ThemeResource ControlContentThemeFontSize}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{ThemeResource SystemControlForegroundBaseHighBrush}" />
                <Setter Property="TabNavigation" Value="Local" />
                <Setter Property="IsHoldingEnabled" Value="True" />
                <Setter Property="Padding" Value="12,0,12,0" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="MinWidth" Value="{ThemeResource ListViewItemMinWidth}" />
                <Setter Property="MinHeight" Value="{ThemeResource ListViewItemMinHeight}" />
                <Setter Property="UseSystemFocusVisuals" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <ContentPresenter
                                x:Name="ContentPresenter"
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                not_win:ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                ContentTransitions="{TemplateBinding ContentTransitions}" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </not_win:Style>
        </ListView.ItemContainerStyle>
    </ListView>

</Page>
