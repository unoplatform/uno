<UserControl
    x:Class="UITests.Shared.Windows_UI_Xaml.xBind.xBind"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="using:System"
    xmlns:wasm="http://uno.ui/wasm"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d ios android wasm">

    <UserControl.Resources>
        <Style x:Key="UnsupportedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Red" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Text" Value="Feature not yet supported" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <StackPanel>
            <TextBlock Foreground="Green" Text="One-Way binding to the ViewModel" />
            <TextBlock
                Margin="0,0,0,20"
                FontSize="30"
                Text="{x:Bind ViewModel.DoubleValue, Mode=OneWay}" />

            <TextBlock Foreground="Green" Text="One-Way binding to the Slider control" />
            <TextBlock
                Margin="0,0,0,20"
                FontSize="30"
                Text="{x:Bind SliderControl.Value, Mode=OneWay}" />

            <TextBlock Foreground="Green" Text="Two-Way binding to the ViewModel" />
            <Slider
                x:Name="SliderControl"
                Margin="0,0,0,20"
                Maximum="50"
                Minimum="1"
                Value="{x:Bind ViewModel.DoubleValue, Mode=TwoWay}" />

            <!--  x:Bind function binding section  -->
            <TextBlock Foreground="Green" Text="One-Time binding using a 'function bind'" />
            <win:TextBlock
                Margin="0,0,0,20"
                FontSize="30"
                Text="{x:Bind sys:DateTime.Now.ToLongTimeString()}" />
            <ios:TextBlock Style="{StaticResource UnsupportedTextStyle}" />
            <android:TextBlock Style="{StaticResource UnsupportedTextStyle}" />
            <wasm:TextBlock Style="{StaticResource UnsupportedTextStyle}" />
        </StackPanel>
    </Grid>
</UserControl>
