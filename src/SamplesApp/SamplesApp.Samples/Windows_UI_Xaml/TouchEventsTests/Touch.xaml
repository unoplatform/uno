<UserControl
    x:Class="Uno.UI.Samples.Content.UITests.TouchEventsTests.Touch"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="using:Uno.UI.Samples.Content.UITests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:uc="using:Uno.UI.Samples.Converters"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d ios android not_win">

    <UserControl.Resources>

        <uc:FromNullableBoolToVisibilityConverter x:Key="boolToVisibility" />

        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter Content="{TemplateBinding Content}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <u:StarStackPanel Background="{TemplateBinding Background}" Orientation="Horizontal">
                            <Border
                                x:Name="UncheckedBorder"
                                Width="30"
                                Height="30"
                                Background="Green" />

                            <Border
                                x:Name="CheckedBorder"
                                Width="30"
                                Height="30"
                                Background="Red"
                                Visibility="Collapsed" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver" />
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="UncheckedBorder" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Collapsed" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CheckedBorder" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="CheckedPointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="UncheckedBorder" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Collapsed" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CheckedBorder" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </u:StarStackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!--  TODO: Visibility, Transparent, Border, Rectangle (Fill), Image, Transform, Opacity, Nested buttons, IsHitTestVisible, ScrollViewer, Native views  -->

    <ScrollViewer>
        <StackPanel>
            <TextBlock x:Uid="touchLog" Text="{Binding [Output]}" />
            <Button
                Command="{Binding [GenericCommand]}"
                CommandParameter="Reset"
                Content="Reset" />
            <StackPanel>
                <TextBlock Text="Button inside a white grid" />
                <Grid
                    Width="100"
                    Height="100"
                    Background="White">

                    <Button
                        x:Uid="button_inside_grid"
                        Width="50"
                        Height="50"
                        Background="Tomato"
                        Command="{Binding [GenericCommand]}"
                        CommandParameter="button inside grid"
                        Style="{StaticResource ButtonStyle}" />
                </Grid>

                <TextBlock Text="Button with a border on top" />
                <Grid
                    Width="100"
                    Height="100"
                    Background="White">

                    <Button
                        x:Uid="button_border_on_top"
                        Width="80"
                        Height="80"
                        Background="Tomato"
                        Command="{Binding [GenericCommand]}"
                        CommandParameter="button under grid"
                        Style="{StaticResource ButtonStyle}" />

                    <Border
                        x:Uid="button_border_on_top_border"
                        Margin="30"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Gray" />
                </Grid>

                <TextBlock Text="Button with a (border inside a border) on top" />
                <Grid
                    Width="100"
                    Height="100"
                    Background="White">

                    <Button
                        x:Uid="button_under_grid"
                        Width="80"
                        Height="80"
                        Background="Tomato"
                        Command="{Binding [GenericCommand]}"
                        CommandParameter="button under grid"
                        Style="{StaticResource ButtonStyle}" />

                    <Border>
                        <Border
                            Margin="30"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="Gray" />
                    </Border>
                </Grid>

                <TextBlock Text="Button with a border inside" />
                <Grid
                    Width="100"
                    Height="100"
                    Background="White">

                    <Button
                        x:Uid="button_with_border_inside"
                        Width="80"
                        Height="80"
                        Background="Tomato"
                        Command="{Binding [GenericCommand]}"
                        CommandParameter="button with border inside"
                        Style="{StaticResource ButtonStyle}">

                        <Border
                            Width="50"
                            Height="50"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="Gray" />

                    </Button>
                </Grid>

                <TextBlock Text="Button in a button" />
                <Grid
                    Width="100"
                    Height="100"
                    Background="White">

                    <Button
                        x:Uid="outer_button"
                        Width="80"
                        Height="80"
                        Background="Tomato"
                        Command="{Binding [GenericCommand]}"
                        CommandParameter="outer button"
                        Style="{StaticResource ButtonStyle}">

                        <Button
                            x:Uid="inner_button"
                            Width="50"
                            Height="50"
                            Background="Olive"
                            Command="{Binding [GenericCommand]}"
                            CommandParameter="inner button"
                            Style="{StaticResource ButtonStyle}" />

                    </Button>
                </Grid>

                <TextBlock Text="Button over a button" />
                <Grid
                    Width="100"
                    Height="100"
                    Background="White">

                    <Button
                        Width="80"
                        Height="80"
                        Background="Tomato"
                        Command="{Binding [GenericCommand]}"
                        CommandParameter="bottom button"
                        Style="{StaticResource ButtonStyle}" />

                    <Button
                        Width="50"
                        Height="50"
                        Background="Olive"
                        Command="{Binding [GenericCommand]}"
                        CommandParameter="top button"
                        Style="{StaticResource ButtonStyle}" />
                </Grid>

                <TextBlock Text="Button in scrollviewer in a button" />
                <Grid
                    Width="100"
                    Height="100"
                    Background="White">

                    <Button
                        Width="80"
                        Height="80"
                        Background="Tomato"
                        Command="{Binding [GenericCommand]}"
                        CommandParameter="bottom button"
                        Style="{StaticResource ButtonStyle}">
                        <ScrollViewer Width="50" Height="50">
                            <Button
                                Width="50"
                                Height="50"
                                Background="Olive"
                                Command="{Binding [GenericCommand]}"
                                CommandParameter="top button"
                                Style="{StaticResource ButtonStyle}" />
                        </ScrollViewer>
                    </Button>
                </Grid>

                <TextBlock Text="Default button" />
                <Button
                    Command="{Binding [GenericCommand]}"
                    CommandParameter="default button"
                    Content="Default" />

                <TextBlock Text="Default combo box" />
                <ComboBox ItemsSource="{Binding [Colors]}" />

                <TextBlock Text="ToggleButton that collapses when clicked" />
                <ToggleButton
                    Command="{Binding [GenericCommand]}"
                    CommandParameter="toggle button"
                    Style="{StaticResource ToggleButtonStyle}" />

            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
