<UserControl
    x:Class="Uno.UI.Samples.Samples.Shared.Content.UITests.TappedEventTest"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="using:Uno.UI.Samples.Content.UITests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <controls:ControlWithTouchEvent Width="200" Height="30">
        <controls:ControlWithTouchEvent.Template>
            <ControlTemplate>
                <Border Background="White">
                    <TextBlock Foreground="Black" Text="Control with tapped event" />
                </Border>
            </ControlTemplate>
        </controls:ControlWithTouchEvent.Template>
    </controls:ControlWithTouchEvent>

</UserControl>
