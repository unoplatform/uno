<Page
    x:Class="UITests.Windows_UI_Xaml.FrameworkElementTests.FrameworkElement_Opacity"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml.FrameworkElementTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel>
        <TextBlock
            FontFamily="Courier New"
            FontSize="20"
            Foreground="Black"
            Opacity="1"
            Text="Opacity 1.0 ██████████" />
        <TextBlock
            FontFamily="Courier New"
            FontSize="20"
            Foreground="Black"
            Opacity="0.5"
            Text="Opacity 0.5 ██████████" />
        <TextBlock
            FontFamily="Courier New"
            FontSize="20"
            Foreground="Black"
            Opacity="0.1"
            Text="Opacity 0.1 ██████████" />
        <Border Background="Red" Opacity="0.5">
            <TextBlock
                FontFamily="Courier New"
                FontSize="20"
                Foreground="Black"
                Text="Border Opacity 0.5 ██████████" />
        </Border>
        <Border
            Background="Red"
            CornerRadius="20"
            Opacity="0.5">
            <TextBlock
                FontFamily="Courier New"
                FontSize="20"
                Foreground="Black"
                Text="Rounded Border Opacity 0.5 ██████████" />
        </Border>
        <Image
            Width="75"
            Height="75"
            Opacity="0.5"
            Source="Assets/ingredient1.png" />
        <StackPanel Opacity=".5">
            <TextBlock
                FontFamily="Courier New"
                FontSize="20"
                Foreground="Black"
                Opacity="1"
                Text="Inherited Opacity 1.0 ██████████" />
            <TextBlock
                FontFamily="Courier New"
                FontSize="20"
                Foreground="Black"
                Opacity="0.5"
                Text="Inherited Opacity 0.5 ██████████" />
            <TextBlock
                FontFamily="Courier New"
                FontSize="20"
                Foreground="Black"
                Opacity="0.1"
                Text="Inherited Opacity 0.1 ██████████" />
            <Border Background="Red" Opacity="0.5">
                <TextBlock
                    FontFamily="Courier New"
                    FontSize="20"
                    Foreground="Black"
                    Text="Inherited Border Opacity 0.5 ██████████" />
            </Border>
            <Border
                Background="Red"
                CornerRadius="20"
                Opacity="0.5">
                <TextBlock
                    FontFamily="Courier New"
                    FontSize="20"
                    Foreground="Black"
                    Text="Rounded Border Opacity 0.5 ██████████" />
            </Border>
            <Image
                Width="75"
                Height="75"
                Opacity="0.5"
                Source="Assets/ingredient1.png" />
        </StackPanel>
    </StackPanel>
</Page>
