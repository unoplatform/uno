<Project Sdk="Microsoft.NET.Sdk">
	<!--
	This project exists ONLY to give Visual Studio Solution Explorer a real
	project node for the SamplesApp.Samples folder, so that "Add → New Item"
	creates files directly under this folder (rather than in a consumer head
	with a Link redirect). The samples are actually compiled into each
	SamplesApp head (SamplesApp.Skia, SamplesApp.Wasm, SamplesApp.Windows,
	SamplesApp.netcoremobile, UnoIslandsSamplesApp.Skia) via the
	SamplesApp.Samples.props import. This csproj does not build.
	-->
	<PropertyGroup>
		<TargetFramework>netstandard2.0</TargetFramework>
		<NoBuild>true</NoBuild>
		<IsPackable>false</IsPackable>
		<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
		<GenerateDocumentationFile>false</GenerateDocumentationFile>
		<EnableDefaultCompileItems>false</EnableDefaultCompileItems>
		<EnableDefaultEmbeddedResourceItems>false</EnableDefaultEmbeddedResourceItems>
		<EnableDefaultNoneItems>false</EnableDefaultNoneItems>
		<EnableDefaultPageItems>false</EnableDefaultPageItems>
	</PropertyGroup>

	<!-- Show all files under this folder in Solution Explorer for browsing/editing. -->
	<ItemGroup>
		<None Include="**\*" Exclude="bin\**;obj\**;*.csproj;*.props" />
	</ItemGroup>

	<!-- Prevent any consumer that accidentally references this project from getting outputs. -->
	<Target Name="GetTargetPath" />
	<Target Name="GetCopyToPublishDirectoryItems" />
</Project>
