<Page
    x:Class="UITests.Shared.Windows_UI_Input.GestureRecognizerTests.Manipulation_WhenInScrollViewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Shared.Windows_UI_Input.GestureRecognizerTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel>
            <ScrollViewer
                x:Name="TheScroller"
                Width="300"
                Height="300"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <Border
                    Width="300"
                    Height="1024"
                    Background="DeepPink">
                    <Border
                        x:Name="TouchTarget"
                        Width="50"
                        Height="50"
                        Margin="10,240,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="DeepSkyBlue"
                        ManipulationCompleted="OnManipCompleted"
                        ManipulationDelta="OnManipDelta"
                        ManipulationMode="TranslateX, TranslateY"
                        ManipulationStarted="OnManipStarted"
                        ManipulationStarting="OnManipStarting" />
                </Border>
            </ScrollViewer>
            <StackPanel Orientation="Horizontal">
                <Button
                    x:Name="SetNone"
                    Click="SetManipModeNone"
                    Content="None" />
                <Button
                    x:Name="SetTranslateXY"
                    Click="SetTranslateXandY"
                    Content="X and Y" />
                <Button
                    x:Name="SetTranslateX"
                    Click="SetTranslateXonly"
                    Content="X only" />
                <Button
                    x:Name="SetTranslateY"
                    Click="SetTranslateYonly"
                    Content="Y only" />
            </StackPanel>
        </StackPanel>
        <ScrollViewer Grid.Column="1">
            <TextBlock
                x:Name="Output"
                FontSize="10"
                TextWrapping="Wrap" />
        </ScrollViewer>
    </Grid>
</Page>
