<Page
    x:Class="UITests.Windows_UI_Input.PointersTests.HitTest_Control"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Input.PointersTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel>
        <Button
            x:Name="ResetButton"
            Click="ResetResult"
            Content="Reset" />
        <Grid Width="200" Height="200">
            <ContentControl Content="dummy" PointerPressed="BehindControlPressed">
                <ContentControl.Template>
                    <ControlTemplate>
                        <Grid
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="Beige" />
                    </ControlTemplate>
                </ContentControl.Template>
            </ContentControl>
            <ContentControl
                x:Name="FrontControl"
                Content="dummy"
                PointerPressed="FrontControlPressed">
                <ContentControl.Template>
                    <ControlTemplate>
                        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Border
                                Width="100"
                                Height="100"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Background="Blue" />
                            <Border
                                Width="100"
                                Height="100"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="LightBlue"
                                IsHitTestVisible="False" />
                        </Grid>
                    </ControlTemplate>
                </ContentControl.Template>
            </ContentControl>
        </Grid>

        <TextBlock x:Name="ResultTextBlock" Text="None" />
    </StackPanel>
</Page>
