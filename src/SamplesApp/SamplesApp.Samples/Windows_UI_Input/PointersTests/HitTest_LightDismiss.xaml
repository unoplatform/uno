<Page
    x:Class="UITests.Windows_UI_Input.PointersTests.HitTest_LightDismiss"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:UITests.ValueConverters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Input.PointersTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:StringConverter x:Key="StringConverter" />
    </Page.Resources>

    <Grid>
        <StackPanel HorizontalAlignment="Left">
            <Button
                x:Name="LaunchDismissiblePopupButton"
                Margin="10"
                Click="LaunchDismissiblePopup"
                Content="Launch dismissible popup" />
            <Button
                x:Name="LaunchUndismissiblePopupButton"
                Margin="10"
                Click="LaunchUndismissiblePopup"
                Content="Launch undismissible popup" />
            <Button
                x:Name="FlyoutButton"
                Margin="10"
                Content="Button with Flyout">
                <Button.Flyout>
                    <Flyout x:Name="ButtonFlyout" Placement="Full">
                        <!--  'Chromeless' flyout presenter style  -->
                        <Flyout.FlyoutPresenterStyle>
                            <Style TargetType="FlyoutPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                <Setter Property="VerticalAlignment" Value="Stretch" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="FlyoutPresenter">
                                            <Border HorizontalAlignment="{TemplateBinding HorizontalAlignment}" VerticalAlignment="{TemplateBinding VerticalAlignment}">
                                                <ContentPresenter
                                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                    Content="{TemplateBinding Content}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    ContentTransitions="{TemplateBinding ContentTransitions}" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Flyout.FlyoutPresenterStyle>

                        <Grid
                            x:Name="FlyoutContentGrid"
                            Width="350"
                            Height="350">
                            <Border
                                x:Name="FlyoutContentBorderWithPressed"
                                Width="350"
                                Height="100"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Background="Red"
                                PointerPressed="OnFlyoutContentPressed" />
                            <Border
                                x:Name="FlyoutContentBorderNoPressed"
                                Width="100"
                                Height="350"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="Orange" />
                            <Border
                                Width="350"
                                Height="100"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                Background="Yellow" />
                            <Border
                                Width="100"
                                Height="250"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Background="YellowGreen" />
                        </Grid>
                    </Flyout>
                </Button.Flyout>
            </Button>
            <ComboBox x:Name="TargetComboBox" ItemsSource="123" />
        </StackPanel>
        <StackPanel HorizontalAlignment="Right" Spacing="6">
            <Button x:Name="DummyButton" Content="dummy" />
            <Button
                x:Name="ResetButton"
                Click="ResetResult"
                Content="Reset" />
            <Button
                x:Name="ActionButton"
                Click="DoAction"
                Content="Apply action" />
            <TextBlock x:Name="ResultTextBlock" Text="None" />
            <TextBlock x:Name="PopupStatusTextBlock" Text="False" />
            <TextBlock x:Name="FlyoutStatusTextBlock" Text="False" />
            <TextBlock x:Name="ComboBoxStatusTextBlock" Text="{Binding ElementName=TargetComboBox, Path=IsDropDownOpen, Converter={StaticResource StringConverter}}" />
        </StackPanel>
    </Grid>
</Page>
