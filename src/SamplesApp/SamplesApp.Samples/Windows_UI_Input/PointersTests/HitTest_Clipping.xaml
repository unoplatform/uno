<Page
    x:Class="UITests.Windows_UI_Input.PointersTests.HitTest_Clipping"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Input.PointersTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="300" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <StackPanel
            Grid.Row="0"
            Grid.Column="0"
            Orientation="Horizontal">
            <Button
                x:Name="Scroll_Prepare"
                Click="PrepareScroller"
                Content="Do scroll" />
            <Button
                x:Name="Scroll_Target"
                Click="OnTargetClicked"
                Content="Click me" />
        </StackPanel>


        <ScrollViewer
            x:Name="The_Scroller"
            Grid.Row="1"
            Grid.Column="0"
            Height="300"
            HorizontalAlignment="Left">
            <StackPanel>
                <Border
                    Width="250"
                    Height="120"
                    Background="DeepSkyBlue" />
                <Border
                    Width="250"
                    Height="120"
                    Background="DeepPink" />
                <Border
                    Width="250"
                    Height="120"
                    Background="Chartreuse" />
                <Border
                    Width="250"
                    Height="120"
                    Background="Coral" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel
            Grid.Row="0"
            Grid.RowSpan="2"
            Grid.Column="1"
            HorizontalAlignment="Left"
            Orientation="Vertical">
            <Button
                x:Name="Clipped_Target"
                Click="OnTargetClicked"
                Content="Click me" />

            <Border
                Width="250"
                Height="250"
                Margin="0,-30,0,0"
                HorizontalAlignment="Left"
                Background="DeepSkyBlue"
                BorderBrush="DeepPink"
                BorderThickness="5">
                <Border.Clip>
                    <RectangleGeometry Rect="0,20,250,230" />
                </Border.Clip>
            </Border>

        </StackPanel>

        <TextBlock
            x:Name="The_Output"
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Text="--none--" />
    </Grid>
</Page>
