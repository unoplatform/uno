<UserControl
    x:Class="UITests.Shared.Toolkit.Elevation"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Uno.UI.Samples.Content.UITests.Elevation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:Uno.UI.Toolkit"
    mc:Ignorable="">

    <Grid>
        <ScrollViewer>
            <StackPanel>

                <!--  Message  -->
                <TextBlock
                    Margin="10"
                    HorizontalAlignment="Center"
                    Text="Elevation is only supported on Android and iOS." />

                <!--  Dialog No Elevation  -->
                <Grid
                    x:Name="MyDialog_NoElevation"
                    Width="300"
                    Height="125"
                    Margin="10"
                    Background="White" />

                <!--  Dialog With Elevation  -->
                <Grid
                    x:Name="MyDialog_WithElevation"
                    Width="300"
                    Height="125"
                    Margin="10"
                    toolkit:UIElementExtensions.Elevation="24"
                    Background="White"
                    Visibility="Collapsed" />

                <!--  Floating Action Button No Elevation  -->
                <Border
                    x:Name="MyButton_NoElevation"
                    Width="56"
                    Height="56"
                    Margin="10"
                    Background="Red"
                    CornerRadius="28" />

                <!--  Floating Action Button With Elevation  -->
                <Border
                    x:Name="MyButton_WithElevation"
                    Width="56"
                    Height="56"
                    Margin="10"
                    toolkit:UIElementExtensions.Elevation="6"
                    Background="Red"
                    CornerRadius="28"
                    Visibility="Collapsed" />

                <!--  Complex Corner Radius Outline Test No Elevation  -->
                <Border
                    x:Name="MyComplexRadius_NoElevation"
                    Width="56"
                    Height="56"
                    Margin="10"
                    Background="Orange"
                    CornerRadius="4,8,12,16" />

                <!--  Complex Corner Radius Outline Test With Elevation  -->
                <Border
                    x:Name="MyComplexRadius_WithElevation"
                    Width="56"
                    Height="56"
                    Margin="10"
                    toolkit:UIElementExtensions.Elevation="6"
                    Background="Orange"
                    CornerRadius="4,8,12,16"
                    Visibility="Collapsed" />

                <!--  App Bar No Elevation  -->
                <CommandBar
                    x:Name="MyAppBar_NoElevation"
                    Width="200"
                    Margin="10"
                    Background="RoyalBlue"
                    Content="Title"
                    Foreground="White" />

                <!--  App Bar With Elevation  -->
                <CommandBar
                    x:Name="MyAppBar_WithElevation"
                    Width="200"
                    Margin="10"
                    toolkit:UIElementExtensions.Elevation="4"
                    Background="RoyalBlue"
                    Content="Title"
                    Foreground="White"
                    Visibility="Collapsed" />

                <!--  Card No Elevation  -->
                <Border
                    x:Name="MyCard_NoElevation"
                    Width="75"
                    Height="100"
                    Margin="10"
                    Background="White" />

                <!--  Card With Elevation  -->
                <Border
                    x:Name="MyCard_WithElevation"
                    Width="75"
                    Height="100"
                    Margin="10"
                    toolkit:UIElementExtensions.Elevation="2"
                    Background="White"
                    Visibility="Collapsed" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel VerticalAlignment="Bottom">

            <!--  Label  -->
            <TextBlock Margin="5" Text="Elevation" />

            <!--  TurnElevation ON Button  -->
            <Button
                x:Name="TurnElevation_ON_Button"
                Margin="5"
                HorizontalAlignment="Left"
                Click="TurnElevation_ON"
                Content="ON" />

            <!--  TurnElevation OFF Button  -->
            <Button
                x:Name="TurnElevation_OFF_Button"
                Margin="5"
                HorizontalAlignment="Left"
                Click="TurnElevation_OFF"
                Content="OFF" />
        </StackPanel>
    </Grid>
</UserControl>
