<Page
    x:Class="SamplesApp.Windows_UI_Xaml_Media.Geometry.ArcSegmentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:skia="http://uno.ui/skia"
    xmlns:wasm="http://uno.ui/wasm"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d android ios wasm skia">
    <Page.Resources>
        <ControlTemplate x:Key="NoncircularPathTemplate">
            <Path
                x:Name="Path"
                Stroke="Black"
                StrokeThickness="1">
                <Path.Data>
                    <PathGeometry>
                        <PathGeometry.Figures>
                            <PathFigureCollection>
                                <PathFigure StartPoint="10,100">
                                    <PathFigure.Segments>
                                        <PathSegmentCollection>
                                            <ArcSegment
                                                IsLargeArc="True"
                                                Point="200,100"
                                                RotationAngle="45"
                                                Size="100,50"
                                                SweepDirection="CounterClockwise" />
                                        </PathSegmentCollection>
                                    </PathFigure.Segments>
                                </PathFigure>
                            </PathFigureCollection>
                        </PathGeometry.Figures>
                    </PathGeometry>
                </Path.Data>
            </Path>
        </ControlTemplate>
        <ControlTemplate x:Key="PlatformUnsupportedTemplate">
            <!--  https://github.com/unoplatform/uno/issues/2366  -->
            <TextBlock Text="Non-circular ArcSegments aren't supported on this platform" />
        </ControlTemplate>
    </Page.Resources>

    <StackPanel>
        <TextBlock Text="Non-circular ArcSegment:" />
        <ContentControl
            android:Template="{StaticResource PlatformUnsupportedTemplate}"
            ios:Template="{StaticResource PlatformUnsupportedTemplate}"
            skia:Template="{StaticResource NoncircularPathTemplate}"
            wasm:Template="{StaticResource NoncircularPathTemplate}"
            win:Template="{StaticResource NoncircularPathTemplate}" />
        <TextBlock Text="Circular ArcSegment:" />
        <Path
            x:Name="Path"
            Stroke="Blue"
            StrokeThickness="1">
            <Path.Data>
                <PathGeometry>
                    <PathGeometry.Figures>
                        <PathFigureCollection>
                            <PathFigure StartPoint="10,100">
                                <PathFigure.Segments>
                                    <PathSegmentCollection>
                                        <ArcSegment
                                            IsLargeArc="True"
                                            Point="200,100"
                                            RotationAngle="45"
                                            Size="75,75"
                                            SweepDirection="CounterClockwise" />
                                    </PathSegmentCollection>
                                </PathFigure.Segments>
                            </PathFigure>
                        </PathFigureCollection>
                    </PathGeometry.Figures>
                </PathGeometry>
            </Path.Data>
        </Path>
    </StackPanel>
</Page>
