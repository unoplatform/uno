<Page
    x:Class="UITests.Windows_UI_Xaml_Media.BrushesTests.DynamicBrushes_On_Shapes"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel Margin="20" Spacing="6">
        <Border>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Border
                    x:Name="border1"
                    Width="50"
                    Height="60" />
                <Ellipse
                    x:Name="shape1"
                    Width="50"
                    Height="60" />
                <Rectangle
                    x:Name="shape2"
                    Width="50"
                    Height="60">
                    <Rectangle.Fill>
                        <ImageBrush ImageSource="ms-appx:///Assets/Formats/uno-overalls.jpg" />
                    </Rectangle.Fill>
                </Rectangle>
                <Path
                    x:Name="shape3"
                    Width="60"
                    Height="60"
                    Data="M 100 100 L 300 100 L 200 300 z"
                    Stretch="UniformToFill" />
            </StackPanel>
        </Border>
        <TextBlock x:Name="txt" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Click="SetFill" Tag="null">
                NULL FILL
            </Button>
            <Button Click="SetFill" Tag="solid1">
                Solid1
            </Button>
            <Button Click="SetFill" Tag="solid2">
                Solid2
            </Button>
            <Button Click="SetFill" Tag="linear">
                Linear Gradient
            </Button>
            <Button Click="SetFill" Tag="radial">
                Radial Gradient
            </Button>
            <Button Click="SetFill" Tag="img1">
                Image 1
            </Button>
            <Button Click="SetFill" Tag="img2">
                Image 2
            </Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock>Solid1:</TextBlock>
            <RadioButton
                Background="Red"
                Click="SetColor"
                GroupName="Solid1"
                IsChecked="True">
                Red
            </RadioButton>
            <RadioButton
                Background="Blue"
                Click="SetColor"
                GroupName="Solid1">
                Blue
            </RadioButton>
            <RadioButton
                Background="Yellow"
                Click="SetColor"
                GroupName="Solid1">
                Yellow
            </RadioButton>
            <RadioButton
                Background="Green"
                Click="SetColor"
                GroupName="Solid1">
                Green
            </RadioButton>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock>Solid1:</TextBlock>
            <RadioButton
                Background="Red"
                Click="SetColor"
                GroupName="Solid2">
                Red
            </RadioButton>
            <RadioButton
                Background="Blue"
                Click="SetColor"
                GroupName="Solid2"
                IsChecked="True">
                Blue
            </RadioButton>
            <RadioButton
                Background="Yellow"
                Click="SetColor"
                GroupName="Solid2">
                Yellow
            </RadioButton>
            <RadioButton
                Background="Green"
                Click="SetColor"
                GroupName="Solid2">
                Green
            </RadioButton>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock>Image1:</TextBlock>
            <RadioButton
                Click="SetImage"
                GroupName="Image1"
                IsChecked="True"
                Tag="ms-appx:///Assets/RatingControl.png">
                Star
            </RadioButton>
            <RadioButton
                Click="SetImage"
                GroupName="Image1"
                Tag="ms-appx:///Assets/Formats/uno-overalls.jpg">
                Overalls
            </RadioButton>
            <RadioButton
                Click="SetImage"
                GroupName="Image1"
                Tag="ms-appx:///Assets/test_image_100_100.png">
                Logo
            </RadioButton>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock>Image2:</TextBlock>
            <RadioButton
                Click="SetImage"
                GroupName="Image2"
                Tag="ms-appx:///Assets/RatingControl.png">
                Star
            </RadioButton>
            <RadioButton
                Click="SetImage"
                GroupName="Image2"
                IsChecked="True"
                Tag="ms-appx:///Assets/Formats/uno-overalls.jpg">
                Overalls
            </RadioButton>
            <RadioButton
                Click="SetImage"
                GroupName="Image2"
                Tag="ms-appx:///Assets/test_image_100_100.png">
                Logo
            </RadioButton>
        </StackPanel>
    </StackPanel>
</Page>
