<UserControl
    x:Class="UITests.Windows_UI_Xaml_Media.BrushesTests.SolidColorBrush_Color_Changed"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Media.BrushesTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <StackPanel Margin="0,50,0,0" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <TextBlock
            x:Name="StatusTextBlock"
            Margin="3"
            Text="Unset" />
        <Button
            x:Name="ChangeBorderColorButton"
            Click="ChangeBorderColor"
            Content="Change border color" />
        <Grid HorizontalAlignment="Left" VerticalAlignment="Center">
            <Border
                x:Name="ToggleableBorder"
                Width="190"
                Height="70"
                Margin="3"
                BorderThickness="15"
                CornerRadius="5">
                <Border.BorderBrush>
                    <SolidColorBrush Color="Green" />
                </Border.BorderBrush>
            </Border>
            <Rectangle
                x:Name="ToggleableBorderViewfinder"
                Width="15"
                Margin="3"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Fill="Transparent" />
        </Grid>
        <Grid HorizontalAlignment="Left" VerticalAlignment="Center">
            <Grid
                x:Name="ToggleableGrid"
                Width="190"
                Height="70"
                Margin="3"
                BorderThickness="15"
                CornerRadius="5">
                <Grid.BorderBrush>
                    <SolidColorBrush Color="IndianRed" />
                </Grid.BorderBrush>
            </Grid>
            <Rectangle
                x:Name="ToggleableGridViewfinder"
                Width="15"
                Margin="3"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Fill="Transparent" />
        </Grid>
        <Grid HorizontalAlignment="Left" VerticalAlignment="Center">
            <Ellipse
                x:Name="ToggleableEllipse"
                Width="190"
                Height="70"
                Margin="3"
                StrokeThickness="15">
                <Ellipse.Stroke>
                    <SolidColorBrush Color="Violet" />
                </Ellipse.Stroke>
            </Ellipse>
            <Rectangle
                x:Name="ToggleableEllipseViewfinder"
                Width="15"
                Margin="3"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Fill="Transparent" />
        </Grid>
        <Grid HorizontalAlignment="Left" VerticalAlignment="Center">
            <Ellipse
                x:Name="ToggleableFillEllipse"
                Width="190"
                Height="70"
                Margin="3"
                Stroke="Transparent"
                StrokeThickness="15">
                <Ellipse.Fill>
                    <SolidColorBrush Color="DarkGoldenrod" />
                </Ellipse.Fill>
            </Ellipse>
            <Rectangle
                x:Name="ToggleableFillEllipseViewfinder"
                Width="15"
                Margin="3"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Fill="Transparent" />
        </Grid>
    </StackPanel>
</UserControl>
