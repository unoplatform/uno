<Page
    x:Class="UITests.Windows_UI_Xaml_Media.GradientBrushTests.GradientsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:media="using:Microsoft.UI.Xaml.Media"
    xmlns:not_win="http://uno.ui/not_win"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d not_win">

    <ScrollViewer>
        <StackPanel Spacing="10">
            <TextBlock FontSize="15">Radial Gradient as background on a Rectangle / Rectangle / Border / Ellipse / Ellipse</TextBlock>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Rectangle Width="100" Height="100">
                    <Rectangle.Fill>
                        <media:RadialGradientBrush FallbackColor="Red">
                            <GradientStop Offset="0.0" Color="Blue" />
                            <GradientStop Offset="0.2" Color="Yellow" />
                            <GradientStop Offset="0.4" Color="LimeGreen" />
                            <GradientStop Offset="0.6" Color="LightBlue" />
                            <GradientStop Offset="0.8" Color="Blue" />
                            <GradientStop Offset="1" Color="LightGray" />
                        </media:RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <Rectangle Width="100" Height="100">
                    <Rectangle.Fill>
                        <media:RadialGradientBrush
                            FallbackColor="Red"
                            RadiusX="0.5"
                            RadiusY="0.5">
                            <GradientStop Offset="0.0" Color="Blue" />
                            <GradientStop Offset="0.2" Color="Yellow" />
                            <GradientStop Offset="0.4" Color="LimeGreen" />
                            <GradientStop Offset="0.6" Color="LightBlue" />
                            <GradientStop Offset="0.8" Color="Blue" />
                            <GradientStop Offset="1" Color="LightGray" />
                        </media:RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <Border Width="100" Height="100">
                    <Border.Background>
                        <media:RadialGradientBrush FallbackColor="Red">
                            <GradientStop Offset="0.0" Color="Blue" />
                            <GradientStop Offset="0.2" Color="Yellow" />
                            <GradientStop Offset="0.4" Color="LimeGreen" />
                            <GradientStop Offset="0.6" Color="LightBlue" />
                            <GradientStop Offset="0.8" Color="Blue" />
                            <GradientStop Offset="1" Color="LightGray" />
                        </media:RadialGradientBrush>
                    </Border.Background>
                </Border>
                <Ellipse Width="100" Height="100">
                    <Ellipse.Fill>
                        <media:RadialGradientBrush FallbackColor="Red">
                            <GradientStop Offset="0.0" Color="Blue" />
                            <GradientStop Offset="0.2" Color="Yellow" />
                            <GradientStop Offset="0.4" Color="LimeGreen" />
                            <GradientStop Offset="0.6" Color="LightBlue" />
                            <GradientStop Offset="0.8" Color="Blue" />
                            <GradientStop Offset="1" Color="LightGray" />
                        </media:RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse Width="150" Height="100">
                    <Ellipse.Fill>
                        <media:RadialGradientBrush FallbackColor="Red">
                            <GradientStop Offset="0.0" Color="Blue" />
                            <GradientStop Offset="0.2" Color="Yellow" />
                            <GradientStop Offset="0.4" Color="LimeGreen" />
                            <GradientStop Offset="0.6" Color="LightBlue" />
                            <GradientStop Offset="0.8" Color="Blue" />
                            <GradientStop Offset="1" Color="LightGray" />
                        </media:RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </StackPanel>
            <TextBlock FontSize="15">Radial Gradient as border/stroke on a Rectangle/ Border / Border with corner radius / Ellipse</TextBlock>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Rectangle
                    Width="100"
                    Height="100"
                    Fill="DarkGray"
                    StrokeThickness="40">
                    <Rectangle.Stroke>
                        <media:RadialGradientBrush FallbackColor="Red">
                            <GradientStop Offset="0.0" Color="Blue" />
                            <GradientStop Offset="0.2" Color="Yellow" />
                            <GradientStop Offset="0.4" Color="LimeGreen" />
                            <GradientStop Offset="0.6" Color="LightBlue" />
                            <GradientStop Offset="0.8" Color="Blue" />
                            <GradientStop Offset="1" Color="LightGray" />
                        </media:RadialGradientBrush>
                    </Rectangle.Stroke>
                </Rectangle>

                <Border
                    Width="100"
                    Height="100"
                    Background="DarkGray"
                    BorderThickness="40">
                    <Border.BorderBrush>
                        <media:RadialGradientBrush FallbackColor="Red">
                            <GradientStop Offset="0.0" Color="Blue" />
                            <GradientStop Offset="0.2" Color="Yellow" />
                            <GradientStop Offset="0.4" Color="LimeGreen" />
                            <GradientStop Offset="0.6" Color="LightBlue" />
                            <GradientStop Offset="0.8" Color="Blue" />
                            <GradientStop Offset="1" Color="LightGray" />
                        </media:RadialGradientBrush>
                    </Border.BorderBrush>
                </Border>

                <Border
                    Width="100"
                    Height="100"
                    Background="DarkGray"
                    BorderThickness="40"
                    CornerRadius="8">
                    <Border.BorderBrush>
                        <media:RadialGradientBrush FallbackColor="Red">
                            <GradientStop Offset="0.0" Color="Blue" />
                            <GradientStop Offset="0.2" Color="Yellow" />
                            <GradientStop Offset="0.4" Color="LimeGreen" />
                            <GradientStop Offset="0.6" Color="LightBlue" />
                            <GradientStop Offset="0.8" Color="Blue" />
                            <GradientStop Offset="1" Color="LightGray" />
                        </media:RadialGradientBrush>
                    </Border.BorderBrush>
                </Border>

                <Ellipse
                    Width="100"
                    Height="100"
                    Fill="DarkGray"
                    StrokeThickness="40">
                    <Ellipse.Stroke>
                        <media:RadialGradientBrush FallbackColor="Red">
                            <media:RadialGradientBrush.GradientStops>
                                <GradientStop Offset="0.0" Color="Blue" />
                                <GradientStop Offset="0.2" Color="Yellow" />
                                <GradientStop Offset="0.4" Color="LimeGreen" />
                                <GradientStop Offset="0.6" Color="LightBlue" />
                                <GradientStop Offset="0.8" Color="Blue" />
                                <GradientStop Offset="1" Color="LightGray" />
                            </media:RadialGradientBrush.GradientStops>
                        </media:RadialGradientBrush>
                    </Ellipse.Stroke>
                </Ellipse>
                <Ellipse
                    Width="150"
                    Height="100"
                    Fill="DarkGray"
                    StrokeThickness="40">
                    <Ellipse.Stroke>
                        <media:RadialGradientBrush FallbackColor="Red">
                            <media:RadialGradientBrush.GradientStops>
                                <GradientStop Offset="0.0" Color="Blue" />
                                <GradientStop Offset="0.2" Color="Yellow" />
                                <GradientStop Offset="0.4" Color="LimeGreen" />
                                <GradientStop Offset="0.6" Color="LightBlue" />
                                <GradientStop Offset="0.8" Color="Blue" />
                                <GradientStop Offset="1" Color="LightGray" />
                            </media:RadialGradientBrush.GradientStops>
                        </media:RadialGradientBrush>
                    </Ellipse.Stroke>
                </Ellipse>
            </StackPanel>
            <TextBlock FontSize="15">Linear Gradient as background on a Rectangle + Border (relative + absolute)</TextBlock>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Rectangle Width="100" Height="100">
                    <Rectangle.Fill>
                        <LinearGradientBrush not_win:FallbackColor="Red">
                            <GradientStop Offset="0.0" Color="Blue" />
                            <GradientStop Offset="0.2" Color="Yellow" />
                            <GradientStop Offset="0.4" Color="LimeGreen" />
                            <GradientStop Offset="0.6" Color="LightBlue" />
                            <GradientStop Offset="0.8" Color="Blue" />
                            <GradientStop Offset="1" Color="LightGray" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Border Width="100" Height="100">
                    <Border.Background>
                        <LinearGradientBrush not_win:FallbackColor="Red">
                            <GradientStop Offset="0.0" Color="Blue" />
                            <GradientStop Offset="0.2" Color="Yellow" />
                            <GradientStop Offset="0.4" Color="LimeGreen" />
                            <GradientStop Offset="0.6" Color="LightBlue" />
                            <GradientStop Offset="0.8" Color="Blue" />
                            <GradientStop Offset="1" Color="LightGray" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Rectangle Width="100" Height="100">
                    <Rectangle.Fill>
                        <LinearGradientBrush not_win:FallbackColor="Red" MappingMode="Absolute" EndPoint="100,100">
                            <GradientStopCollection>
                                <GradientStop Offset="0.0" Color="Blue" />
                                <GradientStop Offset="0.2" Color="Yellow" />
                                <GradientStop Offset="0.4" Color="LimeGreen" />
                                <GradientStop Offset="0.6" Color="LightBlue" />
                                <GradientStop Offset="0.8" Color="Blue" />
                                <GradientStop Offset="1" Color="LightGray" />
                            </GradientStopCollection>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Border Width="100" Height="100">
                    <Border.Background>
                        <LinearGradientBrush not_win:FallbackColor="Red" MappingMode="Absolute" EndPoint="100,100">
                            <LinearGradientBrush.GradientStops>
                                <GradientStop Offset="0.0" Color="Blue" />
                                <GradientStop Offset="0.2" Color="Yellow" />
                                <GradientStop Offset="0.4" Color="LimeGreen" />
                                <GradientStop Offset="0.6" Color="LightBlue" />
                                <GradientStop Offset="0.8" Color="Blue" />
                                <GradientStop Offset="1" Color="LightGray" />
                            </LinearGradientBrush.GradientStops>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </StackPanel>
            <TextBlock FontSize="15">Linear Gradient as border/stroke on a Rectangle + Border (relative + absolute)</TextBlock>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Rectangle
                    Width="100"
                    Height="100"
                    StrokeThickness="40">
                    <Rectangle.Stroke>
                        <LinearGradientBrush not_win:FallbackColor="Red">
                            <LinearGradientBrush.GradientStops>
                                <GradientStopCollection>
                                    <GradientStop Offset="0.0" Color="Blue" />
                                    <GradientStop Offset="0.2" Color="Yellow" />
                                    <GradientStop Offset="0.4" Color="LimeGreen" />
                                    <GradientStop Offset="0.6" Color="LightBlue" />
                                    <GradientStop Offset="0.8" Color="Blue" />
                                    <GradientStop Offset="1" Color="LightGray" />
                                </GradientStopCollection>
                            </LinearGradientBrush.GradientStops>
                        </LinearGradientBrush>
                    </Rectangle.Stroke>
                </Rectangle>
                <Border
                    Width="100"
                    Height="100"
                    BorderThickness="40">
                    <Border.BorderBrush>
                        <LinearGradientBrush not_win:FallbackColor="Red">
                            <GradientStop Offset="0.0" Color="Blue" />
                            <GradientStop Offset="0.2" Color="Yellow" />
                            <GradientStop Offset="0.4" Color="LimeGreen" />
                            <GradientStop Offset="0.6" Color="LightBlue" />
                            <GradientStop Offset="0.8" Color="Blue" />
                            <GradientStop Offset="1" Color="LightGray" />
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                </Border>
                <Border
                    Width="100"
                    Height="100"
                    BorderThickness="40"
                    CornerRadius="8">
                    <Border.BorderBrush>
                        <LinearGradientBrush not_win:FallbackColor="Red">
                            <GradientStop Offset="0.0" Color="Blue" />
                            <GradientStop Offset="0.2" Color="Yellow" />
                            <GradientStop Offset="0.4" Color="LimeGreen" />
                            <GradientStop Offset="0.6" Color="LightBlue" />
                            <GradientStop Offset="0.8" Color="Blue" />
                            <GradientStop Offset="1" Color="LightGray" />
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                </Border>
                <Rectangle
                    Width="100"
                    Height="100"
                    StrokeThickness="40">
                    <Rectangle.Stroke>
                        <LinearGradientBrush not_win:FallbackColor="Red" MappingMode="Absolute" EndPoint="100,100">
                            <GradientStop Offset="0.0" Color="Blue" />
                            <GradientStop Offset="0.2" Color="Yellow" />
                            <GradientStop Offset="0.4" Color="LimeGreen" />
                            <GradientStop Offset="0.6" Color="LightBlue" />
                            <GradientStop Offset="0.8" Color="Blue" />
                            <GradientStop Offset="1" Color="LightGray" />
                        </LinearGradientBrush>
                    </Rectangle.Stroke>
                </Rectangle>
                <Border
                    Width="100"
                    Height="100"
                    BorderThickness="40">
                    <Border.BorderBrush>
                        <LinearGradientBrush not_win:FallbackColor="Red" MappingMode="Absolute" EndPoint="100,100">
                            <GradientStop Offset="0.0" Color="Blue" />
                            <GradientStop Offset="0.2" Color="Yellow" />
                            <GradientStop Offset="0.4" Color="LimeGreen" />
                            <GradientStop Offset="0.6" Color="LightBlue" />
                            <GradientStop Offset="0.8" Color="Blue" />
                            <GradientStop Offset="1" Color="LightGray" />
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                </Border>

                <Border
                    Width="100"
                    Height="100"
                    BorderThickness="40"
                    CornerRadius="8">
                    <Border.BorderBrush>
                        <LinearGradientBrush not_win:FallbackColor="Red" MappingMode="Absolute" EndPoint="100,100">
                            <GradientStop Offset="0.0" Color="Blue" />
                            <GradientStop Offset="0.2" Color="Yellow" />
                            <GradientStop Offset="0.4" Color="LimeGreen" />
                            <GradientStop Offset="0.6" Color="LightBlue" />
                            <GradientStop Offset="0.8" Color="Blue" />
                            <GradientStop Offset="1" Color="LightGray" />
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                </Border>
            </StackPanel>
            <TextBlock FontSize="15">Linear Gradient as border/stroke with relative transform / with single stop</TextBlock>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Border
                    Width="100"
                    Height="100"
                    BorderThickness="40"
                    CornerRadius="8">
                    <Border.BorderBrush>
                        <LinearGradientBrush MappingMode="Absolute" StartPoint="0,0" EndPoint="0,40">
                            <LinearGradientBrush.RelativeTransform>
                                <ScaleTransform CenterY="0.5" ScaleY="-1" />
                            </LinearGradientBrush.RelativeTransform>
                            <LinearGradientBrush.GradientStops>
                                <GradientStop Offset="1" Color="Blue" />
                                <GradientStop Offset="1" Color="Red" />
                            </LinearGradientBrush.GradientStops>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                </Border>
                <Rectangle
                    Width="100"
                    Height="100"
                    RadiusX="8"
                    RadiusY="8"
                    StrokeThickness="40">
                    <Rectangle.Stroke>
                        <LinearGradientBrush MappingMode="Absolute" StartPoint="0,0" EndPoint="0,40">
                            <LinearGradientBrush.RelativeTransform>
                                <ScaleTransform CenterY="0.5" ScaleY="-1" />
                            </LinearGradientBrush.RelativeTransform>
                            <LinearGradientBrush.GradientStops>
                                <GradientStop Offset="1" Color="Blue" />
                                <GradientStop Offset="1" Color="Red" />
                            </LinearGradientBrush.GradientStops>
                        </LinearGradientBrush>
                    </Rectangle.Stroke>
                </Rectangle>
                <Border
                    Width="100"
                    Height="100"
                    BorderThickness="40"
                    CornerRadius="8">
                    <Border.BorderBrush>
                        <LinearGradientBrush MappingMode="Absolute" StartPoint="0,0" EndPoint="0,40">
                            <LinearGradientBrush.GradientStops>
                                <GradientStop Offset="0.5" Color="Red" />
                            </LinearGradientBrush.GradientStops>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                </Border>
                <Rectangle
                    Width="100"
                    Height="100"
                    RadiusX="8"
                    RadiusY="8"
                    StrokeThickness="40">
                    <Rectangle.Stroke>
                        <LinearGradientBrush MappingMode="Absolute" StartPoint="0,0" EndPoint="0,40">
                            <LinearGradientBrush.GradientStops>
                                <GradientStop Offset="0.5" Color="Red" />
                            </LinearGradientBrush.GradientStops>
                        </LinearGradientBrush>
                    </Rectangle.Stroke>
                </Rectangle>
            </StackPanel>
            <TextBlock FontSize="15">Text with Radial/Linear gradient as foreground brush (fallback=red)</TextBlock>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock
                    FontSize="110"
                    FontWeight="Bold"
                    Text="UNO">
                    <TextBlock.Foreground>
                        <media:RadialGradientBrush not_win:FallbackColor="Red">
                            <GradientStop Offset="0.0" Color="Blue" />
                            <GradientStop Offset="0.2" Color="Yellow" />
                            <GradientStop Offset="0.4" Color="LimeGreen" />
                            <GradientStop Offset="0.6" Color="LightBlue" />
                            <GradientStop Offset="0.8" Color="Blue" />
                            <GradientStop Offset="1" Color="LightGray" />
                        </media:RadialGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
                <TextBlock
                    FontSize="110"
                    FontWeight="Bold"
                    Text="UNO">
                    <TextBlock.Foreground>
                        <LinearGradientBrush not_win:FallbackColor="Red">
                            <GradientStop Offset="0.0" Color="Blue" />
                            <GradientStop Offset="0.2" Color="Yellow" />
                            <GradientStop Offset="0.4" Color="LimeGreen" />
                            <GradientStop Offset="0.6" Color="LightBlue" />
                            <GradientStop Offset="0.8" Color="Blue" />
                            <GradientStop Offset="1" Color="LightGray" />
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
