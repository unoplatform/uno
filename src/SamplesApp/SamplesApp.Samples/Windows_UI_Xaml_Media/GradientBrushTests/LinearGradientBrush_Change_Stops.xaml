<UserControl
    x:Class="UITests.Windows_UI_Xaml_Media.GradientBrushTests.LinearGradientBrush_Change_Stops"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Media.GradientBrushTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Color x:Key="UnoBlueColor">#FF229DFC</Color>
        <Color x:Key="UnoPurpleColor">#FF7A69F5</Color>
        <Color x:Key="UnoGreenColor">#FF6CE5AE</Color>
        <Color x:Key="UnoRedColor">#FFF65678</Color>
    </UserControl.Resources>

    <StackPanel Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Rectangle
            x:Name="GradientBrushRectangle"
            Width="150"
            Height="100"
            HorizontalAlignment="Left">
            <Rectangle.Fill>
                <LinearGradientBrush x:Name="UnoGradientBrush" StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0.0" Color="{StaticResource UnoGreenColor}" />
                    <GradientStop Offset="0.1" Color="{StaticResource UnoGreenColor}" />
                    <GradientStop Offset="0.40" Color="{StaticResource UnoBlueColor}" />
                    <GradientStop Offset="0.60" Color="{StaticResource UnoPurpleColor}" />
                    <GradientStop Offset="0.9" Color="{StaticResource UnoRedColor}" />
                    <GradientStop Offset="1" Color="{StaticResource UnoRedColor}" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Button
            x:Name="ChangeBrushButton"
            Click="ChangeBrushButton_Click"
            Content="Change gradient stops" />
        <TextBlock x:Name="StatusTextBlock" Text="Not started" />
    </StackPanel>
</UserControl>
