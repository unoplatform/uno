<UserControl
    x:Class="Uno.UI.Samples.UITests.ImageBrushTestControl.ImageBrushChangingCornerRadius"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="Uno.UI.Samples.UITests.ImageBrushTestControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="2000"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <StackPanel>
        <Button Click="Button_Click" Content="Change corner radius" />
        <TextBlock Text="The image should not flicker when corner radius changes." />
        <Border
            x:Name="MyBorder"
            Width="300"
            Height="300"
            BorderBrush="Red"
            BorderThickness="8"
            CornerRadius="5">
            <Border.Background>
                <ImageBrush ImageSource="https://upload.wikimedia.org/wikipedia/commons/b/b3/1606_Hondius_and_Mercator_Map_of_Mexico_-_Geographicus_-_HispaniaeNovaMexico-mercator-1606.jpg" />
            </Border.Background>
        </Border>
    </StackPanel>
</UserControl>