<UserControl
    x:Class="Uno.UI.Samples.UITests.ImageBrushTestControl.ImageBrushStretch"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://nventive.com/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://nventive.com/ios"
    xmlns:local="using:Uno.UI.Samples.UITests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_ios="http://nventive.com/not_ios"
    xmlns:shapes="clr-namespace:Uno.UI.Xaml.Shapes;assembly=nVentive.Umbrella"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="600"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">
    <controls:SampleControl SampleDescription="Effect of ImageBrush.Stretch on the visual result">
        <controls:SampleControl.SampleContent>
            <DataTemplate>
                <StackPanel>
                    <TextBlock Text="[Stretch=Fill] This should display an image with a red border." />
                    <Border
                        Width="200"
                        Height="100"
                        BorderBrush="Red"
                        BorderThickness="5"
                        CornerRadius="10">
                        <Border.Background>
                            <ImageBrush ImageSource="http://i.imgur.com/tpFJ94J.jpg" Stretch="Fill" />
                        </Border.Background>
                    </Border>

                    <TextBlock Text="[Stretch=None] This should display an image with a red border." />
                    <Border
                        Width="200"
                        Height="100"
                        BorderBrush="Red"
                        BorderThickness="5"
                        CornerRadius="10">
                        <Border.Background>
                            <ImageBrush ImageSource="http://i.imgur.com/tpFJ94J.jpg" Stretch="None" />
                        </Border.Background>
                    </Border>

                    <TextBlock Text="[Stretch=Uniform] This should display an image with a red border." />
                    <Border
                        Width="200"
                        Height="100"
                        BorderBrush="Red"
                        BorderThickness="5"
                        CornerRadius="10">
                        <Border.Background>
                            <ImageBrush ImageSource="http://i.imgur.com/tpFJ94J.jpg" Stretch="Uniform" />
                        </Border.Background>
                    </Border>

                    <TextBlock Text="[Stretch=UniformToFill] This should display an image with a red border." />
                    <Border
                        Width="200"
                        Height="100"
                        BorderBrush="Red"
                        BorderThickness="5"
                        CornerRadius="10">
                        <Border.Background>
                            <ImageBrush ImageSource="http://i.imgur.com/tpFJ94J.jpg" Stretch="UniformToFill" />
                        </Border.Background>
                    </Border>

                </StackPanel>
            </DataTemplate>
        </controls:SampleControl.SampleContent>
    </controls:SampleControl>
</UserControl>