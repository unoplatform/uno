<UserControl
    x:Class="Uno.UI.Samples.UITests.ImageBrushTestControl.EllipsemaskingEllipseGrid"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:android="http://uno.ui/android"
    xmlns:controls="using:Uno.UI.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ios="http://uno.ui/ios"
    xmlns:local="using:Uno.UI.Samples.UITests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_ios="http://uno.ui/not_ios"
    xmlns:shapes="clr-namespace:Microsoft.UI.Xaml.Shapes;assembly=Uno"
    xmlns:u="using:Uno.UI.Samples.Controls"
    xmlns:uBehaviors="using:Uno.UI.Samples.Behaviors"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d ios android">

    <StackPanel>
        <Border>
            <controls:SampleControl SampleDescription="EllipsemaskingEllipseGrid">
                <controls:SampleControl.SampleContent>
                    <DataTemplate>
                        <Grid Width="240" Height="240">
                            <Ellipse Width="200" Height="200">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="/Assets/test_image_200_200.png" Stretch="Fill" />
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse
                                Width="120"
                                Height="120"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="/Assets/Diagnostics/exclamation.png" Stretch="Fill" />
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>
                    </DataTemplate>
                </controls:SampleControl.SampleContent>
            </controls:SampleControl>
        </Border>

    </StackPanel>
</UserControl>
