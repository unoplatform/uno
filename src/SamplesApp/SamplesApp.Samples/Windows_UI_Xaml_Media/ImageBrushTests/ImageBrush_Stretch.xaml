<Page
    x:Class="UITests.Windows_UI_Xaml_Media.ImageBrushTests.ImageBrush_Stretch"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:UITests.Windows_UI_Xaml_Media.ImageBrushTests"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel>
        <TextBlock Text="Stretch=Fill" />
        <Border
            x:Name="FillBorder"
            Width="100"
            Height="100"
            HorizontalAlignment="Left"
            BorderBrush="Red"
            BorderThickness="2">
            <Border.Background>
                <ImageBrush ImageSource="ms-appx:///Assets/colored-ellipse.jpg" Stretch="Fill" />
            </Border.Background>
        </Border>

        <TextBlock Text="Stretch=UniformToFill" />
        <Border
            x:Name="UniformToFillBorder"
            Width="100"
            Height="100"
            HorizontalAlignment="Left"
            BorderBrush="Red"
            BorderThickness="2">
            <Border.Background>
                <ImageBrush ImageSource="ms-appx:///Assets/colored-ellipse.jpg" Stretch="UniformToFill" />
            </Border.Background>
        </Border>

        <TextBlock Text="Stretch=Uniform" />
        <Border
            x:Name="UniformBorder"
            Width="100"
            Height="100"
            HorizontalAlignment="Left"
            BorderBrush="Red"
            BorderThickness="2">
            <Border.Background>
                <ImageBrush ImageSource="ms-appx:///Assets/colored-ellipse.jpg" Stretch="Uniform" />
            </Border.Background>
        </Border>

        <TextBlock Text="Stretch=None" />
        <Border
            x:Name="NoneBorder"
            Width="100"
            Height="100"
            HorizontalAlignment="Left"
            BorderBrush="Red"
            BorderThickness="2">
            <Border.Background>
                <ImageBrush ImageSource="ms-appx:///Assets/colored-ellipse.jpg" Stretch="None" />
            </Border.Background>
        </Border>
    </StackPanel>
</Page>
