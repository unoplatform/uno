<Page
	x:Class="UITests.Windows_UI_ViewManagement.SoftInputTests_FocusChange"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
	mc:Ignorable="d">

	<!-- Test: Multiple TextBoxes with focus changes while keyboard is showing.
		 Expected: Tap bottom TextBox (keyboard shows, page scrolls down),
		 then tap top TextBox (page scrolls back up to show it). -->
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0" Padding="12" Spacing="4">
			<TextBlock Text="Soft Input: Focus Change" FontSize="18" FontWeight="Bold" />
			<TextBlock Text="Tap the bottom TextBox first (keyboard appears, page scrolls). Then tap the top TextBox without dismissing keyboard - page should scroll back up." TextWrapping="Wrap" />
			<TextBlock x:Name="StatusText" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
		</StackPanel>

		<TextBox Grid.Row="1" PlaceholderText="Top TextBox - tap second" Margin="12,8" />

		<Border Grid.Row="2" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" Margin="12,8">
			<TextBlock Text="(Spacer between TextBoxes)" HorizontalAlignment="Center" VerticalAlignment="Center" />
		</Border>

		<TextBox Grid.Row="3" PlaceholderText="Bottom TextBox - tap first" Margin="12,8" />
	</Grid>
</Page>
