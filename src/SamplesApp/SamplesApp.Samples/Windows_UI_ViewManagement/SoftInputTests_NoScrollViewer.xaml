<Page
    x:Class="UITests.Windows_UI_ViewManagement.SoftInputTests_NoScrollViewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <!--
        Test: TextBox at bottom of page with NO ScrollViewer.
        Expected: RootScrollViewer scrolls entire page up to show TextBox above keyboard.
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Padding="12"
            Spacing="4">
            <TextBlock
                FontSize="18"
                FontWeight="Bold"
                Text="Soft Input: No ScrollViewer" />
            <TextBlock Text="Tap the TextBox at the bottom. When the keyboard appears, the page should scroll up so the TextBox is visible above the keyboard." TextWrapping="Wrap" />
            <TextBlock x:Name="StatusText" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
        </StackPanel>

        <!--  Large spacer to push TextBox to bottom  -->
        <Border
            Grid.Row="1"
            Margin="12,8"
            Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Text="(Spacer - no ScrollViewer wrapping this content)" />
        </Border>

        <TextBox
            Grid.Row="2"
            Margin="12,8"
            PlaceholderText="Tap here to open keyboard..." />
    </Grid>
</Page>
