<?xml version="1.0" encoding="utf-8" ?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<PropertyGroup>
		<IsUnoHead Condition="'$(OutputType)'=='Exe' OR '$(OutputType)'=='WinExe'">true</IsUnoHead>
	</PropertyGroup>

	<Target Name="_UnoSkiaLinuxFBFeatureDefines" AfterTargets="PrepareForBuild">

		<PropertyGroup>
			<DefineConstants>$(DefineConstants);UNO_REFERENCE_API;HAS_UNO_SKIA;HAS_UNO_SKIA_LINUX_FB;__DESKTOP__;__UNO_SKIA__;__UNO_SKIA_LINUX_FB__</DefineConstants>
		</PropertyGroup>

	</Target>

	<!-- Fallback for non-Uno.Sdk projects: Uno.Common.targets provides this for Sdk projects -->
	<Target Name="_UnoBeforeCopyLocal_SkiaLinuxFB"
			BeforeTargets="CopyFilesToOutputDirectory;_CopyFilesMarkedCopyLocal"
			Condition="'$(_UnoBeforeCopyLocalDefined)' != 'true'">
		<ItemGroup>
			<ContentWithTargetPath
				Update="@(ContentWithTargetPath)"
				CopyToOutputDirectory="Always" />
		</ItemGroup>
	</Target>

</Project>
