<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>$(NetPrevious);$(NetCurrent)</TargetFrameworks>
	</PropertyGroup>

	<Import Project="../targetframework-override-noplatform.props" />

	<PropertyGroup>
		<GeneratePackageOnBuild Condition="'$(Configuration)'=='Release'">true</GeneratePackageOnBuild>
		<Description>This package provides the platform support for Skia in Uno Platform projects.</Description>

		<PackageId>Uno.WinUI.Runtime.Skia.Win32</PackageId>

		<UseCommonOverridePackage>true</UseCommonOverridePackage>

		<!-- Ignore NU5104 for net7.0 System.Drawing.Common -->
		<NoWarn>$(NoWarn);NU5104</NoWarn>

		<Nullable>enable</Nullable>
	</PropertyGroup>

	<ItemGroup>
		<None Include="..\Common\uno.png" Pack="true" PackagePath="\" Visible="false" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Web.WebView2" Aliases="mswebview2" PrivateAssets="all" />

		<PackageReference Include="Microsoft.Windows.CsWin32" Version="0.3.106" />
		<PackageReference Include="HarfBuzzSharp" />
		<PackageReference Include="Uno.icu-win" />
	</ItemGroup>

	<ItemGroup Condition="$([MSBuild]::IsTargetFrameworkCompatible($(TargetFramework), 'net10.0'))">
		<PackageReference Include="WebView2Aot" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.CodeAnalysis.BannedApiAnalyzers" Version="3.3.4" PrivateAssets="All" />
		<AdditionalFiles Include="$(MSBuildThisFileDirectory)BannedSymbols.txt" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Uno.Foundation\Uno.Foundation.Skia.csproj" />
		<ProjectReference Include="..\Uno.UI.Runtime.Skia.Win32.Support\Uno.UI.Runtime.Skia.Win32.Support.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\Uno.UI.Runtime.Skia\Uno.UI.Runtime.Skia.csproj" />
		<ProjectReference Include="..\Uno.UI\Uno.UI.Skia.csproj" />
		<ProjectReference Include="..\Uno.UWP\Uno.Skia.csproj" TreatAsPackageReference="false" PrivateAssets="all" />
	</ItemGroup>

	<ItemGroup>
		<Content Include="buildTransitive/*.*">
			<Pack>true</Pack>
			<PackagePath>buildTransitive</PackagePath>
		</Content>
	</ItemGroup>

	<!--
		WebView2 ships a WPF assembly (lib_manual) that gets auto-referenced and drags in
		WindowsBase, conflicting with the net10.0 framework reference. We only use the Core
		assembly, so drop the WPF one. Mirrors the WPF-removal target in Uno.Sdk.
	-->
	<Target Name="_UnoWin32RemoveWebView2Wpf" BeforeTargets="ResolveAssemblyReferences">
		<ItemGroup>
			<_unoWpfWebViewReference Include="@(Reference)" Condition="'%(Reference.FileName)' == 'Microsoft.Web.WebView2.Wpf'" />
			<Reference Remove="@(_unoWpfWebViewReference)" Condition=" '@(_unoWpfWebViewReference)' != '' " />
		</ItemGroup>
	</Target>

	<!--
		The Microsoft.Web.WebView2 build targets inject Microsoft.Web.WebView2.Core as a plain
		Reference, which drops the `Aliases` metadata set on the PackageReference. Without it the
		`mswebview2` extern alias is never passed to csc and CoreWebView2 collides with Uno.UI's
		own projection. Re-apply the alias to the resolved reference after it is resolved.
		Mirrors _UnoWebView2Workaround in Uno.Sdk's Uno.SingleProject.Desktop.targets.
	-->
	<Target Name="_UnoWin32WebView2AliasWorkaround" AfterTargets="ResolveAssemblyReferences">
		<ItemGroup>
			<_unoWebView2WithAliases Include="@(PackageReference)" Condition="'%(PackageReference.Aliases)' != ''" />
		</ItemGroup>
		<PropertyGroup Condition=" '@(_unoWebView2WithAliases)' != ''">
			<_unoWebView2Aliases>%(_unoWebView2WithAliases.Aliases)</_unoWebView2Aliases>
		</PropertyGroup>
		<ItemGroup Condition=" '@(_unoWebView2WithAliases)' != ''">
			<ReferencePath Update="@(ReferencePath)" Condition="'%(FileName)' == 'Microsoft.Web.WebView2.Core'">
				<Aliases>$(_unoWebView2Aliases)</Aliases>
			</ReferencePath>
		</ItemGroup>
	</Target>

	<Target Name="_UnoUpdateAdditionalAssemblies" AfterTargets="DispatchToInnerBuilds">
		<ItemGroup>
			<Content Include="../Uno.UI.Runtime.Skia.Win32.Support/bin/$(Configuration)/$(NetPrevious)/*.dll">
				<Pack>true</Pack>
				<PackagePath>lib/$(NetPrevious)</PackagePath>
			</Content>
			<Content Include="../Uno.UI.Runtime.Skia.Win32.Support/bin/$(Configuration)/$(NetPrevious)/*.pdb">
				<Pack>true</Pack>
				<PackagePath>lib/$(NetPrevious)</PackagePath>
			</Content>
			<Content Include="../Uno.UI.Runtime.Skia.Win32.Support/bin/$(Configuration)/$(NetCurrent)/*.dll">
				<Pack>true</Pack>
				<PackagePath>lib/$(NetCurrent)</PackagePath>
			</Content>
			<Content Include="../Uno.UI.Runtime.Skia.Win32.Support/bin/$(Configuration)/$(NetCurrent)/*.pdb">
				<Pack>true</Pack>
				<PackagePath>lib/$(NetCurrent)</PackagePath>
			</Content>
		</ItemGroup>
	</Target>

</Project>
